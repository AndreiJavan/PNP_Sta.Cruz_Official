<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Add Hotline Form -->
    <div class="lg:col-span-1">
        <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-700/50 overflow-hidden">
            <div class="p-8 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-xs">Add New Hotline</h3>
            </div>
            <form action="/admin/hotlines/add" method="POST" class="p-8 space-y-6">
                <div class="space-y-2">
                    <label for="name" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Agency Name</label>
                    <input type="text" name="name" id="name" required placeholder="e.g., PNP Sta. Cruz" class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-black dark:text-white uppercase tracking-wider placeholder:text-gray-300">
                </div>
                <div class="space-y-2">
                    <label for="number" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Contact Number</label>
                    <input type="text" name="number" id="number" required placeholder="e.g., 0912-345-6789" class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-black dark:text-white uppercase tracking-wider placeholder:text-gray-300">
                </div>
                <div class="space-y-2">
                    <label for="category" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Category</label>
                    <select name="category" id="category" required class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-black dark:text-white uppercase tracking-wider">
                        <option value="Police">Police</option>
                        <option value="Fire">Fire</option>
                        <option value="Medical">Medical</option>
                        <option value="Disaster">Disaster</option>
                        <option value="Utility">Utility</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <button type="submit" class="w-full py-5 bg-pnp-blue hover:bg-blue-950 text-white font-black rounded-2xl shadow-xl transition duration-300 uppercase tracking-[0.2em] text-[10px]">
                    Save Hotline
                </button>
            </form>
        </div>
    </div>

    <!-- Hotline List -->
    <div class="lg:col-span-2">
        <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-700/50 overflow-hidden">
            <div class="p-8 border-b border-gray-50 dark:border-slate-700 bg-gray-50/10 dark:bg-slate-900/50">
                <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-xs">Emergency Directory</h3>
            </div>
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead class="bg-gray-50/50 dark:bg-slate-950/50">
                        <tr>
                            <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-700">Agency</th>
                            <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-700">Number</th>
                            <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-700">Category</th>
                            <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-700 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-slate-800">
                        <% hotlines.forEach(h => { %>
                            <tr class="hover:bg-pnp-blue/5 dark:hover:bg-slate-700/40 transition-all group">
                                <td class="px-8 py-6 font-black text-slate-800 dark:text-white uppercase text-[11px] tracking-tight leading-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition duration-300"><%= h.name %></td>
                                <td class="px-8 py-6 font-mono text-[11px] text-gray-500 dark:text-gray-400"><%= h.number %></td>
                                <td class="px-8 py-6">
                                    <span class="px-4 py-1.5 rounded-2xl text-[9px] font-black uppercase tracking-[0.2em] border bg-gray-50 dark:bg-slate-900 text-slate-500 dark:text-slate-400 border-gray-100 dark:border-slate-700">
                                        <%= h.category %>
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-right">
                                    <div class="flex items-center justify-end">
                                        <form action="/admin/hotlines/<%= h.id %>/delete" method="POST" onsubmit="confirmOperationalAction(event, { title: 'Delete Hotline', message: 'Are you sure you want to remove this emergency contact?', confirmText: 'Remove', type: 'danger' })">
                                            <button type="submit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-900 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm" title="Delete Hotline">
                                                <i class="fas fa-trash-alt text-xs"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
