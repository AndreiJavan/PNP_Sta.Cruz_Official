<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Add Hotline Form -->
    <div class="lg:col-span-1">
        <div
            class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Add New Hotline
                </h3>
            </div>
            <form action="/admin/hotlines/add" method="POST" class="p-6 space-y-6" onsubmit="return handleAddHotlineSubmit(event)">
                <div class="space-y-2">
                    <label for="name"
                        class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Agency
                        Name</label>
                    <input type="text" name="name" id="name" required placeholder="e.g., PNP Sta. Cruz" minlength="2" maxlength="100" title="Agency name must be 2 to 100 characters"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                </div>
                <div class="space-y-2">
                    <label for="number"
                        class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Contact
                        Number</label>
                    <input type="text" name="number" id="number" required placeholder="e.g., 09123456789 or 911" pattern="\d{3,11}" maxlength="11" title="Exact digits only (3 to 11 digits)" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                </div>
                <div class="space-y-2">
                    <label for="category"
                        class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Category</label>
                    <input type="text" name="category" id="category" list="categoryList" required placeholder="Type or select category (e.g. Police, Utility)" minlength="2" maxlength="50" title="Category must be 2 to 50 characters"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                    <datalist id="categoryList">
                        <option value="Police">
                        <option value="Fire">
                        <option value="Medical">
                        <option value="Disaster">
                        <option value="Utility">
                    </datalist>
                </div>
                <button type="submit"
                    class="w-full bg-pnp-blue text-white font-bold py-4 rounded-xl shadow-lg transition duration-300 hover:bg-blue-900 uppercase tracking-widest text-xs">
                    Save Hotline
                </button>
            </form>
        </div>
    </div>

    <!-- Hotline List -->
    <div class="lg:col-span-2">
        <div
            class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Emergency
                    Directory</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead
                        class="bg-gray-50 dark:bg-slate-900 text-gray-400 dark:text-gray-500 uppercase text-[10px] font-bold tracking-widest">
                        <tr>
                            <th class="px-6 py-4">Agency</th>
                            <th class="px-6 py-4">Number</th>
                            <th class="px-6 py-4">Category</th>
                            <th class="px-6 py-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                        <% hotlines.forEach(h=> { %>
                            <tr class="hover:bg-gray-50 dark:hover:bg-slate-700 transition">
                                <td class="px-6 py-4 font-bold text-pnp-blue dark:text-pnp-gold" id="name_<%= h.id %>">
                                    <%= h.name %>
                                </td>
                                <td class="px-6 py-4 font-mono text-gray-700 dark:text-gray-300" id="num_<%= h.id %>">
                                    <% let numStr = h.number ? String(h.number) : ''; %>
                                    <%= numStr && numStr.length === 11 ? numStr.replace(/(\d{4})(\d{3})(\d{4})/, '$1 $2 $3') : numStr %>
                                </td>
                                <td class="px-6 py-4" id="cat_<%= h.id %>" data-category="<%= h.category %>">
                                    <span
                                        class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-400">
                                        <%= h.category %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 flex items-center space-x-4">
                                    <button type="button" onclick="toggleEditHotline('<%= h.id %>')" id="editBtn_<%= h.id %>" class="text-pnp-blue hover:text-blue-800 font-bold text-xs uppercase tracking-widest">Edit</button>
                                    <form action="/admin/hotlines/<%= h.id %>/delete" method="POST"
                                        onsubmit="confirmOperationalAction(event, { title: 'Delete Hotline', message: 'Are you sure you want to remove this emergency contact?', confirmText: 'Remove', type: 'danger' }); return false;">
                                        <button type="submit"
                                            class="text-red-600 hover:text-red-800 font-bold text-xs uppercase tracking-widest">Delete</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    async function handleAddHotlineSubmit(event) {
        event.preventDefault();
        const form = event.target;
        const nameInput = document.getElementById('name');
        const numInput = document.getElementById('number');
        const catInput = document.getElementById('category');

        const agencyName = nameInput ? nameInput.value.trim() : '';
        const numVal = numInput ? numInput.value.trim() : '';
        const catVal = catInput ? catInput.value.trim() : '';

        // Agency name limitation check (2 to 100 characters)
        if (!agencyName || agencyName.length < 2 || agencyName.length > 100) {
            if (window.strategicAlert) {
                await window.strategicAlert({
                    title: 'Invalid Agency Name',
                    message: 'Agency name must be between 2 and 100 characters.',
                    type: 'danger'
                });
            } else {
                alert('Agency name must be between 2 and 100 characters.');
            }
            if (nameInput) nameInput.focus();
            return false;
        }

        // Contact number limitation check (exact 3 to 11 digits)
        if (!/^\d{3,11}$/.test(numVal)) {
            if (window.strategicAlert) {
                await window.strategicAlert({
                    title: 'Invalid Contact Number',
                    message: 'Contact number must contain exact numeric digits only (3 to 11 digits). No characters or spaces allowed.',
                    type: 'danger'
                });
            } else {
                alert('Contact number must contain exact numeric digits only (3 to 11 digits). No characters or spaces allowed.');
            }
            if (numInput) numInput.focus();
            return false;
        }

        // Category limitation check (2 to 50 characters)
        if (!catVal || catVal.length < 2 || catVal.length > 50) {
            if (window.strategicAlert) {
                await window.strategicAlert({
                    title: 'Invalid Category',
                    message: 'Category name must be between 2 and 50 characters.',
                    type: 'danger'
                });
            } else {
                alert('Category name must be between 2 and 50 characters.');
            }
            if (catInput) catInput.focus();
            return false;
        }

        let confirmed = false;
        if (window.strategicConfirm) {
            confirmed = await window.strategicConfirm({
                title: 'Confirm Hotline Creation',
                message: `Are you sure you want to save "${agencyName}" with contact number "${numVal}" under category "${catVal}" to the directory?`,
                confirmText: 'Save Hotline',
                type: 'info'
            });
        } else {
            confirmed = confirm(`Are you sure you want to save "${agencyName}" (${numVal}) under category "${catVal}"?`);
        }

        if (confirmed) {
            form.submit();
        }
        return false;
    }

    async function toggleEditHotline(id) {
        const nameTd = document.getElementById('name_' + id);
        const numTd = document.getElementById('num_' + id);
        const catTd = document.getElementById('cat_' + id);
        const editBtn = document.getElementById('editBtn_' + id);
        
        if (numTd.querySelector('input')) {
            const nameInput = nameTd.querySelector('input');
            const numInput = numTd.querySelector('input');
            const catInput = catTd.querySelector('input');

            const agencyName = nameInput ? nameInput.value.trim() : '';
            const numVal = numInput ? numInput.value.trim() : '';
            const catVal = catInput ? catInput.value.trim() : '';

            // Agency Name Limitation
            if (!agencyName || agencyName.length < 2 || agencyName.length > 100) {
                if (window.strategicAlert) {
                    await window.strategicAlert({
                        title: 'Invalid Agency Name',
                        message: 'Agency name must be between 2 and 100 characters.',
                        type: 'danger'
                    });
                } else {
                    alert('Agency name must be between 2 and 100 characters.');
                }
                if (nameInput) nameInput.focus();
                return;
            }

            // Contact Number Limitation (3 to 11 digits only)
            if (!/^\d{3,11}$/.test(numVal)) {
                if (window.strategicAlert) {
                    await window.strategicAlert({
                        title: 'Invalid Contact Number',
                        message: 'Hotline contact number must contain exact digits only (3 to 11 digits). No characters, spaces, or special symbols allowed.',
                        type: 'danger'
                    });
                } else {
                    alert('Hotline contact number must contain exact digits only (3 to 11 digits). No characters, spaces, or special symbols allowed.');
                }
                if (numInput) numInput.focus();
                return;
            }

            // Category Limitation (2 to 50 characters)
            if (!catVal || catVal.length < 2 || catVal.length > 50) {
                if (window.strategicAlert) {
                    await window.strategicAlert({
                        title: 'Invalid Category',
                        message: 'Category name must be between 2 and 50 characters.',
                        type: 'danger'
                    });
                } else {
                    alert('Category name must be between 2 and 50 characters.');
                }
                if (catInput) catInput.focus();
                return;
            }

            // Confirmation before saving edits
            let confirmed = false;
            if (window.strategicConfirm) {
                confirmed = await window.strategicConfirm({
                    title: 'Confirm Hotline Update',
                    message: `Are you sure you want to update the hotline for "${agencyName}" to number "${numVal}" and category "${catVal}"?`,
                    confirmText: 'Update Hotline',
                    type: 'warning'
                });
            } else {
                confirmed = confirm(`Are you sure you want to update the hotline for "${agencyName}"?`);
            }

            if (!confirmed) return;

            const form = document.getElementById('editForm_' + id);
            
            if (nameInput) form.appendChild(nameInput);
            if (catInput) form.appendChild(catInput);
            
            form.submit();
        } else {
            const currentName = nameTd.innerText.trim();
            const currentNum = numTd.innerText.trim().replace(/\s/g, '');
            const currentCat = catTd.getAttribute('data-category') || '';
            
            nameTd.innerHTML = `<input type="text" name="name" value="${currentName}" required minlength="2" maxlength="100" placeholder="Agency Name" class="w-full px-2 py-1 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg outline-none text-sm font-bold dark:text-white">`;
            
            numTd.innerHTML = `<form id="editForm_${id}" action="/admin/hotlines/${id}/edit" method="POST"><input type="text" name="number" value="${currentNum}" required pattern="\\d{3,11}" maxlength="11" title="Exact digits only (3 to 11 digits)" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);" class="w-full px-2 py-1 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg outline-none text-sm font-mono dark:text-white"></form>`;
            
            catTd.innerHTML = `<input type="text" name="category" list="categoryList" value="${currentCat}" required minlength="2" maxlength="50" placeholder="Category" class="w-full px-2 py-1 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg outline-none text-sm font-bold dark:text-white">`;

            editBtn.innerText = 'Save';
            editBtn.classList.remove('text-pnp-blue', 'hover:text-blue-800');
            editBtn.classList.add('text-green-600', 'hover:text-green-800');
        }
    }
</script>