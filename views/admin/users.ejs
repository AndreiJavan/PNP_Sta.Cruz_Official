<div class="space-y-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Personnel Configuration -->
        <div class="lg:col-span-1">
            <div
                class="bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden h-full">
                <div
                    class="p-8 border-b border-gray-50 dark:border-slate-700 bg-gradient-to-r from-pnp-blue/5 to-transparent">
                    <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.2em] text-[11px]">
                        Create Account</h3>
                    <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-1">Account Credentials
                    </p>
                </div>
                <% if (user && user.role==='superadmin' ) { %>
                    <form action="/admin/users/add" method="POST" class="p-8 space-y-6" onsubmit="confirmOperationalAction(event, { title: 'Account Creation Pending', message: 'An email will be sent to the Police Chief for approval. The new personnel will NOT be able to log in until the account is approved. Proceed?', type: 'info', confirmText: 'Create Account' })">

                        <div class="space-y-2">
                            <label for="full_name"
                                class="text-[9px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Full Name</label>
                            <input type="text" name="full_name" id="full_name" required placeholder="User Full Name"
                                class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold text-gray-700 dark:text-gray-300 transition-all">
                        </div>
                        <div class="space-y-2">
                            <label for="email"
                                class="text-[9px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Email Address</label>
                            <input type="email" name="email" id="email" required placeholder="user@example.com"
                                class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold text-gray-700 dark:text-gray-300 transition-all">
                        </div>
                        <div class="space-y-2">
                            <label for="password"
                                class="text-[9px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Password</label>
                            <input type="password" name="password" id="password" required placeholder="••••••••"
                                class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold text-gray-700 dark:text-gray-300 transition-all">
                        </div>
                        <!-- Personnel are always created with 'staff' role by default -->
                        <button type="submit"
                            class="w-full bg-pnp-blue hover:bg-black text-white font-black py-5 rounded-2xl shadow-xl shadow-pnp-blue/20 transition-all transform hover:scale-[1.02] active:scale-95 uppercase tracking-[0.3em] text-[10px]">
                            Create Account
                        </button>
                    </form>
                    <% } else { %>
                        <div class="p-8 py-20 text-center">
                            <div
                                class="w-16 h-16 bg-pnp-blue/5 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i class="fas fa-lock text-pnp-blue/20 text-2xl"></i>
                            </div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-relaxed">
                                Administrator Access Required<br>
                                <span class="text-[8px] opacity-60">Account management is locked for staff.</span>
                            </p>
                        </div>
                        <% } %>
            </div>
        </div>

        <!-- Active Personnel -->
        <div class="lg:col-span-2">
            <div
                class="bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden h-full flex flex-col">
                <div class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
                    <div>
                        <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">
                            Personnel Registry</h3>
                        <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-1">Authorized Administrators & Staff</p>
                    </div>
                    <div class="bg-pnp-blue/10 px-3 py-1.5 rounded-xl">
                        <span class="text-[10px] font-black text-pnp-blue tracking-widest uppercase">
                            <%= users.length %> Users
                        </span>
                    </div>
                </div>
                <div class="flex-grow overflow-x-auto">
                    <table class="w-full text-left text-xs min-w-[600px]">
                        <thead
                            class="bg-gray-50 dark:bg-slate-900/50 text-gray-400 dark:text-gray-500 uppercase text-[9px] font-black tracking-[0.2em]">
                            <tr>
                                <th class="px-8 py-5">Full Name</th>
                                <th class="px-8 py-5">Email Address</th>
                                <th class="px-8 py-5">Status</th>
                                <th class="px-8 py-5">Date Created</th>
                                <th class="px-8 py-5 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50 dark:divide-slate-700/50">
                            <% users.forEach(u=> { %>
                                <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/20 transition-colors">
                                    <td class="px-8 py-5 font-black text-pnp-blue dark:text-pnp-gold uppercase">
                                        <%= u.full_name %>
                                    </td>
                                    <td class="px-8 py-5">
                                        <div class="text-[11px] text-gray-500 dark:text-gray-400 font-mono lowercase mt-0.5"><%= u.email || 'No email provided' %></div>
                                    </td>
                                    <td class="px-8 py-5">
                                        <% if (u.status === 'active') { %>
                                            <span class="px-3 py-1 bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 rounded-lg text-[9px] font-black uppercase tracking-widest border border-green-200 dark:border-green-800">Active</span>
                                        <% } else if (u.status === 'rejected') { %>
                                            <span class="px-3 py-1 bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 rounded-lg text-[9px] font-black uppercase tracking-widest border border-red-200 dark:border-red-800">Rejected</span>
                                        <% } else { %>
                                            <span class="px-3 py-1 bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400 rounded-lg text-[9px] font-black uppercase tracking-widest border border-yellow-200 dark:border-yellow-800">Pending</span>
                                        <% } %>
                                    </td>
                                    <td class="px-8 py-5 text-gray-400 font-mono">
                                        <%= new Date(u.created_at).toLocaleDateString(undefined, {month:'short',
                                            day:'numeric', year:'numeric'}) %>
                                    </td>
                                    <td class="px-8 py-5 text-right">
                                        <% if (user && user.role==='superadmin' ) { %>
                                            <button type="button" onclick="openDeleteUserModal('<%= u.id %>', '<%= u.full_name %>')"
                                                class="w-10 h-10 rounded-xl bg-red-50 dark:bg-red-900/20 text-red-500 hover:bg-red-500 hover:text-white transition-all flex items-center justify-center mx-auto shadow-sm">
                                                <i class="fas fa-trash-alt text-[11px]"></i>
                                            </button>
                                            <% } else { %>
                                                <span
                                                    class="text-[8px] font-black text-slate-300 uppercase italic">Locked</span>
                                                <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Operational Audit Logs Integration -->
    <div
        class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div
            class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center bg-slate-50 dark:bg-slate-900/50">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-pnp-gold/20 rounded-2xl flex items-center justify-center text-pnp-gold">
                    <i class="fas fa-fingerprint text-xl"></i>
                </div>
                <div>
                    <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.25em] text-[12px]">
                        System Audit Log</h3>
                    <p class="text-[9px] text-pnp-gold font-black uppercase tracking-[0.3em] mt-0.5 animate-pulse">
                        System Logs</p>
                </div>
            </div>
            <div class="flex items-center space-x-4">
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full bg-green-500"></div>
                    <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Master Logs Active</span>
                </div>
                <% if (typeof logs !== 'undefined' && logs.length > 5) { %>
                <button onclick="openUsersLogModal()" class="px-4 py-2 bg-pnp-blue text-white rounded-xl text-[9px] font-black uppercase tracking-widest hover:bg-blue-800 transition shadow-md shadow-pnp-blue/20">
                    View All (<%= logs.length %>)
                </button>
                <% } %>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-xs min-w-[600px]">
                <thead
                    class="bg-gray-50 dark:bg-slate-900 text-gray-400 dark:text-gray-500 uppercase text-[9px] font-black tracking-[0.2em]">
                    <tr>
                        <th class="px-8 py-5">Personnel</th>
                        <th class="px-8 py-5">Action</th>
                        <th class="px-8 py-5">Details</th>
                        <th class="px-8 py-5 text-right">Timestamp</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-slate-700/50">
                    <% if (typeof logs !=='undefined' && logs.length> 0) { %>
                        <% logs.slice(0, 5).forEach(l=> { %>
                            <tr class="hover:bg-gray-50/50 dark:hover:bg-slate-700/20 transition-colors group">
                                <td class="px-8 py-5 font-black text-pnp-blue dark:text-white">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-2 h-2 rounded-full bg-pnp-blue"></div>
                                        <span>
                                            <%= l.username %>
                                        </span>
                                    </div>
                                </td>
                                <td class="px-8 py-5 shrink-0">
                                    <span
                                        class="px-3 py-1 bg-slate-100 dark:bg-slate-700 rounded-lg text-[9px] font-black uppercase tracking-widest text-slate-500 border border-slate-200/50 dark:border-slate-600">
                                        <%= l.action %>
                                    </span>
                                </td>
                                <td class="px-8 py-5 text-gray-500 dark:text-gray-400 font-bold max-w-md truncate uppercase tracking-tighter"
                                    title="<%= l.details %>">
                                    <%= l.details %>
                                </td>
                                <td class="px-8 py-5 text-right text-gray-400 font-mono font-bold">
                                    <%= new Date(l.timestamp).toLocaleString(undefined, {hour12: true, month:'short',
                                        day:'numeric', hour:'numeric', minute:'numeric'}) %>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5"
                                            class="px-8 py-20 text-center text-slate-300 font-black uppercase tracking-[0.4em] italic opacity-50">
                                            No operational data captured in current session
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- View All Users Audit Log Modal -->
<div id="usersLogModal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm z-[100] hidden items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-white dark:bg-slate-900 rounded-3xl w-full max-w-5xl mx-4 overflow-hidden shadow-2xl border border-gray-100 dark:border-slate-800 flex flex-col max-h-[85vh] transform scale-95 transition-transform duration-300">
        
        <!-- Modal Header -->
        <div class="px-8 py-6 border-b border-gray-100 dark:border-slate-800 flex items-center justify-between bg-gray-50 dark:bg-slate-900/50">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-pnp-blue rounded-2xl flex items-center justify-center shadow-lg shadow-pnp-blue/20">
                    <i class="fas fa-list text-pnp-gold text-xl"></i>
                </div>
                <div>
                    <h3 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-widest">Complete System Logs</h3>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-[0.2em] mt-1">Full administrative activity stream</p>
                </div>
            </div>
            <button onclick="closeUsersLogModal()" class="w-10 h-10 bg-white dark:bg-slate-800 text-gray-400 hover:text-red-500 rounded-xl shadow-sm border border-gray-100 dark:border-slate-700 flex items-center justify-center transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <!-- Modal Body (Scrollable Table) -->
        <div class="p-0 overflow-y-auto custom-scrollbar flex-grow bg-white dark:bg-slate-900">
            <table class="w-full text-left text-xs min-w-[600px]">
                <thead class="bg-gray-50 dark:bg-slate-900 sticky top-0 z-10 text-gray-400 dark:text-gray-500 uppercase text-[9px] font-black tracking-[0.2em]">
                    <tr>
                        <th class="px-8 py-5">Personnel</th>
                        <th class="px-8 py-5">Action</th>
                        <th class="px-8 py-5">Details</th>
                        <th class="px-8 py-5 text-right">Timestamp</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-slate-800/50">
                    <% if (typeof logs !== 'undefined' && logs.length > 0) { %>
                        <% logs.forEach(l => { %>
                            <tr class="hover:bg-gray-50/50 dark:hover:bg-slate-800/50 transition-colors group">
                                <td class="px-8 py-4 font-black text-pnp-blue dark:text-white whitespace-nowrap">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-2 h-2 rounded-full bg-pnp-blue"></div>
                                        <span><%= l.username %></span>
                                    </div>
                                </td>
                                <td class="px-8 py-4 shrink-0">
                                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 rounded-lg text-[9px] font-black uppercase tracking-widest text-slate-500 border border-slate-200/50 dark:border-slate-700">
                                        <%= l.action %>
                                    </span>
                                </td>
                                <td class="px-8 py-4 text-gray-500 dark:text-gray-400 font-bold">
                                    <%= l.details %>
                                </td>
                                <td class="px-8 py-4 text-right text-gray-400 font-mono font-bold whitespace-nowrap">
                                    <%= new Date(l.timestamp).toLocaleString(undefined, {hour12: true, month:'short', day:'numeric', hour:'numeric', minute:'numeric'}) %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete User Modal -->
<div id="deleteUserModal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm z-[100] hidden items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-white dark:bg-slate-900 rounded-3xl w-full max-w-lg mx-4 overflow-hidden shadow-2xl border border-gray-100 dark:border-slate-800 flex flex-col transform scale-95 transition-transform duration-300">
        
        <form id="deleteUserForm" method="POST" action="">
            <div class="px-8 py-6 border-b border-gray-100 dark:border-slate-800 flex items-center justify-between bg-red-50 dark:bg-red-900/10">
                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-red-100 dark:bg-red-900/30 rounded-2xl flex items-center justify-center shadow-lg shadow-red-500/10">
                        <i class="fas fa-exclamation-triangle text-red-500 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-black text-red-600 dark:text-red-400 uppercase tracking-widest">Neutralize Account</h3>
                        <p class="text-[10px] text-red-400 font-bold uppercase tracking-[0.2em] mt-1">Permanent action for <span id="deleteUserTargetName"></span></p>
                    </div>
                </div>
                <button type="button" onclick="closeDeleteUserModal()" class="w-10 h-10 bg-white dark:bg-slate-800 text-gray-400 hover:text-red-500 rounded-xl shadow-sm border border-gray-100 dark:border-slate-700 flex items-center justify-center transition-colors">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="p-8 space-y-6">
                <p class="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-widest leading-relaxed">
                    Please select the reason for neutralizing this personnel's credentials. An email will be sent to their registered address detailing the reason.
                </p>

                <div class="space-y-3 max-h-48 overflow-y-auto custom-scrollbar pr-2">
                    <label class="flex items-center space-x-3 p-3 rounded-xl border border-gray-100 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-800 cursor-pointer transition">
                        <input type="radio" name="delete_reason" value="Security Breach / Compromised Credentials" class="w-4 h-4 text-pnp-blue focus:ring-pnp-blue border-gray-300" required onchange="toggleCustomReason()">
                        <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Security Breach / Compromised Credentials</span>
                    </label>
                    <label class="flex items-center space-x-3 p-3 rounded-xl border border-gray-100 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-800 cursor-pointer transition">
                        <input type="radio" name="delete_reason" value="Violation of Operational Protocols" class="w-4 h-4 text-pnp-blue focus:ring-pnp-blue border-gray-300" onchange="toggleCustomReason()">
                        <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Violation of Operational Protocols</span>
                    </label>
                    <label class="flex items-center space-x-3 p-3 rounded-xl border border-gray-100 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-800 cursor-pointer transition">
                        <input type="radio" name="delete_reason" value="Reassignment / Transfer of Duties" class="w-4 h-4 text-pnp-blue focus:ring-pnp-blue border-gray-300" onchange="toggleCustomReason()">
                        <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Reassignment / Transfer of Duties</span>
                    </label>
                    <label class="flex items-center space-x-3 p-3 rounded-xl border border-gray-100 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-800 cursor-pointer transition">
                        <input type="radio" name="delete_reason" value="Inactive / Dormant Account" class="w-4 h-4 text-pnp-blue focus:ring-pnp-blue border-gray-300" onchange="toggleCustomReason()">
                        <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Inactive / Dormant Account</span>
                    </label>
                    <label class="flex items-center space-x-3 p-3 rounded-xl border border-gray-100 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-800 cursor-pointer transition">
                        <input type="radio" name="delete_reason" value="Request from Higher Command" class="w-4 h-4 text-pnp-blue focus:ring-pnp-blue border-gray-300" onchange="toggleCustomReason()">
                        <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Request from Higher Command</span>
                    </label>
                    <label class="flex items-center space-x-3 p-3 rounded-xl border border-gray-100 dark:border-slate-700 hover:bg-gray-50 dark:hover:bg-slate-800 cursor-pointer transition">
                        <input type="radio" name="delete_reason" value="Other" class="w-4 h-4 text-pnp-blue focus:ring-pnp-blue border-gray-300" onchange="toggleCustomReason()">
                        <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Other (Custom Reason)</span>
                    </label>
                </div>

                <div id="customReasonContainer" class="hidden mt-4 space-y-2">
                    <label class="text-[9px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Specify Reason</label>
                    <input type="text" name="custom_reason" id="custom_reason" placeholder="Enter custom deletion reason..."
                        class="w-full px-5 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold text-gray-700 dark:text-gray-300 transition-all">
                </div>
            </div>

            <div class="p-6 bg-gray-50 dark:bg-slate-800/50 border-t border-gray-100 dark:border-slate-800 flex justify-end space-x-4">
                <button type="button" onclick="closeDeleteUserModal()" class="px-6 py-3 rounded-xl text-xs font-black text-gray-500 hover:bg-gray-200 dark:hover:bg-slate-700 transition uppercase tracking-widest">
                    Cancel
                </button>
                <button type="submit" class="px-6 py-3 rounded-xl bg-red-500 text-white text-xs font-black uppercase tracking-widest hover:bg-red-600 transition shadow-lg shadow-red-500/20 flex items-center">
                    <i class="fas fa-trash-alt mr-2"></i> Confirm Delete
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openUsersLogModal() {
        const modal = document.getElementById('usersLogModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        void modal.offsetWidth;
        modal.classList.remove('opacity-0');
        modal.children[0].classList.remove('scale-95');
        modal.children[0].classList.add('scale-100');
        document.body.style.overflow = 'hidden';
    }

    function closeUsersLogModal() {
        const modal = document.getElementById('usersLogModal');
        modal.classList.add('opacity-0');
        modal.children[0].classList.remove('scale-100');
        modal.children[0].classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = '';
        }, 300);
    }

    function openDeleteUserModal(userId, userName) {
        document.getElementById('deleteUserForm').action = `/admin/users/${userId}/delete`;
        document.getElementById('deleteUserTargetName').textContent = userName;
        
        // Reset form
        document.getElementById('deleteUserForm').reset();
        toggleCustomReason();

        const modal = document.getElementById('deleteUserModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        void modal.offsetWidth;
        modal.classList.remove('opacity-0');
        modal.children[0].classList.remove('scale-95');
        modal.children[0].classList.add('scale-100');
        document.body.style.overflow = 'hidden';
    }

    function closeDeleteUserModal() {
        const modal = document.getElementById('deleteUserModal');
        modal.classList.add('opacity-0');
        modal.children[0].classList.remove('scale-100');
        modal.children[0].classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = '';
        }, 300);
    }

    function toggleCustomReason() {
        const customContainer = document.getElementById('customReasonContainer');
        const customInput = document.getElementById('custom_reason');
        const otherRadio = document.querySelector('input[name="delete_reason"][value="Other"]');
        
        if (otherRadio && otherRadio.checked) {
            customContainer.classList.remove('hidden');
            customInput.required = true;
        } else {
            customContainer.classList.add('hidden');
            customInput.required = false;
        }
    }
</script>