<div class="space-y-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Personnel Configuration -->
        <div class="lg:col-span-1">
            <div
                class="bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden h-full">
                <div
                    class="p-8 border-b border-gray-50 dark:border-slate-700 bg-gradient-to-r from-pnp-blue/5 to-transparent">
                    <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.2em] text-[11px]">
                        Deploy Personnel</h3>
                    <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-1">Credentials Assignment
                    </p>
                </div>
                <form action="/admin/users/add" method="POST" class="p-8 space-y-6">
                    <div class="space-y-2">
                        <label for="username"
                            class="text-[9px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Designated
                            Username</label>
                        <input type="text" name="username" id="username" required placeholder="pnp_unit_01"
                            class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold text-gray-700 dark:text-gray-300 transition-all">
                    </div>
                    <div class="space-y-2">
                        <label for="full_name"
                            class="text-[9px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Official
                            Full Name</label>
                        <input type="text" name="full_name" id="full_name" required placeholder="Personnel Name"
                            class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold text-gray-700 dark:text-gray-300 transition-all">
                    </div>
                    <div class="space-y-2">
                        <label for="password"
                            class="text-[9px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-black">Access
                            Protocol (Password)</label>
                        <input type="password" name="password" id="password" required placeholder="••••••••"
                            class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold text-gray-700 dark:text-gray-300 transition-all">
                    </div>
                    <!-- Personnel are always created with 'staff' role by default -->
                    <button type="submit"
                        class="w-full bg-pnp-blue hover:bg-black text-white font-black py-5 rounded-2xl shadow-xl shadow-pnp-blue/20 transition-all transform hover:scale-[1.02] active:scale-95 uppercase tracking-[0.3em] text-[10px]">
                        Authorize Credentials
                    </button>
                </form>
            </div>
        </div>

        <!-- Active Personnel -->
        <div class="lg:col-span-2">
            <div
                class="bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden h-full flex flex-col">
                <div class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
                    <div>
                        <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">
                            Personnel Registry</h3>
                        <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-1">Authorized Tactical
                            Operators</p>
                    </div>
                    <div class="bg-pnp-blue/10 px-3 py-1.5 rounded-xl">
                        <span class="text-[10px] font-black text-pnp-blue tracking-widest uppercase">
                            <%= users.length %> Units
                        </span>
                    </div>
                </div>
                <div class="flex-grow overflow-x-auto">
                    <table class="w-full text-left text-xs">
                        <thead
                            class="bg-gray-50 dark:bg-slate-900/50 text-gray-400 dark:text-gray-500 uppercase text-[9px] font-black tracking-[0.2em]">
                            <tr>
                                <th class="px-8 py-5">Designation</th>
                                <th class="px-8 py-5">Full Name</th>
                                <th class="px-8 py-5">Commission Date</th>
                                <th class="px-8 py-5 text-right">Protocol</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50 dark:divide-slate-700/50">
                            <% users.forEach(u=> { %>
                                <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/20 transition-colors">
                                    <td class="px-8 py-5 font-black text-pnp-blue dark:text-pnp-gold uppercase">
                                        <%= u.username %>
                                    </td>
                                    <td class="px-8 py-5 text-gray-600 dark:text-gray-300 font-bold uppercase">
                                        <%= u.full_name %>
                                    </td>
                                    <td class="px-8 py-5 text-gray-400 font-mono">
                                        <%= new Date(u.created_at).toLocaleDateString(undefined, {month:'short',
                                            day:'numeric', year:'numeric'}) %>
                                    </td>
                                    <td class="px-8 py-5 text-right">
                                        <form action="/admin/users/<%= u.id %>/delete" method="POST"
                                            onsubmit="return confirm('Are you sure you want to neutralize (delete) these credentials? This action is absolute.')"
                                            class="inline">
                                            <button type="submit"
                                                class="w-10 h-10 rounded-xl bg-red-50 dark:bg-red-900/20 text-red-500 hover:bg-red-500 hover:text-white transition-all flex items-center justify-center mx-auto shadow-sm">
                                                <i class="fas fa-trash-alt text-[11px]"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Operational Audit Logs Integration -->
    <div
        class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div
            class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center bg-slate-50 dark:bg-slate-900/50">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-pnp-gold/20 rounded-2xl flex items-center justify-center text-pnp-gold">
                    <i class="fas fa-fingerprint text-xl"></i>
                </div>
                <div>
                    <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.25em] text-[12px]">
                        Operational Audit Log</h3>
                    <p class="text-[9px] text-pnp-gold font-black uppercase tracking-[0.3em] mt-0.5 animate-pulse">
                        Real-time Activity Stream</p>
                </div>
            </div>
            <div class="flex items-center space-x-2">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Master Logs Active</span>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-xs">
                <thead
                    class="bg-gray-50 dark:bg-slate-900 text-gray-400 dark:text-gray-500 uppercase text-[9px] font-black tracking-[0.2em]">
                    <tr>
                        <th class="px-8 py-5">Personnel</th>
                        <th class="px-8 py-5">Tactical Action</th>
                        <th class="px-8 py-5">Operational Details</th>
                        <th class="px-8 py-5 text-right">Timestamp</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-slate-700/50">
                    <% if (typeof logs !=='undefined' && logs.length> 0) { %>
                        <% logs.forEach(l=> { %>
                            <tr class="hover:bg-gray-50/50 dark:hover:bg-slate-700/20 transition-colors group">
                                <td class="px-8 py-5 font-black text-pnp-blue dark:text-white">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-2 h-2 rounded-full bg-pnp-blue"></div>
                                        <span>
                                            <%= l.username %>
                                        </span>
                                    </div>
                                </td>
                                <td class="px-8 py-5 shrink-0">
                                    <span
                                        class="px-3 py-1 bg-slate-100 dark:bg-slate-700 rounded-lg text-[9px] font-black uppercase tracking-widest text-slate-500 border border-slate-200/50 dark:border-slate-600">
                                        <%= l.action %>
                                    </span>
                                </td>
                                <td class="px-8 py-5 text-gray-500 dark:text-gray-400 font-bold max-w-md truncate uppercase tracking-tighter"
                                    title="<%= l.details %>">
                                    <%= l.details %>
                                </td>
                                <td class="px-8 py-5 text-right text-gray-400 font-mono font-bold">
                                    <%= new Date(l.timestamp).toLocaleString(undefined, {hour12: true, month:'short',
                                        day:'numeric', hour:'numeric', minute:'numeric'}) %>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5"
                                            class="px-8 py-20 text-center text-slate-300 font-black uppercase tracking-[0.4em] italic opacity-50">
                                            No operational data captured in current session
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>