<div class="space-y-8 animate-fade-in px-4 lg:px-0">
    <!-- Header with Stats and Filters -->
    <div class="flex flex-row flex-wrap justify-between items-center w-full gap-6">
        
        <div class="flex flex-wrap items-center gap-4 w-full xl:w-auto pb-2 xl:pb-0">
            <a href="/admin/bulletins" class="flex-grow md:flex-none px-6 py-3.5 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg transition-colors flex items-center justify-center space-x-2 whitespace-nowrap <%= typeof category === 'undefined' || !category ? 'bg-pnp-gold text-pnp-blue hover:bg-white' : 'bg-pnp-blue text-pnp-gold hover:bg-pnp-gold hover:text-pnp-blue' %>">
                <span>All</span>
            </a>
            <a href="/admin/bulletins?category=Wanted%20Person" class="flex-grow md:flex-none px-6 py-3.5 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg transition-colors flex items-center justify-center space-x-2 whitespace-nowrap <%= typeof category !== 'undefined' && category === 'Wanted Person' ? 'bg-pnp-gold text-pnp-blue hover:bg-white' : 'bg-pnp-blue text-pnp-gold hover:bg-pnp-gold hover:text-pnp-blue' %>">
                <span>Wanted Person</span>
            </a>
            <a href="/admin/bulletins?category=Missing%20Person" class="flex-grow md:flex-none px-6 py-3.5 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg transition-colors flex items-center justify-center space-x-2 whitespace-nowrap <%= typeof category !== 'undefined' && category === 'Missing Person' ? 'bg-pnp-gold text-pnp-blue hover:bg-white' : 'bg-pnp-blue text-pnp-gold hover:bg-pnp-gold hover:text-pnp-blue' %>">
                <span>Missing Person</span>
            </a>
        </div>

        <div class="pnp-card pnp-glass-dark border-pnp-blue/10 p-6 md:p-8 rounded-[2.5rem] flex flex-col md:flex-row items-center md:space-x-8 space-y-6 md:space-y-0 group w-full xl:w-auto">
            <!-- Icon & Stats -->
            <div class="flex items-center space-x-6 w-full md:w-auto justify-center md:justify-start">
                <div class="w-14 h-14 bg-pnp-blue rounded-[1.5rem] flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 group-hover:rotate-0 transition-transform duration-500 shrink-0">
                    <i class="fas fa-bullhorn text-xl"></i>
                </div>
                <div>
                    <h4 class="text-[10px] font-black text-blue-300 uppercase tracking-[0.2em] leading-none opacity-70">Bulletins</h4>
                    <div class="text-3xl font-black text-white mt-1.5 tabular-nums leading-none"><%= String(bulletins.length).padStart(2, '0') %></div>
                    <p class="text-[9px] text-blue-300/50 mt-1 uppercase font-bold tracking-widest">Active Public Notices</p>
                </div>
            </div>
            
            <!-- Publish Button -->
            <div class="md:border-l md:border-white/10 md:pl-8 w-full md:w-auto flex justify-center">
                <a href="/admin/bulletins/create<%= typeof category !== 'undefined' && category ? '?category=' + encodeURIComponent(category) : '' %>" class="w-full md:w-auto px-6 py-3.5 bg-pnp-gold hover:bg-white text-pnp-blue rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg transition-colors flex items-center justify-center space-x-2 whitespace-nowrap">
                    <i class="fas fa-plus"></i>
                    <span>Publish Notice</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Bulletin Grid -->
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden min-h-[500px]">
        <div class="p-8 border-b border-gray-50 dark:border-slate-800 bg-gray-50/10 dark:bg-slate-900/50 flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-sm">Directives</h3>
            </div>
            <div class="flex items-center space-x-4 w-full md:w-auto">
                <div class="relative w-full md:w-72">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-xs"></i>
                    <input type="text" id="bulletinSearchInput" onkeyup="filterBulletins()" placeholder="Search mission labels..." class="w-full pl-10 pr-4 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-100 dark:border-slate-800 rounded-2xl outline-none text-[10px] font-black text-slate-600 dark:text-white uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue/20 transition-all placeholder:text-gray-300">
                </div>
            </div>
        </div>

        <div class="p-6 relative">
            <% 
                const chunkedBulletins = [];
                const sortedBulletins = bulletins.sort((a,b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
                for (let i = 0; i < sortedBulletins.length; i += 5) {
                    chunkedBulletins.push(sortedBulletins.slice(i, i + 5));
                }
            %>
            <div class="relative overflow-hidden w-full">
                <div id="bulletinCarousel" class="flex w-full transition-transform duration-500 ease-in-out">
                    <% if (chunkedBulletins.length === 0) { %>
                        <div class="w-full shrink-0 px-2" style="flex: 0 0 100%;">
                            <div class="py-32 flex flex-col items-center justify-center text-center">
                                <i class="fas fa-bullhorn text-6xl mb-6 text-gray-200 dark:text-slate-800"></i>
                                <h3 class="text-xl font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">No active directives found</h3>
                                <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Publish a new notice to broadcast.</p>
                            </div>
                        </div>
                    <% } else { %>
                        <% chunkedBulletins.forEach((chunk, index) => { %>
                            <div class="w-full shrink-0 px-2 flex flex-col gap-4 carousel-slide" style="flex: 0 0 100%;">
                                <% chunk.forEach(bulletin => { %>
                                    <div class="group bg-white dark:bg-slate-900/50 rounded-3xl p-6 shadow-sm border border-gray-100 dark:border-slate-800 hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row items-start md:items-center gap-6 relative overflow-hidden">
                                        <!-- Thumbnail -->
                                        <% if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                                            <div class="w-full md:w-32 h-40 md:h-24 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800">
                                                <img src="<%= bulletin.photo_paths[0] %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                                            </div>
                                        <% } else if (bulletin.photo_path) { %>
                                            <div class="w-full md:w-32 h-40 md:h-24 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800">
                                                <img src="<%= bulletin.photo_path %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                                            </div>
                                        <% } else { %>
                                            <div class="w-16 h-16 rounded-2xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center shrink-0 border border-gray-100 dark:border-slate-700">
                                                <i class="fas fa-bullhorn text-2xl text-gray-300 dark:text-slate-600 group-hover:text-pnp-blue transition-colors"></i>
                                            </div>
                                        <% } %>

                                        <!-- Content -->
                                        <div class="flex-grow flex flex-col w-full min-w-0">
                                            <div class="flex flex-wrap items-center gap-3 mb-2">
                                                <!-- Badge -->
                                                <% 
                                                    const badgeColors = {
                                                        'Wanted Person': 'bg-red-500/10 text-red-500 border-red-500/10',
                                                        'Missing Person': 'bg-orange-500/10 text-orange-500 border-orange-500/10',
                                                        'Crime Advisory': 'bg-pnp-gold/10 text-pnp-gold border-pnp-gold/10',
                                                        'Recovered Property': 'bg-emerald-500/10 text-emerald-500 border-emerald-500/10',
                                                        'General Announcement': 'bg-pnp-blue/10 text-pnp-blue-300 border-pnp-blue/10'
                                                    };
                                                    const categoryColor = badgeColors[bulletin.category] || 'bg-gray-100 text-gray-500';
                                                %>
                                                <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border <%= categoryColor %>">
                                                    <%= bulletin.category %>
                                                </span>
                                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                                                    <i class="fas fa-clock mr-1 opacity-50"></i> <%= new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'}) %> &middot; <%= new Date(bulletin.created_at).toLocaleTimeString(undefined, {hour:'2-digit', minute:'2-digit'}) %>
                                                </span>
                                            </div>
                                            <h4 class="text-sm font-black text-slate-800 dark:text-white uppercase tracking-tight leading-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition duration-300 mb-1.5 truncate">
                                                <%= bulletin.title %>
                                            </h4>
                                            <p class="text-[11px] text-slate-500 dark:text-slate-400 font-medium leading-relaxed line-clamp-2">
                                                <%= bulletin.body %>
                                            </p>
                                        </div>

                                        <!-- Actions -->
                                        <div class="flex items-center space-x-3 w-full md:w-auto justify-end mt-4 md:mt-0 shrink-0">
                                            <a href="/admin/bulletins/<%= bulletin.id %>/edit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-pnp-blue dark:hover:text-pnp-gold hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-pnp-gold/20 shadow-sm" title="Edit Bulletin">
                                                <i class="fas fa-edit text-xs"></i>
                                            </a>
                                            <form action="/admin/bulletins/<%= bulletin.id %>/delete" method="POST" onsubmit="handleBulletinDelete(event, '<%= bulletin.id %>'); return false;">
                                                <button type="submit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm" title="Delete Bulletin">
                                                    <i class="fas fa-trash-alt text-xs"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% }) %>
                    <% } %>
                </div>

                <!-- Custom Carousel Navigation -->
                <% if (chunkedBulletins.length > 1) { %>
                    <div class="flex justify-center items-center mt-8 space-x-4">
                        <button onclick="prevSlide()" class="w-10 h-10 rounded-full bg-gray-50 dark:bg-slate-800 flex justify-center items-center hover:bg-pnp-blue hover:text-white text-slate-400 transition shadow-sm border border-gray-200 dark:border-slate-700">
                            <i class="fas fa-chevron-left text-xs"></i>
                        </button>
                        <div id="carouselDots" class="flex items-center space-x-2">
                            <% chunkedBulletins.forEach((_, i) => { %>
                                <button onclick="goToSlide(<%= i %>)" class="w-3 h-3 rounded-full <%= i === 0 ? 'bg-pnp-blue' : 'bg-gray-300 dark:bg-slate-700' %> transition-colors"></button>
                            <% }) %>
                        </div>
                        <button onclick="nextSlide()" class="w-10 h-10 rounded-full bg-gray-50 dark:bg-slate-800 flex justify-center items-center hover:bg-pnp-blue hover:text-white text-slate-400 transition shadow-sm border border-gray-200 dark:border-slate-700">
                            <i class="fas fa-chevron-right text-xs"></i>
                        </button>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="p-6 border-t border-gray-50 dark:border-slate-800 flex justify-center items-center space-x-2">
        <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %><%= typeof category !== 'undefined' && category ? '&category=' + encodeURIComponent(category) : '' %>" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 text-gray-600 dark:text-gray-300 rounded-lg text-[10px] font-black uppercase tracking-widest hover:bg-pnp-blue hover:text-white transition">Previous</a>
        <% } %>
        <span class="text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 mx-4">Page <%= currentPage %> of <%= totalPages %></span>
        <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %><%= typeof category !== 'undefined' && category ? '&category=' + encodeURIComponent(category) : '' %>" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 text-gray-600 dark:text-gray-300 rounded-lg text-[10px] font-black uppercase tracking-widest hover:bg-pnp-blue hover:text-white transition">Next</a>
        <% } %>
    </div>
    <% } %>
</div>

<script>
    async function handleBulletinDelete(e, id) {
        e.preventDefault();
        const confirmFn = window.strategicConfirm || window.confirmOperationalAction || (async (args) => {
            return confirm(args?.message || "Delete this entry?");
        });

        const confirmed = await confirmFn({
            title: "Delete Bulletin",
            message: "Permanently remove this intelligence notice from the public grid?",
            confirmText: "Purge Entry",
            type: "danger"
        });
        
        if (confirmed) {
            e.target.closest('form').submit();
        }
    }

    window.filterBulletins = function() {
        const input = document.getElementById('bulletinSearchInput').value.toLowerCase();
        // Just hide/show the actual bulletin cards
        const cards = document.querySelectorAll('.carousel-slide .group');
        cards.forEach(card => {
            const title = card.querySelector('h4')?.textContent.toLowerCase() || '';
            const subtitle = card.querySelector('p')?.textContent.toLowerCase() || '';
            if (title.includes(input) || subtitle.includes(input)) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    }

    // Custom Carousel JS
    let currentSlide = 0;
    const totalSlides = document.querySelectorAll('.carousel-slide').length;
    
    window.updateCarousel = function() {
        const carousel = document.getElementById('bulletinCarousel');
        if (!carousel) return;
        carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
        
        // Update dots
        const dots = document.getElementById('carouselDots')?.children;
        if (dots) {
            Array.from(dots).forEach((dot, index) => {
                if (index === currentSlide) {
                    dot.className = "w-3 h-3 rounded-full bg-pnp-blue transition-colors";
                } else {
                    dot.className = "w-3 h-3 rounded-full bg-gray-300 dark:bg-slate-700 transition-colors";
                }
            });
        }
    }
    
    window.nextSlide = function() {
        if (totalSlides <= 1) return;
        currentSlide = (currentSlide + 1) % totalSlides;
        updateCarousel();
    }
    
    window.prevSlide = function() {
        if (totalSlides <= 1) return;
        currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
        updateCarousel();
    }
    
    window.goToSlide = function(index) {
        currentSlide = index;
        updateCarousel();
    }
</script>
