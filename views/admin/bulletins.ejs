<%
    const advisoryCategories = ['Crime Advisory', 'Traffic Advisory', 'Cybercrime Advisory', 'Community Awareness'];
    const advisoryCount = bulletins.filter(b => advisoryCategories.includes(b.category)).length;
    const newsCount = bulletins.filter(b => b.category === 'General Announcement').length;
%>
<div class="space-y-8 animate-fade-in px-4 lg:px-4 max-w-7xl mx-auto w-full transition-all duration-300">
    <!-- Header with Stats -->
    <div class="w-full transition-all duration-300">
        <div class="bg-white dark:bg-slate-900 border border-gray-150 dark:border-slate-800/60 shadow-sm hover:shadow-2xl p-6 md:p-8 rounded-[2.5rem] flex flex-col lg:flex-row items-center justify-between lg:space-x-8 space-y-6 lg:space-y-0 group w-full transition-all duration-300">
            <!-- Icon & Stats -->
            <div class="flex flex-col sm:flex-row items-center space-y-4 sm:space-y-0 sm:space-x-8 w-full lg:w-auto justify-center lg:justify-start">
                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-pnp-blue rounded-[1.25rem] flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 group-hover:rotate-0 transition-transform duration-500 shrink-0">
                        <i class="fas fa-shield-halved text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-[9px] font-black text-pnp-blue dark:text-blue-300 uppercase tracking-[0.15em] leading-none opacity-80">Public Advisories</h4>
                        <div class="text-2xl font-black text-slate-900 dark:text-white mt-1 tabular-nums leading-none"><%= String(advisoryCount).padStart(2, '0') %></div>
                        <p class="text-[8px] text-slate-400 dark:text-blue-300/50 mt-1 uppercase font-bold tracking-widest">Active Safety Alerts</p>
                    </div>
                </div>

                <div class="hidden sm:block h-8 w-[1px] bg-gray-200 dark:bg-white/10"></div>

                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-pnp-blue rounded-[1.25rem] flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 group-hover:rotate-0 transition-transform duration-500 shrink-0">
                        <i class="fas fa-newspaper text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-[9px] font-black text-pnp-blue dark:text-blue-300 uppercase tracking-[0.15em] leading-none opacity-80">News & Releases</h4>
                        <div class="text-2xl font-black text-slate-900 dark:text-white mt-1 tabular-nums leading-none"><%= String(newsCount).padStart(2, '0') %></div>
                        <p class="text-[8px] text-slate-400 dark:text-blue-300/50 mt-1 uppercase font-bold tracking-widest">Published Articles</p>
                    </div>
                </div>
            </div>
            
            <!-- Publish Button -->
            <div class="w-full lg:w-auto flex justify-center">
                <button type="button" onclick="openPublishNoticeModal()" class="w-full lg:w-auto px-6 py-3.5 bg-pnp-blue hover:bg-pnp-gold text-white hover:text-pnp-blue rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg transition-all transform hover:scale-[1.05] active:scale-95 flex items-center justify-center space-x-2 whitespace-nowrap cursor-pointer">
                    <i class="fas fa-plus"></i>
                    <span>Publish Notice</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Bulletin Grid -->
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden min-h-[500px]">
        <div class="p-8 border-b border-gray-50 dark:border-slate-800 bg-gray-50/10 dark:bg-slate-900/50 flex flex-col lg:flex-row justify-between items-center gap-6">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-sm">Directives</h3>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-4 w-full lg:w-auto">
                <!-- Dropdown -->
                <div class="relative w-full sm:w-56">
                    <select id="bulletinCategoryFilter" onchange="filterBulletins()" class="w-full pl-5 pr-10 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-100 dark:border-slate-800 rounded-2xl outline-none text-[10px] font-black text-slate-600 dark:text-white uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue/20 transition-all cursor-pointer appearance-none">
                        <option value="All" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category === 'undefined' || !category || category === 'All') ? 'selected' : '' %>>All Categories</option>
                        <option value="Crime Advisory" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Crime Advisory') ? 'selected' : '' %>>Crime Advisory</option>
                        <option value="Traffic Advisory" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Traffic Advisory') ? 'selected' : '' %>>Traffic Advisory</option>
                        <option value="Cybercrime Advisory" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Cybercrime Advisory') ? 'selected' : '' %>>Cybercrime Advisory</option>
                        <option value="Community Awareness" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Community Awareness') ? 'selected' : '' %>>Community Awareness</option>
                        <option value="General Announcement" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'General Announcement') ? 'selected' : '' %>>General Announcement</option>
                    </select>
                    <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-xs"></i>
                </div>
                <!-- Search -->
                <div class="relative w-full lg:w-72">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-xs"></i>
                    <input type="text" id="bulletinSearchInput" onkeyup="filterBulletins()" placeholder="Search mission labels..." class="w-full pl-10 pr-4 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-100 dark:border-slate-800 rounded-2xl outline-none text-[10px] font-black text-slate-600 dark:text-white uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue/20 transition-all placeholder:text-gray-300">
                </div>
            </div>
        </div>

        <div class="p-6">
            <!-- Empty state placeholder (visible when no items match) -->
            <div id="emptyStatePlaceholder" class="py-32 flex flex-col items-center justify-center text-center hidden">
                <i class="fas fa-bullhorn text-6xl mb-6 text-gray-200 dark:text-slate-800"></i>
                <h3 class="text-xl font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">No active directives found</h3>
                <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Publish a new notice or adjust filter criteria.</p>
            </div>

            <div id="bulletinList" class="flex flex-col gap-4 transition-all duration-300">
                <% if (bulletins.length === 0) { %>
                    <div class="py-32 flex flex-col items-center justify-center text-center">
                        <i class="fas fa-bullhorn text-6xl mb-6 text-gray-200 dark:text-slate-800"></i>
                        <h3 class="text-xl font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">No active directives found</h3>
                        <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Publish a new notice to broadcast.</p>
                    </div>
                <% } else { %>
                    <% bulletins.sort((a,b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()).forEach(bulletin => { %>
                        <div data-category="<%= bulletin.category %>" class="group bg-white dark:bg-slate-900/50 rounded-3xl p-6 shadow-sm border border-gray-100 dark:border-slate-800 hover:shadow-xl transition-all duration-300 flex flex-col lg:flex-row items-start lg:items-center gap-6 relative overflow-hidden">
                            <!-- Thumbnail -->
                            <% if (bulletin.video_paths && bulletin.video_paths.length > 0) { %>
                                <div class="w-full lg:w-32 h-40 lg:h-24 rounded-2xl overflow-hidden shrink-0 bg-black relative">
                                    <video src="<%= bulletin.video_paths[0] %>" muted class="w-full h-full object-cover group-hover:scale-110 transition duration-700 pointer-events-none"></video>
                                    <div class="absolute inset-0 bg-black/25 flex items-center justify-center">
                                        <i class="fas fa-play text-white text-xl"></i>
                                    </div>
                                </div>
                            <% } else if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                                <div class="w-full lg:w-32 h-40 lg:h-24 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800">
                                    <img src="<%= bulletin.photo_paths[0] %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                                </div>
                            <% } else if (bulletin.photo_path && bulletin.photo_path !== '[]' && !bulletin.photo_path.startsWith('[')) { %>
                                <div class="w-full lg:w-32 h-40 lg:h-24 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800">
                                    <img src="<%= bulletin.photo_path %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                                </div>
                            <% } else if (bulletin.facebook_url) { %>
                                <div class="w-full lg:w-48 h-40 lg:h-28 rounded-2xl overflow-hidden shrink-0 bg-slate-950 border border-[#1877F2]/30 flex items-center justify-center relative group-hover:scale-105 transition duration-500">
                                    <iframe src="https://www.facebook.com/plugins/<%= /video|watch|reel/i.test(bulletin.facebook_url) ? 'video.php' : 'post.php' %>?href=<%= encodeURIComponent(bulletin.facebook_url) %>&show_text=true&width=500" 
                                        width="100%" height="100%" style="border:none;overflow:hidden;" scrolling="no" frameborder="0" allowfullscreen="true" 
                                        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" class="w-full h-full"></iframe>
                                </div>
                            <% } else { %>
                                <div class="w-16 h-16 rounded-2xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center shrink-0 border border-gray-100 dark:border-slate-700">
                                    <i class="fas fa-bullhorn text-2xl text-gray-300 dark:text-slate-600 group-hover:text-pnp-blue transition-colors"></i>
                                </div>
                            <% } %>

                            <!-- Content -->
                            <div class="flex-grow flex flex-col w-full min-w-0">
                                <div class="flex flex-wrap items-center gap-3 mb-2">
                                    <!-- Badge -->
                                    <% 
                                        const badgeColors = {
                                            'Wanted Person': 'bg-red-500/10 text-red-500 border-red-500/10',
                                            'Missing Person': 'bg-orange-500/10 text-orange-500 border-orange-500/10',
                                            'Crime Advisory': 'bg-pnp-gold/10 text-pnp-gold border-pnp-gold/10',
                                            'Traffic Advisory': 'bg-purple-500/10 text-purple-400 border-purple-500/10',
                                            'Cybercrime Advisory': 'bg-pink-500/10 text-pink-400 border-pink-500/10',
                                            'Community Awareness': 'bg-teal-500/10 text-teal-400 border-teal-500/10',
                                            'Recovered Property': 'bg-emerald-500/10 text-emerald-500 border-emerald-500/10',
                                            'General Announcement': 'bg-pnp-blue/10 text-pnp-blue-300 border-pnp-blue/10'
                                        };
                                        const categoryColor = badgeColors[bulletin.category] || 'bg-gray-100 text-gray-500';
                                    %>
                                    <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border <%= categoryColor %>">
                                        <%= bulletin.category %>
                                    </span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                                        <i class="fas fa-clock mr-1 opacity-50"></i> <%= new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'}) %> &middot; <%= new Date(bulletin.created_at).toLocaleTimeString(undefined, {hour:'2-digit', minute:'2-digit'}) %>
                                    </span>
                                </div>
                                <h4 class="text-sm font-black text-slate-800 dark:text-white uppercase tracking-tight leading-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition duration-300 mb-1.5 truncate">
                                    <%= bulletin.title %>
                                </h4>
                                <p class="text-[11px] text-slate-500 dark:text-slate-400 font-medium leading-relaxed line-clamp-2">
                                    <%= bulletin.body %>
                                </p>
                                <% if (bulletin.facebook_url) { %>
                                    <div class="mt-2.5">
                                        <a href="<%= bulletin.facebook_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 px-3.5 py-1.5 bg-[#1877F2] hover:bg-blue-700 text-white rounded-xl text-[10px] font-black uppercase tracking-wider transition shadow-sm hover:shadow-md">
                                            <i class="fab fa-facebook text-xs"></i>
                                            <span>View Official Facebook Post</span>
                                            <i class="fas fa-external-link-alt text-[8px] ml-1 opacity-80"></i>
                                        </a>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Actions -->
                            <div class="flex items-center space-x-3 w-full lg:w-auto justify-end mt-4 lg:mt-0 shrink-0">
                                <a href="/admin/bulletins/<%= bulletin.id %>/edit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-pnp-blue dark:hover:text-pnp-gold hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-pnp-gold/20 shadow-sm" title="Edit Bulletin">
                                    <i class="fas fa-edit text-xs"></i>
                                </a>
                                <form action="/admin/bulletins/<%= bulletin.id %>/delete" method="POST" onsubmit="handleBulletinDelete(event, '<%= bulletin.id %>'); return false;">
                                    <button type="submit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm" title="Delete Bulletin">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>
    <!-- Carousel Pagination Controls -->
    <div id="carouselPagination" class="p-6 border-t border-gray-50 dark:border-slate-800 flex justify-center items-center space-x-2 hidden">
        <button id="prevBtn" onclick="navigateCarousel(-1)" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 hover:bg-pnp-blue hover:text-white text-gray-600 dark:text-gray-300 disabled:opacity-30 disabled:pointer-events-none rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">Previous</button>
        <span id="pageIndicator" class="text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 mx-4">Page 1 of 1</span>
        <button id="nextBtn" onclick="navigateCarousel(1)" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 hover:bg-pnp-blue hover:text-white text-gray-600 dark:text-gray-300 disabled:opacity-30 disabled:pointer-events-none rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">Next</button>
    </div>
</div>

<script>
    let currentPage = 1;
    const itemsPerPage = 5;

    async function handleBulletinDelete(e, id) {
        e.preventDefault();
        const confirmFn = window.strategicConfirm || window.confirmOperationalAction || (async (args) => {
            return confirm(args?.message || "Delete this entry?");
        });

        const confirmed = await confirmFn({
            title: "Delete Bulletin",
            message: "Are you sure you want to delete this bulletin? It will be moved to the Archive for easy recovery.",
            confirmText: "Move to Archive",
            cancelText: "Cancel",
            type: "danger"
        });
        
        if (confirmed) {
            e.target.closest('form').submit();
        }
    }

    window.filterBulletins = function() {
        const selectedCategory = document.getElementById('bulletinCategoryFilter').value;
        const input = document.getElementById('bulletinSearchInput').value.toLowerCase();
        
        const cards = Array.from(document.querySelectorAll('#bulletinList > .group'));
        const matchingCards = [];

        cards.forEach(card => {
            const title = card.querySelector('h4')?.textContent.toLowerCase() || '';
            const subtitle = card.querySelector('p')?.textContent.toLowerCase() || '';
            const category = card.getAttribute('data-category');
            
            const matchesSearch = title.includes(input) || subtitle.includes(input);
            const matchesCategory = selectedCategory === 'All' || category === selectedCategory;
            
            if (matchesSearch && matchesCategory) {
                matchingCards.push(card);
            } else {
                card.style.display = 'none';
            }
        });

        const totalItems = matchingCards.length;
        const totalPages = Math.ceil(totalItems / itemsPerPage);

        // Constrain current page
        if (currentPage > totalPages) {
            currentPage = Math.max(1, totalPages);
        }

        const paginationContainer = document.getElementById('carouselPagination');
        const emptyState = document.getElementById('emptyStatePlaceholder');
        const listWrapper = document.getElementById('bulletinList');

        if (totalItems === 0) {
            if (paginationContainer) paginationContainer.classList.add('hidden');
            if (emptyState) emptyState.classList.remove('hidden');
            if (listWrapper) listWrapper.classList.add('hidden');
        } else {
            if (emptyState) emptyState.classList.add('hidden');
            if (listWrapper) listWrapper.classList.remove('hidden');
            
            if (totalItems > itemsPerPage) {
                if (paginationContainer) paginationContainer.classList.remove('hidden');
            } else {
                if (paginationContainer) paginationContainer.classList.add('hidden');
            }
        }

        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;

        matchingCards.forEach((card, index) => {
            if (index >= startIndex && index < endIndex) {
                card.style.display = 'flex';
                card.classList.add('animate-fade-in');
            } else {
                card.style.display = 'none';
            }
        });

        const pageIndicator = document.getElementById('pageIndicator');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');

        if (pageIndicator) {
            pageIndicator.textContent = `Page ${currentPage} of ${totalPages || 1}`;
        }
        if (prevBtn) {
            prevBtn.disabled = (currentPage === 1);
        }
        if (nextBtn) {
            nextBtn.disabled = (currentPage >= totalPages);
        }
    }

    window.navigateCarousel = function(direction) {
        const listContainer = document.getElementById('bulletinList');
        if (!listContainer) return;

        // Visual fade out transition
        listContainer.classList.add('opacity-0', 'scale-[0.98]');

        setTimeout(() => {
            currentPage += direction;
            window.filterBulletins();
            
            // Visual fade back in
            listContainer.classList.remove('opacity-0', 'scale-[0.98]');
        }, 150);
    }

    // Initialize carousel on document load
    document.addEventListener('DOMContentLoaded', () => {
        const initialCategory = '<%= typeof category !== "undefined" && category ? category : "All" %>';
        const filterSelect = document.getElementById('bulletinCategoryFilter');
        if (filterSelect && initialCategory) {
            filterSelect.value = initialCategory;
        }
        window.filterBulletins();

        // Check query param to auto open modal if redirected
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('openModal') === 'true') {
            openPublishNoticeModal();
        }

        const dropZone = document.getElementById('modalDropZone');
        if (dropZone) {
            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.classList.add('border-pnp-blue', 'bg-pnp-blue/5');
            });
            dropZone.addEventListener('dragleave', () => {
                dropZone.classList.remove('border-pnp-blue', 'bg-pnp-blue/5');
            });
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('border-pnp-blue', 'bg-pnp-blue/5');
                if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
                    handleModalMediaSelect(e.dataTransfer.files);
                }
            });
        }
    });

    let currentPublishType = 'advisory';

    function openPublishNoticeModal(presetType) {
        const modal = document.getElementById('publishNoticeModal');
        const box = document.getElementById('publishNoticeModalBox');
        if (!modal || !box) return;
        
        // Reset form & error state
        const form = document.getElementById('publishNoticeForm');
        if (form) form.reset();
        clearModalMedia();
        const errorEl = document.getElementById('publishFormError');
        if (errorEl) errorEl.classList.add('hidden');

        if (presetType) {
            selectPublishType(presetType);
        } else {
            goToPublishStep(1);
        }

        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            box.classList.remove('scale-95');
            box.classList.add('scale-100');
        }, 20);
    }

    function closePublishNoticeModal() {
        const modal = document.getElementById('publishNoticeModal');
        const box = document.getElementById('publishNoticeModalBox');
        if (!modal || !box) return;
        
        modal.classList.add('opacity-0');
        box.classList.remove('scale-100');
        box.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    function goToPublishStep(step) {
        const step1 = document.getElementById('publishStep1');
        const step2 = document.getElementById('publishNoticeForm');
        const mainTitle = document.getElementById('modalMainTitle');
        const mainSubtitle = document.getElementById('modalMainSubtitle');

        if (step === 1) {
            if (step1) step1.classList.remove('hidden');
            if (step2) step2.classList.add('hidden');
            if (mainTitle) mainTitle.textContent = 'Publish Notice';
            if (mainSubtitle) mainSubtitle.textContent = 'Choose how you would like to publish the bulletin.';
        } else {
            if (step1) step1.classList.add('hidden');
            if (step2) step2.classList.remove('hidden');
            if (mainTitle) mainTitle.textContent = 'Notice Details';
            if (mainSubtitle) mainSubtitle.textContent = 'Provide notice details below to broadcast.';
        }
    }

    function selectPublishType(type) {
        currentPublishType = type;
        const publishTypeInput = document.getElementById('publishTypeInput');
        if (publishTypeInput) publishTypeInput.value = type;

        const manualPanel = document.getElementById('manualPublishPanel');
        const urlPanel = document.getElementById('urlPublishPanel');
        const selectedBadge = document.getElementById('selectedTypeBadge');
        
        const advisorySelect = document.getElementById('publishCategoryAdvisory');
        const newsBadge = document.getElementById('publishCategoryNewsBadge');
        const fbUrlInput = document.getElementById('publishFacebookUrl');
        const publishBody = document.getElementById('publishBody');
        const publishTitle = document.getElementById('publishTitle');
        const urlTitleInput = document.getElementById('urlTitleInput');

        if (type === 'url') {
            if (manualPanel) manualPanel.classList.add('hidden');
            if (urlPanel) urlPanel.classList.remove('hidden');

            if (selectedBadge) {
                selectedBadge.textContent = 'URL Post';
                selectedBadge.className = 'px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-[#1877F2]/10 text-[#1877F2] border border-[#1877F2]/20';
            }

            if (advisorySelect) {
                advisorySelect.classList.add('hidden');
                advisorySelect.name = "category_inactive";
                advisorySelect.disabled = true;
            }

            if (fbUrlInput) fbUrlInput.required = true;
            if (publishBody) publishBody.required = false;

            if (urlTitleInput && publishTitle) {
                urlTitleInput.name = "title";
                publishTitle.name = "title_inactive";
                urlTitleInput.required = true;
                publishTitle.required = false;
            }

            // Set hidden category for URL post
            setFormCategory('General Announcement');
            if (fbUrlInput && fbUrlInput.value) {
                handleFacebookUrlInput(fbUrlInput.value);
            }
        } else {
            if (manualPanel) manualPanel.classList.remove('hidden');
            if (urlPanel) urlPanel.classList.add('hidden');

            if (fbUrlInput) fbUrlInput.required = false;
            if (publishBody) publishBody.required = true;

            if (urlTitleInput && publishTitle) {
                publishTitle.name = "title";
                urlTitleInput.name = "title_inactive";
                publishTitle.required = true;
                urlTitleInput.required = false;
            }

            if (type === 'advisory') {
                if (advisorySelect) {
                    advisorySelect.classList.remove('hidden');
                    advisorySelect.name = "category";
                    advisorySelect.disabled = false;
                }
                if (newsBadge) newsBadge.classList.add('hidden');

                const newsCatHidden = document.getElementById('hiddenNewsCategory');
                if (newsCatHidden) {
                    newsCatHidden.disabled = true;
                    newsCatHidden.name = "category_inactive";
                }

                if (selectedBadge) {
                    selectedBadge.textContent = 'Public Advisory';
                    selectedBadge.className = 'px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-amber-500/10 text-amber-500 border border-amber-500/20';
                }
            } else if (type === 'news') {
                if (advisorySelect) {
                    advisorySelect.classList.add('hidden');
                    advisorySelect.name = "category_inactive";
                    advisorySelect.disabled = true;
                }
                if (newsBadge) newsBadge.classList.remove('hidden');

                setFormCategory('General Announcement');

                if (selectedBadge) {
                    selectedBadge.textContent = 'News & Release';
                    selectedBadge.className = 'px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-pnp-blue/10 text-pnp-blue dark:text-blue-300 border border-pnp-blue/20';
                }
            }
        }

        updateModalCounters();
        goToPublishStep(2);
    }

    function handleFacebookUrlInput(url) {
        const previewBox = document.getElementById('fbUrlPreviewBox');
        const iframeContainer = document.getElementById('fbIframeContainer');
        const urlTitleInput = document.getElementById('urlTitleInput');

        if (!url || !url.trim() || (!url.includes('facebook.com') && !url.includes('fb.watch') && !url.includes('fb.me'))) {
            if (previewBox) previewBox.classList.add('hidden');
            return;
        }

        const cleanUrl = url.trim();
        const isVideo = /video|watch|reel/i.test(cleanUrl);
        const pluginType = isVideo ? 'video.php' : 'post.php';
        const embedSrc = `https://www.facebook.com/plugins/${pluginType}?href=${encodeURIComponent(cleanUrl)}&show_text=true&width=500`;

        if (iframeContainer) {
            iframeContainer.innerHTML = `<iframe src="${embedSrc}" width="100%" height="100%" style="border:none;overflow:hidden;min-height:300px;" scrolling="no" frameborder="0" allowfullscreen="true" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" class="w-full h-full rounded-xl"></iframe>`;
        }

        if (previewBox) previewBox.classList.remove('hidden');

        // Auto-set Category to General Announcement
        setFormCategory('General Announcement');

        // Auto-suggest title if empty
        if (urlTitleInput && !urlTitleInput.value.trim()) {
            urlTitleInput.value = 'Official PNP Facebook Advisory Update';
            updateModalCounters();
        }
    }

    function setFormCategory(catVal) {
        let hiddenCat = document.getElementById('hiddenNewsCategory');
        if (!hiddenCat) {
            hiddenCat = document.createElement('input');
            hiddenCat.type = 'hidden';
            hiddenCat.id = 'hiddenNewsCategory';
            document.getElementById('publishNoticeForm').appendChild(hiddenCat);
        }
        hiddenCat.name = 'category';
        hiddenCat.value = catVal;
        hiddenCat.disabled = false;

        const advisorySelect = document.getElementById('publishCategoryAdvisory');
        if (advisorySelect) {
            advisorySelect.name = 'category_inactive';
            advisorySelect.disabled = true;
        }
    }

    function updateModalCounters() {
        const isUrl = currentPublishType === 'url';
        const titleInput = isUrl ? document.getElementById('urlTitleInput') : document.getElementById('publishTitle');
        const bodyInput = document.getElementById('publishBody');

        const titleCounter = isUrl ? document.getElementById('urlTitleCounter') : document.getElementById('publishTitleCounter');
        const bodyCounter = document.getElementById('publishBodyCounter');

        const titleErrorMsg = isUrl ? document.getElementById('urlTitleError') : document.getElementById('publishTitleError');
        const bodyErrorMsg = document.getElementById('publishBodyError');

        if (titleInput && titleCounter) {
            const letters = titleInput.value ? titleInput.value.length : 0;
            titleCounter.textContent = `${letters} / 100 letters`;

            if (letters === 0) {
                if (titleErrorMsg) {
                    titleErrorMsg.textContent = 'Notice title is required (at least 3 letters).';
                    titleErrorMsg.classList.remove('hidden');
                    titleErrorMsg.className = 'text-[11px] font-bold text-red-500 mt-1';
                }
                titleInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
                titleInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
                titleCounter.classList.add('text-red-500');
                titleCounter.classList.remove('text-slate-400', 'text-emerald-500');
            } else if (letters < 3) {
                if (titleErrorMsg) {
                    titleErrorMsg.textContent = `Title is too short. Minimum 3 letters required (currently ${letters} letters).`;
                    titleErrorMsg.classList.remove('hidden');
                    titleErrorMsg.className = 'text-[11px] font-bold text-red-500 mt-1';
                }
                titleInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
                titleInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
                titleCounter.classList.add('text-red-500');
                titleCounter.classList.remove('text-slate-400', 'text-emerald-500');
            } else if (letters > 100) {
                if (titleErrorMsg) {
                    titleErrorMsg.textContent = `Title exceeds maximum limit of 100 letters (currently ${letters} letters).`;
                    titleErrorMsg.classList.remove('hidden');
                    titleErrorMsg.className = 'text-[11px] font-bold text-red-500 mt-1';
                }
                titleInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
                titleInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
                titleCounter.classList.add('text-red-500');
                titleCounter.classList.remove('text-slate-400', 'text-emerald-500');
            } else {
                if (titleErrorMsg) {
                    titleErrorMsg.textContent = '✓ Title length is valid.';
                    titleErrorMsg.classList.remove('hidden');
                    titleErrorMsg.className = 'text-[11px] font-bold text-emerald-500 mt-1';
                }
                titleInput.classList.remove('border-red-500', 'ring-red-500/20');
                titleInput.classList.add('border-emerald-500', 'ring-2', 'ring-emerald-500/20');
                titleCounter.classList.remove('text-red-500');
                titleCounter.classList.add('text-emerald-500');
            }
        }

        if (!isUrl && bodyInput && bodyCounter) {
            const letters = bodyInput.value ? bodyInput.value.length : 0;
            bodyCounter.textContent = `${letters} / 5,000 letters`;

            if (letters === 0) {
                if (bodyErrorMsg) {
                    bodyErrorMsg.textContent = 'Description is required (at least 10 letters).';
                    bodyErrorMsg.classList.remove('hidden');
                    bodyErrorMsg.className = 'text-[11px] font-bold text-red-500 mt-1';
                }
                bodyInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
                bodyInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
                bodyCounter.classList.add('text-red-500');
                bodyCounter.classList.remove('text-slate-400', 'text-emerald-500');
            } else if (letters < 10) {
                if (bodyErrorMsg) {
                    bodyErrorMsg.textContent = `Description is too short. Minimum 10 letters required (currently ${letters} letters).`;
                    bodyErrorMsg.classList.remove('hidden');
                    bodyErrorMsg.className = 'text-[11px] font-bold text-red-500 mt-1';
                }
                bodyInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
                bodyInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
                bodyCounter.classList.add('text-red-500');
                bodyCounter.classList.remove('text-slate-400', 'text-emerald-500');
            } else if (letters > 5000) {
                if (bodyErrorMsg) {
                    bodyErrorMsg.textContent = `Description exceeds limit of 5,000 letters (currently ${letters} letters).`;
                    bodyErrorMsg.classList.remove('hidden');
                    bodyErrorMsg.className = 'text-[11px] font-bold text-red-500 mt-1';
                }
                bodyInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
                bodyInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
                bodyCounter.classList.add('text-red-500');
                bodyCounter.classList.remove('text-slate-400', 'text-emerald-500');
            } else {
                if (bodyErrorMsg) {
                    bodyErrorMsg.textContent = '✓ Description length is valid.';
                    bodyErrorMsg.classList.remove('hidden');
                    bodyErrorMsg.className = 'text-[11px] font-bold text-emerald-500 mt-1';
                }
                bodyInput.classList.remove('border-red-500', 'ring-red-500/20');
                bodyInput.classList.add('border-emerald-500', 'ring-2', 'ring-emerald-500/20');
                bodyCounter.classList.remove('text-red-500');
                bodyCounter.classList.add('text-emerald-500');
            }
        }
    }

    let modalMediaItems = [];
    let modalCurrentSlide = 0;

    function handleModalMediaSelect(files) {
        if (!files || files.length === 0) return;

        let rejected = [];
        let videoPromises = [];

        Array.from(files).forEach(file => {
            if (modalMediaItems.length + videoPromises.length >= 5) {
                rejected.push(`"${file.name}" (Limit exceeded: Maximum 5 media items allowed)`);
                return;
            }

            if (file.type.startsWith('image/')) {
                if (file.size > 5 * 1024 * 1024) {
                    rejected.push(`Image "${file.name}" (${(file.size/(1024*1024)).toFixed(1)}MB exceeds 5MB limit)`);
                } else {
                    const url = URL.createObjectURL(file);
                    modalMediaItems.push({
                        id: Date.now() + Math.random(),
                        file: file,
                        type: 'image',
                        url: url,
                        name: file.name,
                        size: file.size
                    });
                }
            } else if (file.type.startsWith('video/')) {
                if (file.size > 25 * 1024 * 1024) {
                    rejected.push(`Video "${file.name}" (${(file.size/(1024*1024)).toFixed(1)}MB exceeds 25MB limit)`);
                } else {
                    const p = new Promise(resolve => {
                        const tempVid = document.createElement('video');
                        tempVid.preload = 'metadata';
                        tempVid.src = URL.createObjectURL(file);
                        tempVid.onloadedmetadata = function() {
                            if (tempVid.duration > 180) { // > 3 mins
                                URL.revokeObjectURL(tempVid.src);
                                rejected.push(`Video "${file.name}" (${(tempVid.duration/60).toFixed(1)} mins long - Movie videos exceeding 3 minutes are prohibited)`);
                            } else {
                                modalMediaItems.push({
                                    id: Date.now() + Math.random(),
                                    file: file,
                                    type: 'video',
                                    url: tempVid.src,
                                    name: file.name,
                                    size: file.size,
                                    duration: tempVid.duration
                                });
                            }
                            resolve();
                        };
                        tempVid.onerror = function() {
                            URL.revokeObjectURL(tempVid.src);
                            rejected.push(`Video "${file.name}" (Corrupted or unsupported video format)`);
                            resolve();
                        };
                    });
                    videoPromises.push(p);
                }
            }
        });

        Promise.all(videoPromises).then(() => {
            if (rejected.length > 0) {
                alert(`Upload Notice:\n• ` + rejected.join('\n• '));
            }

            if (modalMediaItems.length > 0) {
                modalCurrentSlide = modalMediaItems.length - 1;
            }

            syncModalMediaInputs();
            renderModalCarousel();

            const input = document.getElementById('modalMediaInput');
            if (input) input.value = '';
        });
    }

    function syncModalMediaInputs() {
        const photosInput = document.getElementById('modalPhotos');
        const videosInput = document.getElementById('modalVideos');

        const dtPhotos = new DataTransfer();
        const dtVideos = new DataTransfer();

        modalMediaItems.forEach(item => {
            if (item.type === 'image') dtPhotos.items.add(item.file);
            else if (item.type === 'video') dtVideos.items.add(item.file);
        });

        if (photosInput) photosInput.files = dtPhotos.files;
        if (videosInput) videosInput.files = dtVideos.files;
    }

    function renderModalCarousel() {
        const previewBox = document.getElementById('modalMediaPreviewBox');
        const placeholder = document.getElementById('modalMediaPlaceholder');
        const img = document.getElementById('modalPreviewImg');
        const vid = document.getElementById('modalPreviewVid');
        const badge = document.getElementById('modalCarouselBadge');
        const dotsContainer = document.getElementById('modalCarouselDots');
        const infoEl = document.getElementById('modalCarouselInfo');
        const prevBtn = document.getElementById('modalPrevSlideBtn');
        const nextBtn = document.getElementById('modalNextSlideBtn');
        const clearBtn = document.getElementById('modalClearMediaBtn');
        const addBtnText = document.getElementById('modalAddMediaBtnText');
        const addBtn = document.getElementById('modalAddMediaBtn');

        if (modalMediaItems.length === 0) {
            if (previewBox) previewBox.classList.add('hidden');
            if (placeholder) placeholder.classList.remove('hidden');
            if (clearBtn) clearBtn.classList.add('hidden');
            if (addBtnText) addBtnText.textContent = 'Choose / Add Media Files';
            if (addBtn) addBtn.disabled = false;
            return;
        }

        if (placeholder) placeholder.classList.add('hidden');
        if (previewBox) previewBox.classList.remove('hidden');
        if (clearBtn) clearBtn.classList.remove('hidden');

        if (modalCurrentSlide >= modalMediaItems.length) {
            modalCurrentSlide = Math.max(0, modalMediaItems.length - 1);
        }

        const currentItem = modalMediaItems[modalCurrentSlide];

        if (currentItem.type === 'image') {
            if (vid) { vid.classList.add('hidden'); vid.pause(); }
            if (img) { img.src = currentItem.url; img.classList.remove('hidden'); }
        } else {
            if (img) img.classList.add('hidden');
            if (vid) { vid.src = currentItem.url; vid.classList.remove('hidden'); }
        }

        if (badge) {
            const icon = currentItem.type === 'image' ? '<i class="fas fa-image text-emerald-400 mr-1.5"></i>' : '<i class="fas fa-film text-amber-400 mr-1.5"></i>';
            badge.innerHTML = `${icon}<span>${currentItem.type.toUpperCase()} (${modalCurrentSlide + 1}/${modalMediaItems.length})</span>`;
        }

        if (infoEl) {
            const sizeMB = (currentItem.size / (1024 * 1024)).toFixed(1);
            const durText = currentItem.duration ? ` • ${Math.round(currentItem.duration)}s clip` : '';
            infoEl.textContent = `${currentItem.name} (${sizeMB} MB${durText})`;
        }

        if (modalMediaItems.length > 1) {
            if (prevBtn) prevBtn.classList.remove('hidden');
            if (nextBtn) nextBtn.classList.remove('hidden');
        } else {
            if (prevBtn) prevBtn.classList.add('hidden');
            if (nextBtn) nextBtn.classList.add('hidden');
        }

        if (dotsContainer) {
            if (modalMediaItems.length > 1) {
                dotsContainer.innerHTML = modalMediaItems.map((_, idx) => `
                    <button type="button" onclick="goToModalSlide(${idx}, event)" class="h-2 rounded-full transition-all cursor-pointer ${idx === modalCurrentSlide ? 'bg-pnp-blue dark:bg-pnp-gold w-6' : 'bg-gray-300 dark:bg-slate-700 hover:bg-gray-400 w-2'}" title="Slide ${idx + 1}"></button>
                `).join('');
                dotsContainer.classList.remove('hidden');
            } else {
                dotsContainer.innerHTML = '';
                dotsContainer.classList.add('hidden');
            }
        }

        if (addBtnText) {
            if (modalMediaItems.length >= 5) {
                addBtnText.textContent = 'Maximum Limit Reached (5/5 Files)';
                if (addBtn) addBtn.disabled = true;
            } else {
                addBtnText.textContent = `Add More Media Files (${modalMediaItems.length}/5)`;
                if (addBtn) addBtn.disabled = false;
            }
        }

        // Sync attached file list in urlPublishPanel if present
        const urlFilesContainer = document.getElementById('urlAttachedFilesContainer');
        const urlFilesList = document.getElementById('urlAttachedFilesList');
        const urlAddBtnText = document.getElementById('urlAddFileBtnText');

        if (urlFilesContainer && urlFilesList) {
            if (modalMediaItems.length === 0) {
                urlFilesContainer.classList.add('hidden');
                if (urlAddBtnText) urlAddBtnText.textContent = 'Choose / Upload File';
            } else {
                urlFilesContainer.classList.remove('hidden');
                if (urlAddBtnText) urlAddBtnText.textContent = `Attached (${modalMediaItems.length}/5) - Add More`;
                urlFilesList.innerHTML = modalMediaItems.map((item, idx) => `
                    <div class="flex items-center justify-between p-2.5 bg-white dark:bg-slate-900 rounded-xl border border-gray-150 dark:border-slate-800 text-xs shadow-sm">
                        <div class="flex items-center space-x-2.5 truncate mr-2">
                            <i class="${item.type === 'image' ? 'fas fa-image text-emerald-500' : 'fas fa-film text-amber-500'} text-sm"></i>
                            <span class="font-bold text-slate-700 dark:text-slate-200 truncate">${item.name}</span>
                            <span class="text-[10px] font-mono font-bold text-slate-400">(${(item.size/(1024*1024)).toFixed(1)}MB)</span>
                        </div>
                        <button type="button" onclick="removeUrlModalMediaItem(${idx})" class="text-red-500 hover:text-white hover:bg-red-500 text-xs px-2.5 py-1 rounded-lg transition flex items-center space-x-1 cursor-pointer" title="Remove file">
                            <i class="fas fa-trash-alt text-[10px]"></i>
                            <span class="text-[10px] font-bold">Remove</span>
                        </button>
                    </div>
                `).join('');
            }
        }
    }

    function removeUrlModalMediaItem(idx) {
        if (idx >= 0 && idx < modalMediaItems.length) {
            const removed = modalMediaItems[idx];
            if (removed && removed.url) URL.revokeObjectURL(removed.url);
            modalMediaItems.splice(idx, 1);
            if (modalCurrentSlide >= modalMediaItems.length) {
                modalCurrentSlide = Math.max(0, modalMediaItems.length - 1);
            }
            syncModalMediaInputs();
            renderModalCarousel();
            updateModalCounters();
        }
    }

    function trashCurrentModalMediaItem(e) {
        if (e) e.stopPropagation();
        if (modalMediaItems.length === 0) return;

        const removedItem = modalMediaItems[modalCurrentSlide];
        if (removedItem && removedItem.url) {
            URL.revokeObjectURL(removedItem.url);
        }

        modalMediaItems.splice(modalCurrentSlide, 1);

        if (modalCurrentSlide >= modalMediaItems.length) {
            modalCurrentSlide = Math.max(0, modalMediaItems.length - 1);
        }

        syncModalMediaInputs();
        renderModalCarousel();
        updateModalCounters();
    }

    function navigateModalCarousel(dir, e) {
        if (e) e.stopPropagation();
        if (modalMediaItems.length <= 1) return;
        modalCurrentSlide = (modalCurrentSlide + dir + modalMediaItems.length) % modalMediaItems.length;
        renderModalCarousel();
    }

    function goToModalSlide(idx, e) {
        if (e) e.stopPropagation();
        modalCurrentSlide = idx;
        renderModalCarousel();
    }

    function clearModalMedia() {
        modalMediaItems.forEach(item => {
            if (item.url) URL.revokeObjectURL(item.url);
        });
        modalMediaItems = [];
        modalCurrentSlide = 0;

        const photosInput = document.getElementById('modalPhotos');
        const videosInput = document.getElementById('modalVideos');
        const mediaInput = document.getElementById('modalMediaInput');
        if (photosInput) photosInput.value = '';
        if (videosInput) videosInput.value = '';
        if (mediaInput) mediaInput.value = '';

        renderModalCarousel();
    }

    let pendingNoticePublishForm = false;

    function handlePublishNoticeSubmit(e) {
        e.preventDefault();
        const errorEl = document.getElementById('publishFormError');
        const errorText = document.getElementById('publishFormErrorText');

        if (currentPublishType === 'url') {
            const urlTitle = document.getElementById('urlTitleInput')?.value.trim() || '';
            const urlBody = document.getElementById('urlBodyInput')?.value.trim() || '';
            const mainTitleInput = document.getElementById('publishTitle');
            const mainBodyInput = document.getElementById('publishBody');
            if (mainTitleInput) mainTitleInput.value = urlTitle;
            if (mainBodyInput) mainBodyInput.value = urlBody;
        }

        const titleInput = currentPublishType === 'url' ? document.getElementById('urlTitleInput') : document.getElementById('publishTitle');
        const fbUrlInput = document.getElementById('publishFacebookUrl');
        const bodyInput = document.getElementById('publishBody');

        const titleVal = titleInput ? titleInput.value.trim() : '';
        const fbUrlVal = fbUrlInput ? fbUrlInput.value.trim() : '';
        const bodyVal = bodyInput ? bodyInput.value.trim() : '';

        const titleWords = titleVal.split(/\s+/).filter(Boolean);
        const bodyWords = bodyVal.split(/\s+/).filter(Boolean);

        if (!titleVal || titleWords.length < 3) {
            if (errorText) errorText.textContent = `Validation Error: Title / Name must be at least 3 words long (currently: ${titleWords.length} words / ${titleVal.length} characters).`;
            if (errorEl) errorEl.classList.remove('hidden');
            return false;
        }

        if (titleVal.length > 100 || titleWords.length > 15) {
            if (errorText) errorText.textContent = `Validation Error: Title is too long (maximum 15 words / 100 characters. Currently: ${titleWords.length} words / ${titleVal.length} characters).`;
            if (errorEl) errorEl.classList.remove('hidden');
            return false;
        }

        if (currentPublishType === 'url') {
            if (!fbUrlVal) {
                if (errorText) errorText.textContent = 'Facebook Post URL is required for URL Post.';
                if (errorEl) errorEl.classList.remove('hidden');
                return false;
            }
        } else {
            if (!bodyVal || bodyWords.length < 5 || bodyVal.length < 15) {
                if (errorText) errorText.textContent = `Validation Error: Bulletin body must be at least 5 words long (currently: ${bodyWords.length} words / ${bodyVal.length} characters).`;
                if (errorEl) errorEl.classList.remove('hidden');
                return false;
            }
            if (bodyWords.length > 500 || bodyVal.length > 5000) {
                if (errorText) errorText.textContent = `Validation Error: Bulletin body is too long (maximum 500 words / 5,000 characters. Currently: ${bodyWords.length} words).`;
                if (errorEl) errorEl.classList.remove('hidden');
                return false;
            }
            if (modalMediaItems.length === 0 && !fbUrlVal) {
                if (errorText) errorText.textContent = 'At least 1 picture, video, or Facebook link must be attached to the notice.';
                if (errorEl) errorEl.classList.remove('hidden');
                return false;
            }
        }

        if (errorEl) errorEl.classList.add('hidden');

        // Show Confirmation Modal
        openPublishConfirmationModal({
            title: titleVal,
            type: currentPublishType === 'advisory' ? 'Public Advisory' : (currentPublishType === 'news' ? 'News & Release' : 'Facebook URL Post'),
            category: (currentPublishType === 'news' || currentPublishType === 'url') ? 'General Announcement' : (document.getElementById('publishCategoryAdvisory')?.value || 'Advisory'),
            mediaBadge: modalMediaItems.length > 0 ? `${modalMediaItems.length} file(s) attached (${modalMediaItems.filter(i => i.type === 'image').length} photo(s), ${modalMediaItems.filter(i => i.type === 'video').length} video(s))` : (currentPublishType === 'url' ? 'Facebook URL Attached' : 'No media attached')
        });

        return false;
    }

    function openPublishConfirmationModal(data) {
        document.getElementById('confirmModalTitle').textContent = data.title;
        document.getElementById('confirmModalType').textContent = data.type;
        document.getElementById('confirmModalCategory').textContent = data.category;
        document.getElementById('confirmModalMedia').textContent = data.mediaBadge;

        const modal = document.getElementById('publishConfirmModal');
        if (modal) {
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.firstElementChild.classList.remove('scale-95');
                modal.firstElementChild.classList.add('scale-100');
            }, 20);
        }
    }

    function closePublishConfirmationModal() {
        const modal = document.getElementById('publishConfirmModal');
        if (modal) {
            modal.classList.add('opacity-0');
            modal.firstElementChild.classList.remove('scale-100');
            modal.firstElementChild.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 200);
        }
    }

    function confirmAndExecuteSubmit() {
        const btn = document.getElementById('finalConfirmPublishBtn');
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>Publishing Notice...</span>';
        }
        document.getElementById('publishNoticeForm').submit();
    }
</script>

