            <div class="w-12 h-12 rounded-2xl bg-pnp-blue/10 flex items-center justify-center text-2xl border border-pnp-blue/20">
                <i class="fas fa-question-circle"></i>
            </div>
            <div>
                <h3 class="text-lg font-black uppercase tracking-wider text-slate-900 dark:text-white">Confirm Notice Publication</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium">Please review details before broadcasting this bulletin.</p>
            </div>
        </div>

        <div class="bg-gray-50 dark:bg-slate-950 border border-gray-200 dark:border-slate-800 rounded-2xl p-4 space-y-3 text-xs">
            <div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Notice Title</span>
                <span id="confirmModalTitle" class="font-bold text-slate-800 dark:text-white text-sm"></span>
            </div>
            <div class="grid grid-cols-2 gap-3 pt-2 border-t border-gray-200 dark:border-slate-800">
                <div>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Type</span>
                    <span id="confirmModalType" class="font-bold text-slate-700 dark:text-slate-200"></span>
                </div>
                <div>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Category</span>
                    <span id="confirmModalCategory" class="font-bold text-pnp-blue dark:text-pnp-gold"></span>
                </div>
            </div>
            <div class="pt-2 border-t border-gray-200 dark:border-slate-800">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Media Attachment</span>
                <span id="confirmModalMedia" class="font-bold text-slate-600 dark:text-slate-300"></span>
            </div>
        </div>

        <div class="flex items-center justify-end space-x-3 pt-2">
            <button type="button" onclick="closePublishConfirmationModal()" class="px-5 py-3 rounded-xl bg-gray-100 dark:bg-slate-800 hover:bg-gray-200 text-slate-600 dark:text-slate-300 text-xs font-bold uppercase tracking-wider transition cursor-pointer">
                Go Back & Edit
            </button>
            <button type="button" onclick="confirmAndExecuteSubmit()" id="finalConfirmPublishBtn" class="px-6 py-3 rounded-xl bg-pnp-blue hover:bg-pnp-gold text-white hover:text-pnp-blue text-xs font-black uppercase tracking-wider shadow-lg transition-all flex items-center space-x-2 cursor-pointer">
                <i class="fas fa-paper-plane"></i>
                <span>Yes, Confirm & Publish</span>
            </button>
        </div>
    </div>
</div>
