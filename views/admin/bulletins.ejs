<%
    const advisoryCategories = ['Crime Advisory', 'Traffic Advisory', 'Cybercrime Advisory', 'Community Awareness'];
    const advisoryCount = bulletins.filter(b => advisoryCategories.includes(b.category)).length;
    const newsCount = bulletins.filter(b => b.category === 'General Announcement').length;
%>
<div class="space-y-8 animate-fade-in px-4 lg:px-4 max-w-7xl mx-auto w-full transition-all duration-300">
    <!-- Header with Stats -->
    <div class="w-full transition-all duration-300">
        <div class="pnp-card pnp-glass-dark border-pnp-blue/10 p-6 md:p-8 rounded-[2.5rem] flex flex-col lg:flex-row items-center justify-between lg:space-x-8 space-y-6 lg:space-y-0 group w-full transition-all duration-300">
            <!-- Icon & Stats -->
            <div class="flex flex-col sm:flex-row items-center space-y-4 sm:space-y-0 sm:space-x-8 w-full lg:w-auto justify-center lg:justify-start">
                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-pnp-blue rounded-[1.25rem] flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 group-hover:rotate-0 transition-transform duration-500 shrink-0">
                        <i class="fas fa-shield-halved text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-[9px] font-black text-blue-300 uppercase tracking-[0.15em] leading-none opacity-70">Public Advisories</h4>
                        <div class="text-2xl font-black text-white mt-1 tabular-nums leading-none"><%= String(advisoryCount).padStart(2, '0') %></div>
                        <p class="text-[8px] text-blue-300/50 mt-1 uppercase font-bold tracking-widest">Active Safety Alerts</p>
                    </div>
                </div>

                <div class="hidden sm:block h-8 w-[1px] bg-white/10"></div>

                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-pnp-blue rounded-[1.25rem] flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 group-hover:rotate-0 transition-transform duration-500 shrink-0">
                        <i class="fas fa-newspaper text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-[9px] font-black text-blue-300 uppercase tracking-[0.15em] leading-none opacity-70">News & Releases</h4>
                        <div class="text-2xl font-black text-white mt-1 tabular-nums leading-none"><%= String(newsCount).padStart(2, '0') %></div>
                        <p class="text-[8px] text-blue-300/50 mt-1 uppercase font-bold tracking-widest">Published Articles</p>
                    </div>
                </div>
            </div>
            
            <!-- Publish Button -->
            <div class="w-full lg:w-auto flex justify-center">
                <a href="/admin/bulletins/create" class="w-full lg:w-auto px-6 py-3.5 bg-pnp-gold hover:bg-white text-pnp-blue rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg transition-all transform hover:scale-[1.05] active:scale-95 flex items-center justify-center space-x-2 whitespace-nowrap">
                    <i class="fas fa-plus"></i>
                    <span>Publish Notice</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Bulletin Grid -->
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden min-h-[500px]">
        <div class="p-8 border-b border-gray-50 dark:border-slate-800 bg-gray-50/10 dark:bg-slate-900/50 flex flex-col lg:flex-row justify-between items-center gap-6">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-sm">Directives</h3>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-4 w-full lg:w-auto">
                <!-- Dropdown -->
                <div class="relative w-full sm:w-56">
                    <select id="bulletinCategoryFilter" onchange="filterBulletins()" class="w-full pl-5 pr-10 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-100 dark:border-slate-800 rounded-2xl outline-none text-[10px] font-black text-slate-600 dark:text-white uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue/20 transition-all cursor-pointer appearance-none">
                        <option value="All" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category === 'undefined' || !category || category === 'All') ? 'selected' : '' %>>All Categories</option>
                        <option value="Crime Advisory" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Crime Advisory') ? 'selected' : '' %>>Crime Advisory</option>
                        <option value="Traffic Advisory" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Traffic Advisory') ? 'selected' : '' %>>Traffic Advisory</option>
                        <option value="Cybercrime Advisory" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Cybercrime Advisory') ? 'selected' : '' %>>Cybercrime Advisory</option>
                        <option value="Community Awareness" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'Community Awareness') ? 'selected' : '' %>>Community Awareness</option>
                        <option value="General Announcement" class="bg-white dark:bg-slate-950 text-slate-800 dark:text-white font-black" <%= (typeof category !== 'undefined' && category === 'General Announcement') ? 'selected' : '' %>>General Announcement</option>
                    </select>
                    <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-xs"></i>
                </div>
                <!-- Search -->
                <div class="relative w-full lg:w-72">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-xs"></i>
                    <input type="text" id="bulletinSearchInput" onkeyup="filterBulletins()" placeholder="Search mission labels..." class="w-full pl-10 pr-4 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-100 dark:border-slate-800 rounded-2xl outline-none text-[10px] font-black text-slate-600 dark:text-white uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue/20 transition-all placeholder:text-gray-300">
                </div>
            </div>
        </div>

        <div class="p-6">
            <!-- Empty state placeholder (visible when no items match) -->
            <div id="emptyStatePlaceholder" class="py-32 flex flex-col items-center justify-center text-center hidden">
                <i class="fas fa-bullhorn text-6xl mb-6 text-gray-200 dark:text-slate-800"></i>
                <h3 class="text-xl font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">No active directives found</h3>
                <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Publish a new notice or adjust filter criteria.</p>
            </div>

            <div id="bulletinList" class="flex flex-col gap-4 transition-all duration-300">
                <% if (bulletins.length === 0) { %>
                    <div class="py-32 flex flex-col items-center justify-center text-center">
                        <i class="fas fa-bullhorn text-6xl mb-6 text-gray-200 dark:text-slate-800"></i>
                        <h3 class="text-xl font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">No active directives found</h3>
                        <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Publish a new notice to broadcast.</p>
                    </div>
                <% } else { %>
                    <% bulletins.sort((a,b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()).forEach(bulletin => { %>
                        <div data-category="<%= bulletin.category %>" class="group bg-white dark:bg-slate-900/50 rounded-3xl p-6 shadow-sm border border-gray-100 dark:border-slate-800 hover:shadow-xl transition-all duration-300 flex flex-col lg:flex-row items-start lg:items-center gap-6 relative overflow-hidden">
                            <!-- Thumbnail -->
                            <% if (bulletin.video_paths && bulletin.video_paths.length > 0) { %>
                                <div class="w-full lg:w-32 h-40 lg:h-24 rounded-2xl overflow-hidden shrink-0 bg-black relative">
                                    <video src="<%= bulletin.video_paths[0] %>" muted class="w-full h-full object-cover group-hover:scale-110 transition duration-700 pointer-events-none"></video>
                                    <div class="absolute inset-0 bg-black/25 flex items-center justify-center">
                                        <i class="fas fa-play text-white text-xl"></i>
                                    </div>
                                </div>
                            <% } else if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                                <div class="w-full lg:w-32 h-40 lg:h-24 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800">
                                    <img src="<%= bulletin.photo_paths[0] %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                                </div>
                            <% } else if (bulletin.photo_path) { %>
                                <div class="w-full lg:w-32 h-40 lg:h-24 rounded-2xl overflow-hidden shrink-0 bg-slate-100 dark:bg-slate-800">
                                    <img src="<%= bulletin.photo_path %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                                </div>
                            <% } else { %>
                                <div class="w-16 h-16 rounded-2xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center shrink-0 border border-gray-100 dark:border-slate-700">
                                    <i class="fas fa-bullhorn text-2xl text-gray-300 dark:text-slate-600 group-hover:text-pnp-blue transition-colors"></i>
                                </div>
                            <% } %>

                            <!-- Content -->
                            <div class="flex-grow flex flex-col w-full min-w-0">
                                <div class="flex flex-wrap items-center gap-3 mb-2">
                                    <!-- Badge -->
                                    <% 
                                        const badgeColors = {
                                            'Wanted Person': 'bg-red-500/10 text-red-500 border-red-500/10',
                                            'Missing Person': 'bg-orange-500/10 text-orange-500 border-orange-500/10',
                                            'Crime Advisory': 'bg-pnp-gold/10 text-pnp-gold border-pnp-gold/10',
                                            'Traffic Advisory': 'bg-purple-500/10 text-purple-400 border-purple-500/10',
                                            'Cybercrime Advisory': 'bg-pink-500/10 text-pink-400 border-pink-500/10',
                                            'Community Awareness': 'bg-teal-500/10 text-teal-400 border-teal-500/10',
                                            'Recovered Property': 'bg-emerald-500/10 text-emerald-500 border-emerald-500/10',
                                            'General Announcement': 'bg-pnp-blue/10 text-pnp-blue-300 border-pnp-blue/10'
                                        };
                                        const categoryColor = badgeColors[bulletin.category] || 'bg-gray-100 text-gray-500';
                                    %>
                                    <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border <%= categoryColor %>">
                                        <%= bulletin.category %>
                                    </span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                                        <i class="fas fa-clock mr-1 opacity-50"></i> <%= new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'}) %> &middot; <%= new Date(bulletin.created_at).toLocaleTimeString(undefined, {hour:'2-digit', minute:'2-digit'}) %>
                                    </span>
                                </div>
                                <h4 class="text-sm font-black text-slate-800 dark:text-white uppercase tracking-tight leading-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition duration-300 mb-1.5 truncate">
                                    <%= bulletin.title %>
                                </h4>
                                <p class="text-[11px] text-slate-500 dark:text-slate-400 font-medium leading-relaxed line-clamp-2">
                                    <%= bulletin.body %>
                                </p>
                            </div>

                            <!-- Actions -->
                            <div class="flex items-center space-x-3 w-full lg:w-auto justify-end mt-4 lg:mt-0 shrink-0">
                                <a href="/admin/bulletins/<%= bulletin.id %>/edit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-pnp-blue dark:hover:text-pnp-gold hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-pnp-gold/20 shadow-sm" title="Edit Bulletin">
                                    <i class="fas fa-edit text-xs"></i>
                                </a>
                                <form action="/admin/bulletins/<%= bulletin.id %>/delete" method="POST" onsubmit="handleBulletinDelete(event, '<%= bulletin.id %>'); return false;">
                                    <button type="submit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm" title="Delete Bulletin">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>
    <!-- Carousel Pagination Controls -->
    <div id="carouselPagination" class="p-6 border-t border-gray-50 dark:border-slate-800 flex justify-center items-center space-x-2 hidden">
        <button id="prevBtn" onclick="navigateCarousel(-1)" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 hover:bg-pnp-blue hover:text-white text-gray-600 dark:text-gray-300 disabled:opacity-30 disabled:pointer-events-none rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">Previous</button>
        <span id="pageIndicator" class="text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 mx-4">Page 1 of 1</span>
        <button id="nextBtn" onclick="navigateCarousel(1)" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 hover:bg-pnp-blue hover:text-white text-gray-600 dark:text-gray-300 disabled:opacity-30 disabled:pointer-events-none rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">Next</button>
    </div>
</div>

<script>
    let currentPage = 1;
    const itemsPerPage = 5;

    async function handleBulletinDelete(e, id) {
        e.preventDefault();
        const confirmFn = window.strategicConfirm || window.confirmOperationalAction || (async (args) => {
            return confirm(args?.message || "Delete this entry?");
        });

        const confirmed = await confirmFn({
            title: "Delete Bulletin",
            message: "Permanently remove this intelligence notice from the public grid?",
            confirmText: "Purge Entry",
            type: "danger"
        });
        
        if (confirmed) {
            e.target.closest('form').submit();
        }
    }

    window.filterBulletins = function() {
        const selectedCategory = document.getElementById('bulletinCategoryFilter').value;
        const input = document.getElementById('bulletinSearchInput').value.toLowerCase();
        
        const cards = Array.from(document.querySelectorAll('#bulletinList > .group'));
        const matchingCards = [];

        cards.forEach(card => {
            const title = card.querySelector('h4')?.textContent.toLowerCase() || '';
            const subtitle = card.querySelector('p')?.textContent.toLowerCase() || '';
            const category = card.getAttribute('data-category');
            
            const matchesSearch = title.includes(input) || subtitle.includes(input);
            const matchesCategory = selectedCategory === 'All' || category === selectedCategory;
            
            if (matchesSearch && matchesCategory) {
                matchingCards.push(card);
            } else {
                card.style.display = 'none';
            }
        });

        const totalItems = matchingCards.length;
        const totalPages = Math.ceil(totalItems / itemsPerPage);

        // Constrain current page
        if (currentPage > totalPages) {
            currentPage = Math.max(1, totalPages);
        }

        const paginationContainer = document.getElementById('carouselPagination');
        const emptyState = document.getElementById('emptyStatePlaceholder');
        const listWrapper = document.getElementById('bulletinList');

        if (totalItems === 0) {
            if (paginationContainer) paginationContainer.classList.add('hidden');
            if (emptyState) emptyState.classList.remove('hidden');
            if (listWrapper) listWrapper.classList.add('hidden');
        } else {
            if (emptyState) emptyState.classList.add('hidden');
            if (listWrapper) listWrapper.classList.remove('hidden');
            
            if (totalItems > itemsPerPage) {
                if (paginationContainer) paginationContainer.classList.remove('hidden');
            } else {
                if (paginationContainer) paginationContainer.classList.add('hidden');
            }
        }

        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;

        matchingCards.forEach((card, index) => {
            if (index >= startIndex && index < endIndex) {
                card.style.display = 'flex';
                card.classList.add('animate-fade-in');
            } else {
                card.style.display = 'none';
            }
        });

        const pageIndicator = document.getElementById('pageIndicator');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');

        if (pageIndicator) {
            pageIndicator.textContent = `Page ${currentPage} of ${totalPages || 1}`;
        }
        if (prevBtn) {
            prevBtn.disabled = (currentPage === 1);
        }
        if (nextBtn) {
            nextBtn.disabled = (currentPage >= totalPages);
        }
    }

    window.navigateCarousel = function(direction) {
        const listContainer = document.getElementById('bulletinList');
        if (!listContainer) return;

        // Visual fade out transition
        listContainer.classList.add('opacity-0', 'scale-[0.98]');

        setTimeout(() => {
            currentPage += direction;
            window.filterBulletins();
            
            // Visual fade back in
            listContainer.classList.remove('opacity-0', 'scale-[0.98]');
        }, 150);
    }

    // Initialize carousel on document load
    document.addEventListener('DOMContentLoaded', () => {
        const initialCategory = '<%= typeof category !== "undefined" && category ? category : "All" %>';
        const filterSelect = document.getElementById('bulletinCategoryFilter');
        if (filterSelect && initialCategory) {
            filterSelect.value = initialCategory;
        }
        window.filterBulletins();
    });
</script>
