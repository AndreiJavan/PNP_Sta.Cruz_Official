<div class="space-y-8 animate-fade-in px-4 lg:px-0">
    <!-- Header with Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="pnp-card pnp-glass-dark border-pnp-blue/10 p-8 rounded-[2.5rem] flex items-center space-x-6 group">
            <div class="w-16 h-16 bg-pnp-blue rounded-[2rem] flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 group-hover:rotate-0 transition-transform duration-500">
                <i class="fas fa-bullhorn text-2xl"></i>
            </div>
            <div>
                <h4 class="text-[10px] font-black text-blue-300 uppercase tracking-[0.2em] leading-none opacity-70">Intelligence Bulletins</h4>
                <div class="text-3xl font-black text-white mt-2 tabular-nums"><%= String(bulletins.length).padStart(2, '0') %></div>
                <p class="text-[9px] text-blue-300/50 mt-1 uppercase font-bold">Active Public Notices</p>
            </div>
        </div>

        <div class="md:col-span-2 pnp-gradient-blue rounded-[2.5rem] p-8 flex flex-col md:flex-row items-center justify-between shadow-2xl relative overflow-hidden group border-2 border-white/5">
            <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10 pointer-events-none"></div>
            <div class="relative z-10 text-center md:text-left">
                <h3 class="text-2xl font-black text-white uppercase tracking-tighter leading-tight">Operational Directives</h3>
                <p class="text-blue-200/60 text-[10px] font-bold uppercase tracking-[0.2em] mt-3 italic">Broadcast critical warnings across the municipal intelligence grid</p>
            </div>
            <a href="/admin/bulletins/create" class="relative z-10 mt-6 md:mt-0 px-10 py-5 bg-pnp-gold hover:bg-white text-pnp-blue rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] shadow-xl transition-all transform hover:scale-[1.05] active:scale-95 flex items-center space-x-3">
                <i class="fas fa-plus"></i>
                <span>Publish Notice</span>
            </a>
        </div>
    </div>

    <!-- Bulletin Grid -->
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden min-h-[500px]">
        <div class="p-8 border-b border-gray-50 dark:border-slate-800 bg-gray-50/10 dark:bg-slate-900/50 flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-sm">Directive Archives</h3>
                <p class="text-[10px] text-slate-400 font-bold uppercase mt-1 tracking-widest italic">Complete Broadcast History</p>
            </div>
            <div class="flex items-center space-x-4 w-full md:w-auto">
                <div class="relative w-full md:w-72">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-xs"></i>
                    <input type="text" placeholder="Search mission labels..." class="w-full pl-10 pr-4 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-100 dark:border-slate-800 rounded-2xl outline-none text-[10px] font-black text-slate-600 dark:text-white uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue/20 transition-all placeholder:text-gray-300">
                </div>
            </div>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse min-w-[800px]">
                <thead class="bg-gray-50/50 dark:bg-slate-950/50">
                    <tr>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800">Directive Title</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800">Operational Category</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800">Logged At</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-right">Protocol</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-slate-800">
                    <% if (bulletins.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-8 py-40 text-center text-gray-300 dark:text-slate-700 font-black uppercase tracking-[0.5em] italic">
                                <div class="flex flex-col items-center justify-center">
                                    <i class="fas fa-bullhorn text-6xl mb-6 opacity-20"></i>
                                    <span>No active directives found</span>
                                </div>
                            </td>
                        </tr>
                    <% } else { %>
                        <% bulletins.sort((a,b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()).forEach(bulletin => { %>
                            <tr class="hover:bg-pnp-blue/5 dark:hover:bg-slate-800/40 transition-all group">
                                <td class="px-8 py-7">
                                    <div class="flex flex-col">
                                        <span class="text-[11px] font-black text-slate-800 dark:text-white uppercase tracking-tight leading-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition duration-300"><%= bulletin.title %></span>
                                        <span class="text-[10px] text-slate-400 font-bold uppercase mt-1.5 opacity-70 truncate max-w-sm"><%= (bulletin.body || '').substring(0, 100) %>...</span>
                                    </div>
                                </td>
                                <td class="px-8 py-7">
                                    <% 
                                        const badgeColors = {
                                            'Wanted Person': 'bg-red-500/10 text-red-500 border-red-500/10',
                                            'Missing Person': 'bg-orange-500/10 text-orange-500 border-orange-500/10',
                                            'Crime Advisory': 'bg-pnp-gold/10 text-pnp-gold border-pnp-gold/10',
                                            'Recovered Property': 'bg-emerald-500/10 text-emerald-500 border-emerald-500/10',
                                            'General Announcement': 'bg-pnp-blue/10 text-pnp-blue-300 border-pnp-blue/10'
                                        };
                                        const categoryColor = badgeColors[bulletin.category] || 'bg-gray-100 text-gray-500';
                                    %>
                                    <span class="px-5 py-2 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] border shadow-sm <%= categoryColor %>">
                                        <%= bulletin.category %>
                                    </span>
                                </td>
                                <td class="px-8 py-7">
                                    <div class="flex flex-col">
                                        <span class="text-[11px] font-black text-slate-800 dark:text-white uppercase leading-none tracking-tighter"><%= new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'}) %></span>
                                        <span class="text-[10px] text-slate-400 font-bold uppercase mt-1.5 tracking-widest opacity-70"><%= new Date(bulletin.created_at).toLocaleTimeString(undefined, {hour:'2-digit', minute:'2-digit'}) %></span>
                                    </div>
                                </td>
                                <td class="px-8 py-7 text-right">
                                    <div class="flex items-center justify-end space-x-3">
                                        <a href="/admin/bulletins/<%= bulletin.id %>/edit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-pnp-blue dark:hover:text-pnp-gold hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-pnp-gold/20 shadow-sm">
                                            <i class="fas fa-edit text-xs"></i>
                                        </a>
                                        <form action="/admin/bulletins/<%= bulletin.id %>/delete" method="POST" onsubmit="return handleBulletinDelete(event, '<%= bulletin.id %>')">
                                            <button type="submit" class="w-11 h-11 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm">
                                                <i class="fas fa-trash-alt text-xs"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="p-6 border-t border-gray-50 dark:border-slate-800 flex justify-center items-center space-x-2">
        <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 text-gray-600 dark:text-gray-300 rounded-lg text-[10px] font-black uppercase tracking-widest hover:bg-pnp-blue hover:text-white transition">Previous</a>
        <% } %>
        <span class="text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 mx-4">Page <%= currentPage %> of <%= totalPages %></span>
        <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>" class="px-4 py-2 bg-gray-50 dark:bg-slate-700 text-gray-600 dark:text-gray-300 rounded-lg text-[10px] font-black uppercase tracking-widest hover:bg-pnp-blue hover:text-white transition">Next</a>
        <% } %>
    </div>
    <% } %>
</div>

<script>
    async function handleBulletinDelete(e, id) {
        e.preventDefault();
        const confirmFn = window.strategicConfirm || window.confirmOperationalAction || (async (args) => {
            return confirm(args?.message || "Delete this entry?");
        });

        const confirmed = await confirmFn({
            title: "Delete Bulletin",
            message: "Permanently remove this intelligence notice from the public grid?",
            confirmText: "Purge Entry",
            type: "danger"
        });
        
        if (confirmed) {
            e.target.closest('form').submit();
        }
    }
</script>
