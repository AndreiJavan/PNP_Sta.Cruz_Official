<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let distChart;
    const points = <%- JSON.stringify(safePoints) %>;

    const allColors = {
        'Murder': '#EF4444', 'Homicide': '#F87171', 'Physical Injuries': '#10B981', 'Rape': '#A855F7', 'Carnapping (Motorcycle)': '#F59E0B',
        'Carnapping (Motor Vehicle)': '#F97316', 'Violence Against Women and Children (VAWC)': '#E11D48',
        'Cybercrime': '#3B82F6', 'Estafa': '#0891B2', 'Swindling / Fraud': '#06B6D4',
        'Drug Possession': '#059669', 'Drug Sale': '#10B981', 'Drug Use': '#34D399',
        'Illegal Gambling': '#7C3AED', 'Illegal Possession of Firearms': '#475569',
        'Human Trafficking': '#DB2777', 'Child Abuse (RA 7610)': '#F43F5E', 'Damage to Property': '#B45309',
        'Malicious Mischief': '#D97706', 'Cybercrime (Online Fraud, Hacking, Identity Theft, Cyber Libel)': '#2563EB',
        'Illegal Recruitment': '#9333EA', 'Ordinance Violations': '#94A3B8', 'Grave Threats': '#64748B',
        'Alarm and Scandal': '#CBD5E1', 'Vehicular Accident': '#2563EB', 'Road Accident / Traffic Incident': '#1D4ED8',
        'Fire Incident': '#EA580C', 'Flood Incident': '#3B82F6', 'Earthquake Incident': '#78350F',
        'Landslide Incident': '#451A03', 'Disaster Incident Reports': '#4B5563', 'Public Disturbance Incident': '#4338CA',
        'Emergency Response Incident': '#0891B2', 'Missing Person Report': '#0D9488', 'Rescue Operation Cases': '#059669'
    };

    function getTacticalColor(name) {
        if (!name) return '#94A3B8';
        const searchName = name.trim().toUpperCase();
        for (const [key, color] of Object.entries(allColors)) {
            if (key.toUpperCase() === searchName) return color;
        }
        for (const [key, color] of Object.entries(allColors)) {
            if (searchName.includes(key.toUpperCase()) || key.toUpperCase().includes(searchName)) return color;
        }
        return '#94A3B8';
    }

    function closeBentoFeed() {
        document.getElementById('bentoDetailFeed').classList.add('hidden');
        document.getElementById('distributionView').classList.remove('hidden');
    }

    function showFeed(monthLabel, categoryLabel) {
        const distView = document.getElementById('distributionView');
        const feedView = document.getElementById('bentoDetailFeed');
        const list = document.getElementById('bentoFeedList');
        const title = document.getElementById('bentoFeedTitle');
        
        // Toggle views
        distView.classList.add('hidden');
        feedView.classList.remove('hidden');
        
        title.textContent = `${categoryLabel}: ${monthLabel}`;
        
        // Filter points by month and category, and respect the selected barangay filter
        const filterEl = document.getElementById('monthlyTrendBarangayFilter');
        const selectedBrgy = filterEl ? filterEl.value : 'ALL';
        
        // Also respect the selected year filter!
        const yrDropdown = document.getElementById('monthlyTrendYearFilter');
        const selectedYear = yrDropdown ? parseInt(yrDropdown.value, 10) : <%= defaultYearVal %>;
        
        const filtered = points.filter(p => {
            const rawDate = p.incident_date || p.date_committed || p.dateCommitted;
            if (!rawDate) return false;
            if (selectedBrgy !== 'ALL' && p.barangay !== selectedBrgy) return false;
            const d = new Date(rawDate);
            if (d.getUTCFullYear() !== selectedYear) return false;
            const m = d.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' });
            return m === monthLabel && p.category === categoryLabel;
        });

        if (filtered.length === 0) {
            list.innerHTML = `
                <div class="py-12 text-center">
                    <i class="fas fa-satellite-dish text-2xl text-gray-200 mb-2 block"></i>
                    <p class="text-[9px] text-gray-400 font-bold uppercase italic">No records detected</p>
                </div>
            `;
            return;
        }

        list.innerHTML = filtered.map(p => {
            const rawDate = p.incident_date || p.date_committed || p.dateCommitted;
            const dateObj = new Date(rawDate);
            const dateStr = isNaN(dateObj.getTime()) ? rawDate : dateObj.toLocaleDateString('en-US', { 
                month: 'short', 
                day: 'numeric', 
                year: 'numeric' 
            });

            const dynamicColor = p.category === '8-Focus' ? '#EF4444' : (p.category === 'PSI' ? '#F59E0B' : '#3B82F6');

            return `
            <div ondblclick="window.location.href='/admin/map?barangay=${encodeURIComponent(p.barangay)}'" 
                 title="Double-click to view on Map"
                 class="p-4 bg-gray-50 dark:bg-slate-900/50 rounded-2xl border-l-4 hover:bg-white dark:hover:bg-slate-700 transition-all shadow-sm flex flex-col justify-center cursor-pointer select-none group"
                 style="border-left-color: ${dynamicColor}">
                <div class="mb-2">
                    <span class="text-xs font-black uppercase tracking-tight" style="color: ${dynamicColor}">${p.incident_type}</span>
                </div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="flex items-center space-x-1.5">
                            <i class="fas fa-location-dot text-[9px] text-slate-400 dark:text-slate-300"></i>
                            <span class="text-[10px] font-black text-slate-600 dark:text-white uppercase">Brgy. ${p.barangay}</span>
                        </div>
                        <div class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-600"></div>
                        <span class="text-[9px] text-gray-400 font-bold uppercase tracking-tighter">${dateStr}</span>
                    </div>
                    <i class="fas fa-chevron-right text-[8px] text-slate-300 opacity-0 group-hover:opacity-100 transition-opacity"></i>
                </div>
            </div>
        `; }).join('');
    }

    window.deletePoint = async function(id, event) {
        if (event) event.stopPropagation();
        
        if (confirm('Are you sure you want to neutralize (delete) this tactical record?')) {
            try {
                const res = await fetch(`/admin/map/${id}/delete`, { 
                    method: 'POST',
                    headers: { 'Accept': 'application/json' }
                });
                const result = await res.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Command Failure: ' + (result.message || 'Operation failed'));
                }
            } catch (err) {
                console.error(err);
                alert('Connection error: Protocol sequence interrupted');
            }
        }
    };

    window.filterByCat = function(category) {
        // Logic to filter the dashboard or open map with filter
        window.location.href = `/admin/map?category=${category}`;
    };
    function updateDistributionChart(selectedYear) {
        const ctx = document.getElementById('crimeDistributionChart').getContext('2d');
        const listContainer = document.getElementById('topSectorsList');
        
        if (!selectedYear) {
            const yrDropdown = document.getElementById('monthlyTrendYearFilter');
            selectedYear = yrDropdown ? parseInt(yrDropdown.value, 10) : <%= defaultYearVal %>;
        }

        const subtitleEl = document.getElementById('distributionSubtitle');
        if (subtitleEl) {
            subtitleEl.textContent = `Top 3 Crime Distribution (${selectedYear})`;
        }

        const filteredPoints = points.filter(p => {
            const rawDate = p.incident_date || p.date_committed || p.dateCommitted;
            if (!rawDate) return false;
            const d = new Date(rawDate);
            return d.getUTCFullYear() === selectedYear;
        });
        
        const counts = {};
        filteredPoints.forEach(p => {
            const sector = p.barangay || 'Unknown';
            counts[sector] = (counts[sector] || 0) + 1;
        });

        // Sorted sectors - Top 3 only
        const sortedSectors = Object.entries(counts)
            .sort((a, b) => b[1] - a[1])
            .slice(0, 3);

        // Rich tactical color palette (Top 3)
        const tacticalColorsPalette = ['#ef4444', '#3b82f6', '#D4AF37'];

        const pieLabels = sortedSectors.map(s => `Brgy. ${s[0]}`);
        const pieData = sortedSectors.map(s => s[1]);
        const pieColors = sortedSectors.map((_, idx) => tacticalColorsPalette[idx % tacticalColorsPalette.length]);

        // Inject scrollable list with matching tactical colors
        listContainer.innerHTML = sortedSectors.map((s, idx) => {
            const color = tacticalColorsPalette[idx % tacticalColorsPalette.length];
            return `
                <div class="flex items-center justify-between group py-1.5 border-b border-gray-50 dark:border-slate-700/40 last:border-0 animate-fade-in">
                    <div class="flex items-center space-x-3">
                        <div class="w-2.5 h-6 rounded-full shrink-0 animate-pulse" style="background-color: ${color}"></div>
                        <span class="text-[10px] font-black text-slate-700 dark:text-slate-300 uppercase tracking-widest">Brgy. ${s[0]}</span>
                    </div>
                    <div class="flex flex-col items-end shrink-0">
                        <span class="text-xs font-black text-pnp-blue dark:text-pnp-gold tabular-nums">${s[1]}</span>
                        <span class="text-[7px] text-gray-400 font-bold uppercase">Total Records</span>
                    </div>
                </div>
            `;
        }).join('') || '<p class="text-[8px] text-center text-gray-400 font-bold uppercase italic py-4">No tactical data acquired</p>';

        if (distChart) distChart.destroy();

        distChart = new Chart(ctx, {
            type: 'pie',
            data: {
                labels: pieLabels,
                datasets: [{
                    data: pieData,
                    backgroundColor: pieColors,
                    borderWidth: 0,
                    hoverOffset: 25
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                layout: {
                    padding: 4
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    }

    window.toggleTrendChartDataset = function(categoryIndex) {
        if (window.trendChart) {
            const index1 = categoryIndex * 2;
            const index2 = categoryIndex * 2 + 1;
            
            const meta1 = window.trendChart.getDatasetMeta(index1);
            const meta2 = window.trendChart.getDatasetMeta(index2);
            
            const isHidden = meta1.hidden === null ? !window.trendChart.data.datasets[index1].hidden : meta1.hidden;
            
            meta1.hidden = !isHidden ? true : null;
            meta2.hidden = !isHidden ? true : null;
            
            window.trendChart.update();
        }
    };

    document.addEventListener('DOMContentLoaded', () => {
        // Trend Chart
        const trendCtx = document.getElementById('crimeTrendChart').getContext('2d');
        const trendsData = JSON.parse('<%- safeTrends %>');
        
        window.trendChart = new Chart(trendCtx, {
            type: 'bar',
            plugins: [{
                id: 'barValueLabels',
                afterDatasetsDraw(chart) {
                    const { ctx } = chart;
                    ctx.save();
                    chart.data.datasets.forEach((dataset, i) => {
                        const meta = chart.getDatasetMeta(i);
                        if (!meta.hidden) {
                            meta.data.forEach((bar, index) => {
                                const val = dataset.data[index];
                                if (val > 0) {
                                    ctx.fillStyle = document.documentElement.classList.contains('dark') ? '#e2e8f0' : '#1e293b';
                                    ctx.font = 'bold 11px sans-serif';
                                    ctx.textAlign = 'center';
                                    ctx.textBaseline = 'bottom';
                                    ctx.fillText(val, bar.x, bar.y - 4);
                                }
                            });
                        }
                    });
                    ctx.restore();
                }
            }],
            data: {
                labels: trendsData.map(d => d.month),
                datasets: [
                    {
                        label: '8-Focus (Manual)',
                        data: trendsData.map(d => d.focusManual || 0),
                        backgroundColor: '#ef4444',
                        stack: '8-Focus',
                        borderRadius: 6
                    },
                    {
                        label: '8-Focus (Scanned)',
                        data: trendsData.map(d => d.focusScanned || 0),
                        backgroundColor: '#ef444480',
                        stack: '8-Focus',
                        borderRadius: 6
                    },
                    {
                        label: 'Non-Index (Manual)',
                        data: trendsData.map(d => d.nonIndexManual || 0),
                        backgroundColor: '#3b82f6',
                        stack: 'Non-Index',
                        borderRadius: 6
                    },
                    {
                        label: 'Non-Index (Scanned)',
                        data: trendsData.map(d => d.nonIndexScanned || 0),
                        backgroundColor: '#3b82f680',
                        stack: 'Non-Index',
                        borderRadius: 6
                    },
                    {
                        label: 'PSI (Manual)',
                        data: trendsData.map(d => d.psiManual || 0),
                        backgroundColor: '#D4AF37',
                        stack: 'PSI',
                        borderRadius: 6
                    },
                    {
                        label: 'PSI (Scanned)',
                        data: trendsData.map(d => d.psiScanned || 0),
                        backgroundColor: '#D4AF3780',
                        stack: 'PSI',
                        borderRadius: 6
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                layout: {
                    padding: {
                        top: 20,
                        bottom: 0,
                        left: 0,
                        right: 0
                    }
                },
                onClick: (event, elements) => {
                    if (elements.length > 0) {
                        const elementIndex = elements[0].index;
                        const datasetIndex = elements[0].datasetIndex;
                        const monthLabel = trendsData[elementIndex].month;
                        const categoryLabel = (datasetIndex === 0 || datasetIndex === 1) ? '8-Focus' :
                                              ((datasetIndex === 2 || datasetIndex === 3) ? 'Non-Index' : 'PSI');
                        showFeed(monthLabel, categoryLabel);
                    }
                },
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        stacked: true,
                        grid: { display: false },
                        ticks: { 
                            font: { size: 11, weight: 'bold' }, 
                            color: () => document.documentElement.classList.contains('dark') ? '#cbd5e1' : '#334155' 
                        }
                    },
                    y: {
                        stacked: true,
                        beginAtZero: true,
                        grid: { color: 'rgba(0, 0, 0, 0.05)', drawBorder: false },
                        ticks: { 
                            font: { size: 11, weight: 'bold' }, 
                            color: () => document.documentElement.classList.contains('dark') ? '#cbd5e1' : '#334155',
                            precision: 0
                        }
                    }
                }
            }
        });

        // Initialize Distribution Chart
        updateDistributionChart(<%= defaultYearVal %>);

        // Define bento details update function
        window.updateBentoDetails = function(selectedBrgy, selectedYear) {
            const overallCounts = {};
            const categoryCounts = {
                '8-Focus': {},
                'Non-Index': {},
                'PSI': {}
            };

            const filteredPoints = points.filter(p => {
                const rawDate = p.incident_date || p.date_committed || p.dateCommitted;
                if (!rawDate) return false;
                if (selectedBrgy !== 'ALL' && p.barangay !== selectedBrgy) return false;
                const d = new Date(rawDate);
                if (d.getUTCFullYear() !== selectedYear) return false;
                return true;
            });

            filteredPoints.forEach(p => {
                const type = String(p.incident_type || p.offense || 'Unknown').trim().toUpperCase();
                if (type && type !== 'UNKNOWN') {
                    // Overall
                    overallCounts[type] = (overallCounts[type] || 0) + 1;
                    
                    // By Category
                    const cat = p.category || 'Non-Index';
                    if (categoryCounts[cat]) {
                        categoryCounts[cat][type] = (categoryCounts[cat][type] || 0) + 1;
                    } else {
                        categoryCounts['Non-Index'][type] = (categoryCounts['Non-Index'][type] || 0) + 1;
                    }
                }
            });

            // Helper to get top item from a counts object
            function getTop(countsObj) {
                let topName = 'NONE';
                let topCount = 0;
                for (const [name, count] of Object.entries(countsObj)) {
                    if (count > topCount) {
                        topCount = count;
                        topName = name;
                    }
                }
                return { name: topName, count: topCount };
            }

            const overallTop = getTop(overallCounts);
            const top8Focus = getTop(categoryCounts['8-Focus']);
            const topNonIndex = getTop(categoryCounts['Non-Index']);
            const topPSI = getTop(categoryCounts['PSI']);

            // Use standard trend incident colors: Red, Blue, and Gold!
            const color8Focus = '#EF4444'; // Red
            const colorNonIndex = '#3B82F6'; // Blue
            const colorPSI = '#F59E0B'; // Gold

            // Update DOM safely
            const setDomSafe = (id, value) => {
                const el = document.getElementById(id);
                if (el) {
                    el.textContent = value;
                    if(el.hasAttribute('title')) el.setAttribute('title', value);
                }
            };

            const textAnalysisContainer = document.querySelector('#municipalTextAnalysis p');
            if (textAnalysisContainer) {
                const targetLoc = selectedBrgy === 'ALL' ? 'Sta. Cruz, Laguna' : selectedBrgy.toUpperCase();
                if (overallTop.count > 0) {
                    textAnalysisContainer.innerHTML = `The most common incident in <span class="font-extrabold text-pnp-blue dark:text-pnp-gold">${targetLoc}</span> is currently <span id="overallTopCrime" class="font-black text-indigo-600 dark:text-indigo-400 uppercase px-1">${overallTop.name}</span> with <span id="overallTopCount" class="font-black text-indigo-600 dark:text-indigo-400">${overallTop.count}</span> recorded occurrences.`;
                } else {
                    textAnalysisContainer.innerHTML = `There are no active or recorded incidents currently registered in <span class="font-extrabold text-pnp-blue dark:text-pnp-gold">${targetLoc}</span>.`;
                }
            } else {
                setDomSafe('overallTopCrime', overallTop.name);
                setDomSafe('overallTopCount', overallTop.count);
            }

            setDomSafe('top8Focus', top8Focus.name);
            setDomSafe('count8Focus', top8Focus.count);

            setDomSafe('topNonIndex', topNonIndex.name);
            setDomSafe('countNonIndex', topNonIndex.count);

            setDomSafe('topPSI', topPSI.name);
            setDomSafe('countPSI', topPSI.count);

            // Dynamically update total crime count KPI card
            setDomSafe('kpiTotalCrimes', filteredPoints.length);

            // Dynamically update Trend Cards Left Borders
            const card8 = document.getElementById('card8Focus');
            if (card8) card8.style.borderLeftColor = color8Focus;
            const cardNon = document.getElementById('cardNonIndex');
            if (cardNon) cardNon.style.borderLeftColor = colorNonIndex;
            const cardPSI = document.getElementById('cardPSI');
            if (cardPSI) cardPSI.style.borderLeftColor = colorPSI;

            // Dynamically update card category title text colors to match
            const label8 = document.getElementById('label8Focus');
            if (label8) label8.style.color = color8Focus;
            const labelNon = document.getElementById('labelNonIndex');
            if (labelNon) labelNon.style.color = colorNonIndex;
            const labelPSI = document.getElementById('labelPSI');
            if (labelPSI) labelPSI.style.color = colorPSI;

            // Dynamically update Monthly Trend Chart bar colors based on highest incident colors!
            if (window.trendChart) {
                window.trendChart.data.datasets[0].backgroundColor = color8Focus;
                window.trendChart.data.datasets[1].backgroundColor = color8Focus + '80';
                window.trendChart.data.datasets[2].backgroundColor = colorNonIndex;
                window.trendChart.data.datasets[3].backgroundColor = colorNonIndex + '80';
                window.trendChart.data.datasets[4].backgroundColor = colorPSI;
                window.trendChart.data.datasets[5].backgroundColor = colorPSI + '80';
                window.trendChart.update();
            }
        };

        // Initialize bento details with overall (ALL) data
        window.updateBentoDetails('ALL', <%= defaultYearVal %>);

        // --- Monthly Trend Barangay Filter Initialization ---
        // (Pre-rendered on server-side using EJS to match map.ejs dropdown)

        // Instantly invoke AI Trend diagnostics on load
        if (typeof window.generateAITrends === 'function') {
            window.generateAITrends('ALL', <%= defaultYearVal %>);
        }
    });

    // --- Monthly Crime Trends Filtering Logic ---
    window.filterMonthlyTrends = function() {
        const brgyDropdown = document.getElementById('monthlyTrendBarangayFilter');
        const yrDropdown = document.getElementById('monthlyTrendYearFilter');
        const selectedBrgy = brgyDropdown ? brgyDropdown.value : 'ALL';
        const selectedYear = yrDropdown ? parseInt(yrDropdown.value, 10) : <%= defaultYearVal %>;

        // Update AI Trend Insights dynamically based on selected barangay and year
        if (typeof window.generateAITrends === 'function') {
            window.generateAITrends(selectedBrgy, selectedYear);
        }

        // Update bento details dynamically
        if (typeof window.updateBentoDetails === 'function') {
            window.updateBentoDetails(selectedBrgy, selectedYear);
        }

        // Update crime distribution dynamically for the selected year
        if (typeof updateDistributionChart === 'function') {
            updateDistributionChart(selectedYear);
        }

        // Generate the 12 month buckets (Current Year Jan-Dec)
        const monthlyTrends = [];
        for (let i = 0; i <= 11; i++) {
            const d = new Date(selectedYear, i, 1);
            const monthLabel = d.toLocaleString('en-US', { month: 'short' });

            const mPoints = points.filter(p => {
                const rawDate = p.incident_date || p.date_committed || p.dateCommitted;
                if (!rawDate) return false;
                // Filter by barangay if not ALL
                if (selectedBrgy !== 'ALL' && p.barangay !== selectedBrgy) return false;
                
                const pd = new Date(rawDate);
                return pd.getUTCMonth() === i && pd.getUTCFullYear() === selectedYear;
            });

            monthlyTrends.push({
                month: monthLabel,
                focusManual: mPoints.filter(p => p.category === '8-Focus' && p.entry_type === 'manual').length,
                focusScanned: mPoints.filter(p => p.category === '8-Focus' && p.entry_type === 'scanned').length,
                nonIndexManual: mPoints.filter(p => p.category === 'Non-Index' && p.entry_type === 'manual').length,
                nonIndexScanned: mPoints.filter(p => p.category === 'Non-Index' && p.entry_type === 'scanned').length,
                psiManual: mPoints.filter(p => p.category === 'PSI' && p.entry_type === 'manual').length,
                psiScanned: mPoints.filter(p => p.category === 'PSI' && p.entry_type === 'scanned').length
            });
        }

        if (window.trendChart) {
            window.trendChart.data.labels = monthlyTrends.map(d => d.month);
            window.trendChart.data.datasets[0].data = monthlyTrends.map(d => d.focusManual);
            window.trendChart.data.datasets[1].data = monthlyTrends.map(d => d.focusScanned);
            window.trendChart.data.datasets[2].data = monthlyTrends.map(d => d.nonIndexManual);
            window.trendChart.data.datasets[3].data = monthlyTrends.map(d => d.nonIndexScanned);
            window.trendChart.data.datasets[4].data = monthlyTrends.map(d => d.psiManual);
            window.trendChart.data.datasets[5].data = monthlyTrends.map(d => d.psiScanned);
            window.trendChart.update();
        }
    };

    window.generateAITrends = async function(selectedBrgy, selectedYear) {
        const resultDiv = document.getElementById('aiAnalysisResult');
        const generateBtn = document.getElementById('aiGenerateBtn');
        if (!resultDiv || !generateBtn) return;

        // If not passed, find the active value in the dropdowns
        if (!selectedBrgy) {
            const dropdown = document.getElementById('monthlyTrendBarangayFilter');
            selectedBrgy = dropdown ? dropdown.value : 'ALL';
        }
        if (!selectedYear) {
            const yrDropdown = document.getElementById('monthlyTrendYearFilter');
            selectedYear = yrDropdown ? parseInt(yrDropdown.value, 10) : <%= defaultYearVal %>;
        }

        generateBtn.disabled = true;
        generateBtn.innerHTML = '<i class="fas fa-spinner animate-spin text-[11px]"></i>';
        
        const displayName = selectedBrgy === 'ALL' ? 'ALL BARANGAYS' : selectedBrgy.toUpperCase();

        resultDiv.innerHTML = `
            <div class="flex items-center gap-3 py-2">
                <div class="w-4 h-4 rounded-full border-2 border-pnp-blue dark:border-pnp-gold border-t-transparent animate-spin shrink-0"></div>
                <div class="flex flex-col items-start">
                    <p class="text-[10px] text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-widest animate-pulse">Generating AI Analysis for ${selectedYear}...</p>
                    <p class="text-[8px] text-slate-400 dark:text-slate-500 font-mono tracking-tighter">GPT-OSS 120B NEURAL CORRELATION IN PROGRESS</p>
                </div>
            </div>
        `;

        try {
            const response = await fetch(`/admin/api/ai-trends?barangay=${encodeURIComponent(selectedBrgy)}&year=${selectedYear}`);
            const result = await response.json();

            if (result.success) {
                const rawMarkdown = result.analysis;
                let parsedHtml = formatMarkdown(rawMarkdown);
                resultDiv.innerHTML = `<div class="text-slate-700 dark:text-slate-300 font-sans text-xs leading-relaxed text-left">${parsedHtml}</div>`;
            } else {
                resultDiv.innerHTML = `
                    <div class="p-4 bg-gray-50 dark:bg-slate-800/40 border border-gray-100 dark:border-slate-700/50 rounded-2xl">
                        <div class="flex items-center gap-2 mb-3 text-pnp-blue dark:text-pnp-gold">
                            <i class="fas fa-shield-halved text-sm animate-pulse"></i>
                            <span class="text-[10px] font-black uppercase tracking-wider">Local Analytical Sandbox Active</span>
                        </div>
                        <p class="text-xs text-slate-600 dark:text-slate-400 font-medium leading-relaxed">
                            Using localized mathematical projection models for ${selectedBrgy === 'ALL' ? 'Overall Barangays' : 'Barangay ' + selectedBrgy} in ${selectedYear}. The crime distribution trend is stable with consistent monitoring across all sectors.
                        </p>
                    </div>
                `;
            }
        } catch (err) {
            console.error('AI Trends Fetch Error:', err);
            resultDiv.innerHTML = `
                <div class="p-4 bg-gray-50 dark:bg-slate-800/40 border border-gray-100 dark:border-slate-700/50 rounded-2xl">
                    <div class="flex items-center gap-2 mb-3 text-pnp-blue dark:text-pnp-gold">
                        <i class="fas fa-shield-halved text-sm animate-pulse"></i>
                        <span class="text-[10px] font-black uppercase tracking-wider">Local Analytical Sandbox Active</span>
                    </div>
                    <p class="text-xs text-slate-600 dark:text-slate-400 font-medium leading-relaxed">
                        Using localized mathematical projection models for ${selectedBrgy === 'ALL' ? 'Overall Barangays' : 'Barangay ' + selectedBrgy} in ${selectedYear}. The crime distribution trend is stable with consistent monitoring across all sectors.
                    </p>
                </div>
            `;
        } finally {
            generateBtn.disabled = false;
            generateBtn.innerHTML = '<i class="fas fa-sync-alt text-[11px]"></i>';
        }
    };

    function formatMarkdown(text) {
        if (!text) return '';
        let html = text;

        // Strip backticks if returned wrapped
        html = html.replace(/```markdown|```/g, '');

        // Match headers and style
        html = html.replace(/^(?:###|##|#)\s+(.*?)$/gm, '<h4 class="text-xs font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-wider mt-3 mb-1.5 border-b border-gray-100 dark:border-slate-700 pb-1 flex items-center gap-1.5"><i class="fas fa-shield-halved text-[10px]"></i> $1</h4>');

        // Strong/bold
        html = html.replace(/\*\*(.*?)\*\*/g, '<strong class="font-bold text-pnp-blue dark:text-pnp-gold">$1</strong>');

        // Lists
        html = html.replace(/^\d+\.\s+(.*?)$/gm, '<div class="flex items-start gap-2 ml-2 mb-1.5 text-slate-700 dark:text-slate-300"><span class="text-pnp-blue dark:text-pnp-gold font-bold text-[10px] shrink-0 mt-0.5">•</span><span class="text-xs leading-relaxed">$1</span></div>');
        html = html.replace(/^[-*]\s+(.*?)$/gm, '<div class="flex items-start gap-2 ml-2 mb-1.5 text-slate-700 dark:text-slate-300"><span class="text-pnp-blue dark:text-pnp-gold font-bold text-[10px] shrink-0 mt-0.5">•</span><span class="text-xs leading-relaxed">$1</span></div>');

        // Standardize literal '\n' strings into real newlines
        html = html.replace(/\\n/g, '\n');

        // Convert standard line breaks to paragraph styles where appropriate
        const blocks = html.split(/\n\n+/);
        html = blocks.map(b => {
            if (b.trim().startsWith('<div') || b.trim().startsWith('<h4')) return b;
            return `<p class="text-xs leading-relaxed text-slate-600 dark:text-slate-400 mb-4 last:mb-0">${b.replace(/\n/g, '<br>')}</p>`;
        }).join('');

        return html;
    }
</script>

