<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
    <!-- Monthly Crime Trend Graph -->
    <div class="lg:col-span-2 bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 p-8 flex flex-col h-[500px] transition-all hover:shadow-xl">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">Monthly Longitudinal Analytics</h3>
                <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest mt-1 italic">Tactical Trend Oscillations (6-Month Horizon)</p>
            </div>
            <div class="flex items-center space-x-6 bg-gray-50 dark:bg-slate-900 p-3 rounded-2xl border border-gray-100 dark:border-slate-700">
                <div class="flex items-center space-x-2">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
                    <span class="text-[8px] font-black text-slate-500 uppercase tracking-tighter">8-Focus</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-2.5 h-2.5 rounded-full bg-pnp-blue"></div>
                    <span class="text-[8px] font-black text-slate-500 uppercase tracking-tighter">Non-Index</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-2.5 h-2.5 rounded-full bg-pnp-gold"></div>
                    <span class="text-[8px] font-black text-slate-500 uppercase tracking-tighter">PSI</span>
                </div>
            </div>
        </div>
        <div class="flex-1 relative">
            <canvas id="crimeTrendChart"></canvas>
        </div>
    </div>

    <!-- Crime Rate Distribution Chart -->
    <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-slate-700 p-8 flex flex-col h-[500px] relative overflow-hidden">
        <div class="relative z-10">
            <div class="flex items-center justify-between mb-8 border-b border-gray-50 dark:border-slate-700 pb-4">
                <div>
                    <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">Sectoral Risk Proportions</h3>
                    <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-1">Cross-Categorical Distribution</p>
                </div>
            </div>
            
            <div class="h-[300px] mb-6">
                <canvas id="crimeDistributionChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let distChart;
    const points = <%- JSON.stringify(safePoints) %>;

    function getCategoryForType(type) {
        const focusTypes = ['Murder', 'Homicide', 'Physical Injury', 'Rape', 'Robbery', 'Theft', 'Carnapping'];
        const psiTypes = ['Search Warrant', 'Warrant of Arrest', 'Checkpoint', 'Buy-Bust', 'Oplan Bakal', 'Oplan Galugad', 'Checkpoint'];
        
        if (focusTypes.some(f => type.toLowerCase().includes(f.toLowerCase()))) return '8-Focus';
        if (psiTypes.some(p => type.toLowerCase().includes(p.toLowerCase()))) return 'PSI';
        return 'Non-Index';
    }

    function updateDistributionChart() {
        const ctx = document.getElementById('crimeDistributionChart').getContext('2d');
        const filteredPoints = points;
        
        const counts = {};
        filteredPoints.forEach(p => {
            const type = p.incident_type || 'Other';
            counts[type] = (counts[type] || 0) + 1;
        });

        const labels = Object.keys(counts);
        const data = Object.values(counts);
        const total = data.reduce((a, b) => a + b, 0);

        const tacticalColors = [
            '#ef4444', '#1A3A5C', '#D4AF37', '#10b981', '#6366f1', 
            '#f59e0b', '#ec4899', '#14b8a6', '#8b5cf6', '#475569'
        ];

        if (distChart) distChart.destroy();

        distChart = new Chart(ctx, {
            type: 'pie',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: tacticalColors.slice(0, labels.length),
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { 
                        display: true,
                        position: 'bottom',
                        labels: {
                            font: {
                                size: 9,
                                family: 'Inter',
                                weight: 'bold'
                            },
                            usePointStyle: true,
                            padding: 15
                        }
                    }
                }
            }
        });

        // Details update logic removed as UI element was decommissioned
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Trend Chart
        const trendCtx = document.getElementById('crimeTrendChart').getContext('2d');
        const trendsData = JSON.parse('<%- safeTrends %>');
        
        new Chart(trendCtx, {
            type: 'bar',
            data: {
                labels: trendsData.map(d => d.month),
                datasets: [
                    {
                        label: '8-Focus',
                        data: trendsData.map(d => d.focus),
                        backgroundColor: '#ef4444',
                        borderRadius: 8,
                        barThickness: 16
                    },
                    {
                        label: 'Non-Index',
                        data: trendsData.map(d => d.nonIndex),
                        backgroundColor: '#1A3A5C',
                        borderRadius: 8,
                        barThickness: 16
                    },
                    {
                        label: 'PSI',
                        data: trendsData.map(d => d.psi),
                        backgroundColor: '#D4AF37',
                        borderRadius: 8,
                        barThickness: 16
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 9, weight: 'bold' }, color: '#94a3b8' }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0, 0, 0, 0.05)', drawBorder: false },
                        ticks: { font: { size: 9, weight: 'bold' }, color: '#94a3b8' }
                    }
                }
            }
        });

        // Initialize Distribution Chart
        updateDistributionChart();
    });
</script>

