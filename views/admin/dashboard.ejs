<% 
    // Safety defaults
    let safeStats = {};
    safeStats.total = 0;
    safeStats.focus = 0;
    safeStats.nonIndex = 0;
    safeStats.psi = 0;
    safeStats.totalTips = 0;
    safeStats.totalBulletins = 0;
    safeStats.totalReports = 0;

    if (typeof todayStats !== 'undefined' && todayStats) {
        safeStats = todayStats;
    }

    let safeTrends = '[]';
    if (typeof monthlyTrends !== 'undefined' && monthlyTrends) {
        safeTrends = monthlyTrends;
    }

    let safePoints = [];
    if (typeof points !== 'undefined' && points) {
        safePoints = points;
    }

    let defaultYearVal = new Date().getFullYear();
    if (typeof defaultYear !== 'undefined' && defaultYear) {
        defaultYearVal = defaultYear;
    }
    
    // Calculate unique barangays covered
    const uniqueBarangays = new Set(safePoints.map(p => p.barangay).filter(b => b));
    const uniqueBarangaysCount = uniqueBarangays.size;
%>
