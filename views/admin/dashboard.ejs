<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
    <!-- Monthly Crime Trend Graph -->
    <div class="lg:col-span-2 bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 p-8 flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">Monthly Crime Trends</h3>
                <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest mt-1">Geospatial Intelligence Analysis (Last 6 Months)</p>
            </div>
            <div class="flex items-center space-x-6">
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full bg-[#ef4444]"></div>
                    <span class="text-[8px] font-black text-gray-400 uppercase">8-Focus</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full bg-[#001F3F]"></div>
                    <span class="text-[8px] font-black text-gray-400 uppercase">Non-Index</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full bg-[#D4AF37]"></div>
                    <span class="text-[8px] font-black text-gray-400 uppercase">PSI</span>
                </div>
            </div>
        </div>
        <div class="flex-1 relative">
            <canvas id="crimeTrendChart"></canvas>
        </div>
    </div>

    <!-- Crime Rate Distribution Pie Chart -->
    <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 p-8 flex flex-col h-[500px]">
        <div class="flex items-center justify-between mb-8 border-b border-gray-50 dark:border-slate-700 pb-4">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">Crime Rate Distribution</h3>
                <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-1">Sectoral Risk Proportions</p>
            </div>
            <i class="fas fa-chart-pie text-pnp-gold text-sm"></i>
        </div>
        
        <div class="flex-1 relative flex flex-col justify-center">
            <div class="h-64 mb-6">
                <canvas id="crimeDistributionChart"></canvas>
            </div>
            <div id="pieLegend" class="grid grid-cols-2 gap-3 max-h-32 overflow-y-auto pr-2 custom-scrollbar">
                <!-- Legend items will be injected here if needed -->
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Trend Chart
        const trendCtx = document.getElementById('crimeTrendChart').getContext('2d');
        const trendsData = JSON.parse('<%- monthlyTrends %>');
        
        new Chart(trendCtx, {
            type: 'bar',
            data: {
                labels: trendsData.map(d => d.month),
                datasets: [
                    {
                        label: '8-Focus Crimes',
                        data: trendsData.map(d => d.focus),
                        backgroundColor: '#ef4444',
                        borderRadius: 6,
                        barThickness: 12
                    },
                    {
                        label: 'Non-Index Crimes',
                        data: trendsData.map(d => d.nonIndex),
                        backgroundColor: '#001F3F',
                        borderRadius: 6,
                        barThickness: 12
                    },
                    {
                        label: 'PSI Cases',
                        data: trendsData.map(d => d.psi),
                        backgroundColor: '#D4AF37',
                        borderRadius: 6,
                        barThickness: 12
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { 
                            font: { size: 9, weight: 'bold' },
                            color: '#94a3b8'
                        }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { 
                            color: 'rgba(0, 0, 0, 0.05)',
                            drawBorder: false
                        },
                        ticks: {
                            stepSize: 5,
                            font: { size: 9, weight: 'bold' },
                            color: '#94a3b8'
                        }
                    }
                }
            }
        });

        // Distribution Pie Chart (Crime Types)
        const distCtx = document.getElementById('crimeDistributionChart').getContext('2d');
        const points = <%- JSON.stringify(points) %>;
        
        // Count crime types
        const crimeCounts = {};
        let totalVal = 0;
        points.forEach(p => {
            const type = p.incident_type || 'Other';
            crimeCounts[type] = (crimeCounts[type] || 0) + 1;
            totalVal++;
        });

        const crimeLabels = Object.keys(crimeCounts);
        const crimeData = Object.values(crimeCounts);

        const colors = [
            '#ef4444', // Red
            '#1A3A5C', // PNP Blue
            '#D4AF37', // PNP Gold
            '#10b981', // Emerald
            '#8b5cf6', // Violet
            '#f59e0b', // Amber
            '#475569'  // Slate
        ];

        new Chart(distCtx, {
            type: 'doughnut',
            data: {
                labels: crimeLabels,
                datasets: [{
                    data: crimeData,
                    backgroundColor: colors.slice(0, crimeLabels.length),
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '0%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            usePointStyle: true,
                            pointStyle: 'circle',
                            font: {
                                size: 8,
                                weight: 'bold',
                                family: 'Inter'
                            },
                            color: '#94a3b8',
                            generateLabels: (chart) => {
                                const data = chart.data;
                                return data.labels.map((label, i) => {
                                    const val = data.datasets[0].data[i];
                                    const percentage = totalVal > 0 ? ((val / totalVal) * 100).toFixed(1) : 0;
                                    return {
                                        text: `${label} (${percentage}%)`,
                                        fillStyle: data.datasets[0].backgroundColor[i],
                                        hidden: false,
                                        index: i,
                                        pointStyle: 'circle'
                                    };
                                });
                            }
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const val = context.raw;
                                const percentage = totalVal > 0 ? ((val / totalVal) * 100).toFixed(1) : 0;
                                return `${context.label}: ${val} (${percentage}%)`;
                            }
                        }
                    }
                }
            }
        });
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0, 31, 63, 0.1);
        border-radius: 10px;
    }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(212, 175, 55, 0.1);
    }
</style>
