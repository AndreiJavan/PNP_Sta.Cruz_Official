<div class="space-y-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-black text-pnp-blue dark:text-white uppercase tracking-tighter leading-none mb-1">System Audit Log</h1>
            <p class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest italic">Tactical Activity Tracking & Protocol Monitoring</p>
        </div>
        <div class="flex items-center space-x-3">
            <div class="px-4 py-2 bg-pnp-blue/5 dark:bg-pnp-gold/5 border border-pnp-blue/10 dark:border-pnp-gold/10 rounded-xl flex items-center space-x-3">
                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                <span class="text-[9px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.2em]">Monitoring Link Active</span>
            </div>
            <button onclick="window.print()" class="w-10 h-10 rounded-xl bg-white dark:bg-slate-800 text-slate-400 hover:text-pnp-blue transition-all flex items-center justify-center border border-gray-100 dark:border-slate-700 shadow-sm">
                <i class="fas fa-print"></i>
            </button>
        </div>
    </div>

    <!-- Stats Row (Mini Bento) -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white dark:bg-slate-800 p-6 rounded-[2rem] border border-gray-100 dark:border-slate-700 shadow-sm">
            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-2 text-center">Total Commands</p>
            <p class="text-3xl font-black text-pnp-blue dark:text-white text-center"><%= logs.length %></p>
        </div>
        <div class="bg-white dark:bg-slate-800 p-6 rounded-[2rem] border border-gray-100 dark:border-slate-700 shadow-sm">
            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-2 text-center">Critical Ops</p>
            <p class="text-3xl font-black text-red-500 text-center"><%= logs.filter(l => l.action?.toLowerCase().includes('delete') || l.action?.toLowerCase().includes('purge')).length %></p>
        </div>
        <div class="col-span-1 md:col-span-2 bg-gradient-to-r from-pnp-blue to-slate-900 p-1 rounded-[2rem]">
            <div class="bg-white dark:bg-slate-800 p-5 rounded-[1.9rem] h-full flex items-center justify-between">
                <div>
                    <h4 class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest">Active Operator</h4>
                    <p class="text-sm font-black text-slate-800 dark:text-white uppercase mt-1">S-SPS System Administrator</p>
                </div>
                <div class="w-12 h-12 bg-pnp-blue/10 dark:bg-pnp-gold/10 rounded-2xl flex items-center justify-center text-pnp-blue dark:text-pnp-gold">
                    <i class="fas fa-user-shield text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Table Card -->
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden">
        <div class="p-8 border-b border-gray-50 dark:border-slate-800 flex justify-between items-center bg-gray-50/50 dark:bg-slate-900/50">
            <div class="flex items-center space-x-4">
                <div class="w-10 h-10 bg-pnp-blue rounded-2xl flex items-center justify-center text-pnp-gold shadow-lg rotate-3">
                    <i class="fas fa-stream"></i>
                </div>
                <div>
                    <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-[11px]">Neural Audit Sequence</h3>
                    <p class="text-[8px] text-slate-400 font-bold uppercase tracking-widest mt-1">Chronological System Verifier</p>
                </div>
            </div>
            
            <div class="relative max-w-xs group">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 dark:text-slate-600 group-focus-within:text-pnp-blue transition-colors"></i>
                <input type="text" id="logSearch" placeholder="Filter protocols..." 
                    class="bg-white dark:bg-slate-800 border-2 border-transparent focus:border-pnp-blue/20 rounded-2xl py-3 pl-12 pr-6 text-[10px] font-black uppercase tracking-widest outline-none shadow-sm transition-all w-64 dark:text-white">
            </div>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-100/50 dark:bg-slate-800/50 border-b border-gray-100 dark:border-slate-700">
                        <th class="px-8 py-5 text-[9px] font-black text-slate-400 uppercase tracking-[0.3em]">Temporal Stamp</th>
                        <th class="px-8 py-5 text-[9px] font-black text-slate-400 uppercase tracking-[0.3em]">Tactical Operator</th>
                        <th class="px-8 py-5 text-[9px] font-black text-slate-400 uppercase tracking-[0.3em]">Protocol Code</th>
                        <th class="px-8 py-5 text-[9px] font-black text-slate-400 uppercase tracking-[0.3em]">Neural Details</th>
                    </tr>
                </thead>
                <tbody id="logBody" class="divide-y divide-gray-50 dark:divide-slate-800">
                    <% if (logs.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-8 py-20 text-center">
                                <div class="opacity-10">
                                    <i class="fas fa-history text-6xl mb-4 block"></i>
                                    <p class="text-xs font-black uppercase tracking-[0.5em]">System Log Empty</p>
                                </div>
                            </td>
                        </tr>
                    <% } else { %>
                        <% logs.forEach(log => { %>
                            <tr class="hover:bg-gray-50/80 dark:hover:bg-slate-800/30 transition-all cursor-default group">
                                <td class="px-8 py-6">
                                    <div class="flex flex-col">
                                        <span class="text-[10px] font-black text-slate-800 dark:text-white uppercase tabular-nums">
                                            <%= new Date(log.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
                                        </span>
                                        <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest mt-1">
                                            <%= new Date(log.timestamp).toLocaleDateString() %>
                                        </span>
                                    </div>
                                </td>
                                <td class="px-8 py-6 text-pnp-blue dark:text-pnp-gold font-black text-[10px] uppercase tracking-widest">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-1.5 h-1.5 rounded-full bg-pnp-blue dark:bg-pnp-gold opacity-30"></div>
                                        <span><%= log.admin_name %></span>
                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <% 
                                        const actionColor = log.action?.toLowerCase().includes('delete') ? 'bg-red-500/10 text-red-500 border-red-500/20' : 
                                                          log.action?.toLowerCase().includes('update') ? 'bg-yellow-500/10 text-yellow-600 border-yellow-500/20' : 
                                                          'bg-blue-500/10 text-blue-500 border-blue-500/20';
                                    %>
                                    <span class="px-3 py-1 rounded-lg text-[9px] font-black border uppercase tracking-widest <%= actionColor %>">
                                        <%= log.action %>
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <p class="text-[10px] text-slate-500 dark:text-slate-400 font-bold leading-relaxed max-w-lg">
                                        <%= log.details %>
                                    </p>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.getElementById('logSearch').addEventListener('input', function(e) {
        const term = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#logBody tr');
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(term) ? '' : 'none';
        });
    });
</script>
