<div class="max-w-7xl mx-auto w-full px-4 py-8">
    <div
        class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden w-full">
        <div class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
            <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">
                <%= bulletin ? 'Edit Bulletin' : 'Create New Bulletin' %>
            </h3>
            <a href="<%= typeof isPublic !== 'undefined' && isPublic ? '/bulletins' : '/admin/bulletins' %>"
                class="text-[10px] font-bold text-gray-400 dark:text-gray-500 hover:text-pnp-blue dark:hover:text-pnp-gold uppercase tracking-widest">Cancel</a>
        </div>

        <form id="bulletinForm"
            action="<%= bulletin ? '/admin/bulletins/' + bulletin.id + '/edit' : (typeof isPublic !== 'undefined' && isPublic ? '/bulletins/create' : '/admin/bulletins/create') %>"
            method="POST" enctype="multipart/form-data" class="p-8 space-y-8"
            onsubmit="handleBulletinSubmit(event); return false;">

            <!-- 2 COLUMN MAIN LAYOUT -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">

                <!-- LEFT SIDE: UNIFIED MEDIA -->
                <div id="leftPanel" class="space-y-4 flex flex-col transition-all duration-300">

                    <label
                        class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">
                        Upload Media (Images & Videos)
                    </label>

                    <!-- UNIFIED MEDIA PREVIEW BOX -->
                    <div
                        class="flex-1 flex flex-col justify-between bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl p-4">

                        <div id="dropZone" onclick="document.getElementById('mediaInput').click()"
                            class="w-full min-h-[350px] flex-1 rounded-lg overflow-hidden bg-gray-100 dark:bg-slate-800 flex items-center justify-center cursor-pointer transition-all duration-300 border-2 border-dashed border-transparent hover:border-pnp-blue p-2 relative">

                            <!-- Existing media OR preview -->
                            <div id="previewCarousel"
                                class="relative w-full h-full min-h-[350px] flex items-center justify-center bg-gray-100 dark:bg-slate-800 group overflow-hidden rounded-md">
                                <% let mediaItems=[]; if (bulletin) { if (bulletin.photo_paths &&
                                    bulletin.photo_paths.length> 0) {
                                    bulletin.photo_paths.forEach(p => mediaItems.push({ type: 'image', path: p }));
                                    } else if (bulletin.photo_path) {
                                    mediaItems.push({ type: 'image', path: bulletin.photo_path });
                                    }
                                    if (bulletin.video_paths && bulletin.video_paths.length > 0) {
                                    bulletin.video_paths.forEach(p => mediaItems.push({ type: 'video', path: p }));
                                    }
                                    }
                                    %>
                                    <% if (mediaItems.length> 0) { %>
                                        <% mediaItems.forEach(function(item, index) { %>
                                            <% if (item.type==='image' ) { %>
                                                <img src="<%= item.path %>"
                                                    class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-in-out <%= index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none' %> preview-slide"
                                                    data-index="<%= index %>" onerror="this.style.display='none';">
                                                <% } else { %>
                                                    <video src="<%= item.path %>" controls
                                                        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-in-out <%= index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none' %> preview-slide"
                                                        data-index="<%= index %>"></video>
                                                    <% } %>
                                                        <% }); %>
                                                            <% if (mediaItems.length> 1) { %>
                                                                <!-- Controls -->
                                                                <button type="button"
                                                                    onclick="event.stopPropagation(); movePreview(-1)"
                                                                    class="absolute left-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                                                                    <i class="fas fa-chevron-left text-xs"></i>
                                                                </button>
                                                                <button type="button"
                                                                    onclick="event.stopPropagation(); movePreview(1)"
                                                                    class="absolute right-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                                                                    <i class="fas fa-chevron-right text-xs"></i>
                                                                </button>
                                                                <!-- Indicators -->
                                                                <div
                                                                    class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex space-x-1.5 bg-black/40 px-3 py-1.5 rounded-full preview-indicators">
                                                                    <% mediaItems.forEach(function(_, index) { %>
                                                                        <div class="w-1.5 h-1.5 rounded-full transition-colors <%= index === 0 ? 'bg-white' : 'bg-white/40' %>"
                                                                            data-indicator="<%= index %>"></div>
                                                                        <% }); %>
                                                                </div>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <div id="placeholderIconContainer"
                                                                            class="flex flex-col items-center justify-center z-10 pointer-events-none">
                                                                            <i
                                                                                class="fas fa-photo-video text-gray-400 text-5xl mb-4"></i>
                                                                            <span
                                                                                class="text-[10px] text-gray-400 font-bold uppercase tracking-widest text-center">Drag
                                                                                & Drop or Click<br>Up to 5 files (Images
                                                                                & Videos combined)</span>
                                                                        </div>
                                                                        <% } %>
                            </div>
                        </div>

                        <!-- FILE INPUTS -->
                        <div class="mt-4">
                            <!-- This input handles the click event and receives both images and videos -->
                            <input type="file" id="mediaInput" accept="image/*,video/*" multiple class="hidden">

                            <!-- These hidden inputs are submitted to the server -->
                            <input type="file" name="photos" id="photos" accept="image/*" multiple class="hidden">

                            <input type="file" name="videos" id="videos" accept="video/*" multiple class="hidden">

                            <!-- Hidden inputs to track existing media files when editing -->
                            <input type="hidden" name="existing_photos" id="existing_photos_input">
                            <input type="hidden" name="existing_videos" id="existing_videos_input">

                            <button type="button" onclick="document.getElementById('mediaInput').click()"
                                class="w-full bg-pnp-blue text-white py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-blue-900 transition mb-2">
                                Choose / Add Media
                            </button>

                            <button type="button" onclick="openMediaGalleryModal()" id="viewGalleryBtn"
                                class="w-full bg-slate-800 text-pnp-gold py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-slate-700 transition mb-2 hidden flex items-center justify-center space-x-2 border border-pnp-gold/20">
                                <i class="fas fa-images text-xs"></i>
                                <span id="viewGalleryBtnText">View & Manage Uploaded Media</span>
                            </button>

                            <button type="button" onclick="clearAllMedia()" id="clearAllMediaBtn"
                                class="w-full bg-red-500/10 text-red-500 py-2 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-500 hover:text-white transition hidden">
                                Remove All Media
                            </button>

                            <p class="mt-2 text-[10px] text-gray-400 dark:text-gray-500 uppercase text-center">
                                Upload & preview media freely — Max 5 files allowed for final posting
                            </p>
                        </div>

                    </div>

                </div>

                <!-- RIGHT SIDE: FORM FIELDS -->
                <div id="rightPanel" class="space-y-6 flex flex-col transition-all duration-300">



                    <!-- TITLE -->
                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <label for="title"
                                class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Bulletin
                                Title</label>
                            <span id="titleCounter" class="text-[10px] font-mono font-bold text-slate-400 uppercase">
                                0 / 100 letters
                            </span>
                        </div>
                        <input type="text" name="title" id="title" value="<%= bulletin ? bulletin.title : '' %>"
                            required minlength="2" maxlength="100" placeholder="Enter title (3-15 words, max 100 characters)"
                            oninput="validateForm()"
                            class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white transition-all">
                        <p id="titleInlineError" class="text-[11px] font-bold text-red-500 mt-1 hidden"></p>
                    </div>

                    <!-- CATEGORY -->
                    <div class="space-y-2">
                        <label
                            class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">
                            Category
                        </label>

                        <% const standardCategories=['Crime Advisory', 'Traffic Advisory', 'Cybercrime Advisory', 'Community Awareness', 'General Announcement']; const isCustomCategory=bulletin &&
                            bulletin.category && !standardCategories.includes(bulletin.category); %>

                            <select name="category" id="category" required
                                class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">

                                <option value="" disabled <%=!bulletin && (typeof defaultCategory==='undefined' ||
                                    !defaultCategory) ? 'selected' : '' %>>Select Category</option>

                                <optgroup label="PUBLIC ADVISORIES (Broadcast to Public Advisory Page)" class="bg-slate-900 text-pnp-gold font-bold text-xs">
                                    <option value="Crime Advisory" <%= ((bulletin && bulletin.category === 'Crime Advisory') || (typeof defaultCategory !== 'undefined' && defaultCategory === 'Crime Advisory')) ? 'selected' : '' %>>Crime Advisory</option>
                                    <option value="Traffic Advisory" <%= ((bulletin && bulletin.category === 'Traffic Advisory') || (typeof defaultCategory !== 'undefined' && defaultCategory === 'Traffic Advisory')) ? 'selected' : '' %>>Traffic Advisory</option>
                                    <option value="Cybercrime Advisory" <%= ((bulletin && bulletin.category === 'Cybercrime Advisory') || (typeof defaultCategory !== 'undefined' && defaultCategory === 'Cybercrime Advisory')) ? 'selected' : '' %>>Cybercrime Advisory</option>
                                    <option value="Community Awareness" <%= ((bulletin && bulletin.category === 'Community Awareness') || (typeof defaultCategory !== 'undefined' && defaultCategory === 'Community Awareness')) ? 'selected' : '' %>>Community Awareness</option>
                                </optgroup>

                                <optgroup label="NEWS & RELEASES (Broadcast to News Feed)" class="bg-slate-900 text-pnp-gold font-bold text-xs">
                                    <option value="General Announcement" <%= ((bulletin && bulletin.category === 'General Announcement') || (typeof defaultCategory !== 'undefined' && defaultCategory === 'General Announcement')) ? 'selected' : '' %>>General Announcement (News / Press Release)</option>
                                </optgroup>

                            </select>
                    </div>

                    <!-- FACEBOOK LINK / URL FIELD -->
                    <div class="space-y-2 p-4 rounded-xl bg-blue-50/60 dark:bg-slate-900/60 border border-blue-150 dark:border-slate-800">
                        <div class="flex justify-between items-center">
                            <label for="facebook_url"
                                class="block text-[10px] font-bold text-[#1877F2] uppercase tracking-widest flex items-center space-x-1.5">
                                <i class="fab fa-facebook text-sm"></i>
                                <span>Facebook Post / Video Link (Optional)</span>
                            </label>
                            <% if (bulletin && (bulletin.facebook_url || bulletin.facebook_post_url)) { %>
                                <span class="text-[9px] font-black uppercase tracking-wider bg-[#1877F2]/10 text-[#1877F2] px-2.5 py-0.5 rounded-full border border-[#1877F2]/20">
                                    Link Active
                                </span>
                            <% } %>
                        </div>
                        <div class="relative">
                            <input type="url" name="facebook_url" id="facebook_url" 
                                value="<%= bulletin ? (bulletin.facebook_url || bulletin.facebook_post_url || '') : '' %>"
                                placeholder="https://www.facebook.com/..."
                                oninput="handleFbUrlChange(this.value);"
                                class="w-full px-4 py-3 bg-white dark:bg-slate-950 border border-gray-200 dark:border-slate-800 rounded-xl focus:ring-2 focus:ring-[#1877F2] outline-none text-xs font-semibold dark:text-white transition-all">
                        </div>
                        <p class="text-[10px] text-slate-400 font-medium">When a Facebook post / video link is attached, file upload is optional.</p>
                    </div>




                    <!-- BODY -->
                    <div class="flex-1 flex flex-col space-y-2">
                        <div class="flex justify-between items-center">
                            <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">
                                Bulletin Body
                            </label>
                            <span id="bodyCounter" class="text-[10px] font-mono font-bold text-slate-400 uppercase">
                                0 / 5,000 letters
                            </span>
                        </div>

                        <textarea name="body" id="body" rows="12" required
                            placeholder="Enter the full content of the bulletin (Min 10 letters, Max 5,000 letters)..."
                            oninput="validateForm()"
                            class="flex-1 w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-sm leading-relaxed dark:text-white transition-all"><%= bulletin ? bulletin.body : '' %></textarea>
                        <p id="bodyInlineError" class="text-[11px] font-bold text-red-500 mt-1 hidden"></p>
                    </div>

                </div>

            </div>

            <!-- SUBMIT CONTAINER WITH REAL-TIME VALIDATION WARNING -->
            <div class="pt-6 border-t border-gray-50 dark:border-slate-700 flex flex-col items-end space-y-3">
                <div id="validationWarning" class="hidden flex items-center space-x-2 text-red-500 bg-red-500/10 border border-red-500/20 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider animate-pulse">
                    <i class="fas fa-exclamation-triangle text-sm"></i>
                    <span id="validationWarningText">Input parameters exceed safety thresholds.</span>
                </div>
                <button type="submit" id="submitBulletinBtn"
                    class="bg-pnp-blue text-white font-bold py-4 px-12 rounded-xl shadow-lg transition-all duration-300 hover:bg-blue-900 uppercase tracking-widest text-xs disabled:bg-slate-300 dark:disabled:bg-slate-800 disabled:text-slate-500 disabled:shadow-none disabled:cursor-not-allowed disabled:pointer-events-none">
                    <%= bulletin ? 'Update Bulletin' : 'Post Bulletin' %>
                </button>
            </div>

        </form>

        <!-- ENHANCED FULLSCREEN MEDIA VIEWER MODAL -->
        <div id="mediaModal" class="fixed inset-0 bg-slate-950/90 backdrop-blur-md hidden items-center justify-center z-[99999] p-4 transition-all duration-300">
            <div class="relative max-w-5xl w-full flex flex-col items-center">
                <!-- MODAL HEADER / CONTROLS -->
                <div class="w-full flex justify-between items-center mb-3 px-2">
                    <span id="modalMediaTitle" class="text-xs font-black uppercase tracking-widest text-slate-300">Media Preview</span>
                    <div class="flex items-center space-x-3">
                        <button type="button" id="modalRemoveBtn" onclick="removeCurrentModalMedia()" class="px-4 py-2 bg-red-500/20 hover:bg-red-600 text-red-400 hover:text-white rounded-xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center space-x-2 border border-red-500/30">
                            <i class="fas fa-trash-alt"></i>
                            <span>Remove This File</span>
                        </button>
                        <button type="button" onclick="closeMediaModal()" class="w-9 h-9 bg-white/10 hover:bg-white/20 text-white rounded-xl flex items-center justify-center transition focus:outline-none">
                            <i class="fas fa-times text-sm"></i>
                        </button>
                    </div>
                </div>

                <!-- MEDIA CONTENT CONTAINER -->
                <div class="w-full max-h-[82vh] bg-slate-900 rounded-2xl overflow-hidden shadow-2xl border border-white/10 flex items-center justify-center p-2 relative">
                    <img id="modalImage" class="max-w-full max-h-[78vh] object-contain rounded-lg hidden">
                    <video id="modalVideo" controls class="max-w-full max-h-[78vh] object-contain rounded-lg hidden"></video>
                </div>
            </div>
        </div>

        <!-- ALL UPLOADED MEDIA GALLERY GRID MODAL -->
        <div id="mediaGalleryModal" class="fixed inset-0 bg-slate-950/95 backdrop-blur-xl hidden items-center justify-center z-[99998] p-4 md:p-8 transition-all duration-300">
            <div class="relative max-w-6xl w-full h-[90vh] bg-slate-900 rounded-3xl border border-white/10 shadow-2xl flex flex-col overflow-hidden">
                <!-- GALLERY MODAL HEADER -->
                <div class="p-6 border-b border-white/10 flex flex-col sm:flex-row sm:items-center justify-between bg-slate-950 gap-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 rounded-2xl bg-pnp-blue text-pnp-gold flex items-center justify-center border border-pnp-gold/20 shadow-md">
                            <i class="fas fa-images text-sm"></i>
                        </div>
                        <div>
                            <h3 class="text-base font-black text-white uppercase tracking-tight leading-none">Uploaded Media Gallery</h3>
                            <p id="mediaGalleryCount" class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Showing 0 attached files</p>
                        </div>
                    </div>

                    <!-- DYNAMIC GALLERY WARNING / STATUS ALERT -->
                    <div id="galleryStatusAlert" class="flex items-center space-x-2 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all hidden">
                        <i id="galleryStatusIcon" class="fas fa-exclamation-triangle text-sm"></i>
                        <span id="galleryStatusText">Status message</span>
                    </div>

                    <div class="flex items-center space-x-3">
                        <button type="button" onclick="document.getElementById('mediaInput').click()" class="px-4 py-2 bg-pnp-blue text-white hover:bg-blue-900 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all">
                            + Add More Files
                        </button>
                        <button type="button" onclick="closeMediaGalleryModal()" class="w-9 h-9 bg-white/10 hover:bg-white/20 text-white rounded-xl flex items-center justify-center transition">
                            <i class="fas fa-times text-sm"></i>
                        </button>
                    </div>
                </div>

                <!-- GALLERY GRID CONTAINER -->
                <div id="mediaGalleryGrid" class="flex-1 p-6 overflow-y-auto custom-scrollbar grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 items-start">
                    <!-- Dynamic media card items will be injected here -->
                </div>

                <!-- GALLERY MODAL FOOTER -->
                <div class="p-6 border-t border-white/10 bg-slate-950 flex flex-col sm:flex-row items-center justify-between gap-4">
                    <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">
                        Note: Each item has a trash icon on top-right to delete individual pictures/videos. Max 5 allowed for final posting.
                    </span>
                    <button type="button" onclick="closeMediaGalleryModal()" class="px-6 py-2.5 bg-white/10 hover:bg-white/20 text-white rounded-xl text-[10px] font-black uppercase tracking-widest transition-all">
                        Close Gallery
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    function toggleCustomCategory(value) {
        const container = document.getElementById('customCategoryContainer');
        const input = document.getElementById('custom_category');
        if (value === 'Other') {
            container.classList.remove('hidden');
            input.required = true;
        } else {
            container.classList.add('hidden');
            input.required = false;
        }
    }

    function validateForm() {
        const titleInput = document.getElementById('title');
        const bodyInput = document.getElementById('body');
        const submitBtn = document.getElementById('submitBulletinBtn');
        const warningBox = document.getElementById('validationWarning');
        const warningText = document.getElementById('validationWarningText');
        
        const titleCounter = document.getElementById('titleCounter');
        const bodyCounter = document.getElementById('bodyCounter');

        const titleInlineError = document.getElementById('titleInlineError');
        const bodyInlineError = document.getElementById('bodyInlineError');

        if (!titleInput || !bodyInput || !submitBtn) return true;

        const cleanTitle = (titleInput.value || '').trim();
        const titleChars = cleanTitle.length;

        if (titleCounter) {
            titleCounter.textContent = `${titleChars} / 100 letters`;
        }

        if (titleChars === 0) {
            if (titleInlineError) {
                titleInlineError.textContent = 'Bulletin title is required (at least 3 letters).';
                titleInlineError.classList.remove('hidden');
                titleInlineError.className = 'text-[11px] font-bold text-red-500 mt-1';
            }
            titleInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
            titleInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
        } else if (titleChars < 3) {
            if (titleInlineError) {
                titleInlineError.textContent = `Title is too short. Minimum 3 letters required (currently ${titleChars} letters).`;
                titleInlineError.classList.remove('hidden');
                titleInlineError.className = 'text-[11px] font-bold text-red-500 mt-1';
            }
            titleInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
            titleInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
        } else if (titleChars > 100) {
            if (titleInlineError) {
                titleInlineError.textContent = `Title exceeds limit of 100 letters (currently ${titleChars} letters).`;
                titleInlineError.classList.remove('hidden');
                titleInlineError.className = 'text-[11px] font-bold text-red-500 mt-1';
            }
            titleInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
            titleInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
        } else {
            if (titleInlineError) {
                titleInlineError.textContent = '✓ Title length is valid.';
                titleInlineError.classList.remove('hidden');
                titleInlineError.className = 'text-[11px] font-bold text-emerald-500 mt-1';
            }
            titleInput.classList.remove('border-red-500', 'ring-red-500/20');
            titleInput.classList.add('border-emerald-500', 'ring-2', 'ring-emerald-500/20');
        }

        const cleanBody = (bodyInput.value || '').trim();
        const bodyChars = cleanBody.length;

        if (bodyCounter) {
            bodyCounter.textContent = `${bodyChars} / 5,000 letters`;
        }

        if (bodyChars === 0) {
            if (bodyInlineError) {
                bodyInlineError.textContent = 'Description body is required (at least 10 letters).';
                bodyInlineError.classList.remove('hidden');
                bodyInlineError.className = 'text-[11px] font-bold text-red-500 mt-1';
            }
            bodyInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
            bodyInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
        } else if (bodyChars < 10) {
            if (bodyInlineError) {
                bodyInlineError.textContent = `Description is too short. Minimum 10 letters required (currently ${bodyChars} letters).`;
                bodyInlineError.classList.remove('hidden');
                bodyInlineError.className = 'text-[11px] font-bold text-red-500 mt-1';
            }
            bodyInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
            bodyInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
        } else if (bodyChars > 5000) {
            if (bodyInlineError) {
                bodyInlineError.textContent = `Description exceeds limit of 5,000 letters (currently ${bodyChars} letters).`;
                bodyInlineError.classList.remove('hidden');
                bodyInlineError.className = 'text-[11px] font-bold text-red-500 mt-1';
            }
            bodyInput.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
            bodyInput.classList.remove('border-emerald-500', 'ring-emerald-500/20');
        } else {
            if (bodyInlineError) {
                bodyInlineError.textContent = '✓ Description content length is valid.';
                bodyInlineError.classList.remove('hidden');
                bodyInlineError.className = 'text-[11px] font-bold text-emerald-500 mt-1';
            }
            bodyInput.classList.remove('border-red-500', 'ring-red-500/20');
            bodyInput.classList.add('border-emerald-500', 'ring-2', 'ring-emerald-500/20');
        }

        let errorMessage = '';
        const totalMediaCount = (existingMedia ? existingMedia.length : 0) + (accumulatedFiles ? accumulatedFiles.length : 0) + (accumulatedVideos ? accumulatedVideos.length : 0);

        let totalBytes = 0;
        if (typeof accumulatedFiles !== 'undefined') accumulatedFiles.forEach(f => totalBytes += f.size);
        if (typeof accumulatedVideos !== 'undefined') accumulatedVideos.forEach(v => totalBytes += v.size);
        const totalMB = (totalBytes / (1024 * 1024)).toFixed(1);

        const fbUrlInput = document.getElementById('facebook_url');
        const hasFbUrl = fbUrlInput && fbUrlInput.value.trim().length > 0;

        if (cleanTitle.length === 0) {
            errorMessage = 'Please enter a bulletin title (at least 3 letters required).';
        } else if (titleChars < 3) {
            errorMessage = `Title must be at least 3 letters long (currently ${titleChars} letters).`;
        } else if (titleChars > 100) {
            errorMessage = `Title exceeds upper limit of 100 letters (currently ${titleChars} letters).`;
        } else if (cleanBody.length === 0) {
            errorMessage = 'Please enter the bulletin body content (at least 10 letters required).';
        } else if (bodyChars < 10) {
            errorMessage = `Bulletin body must be at least 10 letters long (currently ${bodyChars} letters).`;
        } else if (bodyChars > 5000) {
            errorMessage = `Bulletin body exceeds upper limit of 5,000 letters (currently ${bodyChars} letters).`;
        } else if (totalMediaCount === 0 && !hasFbUrl) {
            errorMessage = 'At least 1 picture, video, or Facebook URL link must be provided before posting.';
        } else if (totalMediaCount > 5) {
            errorMessage = `Media limit exceeded: You have ${totalMediaCount} files attached. Please remove files so that 5 or fewer remain.`;
        } else if (totalBytes > 25 * 1024 * 1024) {
            errorMessage = `Payload Limit Exceeded: Combined upload (${totalMB} MB) exceeds maximum limit of 25MB. Please compress files or post fewer files.`;
        }

        const galleryStatusAlert = document.getElementById('galleryStatusAlert');
        const galleryStatusText = document.getElementById('galleryStatusText');

        if (errorMessage) {
            if (warningBox && warningText) {
                warningText.textContent = errorMessage;
                warningBox.classList.remove('hidden');
            }
            if (galleryStatusAlert && galleryStatusText) {
                galleryStatusText.textContent = errorMessage;
                galleryStatusAlert.className = 'flex items-center space-x-2 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all bg-red-500/20 text-red-400 border border-red-500/40 animate-pulse';
                galleryStatusAlert.classList.remove('hidden');
            }
            submitBtn.disabled = true;
            return false;
        } else {
            if (warningBox) {
                warningBox.classList.add('hidden');
            }
            if (galleryStatusAlert && galleryStatusText) {
                galleryStatusText.textContent = 'All media & inputs valid. Ready to post.';
                galleryStatusAlert.className = 'flex items-center space-x-2 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all bg-emerald-500/20 text-emerald-400 border border-emerald-500/40';
                galleryStatusAlert.classList.remove('hidden');
            }
            submitBtn.disabled = false;
            return true;
        }
    }

    async function handleBulletinSubmit(event) {
        event.preventDefault();
        if (!validateForm()) {
            alert('Cannot submit bulletin: One or more validation constraints or payload size limits are broken. Please review the highlighted red warning.');
            return;
        }

        // Final payload pre-flight safety check for any oversized files
        for (const file of accumulatedFiles) {
            if (file.size > 5 * 1024 * 1024) {
                alert(`Payload Protection Blocked Submit: Image "${file.name}" (${(file.size/(1024*1024)).toFixed(1)}MB) exceeds 5MB limit. Submit canceled.`);
                return;
            }
        }
        for (const video of accumulatedVideos) {
            if (video.size > 100 * 1024 * 1024) {
                alert(`Payload Protection Blocked Submit: Video "${video.name}" (${(video.size/(1024*1024)).toFixed(1)}MB) exceeds 100MB limit. Submit canceled.`);
                return;
            }
        }

        const isEdit = <%= bulletin ? 'true' : 'false' %>;
        const action = isEdit ? 'update' : 'create';

        const confirmFn = window.strategicConfirm || (async (args) => {
            return confirm(args?.message || `Confirm ${action} of this strategic bulletin. This will be visible to all monitoring terminals.`);
        });

        const confirmed = await confirmFn({
            title: isEdit ? 'Update Confirmation' : 'Post Confirmation',
            message: `Confirm ${action} of this strategic bulletin. This will be visible to all monitoring terminals.`,
            confirmText: isEdit ? 'Update Now' : 'Post Now',
            type: 'info'
        });

        if (confirmed) {
            document.getElementById('bulletinForm').submit();
        }
    }

    const mediaInput = document.getElementById('mediaInput');
    const fileInput = document.getElementById('photos');
    const videoFileInput = document.getElementById('videos');
    const dropZone = document.getElementById('dropZone');

    let currentPreviewSlide = 0;

    // Existing media from bulletin if editing
    let existingMedia = [];
    <% if (bulletin) { %>
        <% if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
            <% bulletin.photo_paths.forEach(function (path) { %>
        existingMedia.push({ type: 'image', path: '<%= path %>', isExisting: true });
            <% }); %>
        <% } %>
        <% if (bulletin.video_paths && bulletin.video_paths.length > 0) { %>
            <% bulletin.video_paths.forEach(function (path) { %>
            existingMedia.push({ type: 'video', path: '<%= path %>', isExisting: true });
            <% }); %>
        <% } %>
    <% } %>

        let previewTotalSlides = existingMedia.length;

    let accumulatedFiles = []; // New images files
    let accumulatedVideos = []; // New videos files

    function movePreview(direction) {
        if (previewTotalSlides <= 1) return;
        currentPreviewSlide = (currentPreviewSlide + direction + previewTotalSlides) % previewTotalSlides;
        updatePreviewCarousel();
    }

    function updatePreviewCarousel() {
        const slides = document.querySelectorAll('.preview-slide');
        const indicators = document.querySelectorAll('.preview-indicators div');

        slides.forEach((slide, idx) => {
            if (idx === currentPreviewSlide) {
                slide.classList.remove('opacity-0', 'pointer-events-none');
                slide.classList.add('opacity-100', 'z-10');
            } else {
                slide.classList.remove('opacity-100', 'z-10');
                slide.classList.add('opacity-0', 'pointer-events-none');
            }
        });

        indicators.forEach((ind, idx) => {
            if (idx === currentPreviewSlide) {
                ind.classList.add('bg-white');
                ind.classList.remove('bg-white/40');
            } else {
                ind.classList.remove('bg-white');
                ind.classList.add('bg-white/40');
            }
        });

        const deleteBtns = document.querySelectorAll('.delete-slide-btn');
        deleteBtns.forEach((btn, idx) => {
            if (idx === currentPreviewSlide) {
                btn.classList.remove('hidden');
            } else {
                btn.classList.add('hidden');
            }
        });
    }

    if (mediaInput) {
        mediaInput.addEventListener('change', function () {
            handleMediaFiles(this.files);
        });
    }

    if (dropZone) {
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('ring-2', 'ring-pnp-blue');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('ring-2', 'ring-pnp-blue');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('ring-2', 'ring-pnp-blue');
            handleMediaFiles(e.dataTransfer.files);
        });
    }

    function handleMediaFiles(files) {
        if (!files || files.length === 0) return;

        let rejectedFiles = [];
        let videoPromises = [];

        Array.from(files).forEach(file => {
            if (file.type.startsWith('image/')) {
                if (file.size > 5 * 1024 * 1024) {
                    rejectedFiles.push(`Picture "${file.name}" (${(file.size / (1024 * 1024)).toFixed(1)}MB > 5MB limit)`);
                } else {
                    accumulatedFiles.push(file);
                }
            } else if (file.type.startsWith('video/')) {
                if (file.size > 25 * 1024 * 1024) {
                    rejectedFiles.push(`Video "${file.name}" (${(file.size / (1024 * 1024)).toFixed(1)}MB > 25MB limit)`);
                } else {
                    // Check duration asynchronously to reject movie videos (> 3 minutes)
                    const p = new Promise(resolve => {
                        const tempVid = document.createElement('video');
                        tempVid.preload = 'metadata';
                        tempVid.src = URL.createObjectURL(file);
                        tempVid.onloadedmetadata = function() {
                            URL.revokeObjectURL(tempVid.src);
                            if (tempVid.duration > 180) { // > 3 minutes
                                rejectedFiles.push(`Video "${file.name}" (${(tempVid.duration / 60).toFixed(1)} mins long - Movie videos exceeding 3 minutes are prohibited)`);
                            } else {
                                accumulatedVideos.push(file);
                            }
                            resolve();
                        };
                        tempVid.onerror = function() {
                            rejectedFiles.push(`Video "${file.name}" (Corrupted or unsupported video format)`);
                            resolve();
                        };
                    });
                    videoPromises.push(p);
                }
            }
        });

        Promise.all(videoPromises).then(() => {
            if (rejectedFiles.length > 0) {
                const warningBox = document.getElementById('validationWarning');
                const warningText = document.getElementById('validationWarningText');
                const msg = `Upload Limitation Notice:\nThe following files were rejected:\n• ` + rejectedFiles.join('\n• ');
                if (warningBox && warningText) {
                    warningText.textContent = `Upload Blocked: ${rejectedFiles[0]}`;
                    warningBox.classList.remove('hidden');
                }
                alert(msg);
            }

            syncFileInputs();
            renderAllMedia();
            renderMediaGalleryGrid();
            validateForm();
        });
    }

    function syncFileInputs() {
        // Filter out any invalid file reference over 4MB to guarantee Vercel safety
        const validPhotos = accumulatedFiles.filter(f => f.size <= 4 * 1024 * 1024);
        const validVideos = accumulatedVideos.filter(f => f.size <= 4 * 1024 * 1024);

        // Sync photos input
        const dtPhotos = new DataTransfer();
        validPhotos.forEach(f => dtPhotos.items.add(f));
        fileInput.files = dtPhotos.files;

        // Sync videos input
        const dtVideos = new DataTransfer();
        validVideos.forEach(f => dtVideos.items.add(f));
        videoFileInput.files = dtVideos.files;
    }

    function removeMediaItem(item) {
        if (item.isExisting) {
            existingMedia.splice(item.index, 1);
        } else {
            if (item.type === 'image') {
                accumulatedFiles.splice(item.index, 1);
            } else {
                accumulatedVideos.splice(item.index, 1);
            }
            syncFileInputs();
        }

        // Adjust slide index if it is out of bounds
        const totalItems = existingMedia.length + accumulatedFiles.length + accumulatedVideos.length;
        if (currentPreviewSlide >= totalItems) {
            currentPreviewSlide = Math.max(0, totalItems - 1);
        }

        renderAllMedia();
        renderMediaGalleryGrid();
        validateForm();
    }

    function clearAllMedia() {
        existingMedia = [];
        accumulatedFiles = [];
        accumulatedVideos = [];
        syncFileInputs();
        currentPreviewSlide = 0;
        renderAllMedia();
        renderMediaGalleryGrid();
        validateForm();
    }

    function handleFbUrlChange(val) {
        renderAllMedia();
        validateForm();
    }

    function renderAllMedia() {
        const previewCarousel = document.getElementById('previewCarousel');
        if (!previewCarousel) return;

        // Update hidden input fields for the form post
        syncHiddenInputs();

        // Build list of all items to display
        const itemsToRender = [];

        // 1. Existing media
        existingMedia.forEach((item, index) => {
            itemsToRender.push({
                type: item.type,
                src: item.path,
                isExisting: true,
                index: index
            });
        });

        // 2. Newly added photos
        accumulatedFiles.forEach((file, index) => {
            itemsToRender.push({
                type: 'image',
                file: file,
                isExisting: false,
                index: index
            });
        });

        // 3. Newly added videos
        accumulatedVideos.forEach((file, index) => {
            itemsToRender.push({
                type: 'video',
                file: file,
                isExisting: false,
                index: index
            });
        });

        previewTotalSlides = itemsToRender.length;

        const viewGalleryBtn = document.getElementById('viewGalleryBtn');
        const viewGalleryBtnText = document.getElementById('viewGalleryBtnText');
        if (viewGalleryBtn) {
            if (previewTotalSlides > 0) {
                viewGalleryBtn.classList.remove('hidden');
                if (viewGalleryBtnText) viewGalleryBtnText.textContent = `View & Manage Uploaded Media (${previewTotalSlides})`;
            } else {
                viewGalleryBtn.classList.add('hidden');
            }
        }

        const fbUrlInput = document.getElementById('facebook_url');
        const fbUrlVal = fbUrlInput ? fbUrlInput.value.trim() : '';

        if (previewTotalSlides === 0) {
            if (fbUrlVal) {
                const isVideo = /video|watch|reel/i.test(fbUrlVal);
                const pluginType = isVideo ? 'video.php' : 'post.php';
                const embedSrc = `https://www.facebook.com/plugins/${pluginType}?href=${encodeURIComponent(fbUrlVal)}&show_text=true&width=500`;
                previewCarousel.innerHTML = `
                    <div class="w-full h-full min-h-[350px] bg-slate-950 rounded-lg p-2 flex flex-col items-center justify-center relative overflow-hidden">
                        <iframe src="${embedSrc}" width="100%" height="100%" style="border:none;overflow:hidden;min-height:330px;" scrolling="no" frameborder="0" allowfullscreen="true" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" class="w-full h-full rounded-md shadow-lg pointer-events-none"></iframe>
                        <div class="absolute top-3 left-3 bg-[#1877F2] text-white px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest shadow-md flex items-center space-x-1 z-20">
                            <i class="fab fa-facebook"></i>
                            <span>Embedded Facebook Release Preview</span>
                        </div>
                    </div>
                `;
            } else {
                previewCarousel.innerHTML = `
                    <div id="placeholderIconContainer" class="flex flex-col items-center justify-center z-10 pointer-events-none">
                        <i class="fas fa-photo-video text-gray-400 text-5xl mb-4"></i>
                        <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest text-center">Drag & Drop or Click<br>Up to 5 images & 2 videos</span>
                    </div>
                `;
            }
            currentPreviewSlide = 0;
            document.getElementById('clearAllMediaBtn').classList.add('hidden');
            syncPanels();
            return;
        }

        document.getElementById('clearAllMediaBtn').classList.remove('hidden');
        previewCarousel.innerHTML = '';

        let loadedCount = 0;

        itemsToRender.forEach((item, slideIndex) => {
            const isOversized = !item.isExisting && (
                (item.type === 'image' && item.file && item.file.size > 5 * 1024 * 1024) ||
                (item.type === 'video' && item.file && item.file.size > 100 * 1024 * 1024)
            );

            const slideWrapper = document.createElement('div');
            slideWrapper.className = `absolute inset-0 w-full h-full transition-opacity duration-500 ease-in-out preview-slide ${
                slideIndex === currentPreviewSlide ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'
            } ${
                isOversized ? 'border-4 border-red-500 rounded-lg overflow-hidden' : ''
            }`;
            slideWrapper.dataset.index = slideIndex;

            const delBtn = document.createElement('button');
            delBtn.type = "button";
            delBtn.className = `delete-slide-btn absolute top-3 right-3 z-30 bg-red-500/80 hover:bg-red-600 text-white w-8 h-8 rounded-full flex items-center justify-center transition focus:outline-none shadow-lg ${slideIndex === currentPreviewSlide ? '' : 'hidden'}`;
            delBtn.innerHTML = '<i class="fas fa-trash text-[10px]"></i>';
            delBtn.onclick = (event) => {
                event.stopPropagation();
                removeMediaItem(item);
            };

            let carouselWarning = null;
            if (isOversized) {
                const limitText = item.type === 'image' ? '5MB' : '100MB';
                const actualSize = item.file ? (item.file.size / (1024 * 1024)).toFixed(1) : '?';
                carouselWarning = document.createElement('div');
                carouselWarning.className = 'absolute top-3 left-3 z-30 bg-red-600 text-white px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-wider flex items-center space-x-1.5 shadow-xl border border-white/20';
                carouselWarning.innerHTML = `<i class="fas fa-exclamation-triangle"></i><span>EXCEEDS PAYLOAD (${actualSize}MB / ${limitText})</span>`;
                slideWrapper.appendChild(carouselWarning);
            }

            const mediaUrl = item.isExisting ? item.src : URL.createObjectURL(item.file);

            if (item.type === 'image') {
                const img = document.createElement('img');
                img.src = mediaUrl;
                img.className = `w-full h-full object-cover rounded-md cursor-pointer hover:opacity-90 transition`;
                img.onclick = (e) => {
                    e.stopPropagation();
                    openMediaModal(item, mediaUrl);
                };
                slideWrapper.appendChild(img);
            } else {
                const video = document.createElement('video');
                video.src = mediaUrl;
                video.className = `w-full h-full object-cover rounded-md cursor-pointer`;
                video.controls = true;
                video.onclick = (e) => {
                    e.stopPropagation();
                    openMediaModal(item, mediaUrl);
                };
                slideWrapper.appendChild(video);
            }
            slideWrapper.appendChild(delBtn);
            previewCarousel.appendChild(slideWrapper);
            loadedCount++;
            checkAndAddControls(loadedCount, itemsToRender.length);
        });
    }

    function checkAndAddControls(loadedCount, totalCount) {
        if (loadedCount === totalCount && totalCount > 1) {
            const previewCarousel = document.getElementById('previewCarousel');
            let controls = `
                <button type="button" onclick="event.stopPropagation(); movePreview(-1)" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                    <i class="fas fa-chevron-left text-xs"></i>
                </button>
                <button type="button" onclick="event.stopPropagation(); movePreview(1)" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                    <i class="fas fa-chevron-right text-xs"></i>
                </button>
                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex space-x-1.5 bg-black/40 px-3 py-1.5 rounded-full preview-indicators pointer-events-none">
            `;
            for (let i = 0; i < totalCount; i++) {
                controls += `<div class="w-1.5 h-1.5 rounded-full transition-colors ${i === currentPreviewSlide ? 'bg-white' : 'bg-white/40'}" data-indicator="${i}"></div>`;
            }
            controls += `</div>`;
            previewCarousel.insertAdjacentHTML('beforeend', controls);
        }
        syncPanels();
    }

    function syncHiddenInputs() {
        const existingPhotos = existingMedia.filter(m => m.type === 'image').map(m => m.path);
        const existingVideos = existingMedia.filter(m => m.type === 'video').map(m => m.path);

        document.getElementById('existing_photos_input').value = JSON.stringify(existingPhotos);
        document.getElementById('existing_videos_input').value = JSON.stringify(existingVideos);
    }

    let currentActiveModalItem = null;

    function openMediaModal(item, src) {
        const modal = document.getElementById('mediaModal');
        const modalImg = document.getElementById('modalImage');
        const modalVid = document.getElementById('modalVideo');
        const modalTitle = document.getElementById('modalMediaTitle');

        if (!modal || !modalImg || !modalVid) return;

        currentActiveModalItem = item;

        if (item.type === 'video') {
            modalImg.classList.add('hidden');
            modalVid.src = src;
            modalVid.classList.remove('hidden');
            if (modalTitle) modalTitle.textContent = `Video Preview: ${item.file ? item.file.name : 'Existing Video'}`;
        } else {
            modalVid.classList.add('hidden');
            modalVid.pause();
            modalImg.src = src;
            modalImg.classList.remove('hidden');
            if (modalTitle) modalTitle.textContent = `Image Preview: ${item.file ? item.file.name : 'Existing Image'}`;
        }

        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function closeMediaModal() {
        const modal = document.getElementById('mediaModal');
        const modalVid = document.getElementById('modalVideo');
        if (modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        if (modalVid) {
            modalVid.pause();
            modalVid.src = '';
        }
        currentActiveModalItem = null;
    }

    function removeCurrentModalMedia() {
        if (currentActiveModalItem) {
            const itemToRemove = currentActiveModalItem;
            closeMediaModal();
            removeMediaItem(itemToRemove);
            renderMediaGalleryGrid();
        }
    }

    function openMediaGalleryModal() {
        const galleryModal = document.getElementById('mediaGalleryModal');
        if (!galleryModal) return;
        renderMediaGalleryGrid();
        galleryModal.classList.remove('hidden');
        galleryModal.classList.add('flex');
    }

    function closeMediaGalleryModal() {
        const galleryModal = document.getElementById('mediaGalleryModal');
        if (galleryModal) {
            galleryModal.classList.add('hidden');
            galleryModal.classList.remove('flex');
        }
    }

    function renderMediaGalleryGrid() {
        const grid = document.getElementById('mediaGalleryGrid');
        const countText = document.getElementById('mediaGalleryCount');
        const viewGalleryBtnText = document.getElementById('viewGalleryBtnText');
        if (!grid) return;

        // Build list of all current items
        const itemsToRender = [];
        existingMedia.forEach((item, index) => {
            itemsToRender.push({ type: item.type, src: item.path, isExisting: true, index: index });
        });
        accumulatedFiles.forEach((file, index) => {
            itemsToRender.push({ type: 'image', file: file, isExisting: false, index: index });
        });
        accumulatedVideos.forEach((file, index) => {
            itemsToRender.push({ type: 'video', file: file, isExisting: false, index: index });
        });

        if (countText) countText.textContent = `Showing ${itemsToRender.length} attached files`;
        if (viewGalleryBtnText) viewGalleryBtnText.textContent = `Manage Uploaded Media (${itemsToRender.length})`;

        const viewGalleryBtn = document.getElementById('viewGalleryBtn');
        if (viewGalleryBtn) {
            if (itemsToRender.length > 0) {
                viewGalleryBtn.classList.remove('hidden');
            } else {
                viewGalleryBtn.classList.add('hidden');
                closeMediaGalleryModal();
            }
        }

        validateForm();

        if (itemsToRender.length === 0) {
            grid.innerHTML = `
                <div class="col-span-full py-16 flex flex-col items-center justify-center opacity-40 text-white">
                    <i class="fas fa-images text-5xl mb-3"></i>
                    <p class="text-xs font-black uppercase tracking-widest">No Media Files Uploaded Yet</p>
                </div>
            `;
            return;
        }

        grid.innerHTML = '';

        itemsToRender.forEach((item, idx) => {
            const isOversized = !item.isExisting && (
                (item.type === 'image' && item.file && item.file.size > 5 * 1024 * 1024) ||
                (item.type === 'video' && item.file && item.file.size > 100 * 1024 * 1024)
            );

            const card = document.createElement('div');
            card.className = `relative group bg-slate-950 rounded-2xl overflow-hidden shadow-lg aspect-square flex items-center justify-center transition-all ${
                isOversized 
                ? 'border-4 border-red-500 ring-4 ring-red-500/30' 
                : 'border border-white/10'
            }`;

            // Delete trashbin button on top-right of each image/video
            const delBtn = document.createElement('button');
            delBtn.type = 'button';
            delBtn.className = 'absolute top-3 right-3 z-30 bg-red-500 hover:bg-red-600 text-white w-9 h-9 rounded-xl flex items-center justify-center transition shadow-xl border border-white/20';
            delBtn.innerHTML = '<i class="fas fa-trash-alt text-xs"></i>';
            delBtn.title = 'Delete this file';
            delBtn.onclick = (e) => {
                e.stopPropagation();
                removeMediaItem(item);
            };

            const typeBadge = document.createElement('span');
            typeBadge.className = 'absolute bottom-3 left-3 z-30 px-2.5 py-1 bg-black/60 backdrop-blur-md rounded-lg text-[9px] font-black uppercase tracking-widest text-white border border-white/10';
            typeBadge.textContent = item.type === 'video' ? 'Video' : 'Picture';

            let warningBadge = null;
            if (isOversized) {
                const limitText = item.type === 'image' ? '4MB' : '4MB';
                const actualSize = item.file ? (item.file.size / (1024 * 1024)).toFixed(1) : '?';
                warningBadge = document.createElement('div');
                warningBadge.className = 'absolute inset-x-2 top-3 z-20 mr-12 bg-red-600/90 text-white px-2 py-1 rounded-lg text-[9px] font-black uppercase tracking-wider flex items-center space-x-1 shadow-lg border border-red-400';
                warningBadge.innerHTML = `<i class="fas fa-exclamation-circle text-xs"></i><span>EXCEEDS PAYLOAD (${actualSize}MB / ${limitText})</span>`;
            }

            const mediaUrl = item.isExisting ? item.src : URL.createObjectURL(item.file);

            if (item.type === 'image') {
                const img = document.createElement('img');
                img.src = mediaUrl;
                img.className = 'w-full h-full object-cover cursor-pointer group-hover:scale-105 transition duration-300';
                img.onclick = () => openMediaModal(item, mediaUrl);
                card.appendChild(img);
            } else {
                const video = document.createElement('video');
                video.src = mediaUrl;
                video.className = 'w-full h-full object-cover cursor-pointer';
                video.onclick = () => openMediaModal(item, mediaUrl);
                card.appendChild(video);
            }
            card.appendChild(delBtn);
            card.appendChild(typeBadge);
            if (warningBadge) card.appendChild(warningBadge);
            grid.appendChild(card);
        });
    }

    const mediaModal = document.getElementById('mediaModal');
    if (mediaModal) {
        mediaModal.addEventListener('click', (e) => {
            if (e.target === mediaModal) {
                closeMediaModal();
            }
        });
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === "Escape") {
            closeMediaModal();
        }
    });

    function syncPanels() {
        const rightPanel = document.getElementById('rightPanel');
        const leftPanel = document.getElementById('leftPanel');
        const dropZone = document.getElementById('dropZone');

        if (!rightPanel || !leftPanel || !dropZone) return;

        requestAnimationFrame(() => {
            const rightHeight = rightPanel.offsetHeight;
            if (rightHeight > 0) {
                leftPanel.style.minHeight = rightHeight + "px";
            }
        });
    }

    window.addEventListener('load', () => {
        syncPanels();
        setTimeout(syncPanels, 500);
    });
    window.addEventListener('resize', syncPanels);

    // Auto-save form draft to localStorage to prevent data loss on refresh
    const DRAFT_KEY = 'bulletin_form_draft_<%= bulletin ? bulletin.id : "new" %>';

    function saveFormDraft() {
        const titleInput = document.getElementById('title');
        const bodyInput = document.getElementById('body');
        const categorySelect = document.getElementById('category');

        if (!titleInput || !bodyInput) return;

        const draftData = {
            title: titleInput.value || '',
            body: bodyInput.value || '',
            category: categorySelect ? categorySelect.value : ''
        };
        try {
            localStorage.setItem(DRAFT_KEY, JSON.stringify(draftData));
        } catch (e) {}
    }

    function restoreFormDraft() {
        try {
            const saved = localStorage.getItem(DRAFT_KEY);
            if (!saved) return;
            const draft = JSON.parse(saved);

            const titleInput = document.getElementById('title');
            const bodyInput = document.getElementById('body');
            const categorySelect = document.getElementById('category');

            const isEdit = <%= bulletin ? 'true' : 'false' %>;

            // Only restore if fields are currently empty (or new creation)
            if (!isEdit && titleInput && !titleInput.value && draft.title) {
                titleInput.value = draft.title;
            }
            if (!isEdit && bodyInput && !bodyInput.value && draft.body) {
                bodyInput.value = draft.body;
            }
            if (!isEdit && categorySelect && !categorySelect.value && draft.category) {
                categorySelect.value = draft.category;
            }
        } catch (e) {}
    }

    function clearFormDraft() {
        try {
            localStorage.removeItem(DRAFT_KEY);
        } catch (e) {}
    }

    // Real-time input listeners for automatic validation & draft saving
    document.addEventListener('DOMContentLoaded', () => {
        const titleInput = document.getElementById('title');
        const bodyInput = document.getElementById('body');
        const categorySelect = document.getElementById('category');

        restoreFormDraft();

        if (titleInput) {
            titleInput.addEventListener('input', () => { validateForm(); saveFormDraft(); });
            titleInput.addEventListener('keyup', () => { validateForm(); saveFormDraft(); });
        }
        if (bodyInput) {
            bodyInput.addEventListener('input', () => { validateForm(); saveFormDraft(); });
            bodyInput.addEventListener('keyup', () => { validateForm(); saveFormDraft(); });
        }
        if (categorySelect) {
            categorySelect.addEventListener('change', () => { validateForm(); saveFormDraft(); });
        }

        validateForm();
    });

    // Clear draft on successful form submit
    const bulletinForm = document.getElementById('bulletinForm');
    if (bulletinForm) {
        bulletinForm.addEventListener('submit', () => {
            clearFormDraft();
        });
    }

    // Initial load
    renderAllMedia();

</script>