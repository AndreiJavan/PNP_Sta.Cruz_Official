<div class="max-w-7xl mx-auto w-full px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden w-full">
        <div class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
            <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs"><%= bulletin ? 'Edit Bulletin' : 'Create New Bulletin' %></h3>
            <a href="/admin/bulletins" class="text-[10px] font-bold text-gray-400 dark:text-gray-500 hover:text-pnp-blue dark:hover:text-pnp-gold uppercase tracking-widest">Cancel</a>
        </div>
        
        <form id="bulletinForm"
      action="<%= bulletin ? '/admin/bulletins/' + bulletin.id + '/edit' : '/admin/bulletins/create' %>"
      method="POST"
      enctype="multipart/form-data"
      class="p-8 space-y-8"
      onsubmit="handleBulletinSubmit(event); return false;">

    <!-- 2 COLUMN MAIN LAYOUT -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">

        <!-- LEFT SIDE: IMAGE -->
        <div id="leftPanel" class="space-y-4 flex flex-col transition-all duration-300">

            <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">
                Upload Image
            </label>

            <!-- IMAGE PREVIEW BOX -->
            <div class="flex-1 flex flex-col justify-between bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl p-4">

                <div id="dropZone"
                    onclick="document.getElementById('photos').click()"
                    class="w-full min-h-[300px] flex-1 rounded-lg overflow-hidden bg-gray-100 dark:bg-slate-800 flex items-center justify-center cursor-pointer transition-all duration-300 border-2 border-dashed border-transparent hover:border-pnp-blue p-2 relative">

                    <!-- Existing image OR preview -->
                    <div id="previewCarousel" class="relative w-full h-full min-h-[300px] flex items-center justify-center bg-gray-100 dark:bg-slate-800 group overflow-hidden rounded-md">
                        <% if (bulletin && bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                            <% bulletin.photo_paths.forEach(function(path, index) { %>
                                <img src="<%= path %>" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-in-out <%= index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0' %> preview-slide" data-index="<%= index %>" onerror="this.style.display='none';">
                            <% }); %>
                            <% if (bulletin.photo_paths.length > 1) { %>
                                <!-- Controls -->
                                <button type="button" onclick="event.stopPropagation(); movePreview(-1)" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                                    <i class="fas fa-chevron-left text-xs"></i>
                                </button>
                                <button type="button" onclick="event.stopPropagation(); movePreview(1)" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                                    <i class="fas fa-chevron-right text-xs"></i>
                                </button>
                                <!-- Indicators -->
                                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex space-x-1.5 bg-black/40 px-3 py-1.5 rounded-full preview-indicators">
                                    <% bulletin.photo_paths.forEach(function(_, index) { %>
                                        <div class="w-1.5 h-1.5 rounded-full transition-colors <%= index === 0 ? 'bg-white' : 'bg-white/40' %>" data-indicator="<%= index %>"></div>
                                    <% }); %>
                                </div>
                            <% } %>
                        <% } else if (bulletin && bulletin.photo_path) { %>
                            <img src="<%= bulletin.photo_path %>" class="absolute inset-0 w-full h-full object-cover opacity-100 z-10 preview-slide" data-index="0" onerror="this.style.display='none';">
                        <% } else { %>
                            <div id="placeholderIconContainer" class="flex flex-col items-center justify-center z-10">
                                <i class="fas fa-images text-gray-400 text-5xl mb-4"></i>
                                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest text-center">Drag & Drop or Click<br>Up to 5 images</span>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- FILE INPUT -->
                <div class="mt-4">
                    <input type="file"
                        name="photos"
                        id="photos"
                        accept="image/*"
                        multiple
                        class="hidden">

                    <button type="button"
                            onclick="document.getElementById('photos').click()"
                            class="w-full bg-pnp-blue text-white py-2 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-blue-900 transition mb-2">
                        Choose / Add Images (Max 5)
                    </button>

                    <button type="button"
                            onclick="clearAllImages()"
                            id="clearAllImagesBtn"
                            class="w-full bg-red-500/10 text-red-500 py-2 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-500 hover:text-white transition hidden">
                        Remove All Images
                    </button>

                    <p class="mt-2 text-[10px] text-gray-400 dark:text-gray-500 uppercase text-center">
                        PNG, JPG, JPEG or WEBP (Leave empty for imageless)
                    </p>
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE: FORM FIELDS -->
        <div id="rightPanel" class="space-y-6 flex flex-col transition-all duration-300">



            <!-- TITLE -->
            <div class="space-y-2">
                <label for="title" class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Bulletin Title</label>
                <input type="text" name="title" id="title" value="<%= bulletin ? bulletin.title : '' %>" required placeholder="Enter a clear, descriptive title" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
            </div>

            <!-- CATEGORY -->
            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">
                    Category
                </label>

                <% 
                    const standardCategories = ['Wanted Person', 'Missing Person', 'Crime Advisory', 'Recovered Property', 'General Announcement'];
                    const isCustomCategory = bulletin && bulletin.category && !standardCategories.includes(bulletin.category);
                %>

                <select name="category"
                        id="category"
                        required
                        onchange="toggleCustomCategory(this.value)"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">

                    <option value="" disabled <%= !bulletin && (typeof defaultCategory === 'undefined' || !defaultCategory) ? 'selected' : '' %>>Select Category</option>

                    <% standardCategories.forEach(cat => { %>
                        <option value="<%= cat %>" <%= (bulletin && bulletin.category === cat) || (typeof defaultCategory !== 'undefined' && defaultCategory === cat) ? 'selected' : '' %>>
                            <%= cat %>
                        </option>
                    <% }) %>

                    <option value="Other" <%= isCustomCategory ? 'selected' : '' %>>
                        Other (Custom)
                    </option>

                </select>
            </div>

            <!-- CUSTOM CATEGORY -->
            <div id="customCategoryContainer" class="space-y-2 <%= isCustomCategory ? '' : 'hidden' %>">
                <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">
                    New Category
                </label>

                <input type="text"
                       name="custom_category"
                       id="custom_category"
                       value="<%= isCustomCategory ? bulletin.category : '' %>"
                       placeholder="Enter custom category"
                       class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
            </div>

            <!-- BODY -->
            <div class="flex-1 flex flex-col space-y-2">
                <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">
                    Bulletin Body
                </label>

                <textarea name="body"
                          id="body"
                          rows="12"
                          required
                          placeholder="Enter the full content of the bulletin..."
                          class="flex-1 w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-sm leading-relaxed dark:text-white"><%= bulletin ? bulletin.body : '' %></textarea>
            </div>

        </div>

    </div>

    <!-- SUBMIT BUTTON (UNCHANGED STYLE PURPOSE, JUST ALIGNED RIGHT) -->
    <div class="pt-6 border-t border-gray-50 dark:border-slate-700 flex justify-end">
        <button type="submit"
                class="bg-pnp-blue text-white font-bold py-4 px-12 rounded-xl shadow-lg transition duration-300 hover:bg-blue-900 uppercase tracking-widest text-xs">
            <%= bulletin ? 'Update Bulletin' : 'Post Bulletin' %>
        </button>
    </div>

</form>

<!-- IMAGE VIEW MODAL -->
<div id="imageModal"
     class="fixed inset-0 bg-black/70 hidden items-center justify-center z-50">

    <div class="relative max-w-4xl w-full p-4">

        <!-- CLOSE BUTTON -->
        <button onclick="closeImageModal()"
                class="absolute top-2 right-2 text-white text-2xl font-bold">
            &times;
        </button>

        <!-- IMAGE -->
        <img id="modalImage"
             class="w-full max-h-[80vh] object-contain rounded-xl shadow-lg bg-black">
    </div>

</div>

    </div>
</div>

<script>
    function toggleCustomCategory(value) {
        const container = document.getElementById('customCategoryContainer');
        const input = document.getElementById('custom_category');
        if (value === 'Other') {
            container.classList.remove('hidden');
            input.required = true;
        } else {
            container.classList.add('hidden');
            input.required = false;
        }
    }

    async function handleBulletinSubmit(event) {
        event.preventDefault();
        const isEdit = <%= bulletin ? 'true' : 'false' %>;
        const action = isEdit ? 'update' : 'create';
        
        const confirmFn = window.strategicConfirm || (async (args) => {
            return confirm(args?.message || `Confirm ${action} of this strategic bulletin. This will be visible to all monitoring terminals.`);
        });
        
        const confirmed = await confirmFn({
            title: isEdit ? 'Update Confirmation' : 'Post Confirmation',
            message: `Confirm ${action} of this strategic bulletin. This will be visible to all monitoring terminals.`,
            confirmText: isEdit ? 'Update Now' : 'Post Now',
            type: 'info'
        });
        
        if (confirmed) {
            document.getElementById('bulletinForm').submit();
        }
    }

    const fileInput = document.getElementById('photos');
    const dropZone = document.getElementById('dropZone');
    
    let currentPreviewSlide = 0;
    let previewTotalSlides = <%= bulletin && bulletin.photo_paths ? bulletin.photo_paths.length : (bulletin && bulletin.photo_path ? 1 : 0) %>;
    
    let accumulatedFiles = [];

    function movePreview(direction) {
        if (previewTotalSlides <= 1) return;
        currentPreviewSlide = (currentPreviewSlide + direction + previewTotalSlides) % previewTotalSlides;
        updatePreviewCarousel();
    }
    
    function updatePreviewCarousel() {
        const slides = document.querySelectorAll('.preview-slide');
        const indicators = document.querySelectorAll('.preview-indicators div');
        
        slides.forEach((slide, idx) => {
            if (idx === currentPreviewSlide) {
                slide.classList.replace('opacity-0', 'opacity-100');
                slide.classList.replace('z-0', 'z-10');
                slide.classList.remove('pointer-events-none');
            } else {
                slide.classList.replace('opacity-100', 'opacity-0');
                slide.classList.replace('z-10', 'z-0');
                slide.classList.add('pointer-events-none');
            }
        });
        
        indicators.forEach((ind, idx) => {
            if (idx === currentPreviewSlide) {
                ind.classList.add('bg-white');
                ind.classList.remove('bg-white/40');
            } else {
                ind.classList.remove('bg-white');
                ind.classList.add('bg-white/40');
            }
        });

        const deleteBtns = document.querySelectorAll('.delete-slide-btn');
        deleteBtns.forEach((btn, idx) => {
            if (idx === currentPreviewSlide) {
                btn.classList.remove('hidden');
            } else {
                btn.classList.add('hidden');
            }
        });
    }

    if (fileInput) {
        fileInput.addEventListener('change', function () {
            handleFiles(this.files);
        });
    }

    if (dropZone) {
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('ring-2', 'ring-pnp-blue');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('ring-2', 'ring-pnp-blue');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('ring-2', 'ring-pnp-blue');
            handleFiles(e.dataTransfer.files);
        });
    }

    function handleFiles(files) {
        if (!files || files.length === 0) return;
        
        Array.from(files).forEach(file => {
            if (accumulatedFiles.length < 5) {
                accumulatedFiles.push(file);
            }
        });

        if (accumulatedFiles.length > 5) {
            alert('You can only upload a maximum of 5 images. Extra files were ignored.');
            accumulatedFiles = accumulatedFiles.slice(0, 5);
        }
        
        syncFileInput();
        renderAccumulatedFiles();
    }

    function syncFileInput() {
        const dt = new DataTransfer();
        accumulatedFiles.forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        
        const clearBtn = document.getElementById('clearAllImagesBtn');
        if (accumulatedFiles.length > 0) {
            clearBtn.classList.remove('hidden');
        } else {
            clearBtn.classList.add('hidden');
        }
    }

    function removeSingleImage(index) {
        accumulatedFiles.splice(index, 1);
        syncFileInput();
        
        if (accumulatedFiles.length === 0) {
            clearAllImages();
        } else {
            if (currentPreviewSlide >= accumulatedFiles.length) {
                currentPreviewSlide = Math.max(0, accumulatedFiles.length - 1);
            }
            renderAccumulatedFiles();
        }
    }

    function clearAllImages() {
        accumulatedFiles = [];
        syncFileInput();
        const previewCarousel = document.getElementById('previewCarousel');
        previewCarousel.innerHTML = `
            <div id="placeholderIconContainer" class="flex flex-col items-center justify-center z-10">
                <i class="fas fa-images text-gray-400 text-5xl mb-4"></i>
                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest text-center">Drag & Drop or Click<br>Up to 5 images</span>
            </div>
        `;
        currentPreviewSlide = 0;
        previewTotalSlides = 0;
        document.getElementById('clearAllImagesBtn').classList.add('hidden');
    }

    function renderAccumulatedFiles() {
        const previewCarousel = document.getElementById('previewCarousel');
        previewCarousel.innerHTML = '';
        previewTotalSlides = accumulatedFiles.length;

        if (accumulatedFiles.length === 0) {
            clearAllImages();
            return;
        }

        let loadedCount = 0;

        accumulatedFiles.forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = function (e) {
                const slideWrapper = document.createElement('div');
                slideWrapper.className = `absolute inset-0 w-full h-full transition-opacity duration-500 ease-in-out preview-slide ${index === currentPreviewSlide ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'}`;
                slideWrapper.dataset.index = index;
                
                const img = document.createElement('img');
                img.src = e.target.result;
                img.className = `w-full h-full object-cover rounded-md`;
                
                const delBtn = document.createElement('button');
                delBtn.type = "button";
                delBtn.className = `delete-slide-btn absolute top-3 right-3 z-30 bg-red-500/80 hover:bg-red-600 text-white w-8 h-8 rounded-full flex items-center justify-center transition focus:outline-none shadow-lg ${index === currentPreviewSlide ? '' : 'hidden'}`;
                delBtn.innerHTML = '<i class="fas fa-trash text-[10px]"></i>';
                delBtn.onclick = (event) => {
                    event.stopPropagation();
                    removeSingleImage(index);
                };

                slideWrapper.appendChild(img);
                slideWrapper.appendChild(delBtn);
                previewCarousel.appendChild(slideWrapper);
                
                loadedCount++;
                
                if (loadedCount === accumulatedFiles.length && accumulatedFiles.length > 1) {
                    let controls = `
                        <button type="button" onclick="event.stopPropagation(); movePreview(-1)" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                            <i class="fas fa-chevron-left text-xs"></i>
                        </button>
                        <button type="button" onclick="event.stopPropagation(); movePreview(1)" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 bg-black/50 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-pnp-blue transition focus:outline-none">
                            <i class="fas fa-chevron-right text-xs"></i>
                        </button>
                        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex space-x-1.5 bg-black/40 px-3 py-1.5 rounded-full preview-indicators pointer-events-none">
                    `;
                    for(let i = 0; i < accumulatedFiles.length; i++) {
                        controls += `<div class="w-1.5 h-1.5 rounded-full transition-colors ${i === currentPreviewSlide ? 'bg-white' : 'bg-white/40'}" data-indicator="${i}"></div>`;
                    }
                    controls += `</div>`;
                    previewCarousel.insertAdjacentHTML('beforeend', controls);
                }
                syncPanels();
            };
            reader.readAsDataURL(file);
        });
    }

    const modal = document.getElementById('imageModal');
    const modalImage = document.getElementById('modalImage');

    function openImageModal(src) {
        // Fallback to previewImage src if not provided
        const finalSrc = src || document.getElementById('previewImage')?.src;
        if (!finalSrc || finalSrc.includes('hidden')) return;

        modalImage.src = finalSrc;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function closeImageModal() {
        if (modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    }

    if (modal) {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                closeImageModal();
            }
        });
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === "Escape") {
            closeImageModal();
        }
    });
    
    function syncPanels() {
        const rightPanel = document.getElementById('rightPanel');
        const leftPanel = document.getElementById('leftPanel');
        const dropZone = document.getElementById('dropZone');

        if (!rightPanel || !leftPanel || !dropZone) return;

        // Use requestAnimationFrame for smoother sync
        requestAnimationFrame(() => {
            const rightHeight = rightPanel.offsetHeight;
            if (rightHeight > 0) {
                leftPanel.style.minHeight = rightHeight + "px";
            }
        });
    }

    window.addEventListener('load', () => {
        syncPanels();
        // Additional sync after small delay to catch late layout shifts
        setTimeout(syncPanels, 500);
    });
    window.addEventListener('resize', syncPanels);

</script>
