            modeSelect.value = 'clear';
            updateHeatmap();
            updateLegend();
        }
    }

    function updateHeatmap() {
        if (boundaryLayerGroup) {
            boundaryLayerGroup.eachLayer(layer => {
                if (layer.feature) {
                    layer.setStyle(getThematicStyleForFeature(layer.feature));
                }
            });
        }
    }

    function updateLegend() {
        const legendContainer = document.getElementById('dynamicLegend');
        if (!legendContainer) return;

        const modeSelect = document.getElementById('mapDisplayMode');
        const mode = modeSelect ? modeSelect.value : 'density';
        const selectedBarangay = document.getElementById('filterBarangay')?.value || '';

        if (selectedBarangay) {
            // Detailed sector-specific view!
            let brgyPoints = currentPoints.filter(p => p.barangay === selectedBarangay);
            let globalPoints = currentPoints;

            let targetCategory = null;
            if (mode === 'density_focus') targetCategory = '8-Focus';
            else if (mode === 'density_nonindex') targetCategory = 'Non-Index';
            else if (mode === 'density_psi') targetCategory = 'PSI';

            if (targetCategory) {
                brgyPoints = brgyPoints.filter(p => (p.category || 'Non-Index') === targetCategory);
                globalPoints = globalPoints.filter(p => (p.category || 'Non-Index') === targetCategory);
            }

            const totalIncidents = brgyPoints.length;

            const allCounts = Object.values(globalPoints.reduce((acc, curr) => {
