<% 
const safePoints = (typeof points !== 'undefined' && points) ? points : [];
const colors = {
    'Theft': '#FFE135', 
    'Robbery': '#D97706', 
    'Murder': '#FF0000', 
    'Homicide': '#3B82F6', 
    'Physical Injuries': '#10B981', 
    'Rape': '#A855F7', 
    'Carnapping (MC)': '#F59E0B', 
    'Carnapping (MV)': '#059669', 
    'VAWC': '#E11D48', 
    'Cybercrime': '#2563EB', 
    'Other': '#94A3B8'
};

%>
<div class="relative w-full h-[calc(100vh-80px)] overflow-hidden bg-slate-50 dark:bg-slate-950 p-6">
    <div class="flex flex-col lg:flex-row h-full gap-6">
        <!-- Unified Tactical Hub (Left) -->
        <div id="registryPanel" class="lg:w-1/2 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-[2.5rem] shadow-2xl border border-white/20 dark:border-slate-700/50 overflow-hidden flex flex-col">
            <!-- Panel Header -->
            <div class="p-6 border-b border-gray-100/50 dark:border-slate-800/50 bg-gradient-to-r from-pnp-blue/10 to-transparent flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <div class="w-10 h-10 bg-pnp-blue rounded-2xl flex items-center justify-center text-pnp-gold shadow-lg shadow-pnp-blue/20 border border-pnp-gold/20">
                        <i class="fas fa-tower-broadcast animate-pulse"></i>
                    </div>
                    <div>
                        <h2 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.25em] text-[11px] leading-tight">Tactical Hub</h2>
                        <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-0.5">S-SPS Unified Intelligence</p>
                    </div>
                </div>
                
                <!-- Tactical Tabs -->
                <div class="flex bg-gray-100 dark:bg-slate-800 p-1 rounded-xl border border-gray-200 dark:border-slate-700">
                    <button onclick="switchTab('records')" id="tab-records" class="px-4 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest transition-all bg-white dark:bg-slate-900 shadow-sm text-pnp-blue dark:text-pnp-gold">
                        Live Grid
                    </button>
                    <button onclick="switchTab('legend')" id="tab-legend" class="px-4 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest transition-all text-gray-400 hover:text-pnp-blue dark:hover:text-pnp-gold">
                        Intel Legend
                    </button>
                </div>
            </div>
            
            <div id="registryContent" class="p-6 flex-grow overflow-y-auto custom-scrollbar">
                <!-- Tab 1: Live Records Grid -->
                <div id="content-records" class="space-y-6">
                    <!-- Barangay Selector -->
                    <div class="space-y-2">
                        <label for="sectorSelector" class="text-[9px] text-gray-400 uppercase tracking-widest font-black block">Monitor Sector (Barangay)</label>
                        <div class="relative">
                            <i class="fas fa-map-marker-alt absolute left-3 top-1/2 -translate-y-1/2 text-pnp-blue dark:text-pnp-gold text-[10px]"></i>
                            <select id="sectorSelector" onchange="monitorSector(this.value)" class="w-full pl-9 pr-4 py-3 bg-gray-50 dark:bg-slate-800 border border-gray-100 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-black dark:text-white appearance-none uppercase tracking-widest">
                                <option value="">Full Municipal Grid</option>
                                <% ["Alipit", "Bagumbayan", "Bubukal", "Calios", "Duhat", "Gatid", "Jasaan", "Labuin", "Malinao", "Oogong", "Pagsawitan", "Palasan", "Patimbao", "Poblacion I (Barangay I)", "Poblacion II (Barangay II)", "Poblacion III (Barangay III)", "Poblacion IV (Barangay IV)", "Poblacion V (Barangay V)", "San Jose", "San Juan", "San Pablo Norte", "San Pablo Sur", "Santisima Cruz", "Santo Angel Central", "Santo Angel Norte", "Santo Angel Sur"].forEach(brgy => { %>
                                    <option value="<%= brgy %>" <%= brgy === 'Bagumbayan' ? 'selected' : '' %>>BRGY. <%= brgy %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <!-- Incident List Container -->
                    <div id="sectorIncidentContainer" class="space-y-3">
                        <div class="flex items-center justify-between px-1">
                            <span class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.2em]">Regional Intel</span>
                            <span id="incidentCount" class="text-[9px] font-black text-slate-400 uppercase">0 Records</span>
                        </div>
                        
                        <div id="incidentList" class="space-y-2 max-h-[400px] overflow-y-auto pr-1 custom-scrollbar">
                            <div class="py-12 text-center">
                                <i class="fas fa-radar text-3xl text-gray-100 dark:text-slate-800 mb-3 block"></i>
                                <p class="text-[9px] text-gray-300 font-bold uppercase tracking-widest italic">Syncing localized intelligence...</p>
                            </div>
                        </div>
                    </div>

                    <!-- Action Button -->
                    <div class="pt-4 border-t border-gray-50 dark:border-slate-800">
                        <a href="/admin/reports" class="w-full py-4 bg-slate-100 dark:bg-slate-800 hover:bg-pnp-blue hover:text-white text-pnp-blue dark:text-pnp-gold rounded-2xl text-[9px] font-black uppercase tracking-[0.2em] transition-all flex items-center justify-center space-x-3 border border-gray-200 dark:border-slate-700 shadow-sm">
                            <i class="fas fa-file-invoice"></i>
                            <span>Manual Entry</span>
                        </a>
                    </div>
                </div>

                <!-- Tab 2: Tactical Legend & Intel -->
                <div id="content-legend" class="hidden space-y-6 animate-in fade-in slide-in-from-right-4 duration-500">
                    <!-- Legend Image -->
                    <div class="bg-gray-50 dark:bg-slate-800 p-4 rounded-[2rem] border border-gray-100 dark:border-slate-700 shadow-inner">
                        <h3 class="text-[9px] text-gray-400 uppercase tracking-widest font-black block mb-4 px-2">Authoritative Legend</h3>
                        <img src="/images/legend.jpg" alt="Crime Legend" class="w-full h-auto rounded-2xl shadow-2xl">
                    </div>

                    <!-- Sector Statistics Table -->
                    <div class="space-y-3">
                        <h3 class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest block px-1">Highly Usual Crime per Sector</h3>
                        <div class="overflow-hidden rounded-[2rem] border border-gray-100 dark:border-slate-800 bg-gray-50/50 dark:bg-slate-900/50">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-gray-100 dark:bg-slate-800">
                                    <tr>
                                        <th class="px-6 py-4 text-[9px] font-black text-slate-500 uppercase tracking-widest">Sector (Barangay)</th>
                                        <th class="px-6 py-4 text-[9px] font-black text-slate-500 uppercase tracking-widest">Highest Frequency</th>
                                    </tr>
                                </thead>
                                <tbody id="sectorStatsTable" class="text-[10px] font-bold dark:text-white">
                                    <!-- Dynamic rows injected by script -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Interactive Map (Right) -->
        <div id="mapWrapper" class="lg:w-1/2 h-64 lg:h-full relative group rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white dark:border-slate-800 transition-all duration-500">
            <div id="leafletMap" class="w-full h-full z-0 cursor-pointer"></div>
            
            <!-- Map Overlay Controls -->
            <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-all pointer-events-none flex items-center justify-center">
                <div class="bg-pnp-blue/80 backdrop-blur-md px-4 py-2 rounded-full text-white text-[10px] font-black uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all transform translate-y-4 group-hover:translate-y-0">
                    <i class="fas fa-expand-arrows-alt mr-2"></i> Click to Expand Tactical View
                </div>
            </div>

            <!-- Minimize Button -->
            <button id="minimizeMap" onclick="toggleMapExpansion(event)" class="absolute top-6 right-6 z-[10001] w-12 h-12 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-2xl shadow-2xl flex items-center justify-center text-pnp-blue dark:text-pnp-gold hover:scale-110 transition-all hidden">
                <i class="fas fa-compress-alt"></i>
            </button>
        </div>
    </div>

    <!-- Map Loading Layer -->
    <div id="mapLoading" class="absolute inset-0 bg-slate-900 z-[12000] flex flex-col items-center justify-center text-white transition-opacity duration-500 pointer-events-none">
        <div class="w-16 h-16 border-4 border-pnp-gold border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-[8px] font-black uppercase tracking-[0.3em] animate-pulse">Synchronizing Tactical Intelligence...</p>
    </div>
</div>

<script>
    let map;
    let santaCruzGeoJSON;
    let pinLayer = L.layerGroup();
    let incidentLayer = L.layerGroup();
    let boundaryLinesLayer = L.layerGroup();
    let barangayLayer; // Direct reference for thematic updates
    let boundaryLayer;
    let glowLayer;

    // Use correct PSGC for Santa Cruz Laguna: 043426000
    const barangayGeoJsonUrl = 'https://raw.githubusercontent.com/faeldon/philippines-json-maps/master/2019/geojson/barangays/medres/barangays-municity-ph043426000.0.01.json';
    const colors = <%- JSON.stringify(colors) %>;
    // Fix: Using EJS to stringify the points data for client-side use
    const pointsData = <%- JSON.stringify(safePoints) %>;
    let activeTab = 'records'; // Global state for map interactions

const normalizeCrimeName = (type) => {
        if (!type) return 'Other';
        let name = type;
        if (name.includes('Carnapping (Motorcycle)')) name = 'Carnapping (MC)';
        if (name.includes('Carnapping (Motor Vehicle)')) name = 'Carnapping (MV)';
        if (name.includes('Physical Injury')) name = 'Physical Injuries';
        return name;
    };

    // Tab Switching Logic
    window.switchTab = function(tab) {
        activeTab = tab; // Update state
        const records = document.getElementById('content-records');
        const legend = document.getElementById('content-legend');
        const tabRecords = document.getElementById('tab-records');
        const tabLegend = document.getElementById('tab-legend');

        if (tab === 'records') {
            records.classList.remove('hidden');
            legend.classList.add('hidden');
            tabRecords.classList.add('bg-white', 'dark:bg-slate-900', 'shadow-sm', 'text-pnp-blue', 'text-pnp-gold');
            tabRecords.classList.remove('text-gray-400');
            tabLegend.classList.remove('bg-white', 'dark:bg-slate-900', 'shadow-sm', 'text-pnp-blue', 'text-pnp-gold');
            tabLegend.classList.add('text-gray-400');

            // Show Pins & Incidents
            if (!map.hasLayer(pinLayer)) pinLayer.addTo(map);
            if (!map.hasLayer(incidentLayer)) incidentLayer.addTo(map);
            addIncidentPins(); // Re-enable pins

            // Remove sector shading
            if (barangayLayer) {
                barangayLayer.eachLayer(layer => {
                    layer.setStyle({ fillOpacity: 0, weight: 1, color: '#C8A415' });
                });
            }
        } else {
            records.classList.add('hidden');
            legend.classList.remove('hidden');
            tabLegend.classList.add('bg-white', 'dark:bg-slate-900', 'shadow-sm', 'text-pnp-blue', 'text-pnp-gold');
            tabLegend.classList.remove('text-gray-400');
            tabRecords.classList.remove('bg-white', 'dark:bg-slate-900', 'shadow-sm', 'text-pnp-blue', 'text-pnp-gold');
            tabRecords.classList.add('text-gray-400');

            // Hide Pins & Incidents
            map.removeLayer(pinLayer);
            map.removeLayer(incidentLayer);

            // Re-apply thematic shading
            if (barangayLayer) {
                barangayLayer.eachLayer(layer => {
                    if (layer.feature) {
                        const style = getThematicStyleForFeature(layer.feature);
                        layer.setStyle(style);
                    }
                });
            }
        }
    };

    function getThematicStyleForFeature(feature) {
        // Helper to normalize Poblacion names to match database/manualPins
        const normalizeBrgyName = (name) => {
            const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
            if (match) {
                return `Poblacion ${match[1]} (Barangay ${match[1]})`;
            }
            return name;
        };

        const brgyName = normalizeBrgyName(feature.properties.ADM4_EN);
        const brgyPoints = pointsData.filter(p => p.barangay === brgyName);
        let fillColor = '#1A3A5C'; 
        
        if (brgyPoints.length > 0) {
            const stats = {};
            brgyPoints.forEach(p => {
                const normType = normalizeCrimeName(p.incident_type);
                stats[normType] = (stats[normType] || 0) + 1;
            });
            const topCrime = Object.entries(stats).sort((a,b) => b[1] - a[1])[0];
            fillColor = colors[topCrime[0]] || '#1A3A5C';
        }

        return { 
            color: '#FFD700', 
            weight: 3, 
            fillOpacity: 0.5, 
            fillColor: fillColor,
            dashArray: '5, 5' 
        };
    }

    // Map Expansion Logic
    window.toggleMapExpansion = function(event) {
        if (event) event.stopPropagation();
        
        const wrapper = document.getElementById('mapWrapper');
        const minimizeBtn = document.getElementById('minimizeMap');
        const isExpanded = wrapper.classList.contains('map-expanded');

        if (isExpanded) {
            // Minimize
            wrapper.classList.remove('map-expanded');
            minimizeBtn.classList.add('hidden');
            document.body.style.overflow = '';
        } else {
            // Expand
            wrapper.classList.add('map-expanded');
            minimizeBtn.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
        
        // Trigger map resize and zoom adjustment
        setTimeout(() => {
            map.invalidateSize({ animate: true });
            if (!isExpanded) {
                // When expanding, zoom out to view the whole of Santa Cruz (Centered)
                const c1 = L.latLng(14.18, 121.30);
                const c2 = L.latLng(14.33, 121.47);
                map.flyToBounds(L.latLngBounds(c1, c2), { duration: 1.5 });
            } else {
                // When minimizing, focus back on Bagumbayan
                monitorSector('Bagumbayan');
            }
        }, 600);
    };

    // Add click listener to map wrapper for expansion
    document.getElementById('leafletMap').addEventListener('click', function(e) {
        const wrapper = document.getElementById('mapWrapper');
        if (!wrapper.classList.contains('map-expanded')) {
            toggleMapExpansion();
        }
    });

    window.monitorSector = function(barangay) {
        if (!barangay) {
            renderIncidentList(pointsData);
            map.flyToBounds(L.latLngBounds(L.latLng(14.18, 121.30), L.latLng(14.33, 121.47)), { duration: 1.5 });
            return;
        }
        
        const filtered = pointsData.filter(p => p.barangay === barangay);
        renderIncidentList(filtered, barangay);
        
        const pin = manualPins.find(p => p.name === barangay);
        if (pin) {
            map.flyTo([pin.lat, pin.lng], 16, { duration: 1.5 });
        }
    };

    function getCategoryForType(type) {
        const focusTypes = ['Murder', 'Homicide', 'Physical Injury', 'Rape', 'Robbery', 'Theft', 'Carnapping'];
        const psiTypes = [
            'Search Warrant', 'Warrant of Arrest', 'Checkpoint', 'Buy-Bust', 'Oplan Bakal', 'Oplan Galugad',
            'Vehicular Accident', 'Traffic Accident', 'Public Safety', 'Fire Incident'
        ];
        
        if (focusTypes.some(f => type.toLowerCase().includes(f.toLowerCase()))) return '8-Focus';
        if (psiTypes.some(p => type.toLowerCase().includes(p.toLowerCase()))) return 'PSI';
        return 'Non-Index';
    }

    function renderIncidentList(data, sectorName = 'Regional Grid') {
        const list = document.getElementById('incidentList');
        const count = document.getElementById('incidentCount');
        
        count.textContent = `${data.length} Records`;
        
        if (data.length === 0) {
            list.innerHTML = `
                <div class="py-12 text-center">
                    <i class="fas fa-satellite-dish text-3xl text-gray-100 dark:text-slate-800 mb-3 block"></i>
                    <p class="text-[9px] text-gray-300 font-bold uppercase tracking-widest italic">Negative Contact: No intelligence for this sector</p>
                </div>
            `;
            return;
        }

        // Sort by date descending
        const sorted = [...data].sort((a,b) => new Date(b.incident_date).getTime() - new Date(a.incident_date).getTime());

        list.innerHTML = sorted.map(item => {
            const cat = getCategoryForType(item.incident_type || 'Other');
            const stripeColor = cat === '8-Focus' ? 'border-red-500' : (cat === 'PSI' ? 'border-pnp-gold' : 'border-pnp-blue');
            const badgeClass = cat === '8-Focus' ? 'bg-red-500/10 text-red-500' : (cat === 'PSI' ? 'bg-pnp-gold/10 text-pnp-gold' : 'bg-pnp-blue/10 text-pnp-blue dark:text-blue-300');
            
            return `
                <div class="p-4 bg-gray-50 dark:bg-slate-800/50 rounded-2xl border-l-4 ${stripeColor} hover:bg-white dark:hover:bg-slate-700 transition-all cursor-pointer group shadow-sm flex justify-between items-center">
                    <div onclick="focusPoint('${item.barangay}', '${item.incident_type}')" class="flex-grow">
                        <div class="flex justify-between items-start mb-2">
                            <span class="text-[10px] font-black text-slate-800 dark:text-white uppercase leading-tight group-hover:text-pnp-blue transition">${item.incident_type}</span>
                            <span class="text-[8px] font-bold text-slate-400 uppercase tabular-nums">${new Date(item.incident_date).toLocaleDateString(undefined, {month:'short', day:'numeric'})}</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="px-2 py-0.5 rounded-lg text-[7px] font-black uppercase tracking-widest ${badgeClass}">${cat}</span>
                            <span class="text-[8px] font-black text-slate-400 uppercase">Brgy. ${item.barangay}</span>
                        </div>
                    </div>
                    <button onclick="deletePoint('${item.id}', event)" class="ml-3 w-8 h-8 rounded-xl bg-red-50 dark:bg-red-900/20 text-red-400 hover:bg-red-500 hover:text-white transition-all flex items-center justify-center opacity-0 group-hover:opacity-100">
                        <i class="fas fa-trash-alt text-[10px]"></i>
                    </button>
                </div>
            `;
        }).join('');
    }

    window.deletePoint = async function(id, event) {
        if (event) event.stopPropagation();
        
        if (confirm('Are you sure you want to delete this tactical data point?')) {
            try {
                const res = await fetch(`/admin/map/${id}/delete`, { 
                    method: 'POST',
                    headers: { 'Accept': 'application/json' }
                });
                const result = await res.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Command Failure: ' + (result.message || 'Operation failed'));
                }
            } catch (err) {
                console.error(err);
                alert('Connection error: Protocol sequence interrupted');
            }
        }
    };

    window.focusBarangay = function(barangay) {
        if (!barangay) return;
        const pin = manualPins.find(p => p.name === barangay);
        if (pin) {
            map.flyTo([pin.lat, pin.lng], 17, { duration: 1.5 });
        }
    };

    window.focusPoint = function(barangay, type) {
        const pin = manualPins.find(p => p.name === barangay);
        if (pin) {
            map.flyTo([pin.lat, pin.lng], 17);
            incidentLayer.eachLayer(layer => {
                const popup = layer.getPopup();
                if (popup && popup.getContent().includes(`Brgy. ${barangay}`) && popup.getContent().includes(type)) {
                    layer.openPopup();
                }
            });
        }
    };

    function renderSectorStats() {
        const table = document.getElementById('sectorStatsTable');
        if (!table) return;

        // Group by barangay
        const stats = {};
        pointsData.forEach(p => {
            if (!stats[p.barangay]) stats[p.barangay] = {};
            stats[p.barangay][p.incident_type] = (stats[p.barangay][p.incident_type] || 0) + 1;
        });

        const rows = Object.entries(stats).map(([brgy, crimes]) => {
            // Find most frequent crime
            const topCrime = Object.entries(crimes).sort((a,b) => b[1] - a[1])[0];
            const rawType = topCrime[0];
            const crimeType = normalizeCrimeName(rawType);
            const color = colors[crimeType] || '#ccc';

            return `
                <tr class="border-b border-gray-100 dark:border-slate-800 hover:bg-white dark:hover:bg-slate-800 transition">
                    <td class="px-4 py-2 uppercase text-[7px] font-black">${brgy}</td>
                    <td class="px-4 py-2">
                        <div class="flex items-center space-x-2">
                            <div class="w-2 h-2 rounded-full" style="background-color: ${color}"></div>
                            <span class="uppercase text-[7px] font-black tracking-tighter">${crimeType}</span>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');

        table.innerHTML = rows || `<tr><td colspan="2" class="py-4 text-center text-[7px] text-gray-400">No Intelligence Data</td></tr>`;
    }

    async function loadMunicipalBoundary() {
        try {
            const response = await fetch('https://nominatim.openstreetmap.org/search?format=json&q=Santa+Cruz,+Laguna,+Philippines&polygon_geojson=1&limit=5');
            const data = await response.json();
            const boundary = data.find(item => item.osm_type === 'relation' && item.geojson);

            if (boundary && boundary.geojson) {
                const updateStyles = () => {
                    const zoom = map.getZoom();
                    const baseWeight = zoom < 14 ? 10 : (zoom < 16 ? 18 : 30);
                    const glowWeight = baseWeight * 1.8;

                    if (glowLayer) glowLayer.setStyle({ weight: glowWeight });
                    if (boundaryLayer) boundaryLayer.setStyle({ weight: baseWeight });
                };

                glowLayer = L.geoJSON(boundary.geojson, {
                    style: {
                        color: "#000000",
                        weight: 25,
                        opacity: 0.2,
                        fillColor: "transparent",
                        interactive: false
                    }
                }).addTo(map);

                boundaryLayer = L.geoJSON(boundary.geojson, {
                    style: {
                        color: "#000000",
                        weight: 12,
                        opacity: 0.9,
                        fillColor: "rgba(0,0,0,0.05)",
                        fillOpacity: 0.1,
                        interactive: false
                    }
                }).addTo(map);

                map.on('zoomend', updateStyles);
                updateStyles();
            }
        } catch (err) {
            console.error("Error loading municipal boundary:", err);
        }
    }

    window.manualPins = [
        { name: 'Alipit', lat: 14.223931, lng: 121.405213 },
        { name: 'Bagumbayan', lat: 14.268334, lng: 121.398454 },
        { name: 'Duhat', lat: 14.2525, lng: 121.3825 },
        { name: 'Bubukal', lat: 14.256460, lng: 121.399183 },
        { name: 'Calios', lat: 14.2750, lng: 121.4050 },
        { name: 'Gatid', lat: 14.2600, lng: 121.3830 },
        { name: 'Jasaan', lat: 14.223577, lng: 121.394827 },
        { name: 'Labuin', lat: 14.250158, lng: 121.400664 },
        { name: 'Malinao', lat: 14.232833, lng: 121.396823 },
        { name: 'Oogong', lat: 14.226323, lng: 121.400621 },
        { name: 'Pagsawitan', lat: 14.265754, lng: 121.426545 },
        { name: 'Palasan', lat: 14.257498, lng: 121.418992 },
        { name: 'Patimbao', lat: 14.270081, lng: 121.418366 },
        { name: 'Poblacion I (Barangay I)', lat: 14.277068, lng: 121.418881 },
        { name: 'Poblacion II (Barangay II)', lat: 14.279647, lng: 121.416006 },
        { name: 'Poblacion III (Barangay III)', lat: 14.282028, lng: 121.415159 },
        { name: 'Poblacion IV (Barangay IV)', lat: 14.283790, lng: 121.414016 },
        { name: 'Poblacion V (Barangay V)', lat: 14.285282, lng: 121.412476 },
        { name: 'San Jose', lat: 14.237118, lng: 121.403754 },
        { name: 'San Juan', lat: 14.243815, lng: 121.406972 },
        { name: 'San Pablo Norte', lat: 14.290210, lng: 121.413023 },
        { name: 'San Pablo Sur', lat: 14.282211, lng: 121.422261 },
        { name: 'Santisima Cruz', lat: 14.290647, lng: 121.409140 },
        { name: 'Santo Angel Central', lat: 14.285137, lng: 121.408947 },
        { name: 'Santo Angel Norte', lat: 14.288547, lng: 121.406307 },
        { name: 'Santo Angel Sur', lat: 14.282329, lng: 121.410985 }
    ];

    const crimeCounts = pointsData.reduce((acc, p) => {
        acc[p.barangay] = (acc[p.barangay] || 0) + 1;
        return acc;
    }, {});

    function getDensityColor(d) {
        return d > 10 ? '#7f1d1d' : d > 7 ? '#b91c1c' : d > 4 ? '#ea580c' : d > 2 ? '#ca8a04' : d > 0 ? '#C8A415' : 'rgba(30, 41, 59, 0.5)';
    }

    function addIncidentPins(filterBrgy = '', filterType = '') {
        incidentLayer.clearLayers();
        
        pointsData.forEach(point => {
            if (filterBrgy && point.barangay !== filterBrgy) return;
            if (filterType && point.incident_type !== filterType) return;
            const brgyRef = manualPins.find(p => p.name === point.barangay);
            if (!brgyRef) return;
            const lat = brgyRef.lat + (Math.random() - 0.5) * 0.002;
            const lng = brgyRef.lng + (Math.random() - 0.5) * 0.002;

            const normalizedType = normalizeCrimeName(point.incident_type);

            const marker = L.marker([lat, lng], {
                icon: L.divIcon({
                    className: 'incident-pin-container',
                    html: `<div class="w-4 h-4 rounded-full border-2 border-white shadow-lg animate-pulse" style="background-color: ${colors[normalizedType] || '#ccc'}"></div>`,
                    iconSize: [16, 16],
                    iconAnchor: [8, 8]
                })
            }).addTo(incidentLayer).bindPopup(`
                <div class="p-3 min-w-[180px] bg-slate-900 text-white rounded-2xl shadow-2xl border border-white/10">
                    <div class="flex items-center justify-between mb-2">
                        <span class="px-2 py-0.5 rounded-full text-[7px] font-black uppercase tracking-widest" style="background-color: ${colors[normalizedType] || '#ccc'}">${normalizedType}</span>
                        <span class="text-[7px] text-white/40 font-bold">${new Date(point.incident_date).toLocaleDateString()}</span>
                    </div>
                    <h3 class="text-[10px] font-black uppercase tracking-tighter mb-1">Brgy. ${point.barangay}</h3>
                    <p class="text-[8px] text-white/60 leading-tight">${point.description || 'No additional intelligence'}</p>
                </div>
            `, { className: 'intelligence-popup' });
            
            marker.on('click', () => {
                map.flyTo([lat, lng], 18);
            });
        });
    }

    function addManualPins() {
        manualPins.forEach(pin => {
            const marker = L.marker([pin.lat, pin.lng], {
                icon: L.divIcon({
                    className: 'manual-pin-container',
                    html: `
                        <div class="relative group flex flex-col items-center">
                            <!-- Pulse Effect -->
                            <div class="absolute w-8 h-8 bg-pnp-gold/30 rounded-full animate-ping"></div>
                            <!-- Main Pin -->
                            <div class="relative w-10 h-10 bg-pnp-blue dark:bg-pnp-gold rounded-full flex items-center justify-center shadow-2xl border-2 border-white dark:border-slate-900 transform group-hover:scale-110 transition-all duration-300">
                                <i class="fas fa-tower-observation text-white dark:text-pnp-blue text-xs"></i>
                            </div>
                            <!-- Pointer -->
                            <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-pnp-blue dark:border-t-pnp-gold -mt-1"></div>
                        </div>
                    `,
                    iconSize: [40, 48],
                    iconAnchor: [20, 48]
                })
            }).addTo(pinLayer).bindPopup(`
                <div class="p-4 min-w-[200px] bg-slate-900 text-white rounded-2xl shadow-2xl border border-white/10">
                    <div class="flex items-center space-x-3 mb-3 pb-3 border-b border-white/10">
                        <div class="w-8 h-8 bg-pnp-gold rounded-lg flex items-center justify-center">
                            <i class="fas fa-shield-halved text-pnp-blue text-xs"></i>
                        </div>
                        <div>
                            <h3 class="text-pnp-gold font-black uppercase tracking-widest text-[10px] leading-none">${pin.name} Sector</h3>
                            <p class="text-[7px] text-white/50 font-bold uppercase mt-1">Intelligence Division</p>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center text-[8px] font-black uppercase text-white/70">
                            <span>Sector Ref</span>
                            <span class="text-pnp-gold">SCT-${pin.name.slice(0, 3).toUpperCase()}</span>
                        </div>
                    </div>
                </div>
            `, { className: 'intelligence-popup' });

            marker.on('click', () => {
                map.flyTo([pin.lat, pin.lng], 16);
            });
        });
    }

    function initMap() {
        // Sta. Cruz Laguna Bounds (Recalibrated for perfect centering)
        const corner1 = L.latLng(14.18, 121.30);
        const corner2 = L.latLng(14.33, 121.47);
        const bounds = L.latLngBounds(corner1, corner2);

        map = L.map('leafletMap', { 
            zoomControl: false,
            maxBounds: bounds,
            maxBoundsViscosity: 1.0,
            minZoom: 13
        }).fitBounds(bounds);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19
        }).addTo(map);
        pinLayer.addTo(map);
        incidentLayer.addTo(map);
        boundaryLinesLayer.addTo(map);
        addManualPins();
        addIncidentPins();
        loadMunicipalBoundary();

        // Error handling for GeoJSON fetch to prevent SyntaxError on 404
        fetch(barangayGeoJsonUrl)
            .then(r => {
                if (!r.ok) throw new Error('Network response was not ok: ' + r.statusText);
                return r.json();
            })
            .then(data => {
                santaCruzGeoJSON = data;
                
                // Helper to normalize Poblacion names to match database/manualPins
                const normalizeBrgyName = (name) => {
                    const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
                    if (match) {
                        return `Poblacion ${match[1]} (Barangay ${match[1]})`;
                    }
                    return name;
                };

                barangayLayer = L.geoJSON(data, {
                    style: f => {
                        return { fillOpacity: 0, weight: 1, color: '#C8A415' }; // Start empty for Live Grid
                    },
                    onEachFeature: (f, l) => {
                        const brgyName = normalizeBrgyName(f.properties.ADM4_EN);
                        
                        // Interaction
                        l.on({
                            mouseover: (e) => {
                                const layer = e.target;
                                // In both modes, provide a visual focus on hover
                                layer.setStyle({ 
                                    weight: activeTab === 'records' ? 4 : 6, 
                                    fillOpacity: activeTab === 'records' ? 0.2 : 0.7,
                                    color: '#FFFFFF', 
                                    dashArray: ''
                                });
                                layer.bringToFront();
                            },
                            mouseout: (e) => {
                                const layer = e.target;
                                if (activeTab === 'records') {
                                    // Reset to clear state for Live Grid
                                    layer.setStyle({ 
                                        fillOpacity: 0, 
                                        weight: 1, 
                                        color: '#C8A415',
                                        dashArray: ''
                                    });
                                } else {
                                    // Reset to thematic state for Intel Legend
                                    const style = getThematicStyleForFeature(layer.feature);
                                    layer.setStyle(style);
                                }
                            }
                        });

                        l.bindPopup(`<div class="p-3 min-w-[180px] bg-slate-900 text-white rounded-2xl shadow-2xl border border-white/10">
                                        <div class="flex items-center justify-between mb-3 border-b border-white/10 pb-2">
                                            <h3 class="text-pnp-gold font-black uppercase tracking-widest text-[10px]">Brgy. ${brgyName}</h3>
                                        </div>
                                        <div class="flex justify-between items-center">
                                            <span class="text-[9px] font-black uppercase text-white/70">Incidents</span>
                                            <span class="text-lg font-black text-pnp-gold">${crimeCounts[brgyName] || 0}</span>
                                        </div>
                                    </div>`, { className: 'intelligence-popup' });
                    }
                }).addTo(boundaryLinesLayer);
            })
            .catch(err => {
                console.error("Geospatial Intelligence Acquisition Failure:", err);
            });

        // Hide Loading
        const loading = document.getElementById('mapLoading');
        if (loading) {
            loading.classList.add('opacity-0');
            setTimeout(() => loading.classList.add('hidden'), 500);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        initMap();
        // Guard to prevent error if element is missing
        const dateInput = document.getElementById('incident_date');
        if (dateInput) {
            dateInput.valueAsDate = new Date();
        }
        
        // Initial render
        renderIncidentList(pointsData);
        renderSectorStats();

        // Default: Focus on Bagumbayan
        setTimeout(() => {
            monitorSector('Bagumbayan');
        }, 1000);
    });
</script>

