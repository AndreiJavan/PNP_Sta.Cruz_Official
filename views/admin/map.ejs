<% const safePoints=(typeof points !=='undefined' && points) ? points : []; // MASTER PALETTES const
    palettes={ '8-Focus' : { 'Theft' : '#FFE135' , 'Robbery' : '#D97706' , 'Murder' : '#FF0000' , 'Homicide' : '#EF4444'
    , 'Physical Injuries' : '#10B981' , 'Rape' : '#A855F7' , 'Carnapping (Motorcycle)' : '#F59E0B'
    , 'Carnapping (Motor Vehicle)' : '#F97316' , 'Violence Against Women and Children (VAWC)' : '#E11D48' , 'Cybercrime'
    : '#3B82F6' }, 'Non-Index' : { 'Estafa' : '#0891B2' , 'Swindling / Fraud' : '#06B6D4' , 'Drug Possession'
    : '#059669' , 'Drug Sale' : '#10B981' , 'Drug Use' : '#34D399' , 'Illegal Gambling' : '#7C3AED'
    , 'Illegal Possession of Firearms' : '#475569' , 'Human Trafficking' : '#DB2777' , 'Child Abuse (RA 7610)'
    : '#F43F5E' , 'Damage to Property' : '#B45309' , 'Malicious Mischief' : '#D97706'
    , 'Cybercrime (Online Fraud, Hacking, Identity Theft, Cyber Libel)' : '#2563EB' , 'Illegal Recruitment' : '#9333EA'
    , 'Ordinance Violations' : '#94A3B8' , 'Grave Threats' : '#64748B' , 'Alarm and Scandal' : '#CBD5E1' }, 'PSI' :
    { 'Vehicular Accident' : '#2563EB' , 'Road Accident / Traffic Incident' : '#1D4ED8' , 'Fire Incident' : '#EA580C'
    , 'Flood Incident' : '#3B82F6' , 'Earthquake Incident' : '#78350F' , 'Landslide Incident' : '#451A03'
    , 'Disaster Incident Reports' : '#4B5563' , 'Public Disturbance Incident' : '#4338CA'
    , 'Emergency Response Incident' : '#0891B2' , 'Missing Person Report' : '#0D9488' , 'Rescue Operation Cases'
    : '#059669' } }; const allColors={ ...palettes['8-Focus'], ...palettes['Non-Index'], ...palettes['PSI'] }; %>

    <div class="relative w-full h-[calc(100vh-80px)] overflow-hidden bg-slate-50 dark:bg-slate-950 p-6">
        <div class="flex flex-col lg:flex-row h-full gap-6">
            <!-- Unified Tactical Hub (Left) -->
            <div id="registryPanel"
                class="lg:w-[450px] bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-[2.5rem] shadow-2xl border border-white/20 dark:border-slate-700/50 overflow-hidden flex flex-col transition-all duration-500">
                <!-- Panel Header -->
                <div
                    class="p-6 border-b border-gray-100/50 dark:border-slate-800/50 bg-gradient-to-r from-pnp-blue/10 to-transparent">
                    <div class="flex items-center space-x-4 mb-6">
                        <div
                            class="w-12 h-12 bg-pnp-blue rounded-2xl flex items-center justify-center text-pnp-gold shadow-lg shadow-pnp-blue/20 border border-pnp-gold/20">
                            <i class="fas fa-shield-halved text-lg"></i>
                        </div>
                        <div>
                            <h2
                                class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.25em] text-sm leading-tight">
                                Tactical Command</h2>
                            <p
                                class="text-[10px] text-gray-500 dark:text-gray-400 font-bold uppercase tracking-widest mt-1">
                                S-SPS Unified Intelligence</p>
                        </div>
                    </div>

                    <!-- Category Filtering System -->
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-[10px] text-gray-400 uppercase tracking-[0.2em] font-black px-1">Primary
                                Intelligence Category</label>
                            <div class="relative group">
                                <i
                                    class="fas fa-filter absolute left-4 top-1/2 -translate-y-1/2 text-pnp-blue dark:text-pnp-gold z-10"></i>
                                <select id="categorySelector" onchange="switchCategory(this.value)"
                                    class="w-full pl-11 pr-4 py-4 bg-gray-100 dark:bg-slate-800 border-none rounded-2xl focus:ring-2 focus:ring-pnp-blue outline-none text-[11px] font-black dark:text-white appearance-none uppercase tracking-[0.15em] cursor-pointer hover:bg-gray-200 dark:hover:bg-slate-750 transition-all">
                                    <option value="8-Focus">8-Focus Crimes (Index)</option>
                                    <option value="Non-Index">Non-Index Crimes</option>
                                    <option value="PSI">PSI (Public Safety)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="registryContent" class="p-4 flex-grow overflow-y-auto custom-scrollbar">
                    <!-- Intelligence Legend -->
                    <div class="mb-4">
                        <div id="dynamicLegend"
                            class="grid grid-cols-2 gap-2 bg-gray-50 dark:bg-slate-800/50 p-4 rounded-3xl border border-gray-100 dark:border-slate-800 shadow-inner">
                            <!-- Legend items -->
                        </div>
                    </div>

                    <div id="registryContent" class="p-4 flex-grow overflow-y-auto custom-scrollbar">
                        <!-- Intelligence Legend -->
                        <div class="mb-4">
                            <div id="dynamicLegend"
                                class="grid grid-cols-2 gap-2 bg-gray-50 dark:bg-slate-800/50 p-4 rounded-3xl border border-gray-100 dark:border-slate-800 shadow-inner">
                                <!-- Legend items -->
                            </div>
                        </div>

                        <!-- Unified Tactical Command Stream -->
                        <div class="space-y-4">
                            <div class="flex items-center justify-between px-2">
                                <h3
                                    class="text-[11px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.2em] flex items-center">
                                    <i class="fas fa-tower-broadcast mr-2 text-[10px] animate-pulse"></i>
                                    <span>Tactical Command Stream</span>
                                </h3>
                                <span id="incidentCount"
                                    class="text-[9px] font-black text-slate-500 bg-gray-100 dark:bg-slate-800 px-2 py-0.5 rounded-full">REAL-TIME
                                    MONITORING</span>
                            </div>

                            <div id="unifiedRegistryBody" class="space-y-2">
                                <!-- Dynamic Intelligence Cards -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions Footer -->
                <div
                    class="p-6 border-t border-gray-100 dark:border-slate-800 bg-gray-50 dark:bg-slate-900/50 flex space-x-3">
                    <a href="/admin/reports"
                        class="flex-grow py-4 bg-pnp-blue text-white rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] transition-all flex items-center justify-center space-x-3 shadow-lg shadow-pnp-blue/20 hover:scale-[1.02] active:scale-95">
                        <i class="fas fa-plus"></i>
                        <span>Add Incident</span>
                    </a>
                    <button onclick="toggleMapExpansion()"
                        class="w-14 h-14 bg-white dark:bg-slate-800 text-pnp-blue dark:text-pnp-gold rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm hover:bg-gray-100 transition-all">
                        <i class="fas fa-expand"></i>
                    </button>
                </div>
            </div>

            <!-- Interactive Map (Right) -->
            <div id="mapWrapper"
                class="flex-grow h-full relative rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white dark:border-slate-800 transition-all duration-500 z-10">
                <div id="leafletMap" class="w-full h-full z-0 cursor-default"></div>

                <!-- Minimize Button -->
                <button id="minimizeMap" onclick="toggleMapExpansion(event)"
                    class="absolute top-6 right-6 z-[10001] w-12 h-12 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-2xl shadow-2xl flex items-center justify-center text-pnp-blue dark:text-pnp-gold hover:scale-110 transition-all hidden">
                    <i class="fas fa-compress-alt"></i>
                </button>

                <!-- Map Floating Controls -->
                <div class="absolute bottom-6 right-6 z-[1000] flex flex-col space-y-2">
                    <div
                        class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-md p-2 rounded-2xl shadow-2xl border border-white/20 dark:border-slate-700 flex flex-col space-y-1">
                        <button onclick="map.zoomIn()"
                            class="w-10 h-10 rounded-xl hover:bg-pnp-blue hover:text-white transition-all text-pnp-blue dark:text-pnp-gold"><i
                                class="fas fa-plus"></i></button>
                        <button onclick="map.zoomOut()"
                            class="w-10 h-10 rounded-xl hover:bg-pnp-blue hover:text-white transition-all text-pnp-blue dark:text-pnp-gold"><i
                                class="fas fa-minus"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Map Loading Layer -->
        <div id="mapLoading"
            class="absolute inset-0 bg-slate-950 z-[12000] flex flex-col items-center justify-center text-white transition-opacity duration-700 pointer-events-none">
            <div class="relative w-24 h-24 mb-6">
                <div class="absolute inset-0 border-4 border-pnp-gold/20 rounded-full"></div>
                <div class="absolute inset-0 border-4 border-pnp-gold border-t-transparent rounded-full animate-spin">
                </div>
                <div class="absolute inset-4 bg-pnp-blue rounded-full flex items-center justify-center">
                    <i class="fas fa-shield-halved text-xl text-pnp-gold animate-pulse"></i>
                </div>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.4em] text-pnp-gold animate-pulse">Initializing
                Command Center Grid</p>
        </div>
    </div>

    <script>
        let map;
        let incidentLayer = L.layerGroup();
        let barangayLayer;
        let masterBorderLayer;
        let activeCategory = '8-Focus';

        const pointsData = <% - JSON.stringify(safePoints) %>;
        const palettes = <% - JSON.stringify(palettes) %>;
        const allColors = <% - JSON.stringify(allColors) %>;
        const barangayGeoJsonUrl = '/data/santa_cruz_boundaries.json';

        const manualPins = [
            { name: 'Alipit', lat: 14.223931, lng: 121.405213 }, { name: 'Bagumbayan', lat: 14.268334, lng: 121.398454 },
            { name: 'Duhat', lat: 14.2525, lng: 121.3825 }, { name: 'Bubukal', lat: 14.256460, lng: 121.399183 },
            { name: 'Calios', lat: 14.2750, lng: 121.4050 }, { name: 'Gatid', lat: 14.2600, lng: 121.3830 },
            { name: 'Jasaan', lat: 14.223577, lng: 121.394827 }, { name: 'Labuin', lat: 14.250158, lng: 121.400664 },
            { name: 'Malinao', lat: 14.232833, lng: 121.396823 }, { name: 'Oogong', lat: 14.226323, lng: 121.400621 },
            { name: 'Pagsawitan', lat: 14.265754, lng: 121.426545 }, { name: 'Palasan', lat: 14.257498, lng: 121.418992 },
            { name: 'Patimbao', lat: 14.270081, lng: 121.418366 }, { name: 'Poblacion I (Barangay I)', lat: 14.277068, lng: 121.418881 },
            { name: 'Poblacion II (Barangay II)', lat: 14.279647, lng: 121.416006 }, { name: 'Poblacion III (Barangay III)', lat: 14.282028, lng: 121.415159 },
            { name: 'Poblacion IV (Barangay IV)', lat: 14.283790, lng: 121.414016 }, { name: 'Poblacion V (Barangay V)', lat: 14.285282, lng: 121.412476 },
            { name: 'San Jose', lat: 14.237118, lng: 121.403754 }, { name: 'San Juan', lat: 14.243815, lng: 121.406972 },
            { name: 'San Pablo Norte', lat: 14.290210, lng: 121.413023 }, { name: 'San Pablo Sur', lat: 14.282211, lng: 121.422261 },
            { name: 'Santisima Cruz', lat: 14.290647, lng: 121.409140 }, { name: 'Santo Angel Central', lat: 14.285137, lng: 121.408947 },
            { name: 'Santo Angel Norte', lat: 14.288547, lng: 121.406307 }, { name: 'Santo Angel Sur', lat: 14.282329, lng: 121.410985 }
        ];

        // --- LOGIC FUNCTIONS ---

        function switchCategory(cat) {
            activeCategory = cat;
            updateVisualization();
        }

        // --- HELPERS ---
        function getTacticalColor(name) {
            if (!name) return '#ccc';
            const searchName = name.trim().toUpperCase();

            const palette = palettes[activeCategory];
            if (!palette) return '#ccc';

            for (const [key, color] of Object.entries(palette)) {
                if (key.toUpperCase() === searchName) return color;
            }

            for (const [key, color] of Object.entries(palette)) {
                if (searchName.includes(key.toUpperCase()) || key.toUpperCase().includes(searchName)) return color;
            }

            return '#ccc';
        }

        function updateVisualization() {
            // 1. Update Legend
            const legend = document.getElementById('dynamicLegend');
            const currentPalette = palettes[activeCategory];
            legend.innerHTML = Object.entries(currentPalette).map(([name, color]) => `
            <div class="flex items-center space-x-3 px-1">
                <div class="w-3 h-3 rounded-full shadow-md shrink-0" style="background-color: ${color}"></div>
                <span class="text-[9px] font-black uppercase tracking-tight text-slate-700 dark:text-slate-200 truncate">${name}</span>
            </div>
        `).join('');

            // 2. Update Map Layers
            incidentLayer.clearLayers();
            const filteredPoints = pointsData.filter(p => p.category === activeCategory);

            // 3. Update Markers
            filteredPoints.forEach(p => {
                const pin = manualPins.find(m => m.name === p.barangay);
                if (!pin) return;
                const lat = pin.lat + (Math.random() - 0.5) * 0.003;
                const lng = pin.lng + (Math.random() - 0.5) * 0.003;
                const color = getTacticalColor(p.incident_type);

                L.circleMarker([lat, lng], {
                    radius: 6, fillColor: color, color: '#fff', weight: 1.5, opacity: 1, fillOpacity: 0.9
                }).addTo(incidentLayer).bindPopup(`
                <div class="p-3 bg-slate-950 text-white rounded-2xl border border-white/10 min-w-[200px]">
                    <div class="flex items-center space-x-2 mb-2 pb-2 border-b border-white/5">
                         <div class="w-2 h-2 rounded-full" style="background-color: ${color}"></div>
                         <span class="text-[9px] font-black uppercase tracking-widest">${p.incident_type}</span>
                    </div>
                    <p class="text-[10px] font-bold mb-2">BRGY. ${p.barangay}</p>
                    <p class="text-[8px] text-white/50 italic">"${p.description || 'Verified tactical point'}"</p>
                </div>
            `, { className: 'intelligence-popup' });
            });

            // 4. Render Unified Registry
            renderUnifiedRegistry(filteredPoints);

            // 5. Update Heatmap
            if (barangayLayer) {
                barangayLayer.eachLayer(layer => {
                    if (layer.feature) {
                        layer.setStyle(getThematicStyleForFeature(layer.feature));
                    }
                });
            }
        }

        function renderUnifiedRegistry(filteredPoints) {
            const body = document.getElementById('unifiedRegistryBody');
            const count = document.getElementById('incidentCount');
            count.textContent = `${filteredPoints.length} TOTAL REPORTS`;

            // Group by barangay
            const registry = {};
            manualPins.forEach(p => {
                registry[p.name] = { dominant: 'Clear', color: '#ccc', count: 0, latest: '-', latestDate: '-' };
            });

            filteredPoints.forEach(p => {
                if (!registry[p.barangay]) return;
                registry[p.barangay].count++;
                const pDate = new Date(p.incident_date);
                if (registry[p.barangay].latestDate === '-' || pDate > new Date(registry[p.barangay].latestDate)) {
                    registry[p.barangay].latest = p.incident_type;
                    registry[p.barangay].latestDate = p.incident_date;
                }
            });

            Object.keys(registry).forEach(brgy => {
                const brgyPoints = filteredPoints.filter(p => p.barangay === brgy);
                if (brgyPoints.length > 0) {
                    const stats = {};
                    brgyPoints.forEach(p => { stats[p.incident_type] = (stats[p.incident_type] || 0) + 1; });
                    const top = Object.entries(stats).sort((a, b) => b[1] - a[1])[0];
                    registry[brgy].dominant = top[0];
                    registry[brgy].color = getTacticalColor(top[0]);
                }
            });

            body.innerHTML = Object.entries(registry)
                .sort((a, b) => b[1].count - a[1].count) // Sort by activity
                .map(([brgy, data]) => {
                    const pin = manualPins.find(m => m.name === brgy);
                    const hasActivity = data.count > 0;

                    return `
                    <div onclick="map.flyTo([${pin.lat}, ${pin.lng}], 17)" 
                         class="group p-4 bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-800 rounded-[2rem] hover:bg-pnp-blue/5 dark:hover:bg-slate-800/80 transition-all cursor-pointer shadow-sm hover:shadow-md">
                        
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <h4 class="text-[10px] font-black text-slate-800 dark:text-white uppercase tracking-wider group-hover:text-pnp-blue transition">
                                    ${brgy.replace('Poblacion ', 'POB. ')}
                                </h4>
                                <div class="flex items-center space-x-2 mt-1">
                                    <div class="w-2 h-2 rounded-full" style="background-color: ${data.color}"></div>
                                    <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest">${data.dominant}</span>
                                </div>
                            </div>
                            <div class="bg-gray-50 dark:bg-slate-800 px-3 py-1.5 rounded-xl border border-gray-100 dark:border-slate-700">
                                <span class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold">${data.count}</span>
                            </div>
                        </div>

                        ${hasActivity ? `
                        <div class="pt-3 border-t border-gray-50 dark:border-slate-800 flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="text-[7px] font-black text-slate-400 uppercase tracking-[0.2em] mb-0.5">Live Intelligence Pulse</span>
                                <span class="text-[9px] font-black text-slate-600 dark:text-slate-300 uppercase truncate max-w-[150px]">
                                    ${data.latest}
                                </span>
                            </div>
                            <div class="text-right">
                                <span class="text-[8px] font-black text-pnp-blue dark:text-pnp-gold bg-pnp-blue/10 px-2 py-1 rounded-lg uppercase">
                                    ${new Date(data.latestDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                                </span>
                            </div>
                        </div>
                        ` : `
                        <div class="pt-3 border-t border-gray-50 dark:border-slate-800 text-[8px] font-black text-slate-300 uppercase tracking-widest italic">
                            Sector Clear • Zero Reports
                        </div>
                        `}
                    </div>
                `;
                }).join('');
        }

        function getThematicStyleForFeature(feature) {
            const normalizeBrgyName = (name) => {
                const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
                if (match) return `Poblacion ${match[1]} (Barangay ${match[1]})`;
                return name;
            };
            const brgyName = normalizeBrgyName(feature.properties.ADM4_EN);
            const brgyPoints = pointsData.filter(p => p.barangay === brgyName && p.category === activeCategory);

            let fillColor = 'transparent';
            let weight = 1;
            let fillOpacity = 0;

            if (brgyPoints.length > 0) {
                const stats = {};
                brgyPoints.forEach(p => { stats[p.incident_type] = (stats[p.incident_type] || 0) + 1; });
                const topCrime = Object.entries(stats).sort((a, b) => b[1] - a[1])[0];
                fillColor = getTacticalColor(topCrime[0]);
                fillOpacity = 0.6;
                weight = 2;
            } else {
                weight = 1;
                fillOpacity = 0.05;
                fillColor = 'rgba(15, 23, 42, 0.5)';
            }
            return { color: '#C8A415', weight: weight, fillOpacity: fillOpacity, fillColor: fillColor };
        }


        function initMap() {
            const bounds = L.latLngBounds(L.latLng(14.18, 121.30), L.latLng(14.33, 121.47));
            map = L.map('leafletMap', { zoomControl: false, maxBounds: bounds, minZoom: 13 }).fitBounds(bounds);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
            incidentLayer.addTo(map);

            fetch(barangayGeoJsonUrl)
                .then(r => r.json())
                .then(data => {
                    barangayLayer = L.geoJSON(data, {
                        style: { fillOpacity: 0, weight: 1, color: '#C8A415' },
                        onEachFeature: (f, l) => {
                            l.on('mouseover', (e) => { e.target.setStyle({ weight: 4, color: '#FFFFFF' }); e.target.bringToFront(); });
                            l.on('mouseout', (e) => { e.target.setStyle(getThematicStyleForFeature(f)); });
                            l.on('click', (e) => {
                                const normalizeBrgyName = (name) => {
                                    const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
                                    if (match) return `Poblacion ${match[1]} (Barangay ${match[1]})`;
                                    return name;
                                };
                                const brgyName = normalizeBrgyName(f.properties.ADM4_EN);
                                const pin = manualPins.find(m => m.name === brgyName);
                                if (pin) {
                                    map.flyTo([pin.lat, pin.lng], 17);
                                }
                            });
                        }
                    }).addTo(map);
                    updateVisualization();
                });

            document.getElementById('mapLoading').classList.add('opacity-0');
            setTimeout(() => document.getElementById('mapLoading').remove(), 700);
        }

        window.toggleMapExpansion = function () {
            const wrapper = document.getElementById('mapWrapper');
            const minimizeBtn = document.getElementById('minimizeMap');
            const isExpanded = wrapper.classList.toggle('map-expanded');
            minimizeBtn.classList.toggle('hidden', !isExpanded);
            document.body.style.overflow = isExpanded ? 'hidden' : '';
            setTimeout(() => map.invalidateSize(), 600);
        };

        document.addEventListener('DOMContentLoaded', initMap);
    </script>

    <style>
        .intelligence-popup .leaflet-popup-content-wrapper {
            background: transparent !important;
            box-shadow: none !important;
            padding: 0 !important;
        }

        .intelligence-popup .leaflet-popup-tip {
            background: #0f172a !important;
        }

        .map-expanded {
            position: fixed !important;
            inset: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            z-index: 9999 !important;
            margin: 0 !important;
            border-radius: 0 !important;
            border: none !important;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(200, 164, 21, 0.2);
            border-radius: 10px;
        }
    </style>