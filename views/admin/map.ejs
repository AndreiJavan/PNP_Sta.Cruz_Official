    function getBarangayLabel(name, zoom) {
        const pobMatch = name.match(/Poblacion (I{1,3}|IV|V)/);
        if (pobMatch) {
            const romanToNum = { 'I': '1', 'II': '2', 'III': '3', 'IV': '4', 'V': '5' };
            const num = romanToNum[pobMatch[1]];
            if (zoom < 16) {
                return `POB. ${num}`;
            } else {
                return name.replace('Poblacion', 'POB.').replace(' (Barangay ', '\n(BRGY. ').replace(')', '');
            }
        }
        return name.replace('Poblacion', 'POB.').replace(' (Barangay ', '\n(BRGY. ').replace(')', '');
    }

    function getTacticalColor(name) {
        if (!name) return '#ccc';
        const searchName = name.trim().toUpperCase();
        for (const [key, color] of Object.entries(allColors)) {
            if (key.toUpperCase() === searchName) return color;
        }
        for (const [key, color] of Object.entries(allColors)) {
            if (searchName.includes(key.toUpperCase()) || key.toUpperCase().includes(searchName)) return color;
        }
        return '#ccc';
    }

