    function initMap() {
        try {
            // Shifted bounds slightly north and west to center Sta. Cruz
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];

            map = L.map('leafletMap', {
                zoomControl: false,
                dragging: false,
                touchZoom: false,
                doubleClickZoom: false,
                scrollWheelZoom: false,
                boxZoom: false,
                keyboard: false,
                attributionControl: false,
                minZoom: 13,
                maxZoom: 18,
                maxBounds: bounds,
                maxBoundsViscosity: 1.0
            }).fitBounds(bounds);

            window.map = map;

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
            }).addTo(map);

            // Initialize incident markers layer
            incidentMarkers.addTo(map);
            selectedPinsLayer.addTo(map);
            policeStationsLayer.addTo(map);
            // Initial markers are now handled dynamically by GeoJSON load to ensure precision
            // addManualPins();
            loadMapPoints();
            addPoliceStations();

            // Track mouse movement for live coordinates
            /* 
            // Removing live mouse coord tracking to avoid clutter, will use click instead
            map.on('mousemove', (e) => {
                document.getElementById('liveLat').textContent = e.latlng.lat.toFixed(6);
                document.getElementById('liveLng').textContent = e.latlng.lng.toFixed(6);
            });
            */



            // Hide loading as soon as map is initialized
            hideLoading();

            // Load Barangay GeoJSON
            fetch(barangayGeoJsonUrl)
                .then(res => {
                    if (!res.ok) throw new Error('Network response was not ok');
                    return res.json();
                })
                .then(data => {
                    santaCruzGeoJSON = data;

                    // --- APPLY INVERTED MASK TO HIDE OUTSIDE MUNICIPALITIES ---
                    const worldRing = [[180, 90], [180, -90], [-180, -90], [-180, 90], [180, 90]];
                    let maskCoords = [worldRing];
                    data.features.forEach(f => {
                        if (f.geometry && f.geometry.type === 'Polygon') {
                            maskCoords.push(f.geometry.coordinates[0]);
                        } else if (f.geometry && f.geometry.type === 'MultiPolygon') {
                            f.geometry.coordinates.forEach(poly => maskCoords.push(poly[0]));
                        }
                    });
                    
                    const isDark = document.documentElement.classList.contains('dark');
                    L.geoJSON({ type: 'Feature', geometry: { type: 'Polygon', coordinates: maskCoords } }, {
                        style: {
                            fillColor: isDark ? '#0f172a' : '#f8fafc',
                            fillOpacity: 1, // Completely opaque!
                            color: 'transparent',
                            weight: 0,
                            className: 'map-outside-mask-solid'
                        }, interactive: false
                    }).addTo(map);

                    const observer = new MutationObserver(() => {
                        const dark = document.documentElement.classList.contains('dark');
                        document.querySelectorAll('.map-outside-mask-solid').forEach(el => el.setAttribute('fill', dark ? '#0f172a' : '#f8fafc'));
                    });
                    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
                    // ---------------------------------------------------------

                    boundaryLayerGroup = L.geoJSON(data, {
                        style: function (feature) {
                            return getThematicStyleForFeature(feature);
                        },
                        onEachFeature: function (feature, layer) {
                            let name = feature.properties.ADM4_EN;
                            // Helper to normalize Poblacion names to match manualPins
                            const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
                            if (match) {
                                name = `Poblacion ${match[1]} (Barangay ${match[1]})`;
                            }

                            const displayName = getBarangayLabel(name, map.getZoom());

                            layer.bindTooltip(displayName, {
                                permanent: true,
                                direction: 'center',
                                className: 'barangay-label-tooltip',
                                opacity: 1,
                                interactive: false
                            });

                            layer.on({
                                mouseover: function (e) {
                                    const layer = e.target;
                                    layer.setStyle({
                                        fillOpacity: 0.8,
                                        weight: 3,
                                        color: '#FFFFFF'
                                    });
                                },
                                mouseout: function (e) {
                                    const layer = e.target;
                                    layer.setStyle(getThematicStyleForFeature(feature));
                                },
                                click: function (e) {
                                    if (map) {
                                        map.dragging.enable();
                                        map.touchZoom.enable();
                                        map.doubleClickZoom.enable();
                                        map.scrollWheelZoom.enable();
                                        map.boxZoom.enable();
                                        map.keyboard.enable();
                                    }
                                    const barangaySelect = document.getElementById('filterBarangay');
                                    if (barangaySelect) {
                                        barangaySelect.value = name;
                                        loadMapPoints(false); // Update stats without relocating yet
                                        locateBarangay(); // Now do the fancy locate animation
                                    }
                                }
                            });

                            // Add marker for each barangay at true geographic center
                            try {
                                const centroid = layer.getBounds().getCenter();

                                // Update dynamic reference for search/locate system
                                const pinIndex = manualPins.findIndex(p => p.name.toLowerCase() === name.toLowerCase());
                                if (pinIndex !== -1) {
                                    manualPins[pinIndex].lat = centroid.lat;
                                    manualPins[pinIndex].lng = centroid.lng;
                                }
                            } catch (err) {
                                console.error('Error adding accurate marker for barangay:', name, err);
                            }
                        }
                    }).addTo(map);
                    setTimeout(manageTooltipVisibility, 100);
                })
                .catch(err => {
                    console.error('Error loading GeoJSON:', err);
                });

            map.on('zoomend', () => {
                updateBarangayLabels();
                setTimeout(manageTooltipVisibility, 50);
            });
            map.on('resize', () => setTimeout(manageTooltipVisibility, 50));
        } catch (err) {
            console.error('Error initializing map:', err);
            hideLoading();
        }
    }


    function toggleMapSidebar() {
        const sidebar = document.getElementById('filterSidebar');
        const toggleBtn = document.getElementById('mapSidebarToggle');

        if (sidebar.classList.contains('sidebar-hidden')) {
            sidebar.classList.remove('sidebar-hidden');
            sidebar.classList.add('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.add('opacity-0', 'pointer-events-none');

            // Re-render data when sidebar opens
            loadMapPoints(false);
        } else {
            sidebar.classList.add('sidebar-hidden');
            sidebar.classList.remove('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.remove('opacity-0', 'pointer-events-none');
        }

        // Prevent rendering errors (grey tiles) and keep map static
        setTimeout(() => {
            if (window.map) {
                window.map.invalidateSize({ pan: false });
            }
        }, 350);
    }

    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const barangayParam = urlParams.get('barangay');
        targetHighlightBarangay = barangayParam;
        const offenseParam = urlParams.get('offense');
        const latParam = parseFloat(urlParams.get('lat'));
        const lngParam = parseFloat(urlParams.get('lng'));

        if (barangayParam) {
            const barangaySelect = document.getElementById('filterBarangay');
            if (barangaySelect) {
                const options = Array.from(barangaySelect.options);
                const exactMatch = options.find(opt => opt.value.toLowerCase() === barangayParam.toLowerCase());
                if (exactMatch) {
                    barangaySelect.value = exactMatch.value;
                }
            }
        }

        // Prefill default custom range picker dates
        const currentYear = new Date().getFullYear();
        const fromDateInput = document.getElementById('filterFromDate');
        const toDateInput = document.getElementById('filterToDate');
        const todayStr = new Date().toISOString().split('T')[0];
        if (fromDateInput) {
            fromDateInput.value = `${currentYear}-01-01`;
            fromDateInput.setAttribute('max', todayStr);
        }
        if (toDateInput) {
            toDateInput.value = todayStr;
            toDateInput.setAttribute('max', todayStr);
        }

        // Initialize display badge text
        updateActivePeriodDisplay();

        initMap();

        if (!isNaN(latParam) && !isNaN(lngParam) && latParam !== 0 && lngParam !== 0) {
            setTimeout(() => {
                if (window.map) {
                    window.map.flyTo([latParam, lngParam], 16, { duration: 1.5 });
                    
                    const highlightPulse = L.divIcon({
                        className: 'crime-highlight-marker',
                        html: `
                            <div class="relative flex items-center justify-center">
                                <div class="absolute w-12 h-12 bg-red-500/50 rounded-full animate-ping"></div>
                                <div class="w-8 h-8 bg-red-600 rounded-full border-2 border-white flex items-center justify-center text-white shadow-2xl z-10">
                                    <i class="fas fa-bullseye text-xs"></i>
                                </div>
                            </div>
                        `,
                        iconSize: [32, 32],
                        iconAnchor: [16, 16]
                    });

                    const popupContent = `
                        <div class="p-3 text-center min-w-[140px]">
                            <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase bg-red-500 text-white tracking-widest inline-block">${offenseParam || 'CRIME INCIDENT'}</span>
                            <p class="text-xs font-black text-slate-800 dark:text-white mt-2 uppercase">BRGY. ${barangayParam || 'LOCATION'}</p>
                            <p class="text-[10px] text-slate-400 font-mono mt-1">${latParam.toFixed(4)}, ${lngParam.toFixed(4)}</p>
                        </div>
                    `;

                    highlightMarker = L.marker([latParam, lngParam], { icon: highlightPulse }).addTo(window.map).bindPopup(popupContent).openPopup();
                    updateHighlightMarkerVisibility();
                }
            }, 1000);
        }

        // Robust event listeners for all map filters
        const setupListener = (id, callback) => {
            const el = document.getElementById(id);
            if (el) {
                el.addEventListener('change', callback);
                el.addEventListener('input', callback); // Catch changes faster in some browsers
            }
        };

        setupListener('mapDisplayMode', () => {
            updateHeatmap();
            updateLegend();
            updateSidebarStats();
        });

        setupListener('filterBarangay', () => loadMapPoints());
    });
</script>

