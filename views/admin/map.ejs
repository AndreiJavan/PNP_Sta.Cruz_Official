<% 
const colors = {
    'Theft': '#dc2626',
    'Vandalism': '#f97316',
    'Assault': '#7f1d1d',
    'Suspicious Activity': '#eab308',
    'Robbery': '#9333ea',
    'Other': '#6b7280'
};
%>
<div class="relative w-full h-full min-h-[calc(100vh-80px)] overflow-hidden">
    <!-- Map Area (Full Coverage) -->
    <div id="leafletMap" class="absolute inset-0 z-0"></div>

    <!-- Map Loading Layer -->
    <div id="mapLoading" class="absolute inset-0 bg-slate-900 z-[1200] flex flex-col items-center justify-center text-white transition-opacity duration-500">
        <div class="w-16 h-16 border-4 border-pnp-gold border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-[8px] font-black uppercase tracking-[0.3em] animate-pulse">Synchronizing Tactical Intelligence...</p>
    </div>

    <!-- Floating Add Crime Form (Top Right) -->
    <div id="registryPanel" class="absolute top-6 right-6 z-[1000] w-80 bg-white/95 dark:bg-slate-800/95 backdrop-blur-md rounded-3xl shadow-2xl border border-white/20 dark:border-slate-700/50 overflow-hidden transform transition-all duration-500 hover:scale-[1.01]">
        <div class="p-5 border-b border-gray-100/50 dark:border-slate-700/50 bg-gray-50/30 dark:bg-slate-900/10 flex justify-between items-center cursor-pointer" onclick="toggleRegistry()">
            <div class="flex flex-col">
                <h2 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.25em] text-[10px]">Crime Registry</h2>
                <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest mt-0.5">S-SPS Intelligence Unit</p>
            </div>
            <div class="flex items-center space-x-3">
                <div class="flex items-center -space-x-1">
                    <span class="w-1.5 h-1.5 bg-pnp-gold rounded-full animate-pulse"></span>
                    <span class="w-1.5 h-1.5 bg-pnp-gold/40 rounded-full"></span>
                </div>
                <i id="registryToggleIcon" class="fas fa-chevron-down text-pnp-blue/30 transition-transform duration-500 text-[10px]"></i>
            </div>
        </div>
        
        <div id="registryContent" class="p-6 transition-all duration-500 overflow-y-auto max-h-[calc(100vh-180px)] custom-scrollbar">
            <div class="space-y-5">
                <!-- Map Tools -->
                <div class="grid grid-cols-2 gap-3 mb-6">
                    <button onclick="zoomToMunicipal()" class="p-3 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-700 hover:bg-white dark:hover:bg-slate-800 transition-all group">
                        <i class="fas fa-expand-arrows-alt text-pnp-blue dark:text-pnp-gold text-xs block mb-1 group-hover:scale-110 transition"></i>
                        <span class="text-[8px] font-black text-gray-400 uppercase tracking-widest">Reset View</span>
                    </button>
                    <button onclick="toggleChoropleth()" id="choroplethToggle" class="p-3 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-700 hover:bg-white dark:hover:bg-slate-800 transition-all group">
                        <i class="fas fa-layer-group text-pnp-blue dark:text-pnp-gold text-xs block mb-1 group-hover:scale-110 transition"></i>
                        <span class="text-[8px] font-black text-gray-400 uppercase tracking-widest">Density Map</span>
                    </button>
                </div>

                <form action="/admin/map/add" method="POST" class="space-y-4" id="addCrimeForm">
                    <div class="space-y-1">
                        <label for="barangay" class="text-[9px] text-gray-400 uppercase tracking-widest font-black">Barangay Sector</label>
                        <select name="barangay" id="barangay" required class="w-full px-3 py-2.5 bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold dark:text-white appearance-none">
                            <option value="">Select Sector</option>
                            <% ["Alipit", "Bagumbayan", "Bubukal", "Calios", "Duhat", "Gatid", "Jasaan", "Labuin", "Malinao", "Oogong", "Pagsawitan", "Palasan", "Patimbao", "Poblacion I (Barangay I)", "Poblacion II (Barangay II)", "Poblacion III (Barangay III)", "Poblacion IV (Barangay IV)", "Poblacion V (Barangay V)", "San Jose", "San Juan", "San Pablo Norte", "San Pablo Sur", "Santisima Cruz", "Santo Angel Central", "Santo Angel Norte", "Santo Angel Sur"].forEach(brgy => { %>
                                <option value="<%= brgy %>"><%= brgy %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div class="space-y-1">
                            <label for="incident_type" class="text-[9px] text-gray-400 uppercase tracking-widest font-black">Type</label>
                            <select name="incident_type" id="incident_type" required class="w-full px-3 py-2.5 bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold dark:text-white appearance-none">
                                <option value="Theft">Theft</option>
                                <option value="Robbery">Robbery</option>
                                <option value="Assault">Assault</option>
                                <option value="Vandalism">Vandalism</option>
                                <option value="Suspicious Activity">Suspicious Activity</option>
                                <option value="Murder">Murder</option>
                                <option value="Homicide">Homicide</option>
                                <option value="Rape">Rape</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label for="incident_date" class="text-[9px] text-gray-400 uppercase tracking-widest font-black">Date</label>
                            <input type="date" name="incident_date" id="incident_date" required class="w-full px-3 py-2 bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-xs font-bold dark:text-white">
                        </div>
                    </div>

                    <div class="space-y-1">
                        <label for="description" class="text-[9px] text-gray-400 uppercase tracking-widest font-black">Intel Brief</label>
                        <textarea name="description" id="description" rows="2" placeholder="Tactical notes..." class="w-full px-3 py-2 bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-pnp-blue outline-none text-[10px] font-bold dark:text-white resize-none"></textarea>
                    </div>

                    <button type="submit" class="w-full py-4 bg-pnp-blue hover:bg-black text-white rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] shadow-xl shadow-pnp-blue/20 transition-all flex items-center justify-center space-x-2 group">
                        <i class="fas fa-shield-halved group-hover:scale-110 transition"></i>
                        <span>Transmit Intelligence</span>
                    </button>
                </form>

                <div class="pt-6 border-t border-gray-100 dark:border-slate-700/50">
                    <h4 class="text-[9px] text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-[0.2em] mb-4 flex items-center">
                        <i class="fas fa-list-ul mr-2 text-[8px]"></i> Recent Activity Log
                    </h4>
                    <div class="space-y-3 max-h-64 overflow-y-auto pr-2 custom-scrollbar" id="recentActivityList">
                        <% points.sort((a,b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()).slice(0, 15).forEach(point => { %>
                            <div onclick="focusPoint('<%= point.barangay %>', '<%= point.incident_type %>')" class="p-3 bg-gray-50 dark:bg-slate-900/50 rounded-2xl border border-transparent hover:border-pnp-gold/30 cursor-pointer transition-all group">
                                <div class="flex justify-between items-start mb-1">
                                    <span class="text-[9px] font-black text-slate-700 dark:text-slate-200 uppercase group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition"><%= point.incident_type %></span>
                                    <span class="text-[8px] font-bold text-slate-400"><%= new Date(point.incident_date).toLocaleDateString(undefined, {month:'short', day:'numeric'}) %></span>
                                </div>
                                <div class="flex items-center text-[8px] font-bold text-slate-500 uppercase">
                                    <i class="fas fa-location-dot mr-1 text-[7px]"></i> <%= point.barangay %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
            </div>
        </div>
    </div>
</div>

<script>
    let map;
    let santaCruzGeoJSON;
    let pinLayer = L.layerGroup();
    let incidentLayer = L.layerGroup();
    let choroplethLayer = L.layerGroup();
    let boundaryLayer;
    let glowLayer;

    const barangayGeoJsonUrl = 'https://raw.githubusercontent.com/faeldon/philippines-json-maps/master/2019/geojson/barangay/philippines-barangay-043424000.json';
    const colors = <%- JSON.stringify(colors) %>;
    const pointsData = <%- JSON.stringify(points) %>;

    // Map Toggle Logic
    window.toggleRegistry = function() {
        const body = document.getElementById('registryBody');
        const icon = document.getElementById('registryToggleIcon');
        if (body.style.maxHeight === '0px') {
            body.style.maxHeight = '1000px';
            icon.style.transform = 'rotate(0deg)';
        } else {
            body.style.maxHeight = '0px';
            icon.style.transform = 'rotate(180deg)';
        }
    };

    window.toggleChoropleth = function() {
        const btn = document.getElementById('choroplethToggle');
        if (map.hasLayer(choroplethLayer)) {
            map.removeLayer(choroplethLayer);
            btn.classList.remove('bg-pnp-blue', 'text-white');
            btn.classList.add('bg-gray-50', 'dark:bg-slate-900', 'text-gray-700', 'dark:text-gray-300');
        } else {
            map.addLayer(choroplethLayer);
            btn.classList.add('bg-pnp-blue', 'text-white');
            btn.classList.remove('bg-gray-50', 'dark:bg-slate-900', 'text-gray-700', 'dark:text-gray-300');
        }
    };

    window.zoomToMunicipal = function() {
        const bounds = [[14.1800, 121.3200], [14.3300, 121.4950]];
        map.flyToBounds(bounds, { animate: true, duration: 1.5 });
    };

    window.focusPoint = function(barangay, type) {
        const pin = manualPins.find(p => p.name === barangay);
        if (pin) {
            map.flyTo([pin.lat, pin.lng], 17);
            // Optionally open popup
            incidentLayer.eachLayer(layer => {
                const popup = layer.getPopup();
                if (popup && popup.getContent().includes(`Brgy. ${barangay}`) && popup.getContent().includes(type)) {
                    layer.openPopup();
                }
            });
        }
    };

    async function loadMunicipalBoundary() {
        try {
            const response = await fetch('https://nominatim.openstreetmap.org/search?format=json&q=Santa+Cruz,+Laguna,+Philippines&polygon_geojson=1&limit=5');
            const data = await response.json();
            const boundary = data.find(item => item.osm_type === 'relation' && item.geojson);

            if (boundary && boundary.geojson) {
                const updateStyles = () => {
                    const zoom = map.getZoom();
                    const baseWeight = zoom < 14 ? 10 : (zoom < 16 ? 18 : 30);
                    const glowWeight = baseWeight * 1.8;

                    if (glowLayer) glowLayer.setStyle({ weight: glowWeight });
                    if (boundaryLayer) boundaryLayer.setStyle({ weight: baseWeight });
                };

                glowLayer = L.geoJSON(boundary.geojson, {
                    style: {
                        color: "#000000",
                        weight: 25,
                        opacity: 0.2,
                        fillColor: "transparent",
                        interactive: false
                    }
                }).addTo(map);

                boundaryLayer = L.geoJSON(boundary.geojson, {
                    style: {
                        color: "#000000",
                        weight: 12,
                        opacity: 0.9,
                        fillColor: "rgba(0,0,0,0.05)",
                        fillOpacity: 0.1,
                        interactive: false
                    }
                }).addTo(map);

                map.on('zoomend', updateStyles);
                updateStyles();
            }
        } catch (err) {
            console.error("Error loading municipal boundary:", err);
        }
    }

    function calculateTopIncidents() {
        // Simplified for Admin Map integration
    }

    window.manualPins = [
        { name: 'Alipit', lat: 14.223931, lng: 121.405213 },
        { name: 'Bagumbayan', lat: 14.268334, lng: 121.398454 },
        { name: 'Duhat', lat: 14.2525, lng: 121.3825 },
        { name: 'Bubukal', lat: 14.256460, lng: 121.399183 },
        { name: 'Calios', lat: 14.2750, lng: 121.4050 },
        { name: 'Gatid', lat: 14.2600, lng: 121.3830 },
        { name: 'Jasaan', lat: 14.223577, lng: 121.394827 },
        { name: 'Labuin', lat: 14.250158, lng: 121.400664 },
        { name: 'Malinao', lat: 14.232833, lng: 121.396823 },
        { name: 'Oogong', lat: 14.226323, lng: 121.400621 },
        { name: 'Pagsawitan', lat: 14.265754, lng: 121.426545 },
        { name: 'Palasan', lat: 14.257498, lng: 121.418992 },
        { name: 'Patimbao', lat: 14.270081, lng: 121.418366 },
        { name: 'Poblacion I (Barangay I)', lat: 14.277068, lng: 121.418881 },
        { name: 'Poblacion II (Barangay II)', lat: 14.279647, lng: 121.416006 },
        { name: 'Poblacion III (Barangay III)', lat: 14.282028, lng: 121.415159 },
        { name: 'Poblacion IV (Barangay IV)', lat: 14.283790, lng: 121.414016 },
        { name: 'Poblacion V (Barangay V)', lat: 14.285282, lng: 121.412476 },
        { name: 'San Jose', lat: 14.237118, lng: 121.403754 },
        { name: 'San Juan', lat: 14.243815, lng: 121.406972 },
        { name: 'San Pablo Norte', lat: 14.290210, lng: 121.413023 },
        { name: 'San Pablo Sur', lat: 14.282211, lng: 121.422261 },
        { name: 'Santisima Cruz', lat: 14.290647, lng: 121.409140 },
        { name: 'Santo Angel Central', lat: 14.285137, lng: 121.408947 },
        { name: 'Santo Angel Norte', lat: 14.288547, lng: 121.406307 },
        { name: 'Santo Angel Sur', lat: 14.282329, lng: 121.410985 }
    ];

    const crimeCounts = pointsData.reduce((acc, p) => {
        acc[p.barangay] = (acc[p.barangay] || 0) + 1;
        return acc;
    }, {});

    function getDensityColor(d) {
        return d > 10 ? '#7f1d1d' : d > 7 ? '#b91c1c' : d > 4 ? '#ea580c' : d > 2 ? '#ca8a04' : d > 0 ? '#C8A415' : 'rgba(30, 41, 59, 0.5)';
    }

    function addIncidentPins(filterBrgy = '', filterType = '') {
        incidentLayer.clearLayers();
        pointsData.forEach(point => {
            if (filterBrgy && point.barangay !== filterBrgy) return;
            if (filterType && point.incident_type !== filterType) return;
            const brgyRef = manualPins.find(p => p.name === point.barangay);
            if (!brgyRef) return;
            const lat = brgyRef.lat + (Math.random() - 0.5) * 0.002;
            const lng = brgyRef.lng + (Math.random() - 0.5) * 0.002;
            const marker = L.marker([lat, lng], {
                icon: L.divIcon({
                    className: 'incident-pin-container',
                    html: `<div class="w-4 h-4 rounded-full border-2 border-white shadow-lg animate-pulse" style="background-color: ${colors[point.incident_type] || '#ccc'}"></div>`,
                    iconSize: [16, 16],
                    iconAnchor: [8, 8]
                })
            }).addTo(incidentLayer).bindPopup(`
                <div class="p-3 min-w-[180px] bg-slate-900 text-white rounded-2xl shadow-2xl border border-white/10">
                    <div class="flex items-center justify-between mb-2">
                        <span class="px-2 py-0.5 rounded-full text-[7px] font-black uppercase tracking-widest" style="background-color: ${colors[point.incident_type] || '#ccc'}">${point.incident_type}</span>
                        <span class="text-[7px] text-white/40 font-bold">${new Date(point.incident_date).toLocaleDateString()}</span>
                    </div>
                    <h3 class="text-[10px] font-black uppercase tracking-tighter mb-1">Brgy. ${point.barangay}</h3>
                    <p class="text-[8px] text-white/60 leading-tight">${point.description || 'No additional intelligence'}</p>
                </div>
            `, { className: 'intelligence-popup' });
            
            marker.on('click', () => {
                map.flyTo([lat, lng], 18);
            });
        });
    }

    function addManualPins() {
        manualPins.forEach(pin => {
            const marker = L.marker([pin.lat, pin.lng], {
                icon: L.divIcon({
                    className: 'manual-pin-container',
                    html: `
                        <div class="relative group flex flex-col items-center">
                            <!-- Pulse Effect -->
                            <div class="absolute w-8 h-8 bg-pnp-gold/30 rounded-full animate-ping"></div>
                            <!-- Main Pin -->
                            <div class="relative w-10 h-10 bg-pnp-blue dark:bg-pnp-gold rounded-full flex items-center justify-center shadow-2xl border-2 border-white dark:border-slate-900 transform group-hover:scale-110 transition-all duration-300">
                                <i class="fas fa-tower-observation text-white dark:text-pnp-blue text-xs"></i>
                            </div>
                            <!-- Pointer -->
                            <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-pnp-blue dark:border-t-pnp-gold -mt-1"></div>
                        </div>
                    `,
                    iconSize: [40, 48],
                    iconAnchor: [20, 48]
                })
            }).addTo(pinLayer).bindPopup(`
                <div class="p-4 min-w-[200px] bg-slate-900 text-white rounded-2xl shadow-2xl border border-white/10">
                    <div class="flex items-center space-x-3 mb-3 pb-3 border-b border-white/10">
                        <div class="w-8 h-8 bg-pnp-gold rounded-lg flex items-center justify-center">
                            <i class="fas fa-shield-halved text-pnp-blue text-xs"></i>
                        </div>
                        <div>
                            <h3 class="text-pnp-gold font-black uppercase tracking-widest text-[10px] leading-none">${pin.name} Sector</h3>
                            <p class="text-[7px] text-white/50 font-bold uppercase mt-1">Intelligence Division</p>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center text-[8px] font-black uppercase text-white/70">
                            <span>Sector Ref</span>
                            <span class="text-pnp-gold">SCT-${pin.name.slice(0, 3).toUpperCase()}</span>
                        </div>
                    </div>
                </div>
            `, { className: 'intelligence-popup' });

            marker.on('click', () => {
                map.flyTo([pin.lat, pin.lng], 16);
            });
        });
    }

    function applyFilters() {
        const brgy = document.getElementById('barangay').value;
        const type = document.getElementById('filterIncidentType').value;
        document.getElementById('barangayFilterLabel').textContent = brgy || 'All';
        addIncidentPins(brgy, type);
        if (brgy && !type) {
            const pin = manualPins.find(p => p.name === brgy);
            if (pin) map.flyTo([pin.lat, pin.lng], 16);
        } else if (!brgy) {
            map.flyToBounds([[14.2100, 121.3400], [14.3100, 121.4850]]);
        }
    }

    function initMap() {
        const bounds = [[14.1800, 121.3200], [14.3300, 121.4950]];
        map = L.map('leafletMap', { 
            zoomControl: true
        }).fitBounds(bounds);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            minZoom: 10,
            maxZoom: 20
        }).addTo(map);
        pinLayer.addTo(map);
        incidentLayer.addTo(map);
        choroplethLayer.addTo(map);
        addManualPins();
        addIncidentPins();
        calculateTopIncidents();
        loadMunicipalBoundary();

        fetch(barangayGeoJsonUrl).then(r => r.json()).then(data => {
            santaCruzGeoJSON = data;
            L.geoJSON(data, {
                style: f => ({ color: '#111827', weight: 1, fillOpacity: 0.5, fillColor: getDensityColor(crimeCounts[f.properties.NAME_3] || 0) }),
                onEachFeature: (f, l) => l.bindPopup(`<div class="p-3 min-w-[180px] bg-slate-900 text-white rounded-2xl shadow-2xl border border-white/10">
                                    <div class="flex items-center justify-between mb-3 border-b border-white/10 pb-2">
                                        <h3 class="text-pnp-gold font-black uppercase tracking-widest text-[10px]">Brgy. ${f.properties.NAME_3}</h3>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-[9px] font-black uppercase text-white/70">Incidents</span>
                                        <span class="text-lg font-black text-pnp-gold">${crimeCounts[f.properties.NAME_3] || 0}</span>
                                    </div>
                                </div>`, { className: 'intelligence-popup' })
            }).addTo(choroplethLayer);
            
            // Default: Choropleth off
            map.removeLayer(choroplethLayer);
        });

        // Hide Loading
        const loading = document.getElementById('mapLoading');
        if (loading) {
            loading.classList.add('opacity-0');
            setTimeout(() => loading.classList.add('hidden'), 500);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        initMap();
        document.getElementById('incident_date').valueAsDate = new Date();
    });
</script>

<style>
    .intelligence-popup .leaflet-popup-content-wrapper {
        background: transparent !important;
        box-shadow: none !important;
        padding: 0 !important;
    }
    .intelligence-popup .leaflet-popup-tip {
        background: #0f172a !important;
    }
    .leaflet-container {
        font-family: inherit;
    }
    .incident-pin-container {
        pointer-events: auto !important;
    }
    .incident-pin-container > div {
        cursor: pointer;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .incident-pin-container > div:hover {
        transform: scale(1.4);
        z-index: 1000;
    }
</style>
