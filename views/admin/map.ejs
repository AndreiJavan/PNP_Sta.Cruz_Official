<script>
    function cycleBarangay(direction) {
        const select = document.getElementById('filterBarangay');
        if (!select) return;

        let newIndex = select.selectedIndex + direction;
        if (newIndex < 0) newIndex = select.options.length - 1;
        if (newIndex >= select.options.length) newIndex = 0;

        select.selectedIndex = newIndex;

        const event = new Event('change');
        select.dispatchEvent(event);

        if (typeof locateBarangay === 'function' && select.value !== "") {
            locateBarangay();
        } else if (select.value === "" && map) {
            map.setView([14.2800, 121.4150], 13);
        }
    }

    document.addEventListener('keydown', function (e) {
        if (['INPUT', 'TEXTAREA', 'SELECT'].includes(e.target.tagName)) return;

        if (e.key === 'ArrowLeft') {
            e.preventDefault();
            cycleBarangay(-1);
        } else if (e.key === 'ArrowRight') {
            e.preventDefault();
            cycleBarangay(1);
        }
    });

    let map;
    let santaCruzGeoJSON;
    let incidentMarkers = L.layerGroup();
    let selectedPinsLayer = L.layerGroup();
    let policeStationsLayer = L.layerGroup();
    let boundaryLayerGroup;
    let currentPoints = [];
    let highlightMarker = null;
    let targetHighlightBarangay = null;
    const barangayGeoJsonUrl = '/data/santa_cruz_boundaries.json';

    // Custom Crime Date Filter State & Functions
    let crimeDateFilterMode = 'thisYear'; // 'thisYear', 'monthYear', 'yearOnly', 'customRange'
    let crimeDateSelectedMonth = new Date().getMonth() + 1; // 1-12
    let crimeDateSelectedYear = new Date().getFullYear();
    let crimeDateCustomFrom = '';
    let crimeDateCustomTo = '';
    let allMapPointsCached = [];

    function populateYearDropdowns(points) {
        const years = new Set();
        // Always include the current/present year
        const currentYear = new Date().getFullYear();
        years.add(currentYear);

        points.forEach(p => {
            const pDateStr = p.incident_date || p.date || p.created_at;
            if (pDateStr) {
                const itemDate = new Date(pDateStr);
                if (!isNaN(itemDate.getTime())) {
                    years.add(itemDate.getFullYear());
                }
            }
        });
        
        // Convert to array and sort descending
        let sortedYears = Array.from(years).sort((a, b) => b - a);
        
        const filterMonthYear = document.getElementById('filterMonthYear');
        const filterYear = document.getElementById('filterYear');
        
        if (filterMonthYear) {
            const currentVal = filterMonthYear.value;
            filterMonthYear.innerHTML = sortedYears.map(yr => 
                `<option value="${yr}">${yr}</option>`
            ).join('');
            // Try to restore previous value, otherwise select first option
            if (sortedYears.includes(parseInt(currentVal))) {
                filterMonthYear.value = currentVal;
            } else {
                filterMonthYear.value = currentYear;
                crimeDateSelectedYear = currentYear;
            }
        }
        
        if (filterYear) {
            const currentVal = filterYear.value;
            filterYear.innerHTML = `<option value="all">All Years</option>` + sortedYears.map(yr => 
                `<option value="${yr}">${yr}</option>`
            ).join('');
            // Try to restore previous value, otherwise select first option
            if (currentVal === 'all' || sortedYears.includes(parseInt(currentVal))) {
                filterYear.value = currentVal;
            } else {
                filterYear.value = currentYear;
                crimeDateSelectedYear = currentYear;
            }
        }

        // Restrict calendar pickers dynamically based on available/present years
        const minYear = Math.min(...sortedYears);
        const fromDateInput = document.getElementById('filterFromDate');
        const toDateInput = document.getElementById('filterToDate');
        const todayStr = new Date().toISOString().split('T')[0];

        if (fromDateInput) {
            fromDateInput.setAttribute('min', `${minYear}-01-01`);
            fromDateInput.setAttribute('max', todayStr);
        }
        if (toDateInput) {
            toDateInput.setAttribute('min', `${minYear}-01-01`);
            toDateInput.setAttribute('max', todayStr);
        }
    }

    function toggleCrimeDatePopover(event) {
        if (event) event.stopPropagation();
        const popover = document.getElementById('crimeDatePopover');
        if (popover) {
            popover.classList.toggle('hidden');
        }
    }

    function onCrimeDateModeChange() {
        const mode = document.getElementById('crimeDateMode').value;
        
        // Hide all sub-controls
        document.getElementById('modeMonthYear').classList.add('hidden');
        document.getElementById('modeYearOnly').classList.add('hidden');
        document.getElementById('modeCustomRange').classList.add('hidden');
        
        // Show selected sub-controls
        if (mode === 'monthYear') {
            document.getElementById('modeMonthYear').classList.remove('hidden');
        } else if (mode === 'yearOnly') {
            document.getElementById('modeYearOnly').classList.remove('hidden');
        } else if (mode === 'customRange') {
            document.getElementById('modeCustomRange').classList.remove('hidden');
        }

        // Apply automatically
        applyCrimeDateFilter(false);
    }

    function filterPointsByDate(points) {
        const currentYear = new Date().getFullYear();
        
        return points.filter(p => {
            const pDateStr = p.incident_date || p.date || p.created_at;
            if (!pDateStr) return true; // Keep if no date available
            
            const itemDate = new Date(pDateStr);
            if (isNaN(itemDate.getTime())) return true; // Keep if date is invalid
            
            if (crimeDateFilterMode === 'allYears' || crimeDateFilterMode === 'allTime') {
                return true;
            }
            else if (crimeDateFilterMode === 'thisYear') {
                const startOfYear = new Date(currentYear, 0, 1);
                return itemDate >= startOfYear && itemDate <= new Date();
            } 
            else if (crimeDateFilterMode === 'monthYear') {
                const selectedMonth0Idx = parseInt(crimeDateSelectedMonth) - 1;
                const selectedYearInt = parseInt(crimeDateSelectedYear);
                
                const startOfMonth = new Date(selectedYearInt, selectedMonth0Idx, 1);
                const endOfMonth = new Date(selectedYearInt, selectedMonth0Idx + 1, 0, 23, 59, 59, 999);
                return itemDate >= startOfMonth && itemDate <= endOfMonth;
            } 
            else if (crimeDateFilterMode === 'yearOnly') {
                if (crimeDateSelectedYear === 'all') return true;
                const selectedYearInt = parseInt(crimeDateSelectedYear);
                const startOfYear = new Date(selectedYearInt, 0, 1);
                const endOfYear = new Date(selectedYearInt, 11, 31, 23, 59, 59, 999);
                return itemDate >= startOfYear && itemDate <= endOfYear;
            } 
            else if (crimeDateFilterMode === 'customRange') {
                let start = null;
                if (crimeDateCustomFrom) {
                    start = new Date(crimeDateCustomFrom + 'T00:00:00');
                }
                let end = null;
                if (crimeDateCustomTo) {
                    end = new Date(crimeDateCustomTo + 'T23:59:59');
                }
                
                if (start && end) {
                    return itemDate >= start && itemDate <= end;
                } else if (start) {
                    return itemDate >= start;
                } else if (end) {
                    return itemDate <= end;
                }
                return true;
            }
            return true;
        });
    }

    function updateActivePeriodDisplay() {
        const activePeriodEl = document.getElementById('activePeriodDisplay');
        if (activePeriodEl) {
            let text = '';
            const currentYear = new Date().getFullYear();
            
            if (crimeDateFilterMode === 'allYears' || crimeDateFilterMode === 'allTime') {
                text = `Showing: All Years`;
            } 
            else if (crimeDateFilterMode === 'thisYear') {
                text = `Showing: January 1, ${currentYear} – Today`;
            } 
            else if (crimeDateFilterMode === 'monthYear') {
                const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
                const mName = monthNames[parseInt(crimeDateSelectedMonth) - 1];
                text = `Showing: ${mName} ${crimeDateSelectedYear}`;
            } 
            else if (crimeDateFilterMode === 'yearOnly') {
                if (crimeDateSelectedYear === 'all') {
                    text = `Showing: All Years`;
                } else {
                    text = `Showing: Year ${crimeDateSelectedYear}`;
                }
            } 
            else if (crimeDateFilterMode === 'customRange') {
                const formatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
                let fromText = 'Beginning';
                let toText = 'Today';
                
                if (crimeDateCustomFrom) {
                    fromText = new Date(crimeDateCustomFrom + 'T00:00:00').toLocaleDateString('en-US', formatOptions);
                }
                if (crimeDateCustomTo) {
                    toText = new Date(crimeDateCustomTo + 'T00:00:00').toLocaleDateString('en-US', formatOptions);
                }
                text = `Showing: ${fromText} – ${toText}`;
            }
            activePeriodEl.textContent = text;
        }
        
        const btnLabelEl = document.getElementById('crimeDateLabel');
        if (btnLabelEl) {
            if (crimeDateFilterMode === 'allYears' || crimeDateFilterMode === 'allTime') {
                btnLabelEl.textContent = 'All Years';
            } else if (crimeDateFilterMode === 'thisYear') {
                btnLabelEl.textContent = 'This Year (Default)';
            } else if (crimeDateFilterMode === 'monthYear') {
                const monthNamesShort = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
