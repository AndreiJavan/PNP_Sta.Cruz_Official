    function getCategoryForType(type) {
        const focusTypes = ['Murder', 'Homicide', 'Physical Injury', 'Rape', 'Robbery', 'Theft', 'Carnapping'];
        const psiTypes = ['Search Warrant', 'Warrant of Arrest', 'Checkpoint', 'Buy-Bust', 'Oplan Bakal', 'Oplan Galugad', 'Checkpoint'];
        
        if (focusTypes.some(f => type.toLowerCase().includes(f.toLowerCase()))) return '8-Focus';
        if (psiTypes.some(p => type.toLowerCase().includes(p.toLowerCase()))) return 'PSI';
        return 'Non-Index';
    }

    function renderIncidentList(data, sectorName = 'Regional Grid') {
        const list = document.getElementById('incidentList');
        const count = document.getElementById('incidentCount');
        
        count.textContent = `${data.length} Records`;
        
        if (data.length === 0) {
            list.innerHTML = `
                <div class="py-12 text-center">
                    <i class="fas fa-satellite-dish text-3xl text-gray-100 dark:text-slate-800 mb-3 block"></i>
                    <p class="text-[9px] text-gray-300 font-bold uppercase tracking-widest italic">Negative Contact: No intelligence for this sector</p>
                </div>
            `;
            return;
        }

        // Sort by date descending
        const sorted = [...data].sort((a,b) => new Date(b.incident_date).getTime() - new Date(a.incident_date).getTime());

        list.innerHTML = sorted.map(item => {
            const cat = getCategoryForType(item.incident_type || 'Other');
