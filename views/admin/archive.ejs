<%
    const activeCategory = category || 'All';
    const displayItems = items || [];
%>
<div class="space-y-6 md:space-y-8 animate-fade-in px-2 sm:px-4 max-w-7xl mx-auto w-full transition-all duration-300">
    <!-- Header -->
    <div class="pnp-card pnp-glass-dark border-pnp-blue/10 p-5 sm:p-6 md:p-8 rounded-3xl md:rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between gap-4 md:gap-6">
        <div class="flex items-center space-x-4 md:space-x-5 w-full md:w-auto">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-pnp-blue rounded-2xl flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 shrink-0">
                <i class="fas fa-box-archive text-xl md:text-2xl"></i>
            </div>
            <div class="min-w-0">
                <h1 class="text-xl sm:text-2xl font-black text-pnp-blue dark:text-white uppercase tracking-tighter leading-none mb-1 truncate">Recycle Bin & Archive</h1>
                <p class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest italic truncate">Restorable deleted data categorized for easy recovery</p>
            </div>
        </div>
        <div class="flex items-center justify-between md:justify-end space-x-3 w-full md:w-auto">
            <span id="headerItemCount" class="text-xs font-black uppercase tracking-widest px-4 py-2 bg-pnp-blue/10 dark:bg-pnp-gold/10 text-pnp-blue dark:text-pnp-gold rounded-xl border border-pnp-blue/20 shrink-0">
                <%= displayItems.length %> Archived Items
            </span>
            <button type="button" onclick="promptDeleteAll()" id="deleteAllHeaderBtn" class="px-4 py-2 rounded-xl bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white border border-red-500/20 text-xs font-black uppercase tracking-widest transition-all flex items-center space-x-2 shadow-sm shrink-0">
                <i class="fas fa-trash-can text-xs"></i>
                <span class="hidden sm:inline">Delete All</span>
            </button>
        </div>
    </div>

    <!-- Category Filter Tabs & Actions -->
    <div class="bg-white dark:bg-slate-900 p-4 md:p-6 rounded-3xl md:rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-slate-800 flex flex-col lg:flex-row justify-between items-stretch lg:items-center gap-4">
        <!-- Category Buttons (Zero Page Reload) -->
        <div class="flex flex-wrap items-center gap-2" id="categoryTabs">
            <button type="button" onclick="selectCategoryFilter('All')" data-cat="All" class="cat-tab-btn px-4 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all shadow-sm">
                All Archives (<span id="count-All">0</span>)
            </button>
            <button type="button" onclick="selectCategoryFilter('Public Advisories')" data-cat="Public Advisories" class="cat-tab-btn px-4 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all shadow-sm">
                Public Advisories (<span id="count-Public Advisories">0</span>)
            </button>
            <button type="button" onclick="selectCategoryFilter('News Releases')" data-cat="News Releases" class="cat-tab-btn px-4 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all shadow-sm">
                News Releases (<span id="count-News Releases">0</span>)
            </button>
            <button type="button" onclick="selectCategoryFilter('Crime Reports')" data-cat="Crime Reports" class="cat-tab-btn px-4 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all shadow-sm">
                Crime Reports (<span id="count-Crime Reports">0</span>)
            </button>
        </div>

        <div class="flex items-center space-x-3 w-full lg:w-auto">
            <div class="relative flex-grow lg:w-64">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                <input type="text" id="archiveSearchInput" onkeyup="filterArchiveTable()" placeholder="Search archived items..." class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-slate-950 border border-gray-200 dark:border-slate-800 rounded-xl outline-none text-xs font-bold text-slate-700 dark:text-white uppercase tracking-wider">
            </div>
            <button type="button" onclick="promptDeleteAll()" class="px-4 py-2.5 rounded-xl bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white border border-red-500/20 text-xs font-black uppercase tracking-wider transition-all flex items-center space-x-2 shadow-sm shrink-0 lg:hidden">
                <i class="fas fa-trash-can text-xs"></i>
                <span>Delete All</span>
            </button>
        </div>
    </div>

    <!-- Archive Table Container -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl md:rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden">
        <div class="overflow-x-auto w-full custom-scrollbar">
            <table class="w-full text-left border-collapse min-w-[700px]">
                <thead>
                    <tr class="bg-gray-50/50 dark:bg-slate-950/50 border-b border-gray-100 dark:border-slate-800">
                        <th class="px-4 sm:px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] whitespace-nowrap">Category</th>
                        <th class="px-4 sm:px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Title / Item Name</th>
                        <th class="px-4 sm:px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] whitespace-nowrap">Deleted By</th>
                        <th class="px-4 sm:px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] whitespace-nowrap">Deleted Date</th>
                        <th class="px-4 sm:px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-right whitespace-nowrap">Actions</th>
                    </tr>
                </thead>
                <tbody id="archiveTableBody" class="divide-y divide-gray-50 dark:divide-slate-800">
                    <% if (displayItems.length === 0) { %>
                        <tr id="emptyStateRow">
                            <td colspan="5" class="px-8 py-24 text-center">
                                <div class="flex flex-col items-center justify-center opacity-30">
                                    <i class="fas fa-box-open text-6xl mb-4 text-slate-400"></i>
                                    <p class="text-xs font-black uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">No Archived Items Found</p>
                                </div>
                            </td>
                        </tr>
                    <% } else { %>
                        <% displayItems.forEach((item) => { %>
                            <tr class="archive-row hover:bg-gray-50/80 dark:hover:bg-slate-800/40 transition-all group" data-category="<%= item.category %>" data-title="<%= item.title %>">
                                <td class="px-4 sm:px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest inline-block <%= item.category === 'Crime Reports' ? 'bg-red-500/10 text-red-500 border border-red-500/20' : (item.category === 'News Releases' ? 'bg-blue-500/10 text-blue-500 border border-blue-500/20' : 'bg-pnp-gold/10 text-pnp-gold border border-pnp-gold/20') %>">
                                        <%= item.category %>
                                    </span>
                                </td>
                                <td class="px-4 sm:px-6 py-4">
                                    <div class="flex flex-col min-w-[200px] max-w-md">
                                        <span class="text-xs font-black text-slate-800 dark:text-white uppercase tracking-tight break-words"><%= item.title %></span>
                                        <span class="text-[10px] text-slate-400 font-bold truncate mt-0.5"><%= item.original_id ? 'ID: ' + item.original_id.slice(-8).toUpperCase() : 'N/A' %></span>
                                    </div>
                                </td>
                                <td class="px-4 sm:px-6 py-4 text-xs font-bold text-slate-600 dark:text-slate-300 uppercase whitespace-nowrap">
                                    <%= item.deleted_by || 'System Admin' %>
                                </td>
                                <td class="px-4 sm:px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 font-mono whitespace-nowrap">
                                    <%= new Date(item.deleted_at).toLocaleString(undefined, { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                </td>
                                <td class="px-4 sm:px-6 py-4 text-right whitespace-nowrap">
                                    <div class="flex items-center justify-end space-x-2">
                                        <button type="button" onclick="promptRestore('<%= item.id %>', '<%= item.title.replace(/'/g, "\\'").replace(/"/g, '&quot;') %>')" class="px-3.5 py-2 rounded-xl bg-emerald-500/10 hover:bg-emerald-500 text-emerald-600 hover:text-white border border-emerald-500/20 text-[10px] font-black uppercase tracking-widest transition-all flex items-center space-x-1.5 shadow-sm">
                                            <i class="fas fa-rotate-left"></i>
                                            <span>Restore</span>
                                        </button>
                                        <button type="button" onclick="promptDelete('<%= item.id %>', '<%= item.title.replace(/'/g, "\\'").replace(/"/g, '&quot;') %>')" class="w-9 h-9 rounded-xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm" title="Permanently Delete">
                                            <i class="fas fa-trash-alt text-xs"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <tr id="noResultsRow" class="hidden">
                            <td colspan="5" class="px-8 py-20 text-center">
                                <div class="flex flex-col items-center justify-center opacity-40">
                                    <i class="fas fa-filter text-5xl mb-3 text-slate-400"></i>
                                    <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">No items match the selected category/filter</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Hidden Action Forms for Modal Submission -->
<form id="restoreForm" method="POST" class="hidden"></form>
<form id="deleteForm" method="POST" class="hidden"></form>
<form id="deleteAllForm" action="/admin/archive/clear-all" method="POST" class="hidden">
    <input type="hidden" name="category" id="deleteAllCategoryInput" value="All">
</form>

<!-- Confirmation Modal (Yes / No) -->
<div id="confirmModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/70 backdrop-blur-md hidden transition-opacity duration-200">
    <div class="bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-800 rounded-3xl p-6 sm:p-8 max-w-md w-full shadow-2xl space-y-6 transform scale-95 transition-transform duration-200" id="confirmModalCard">
        <div class="flex items-start space-x-4">
            <div id="confirmModalIconBg" class="w-12 h-12 rounded-2xl flex items-center justify-center text-xl shrink-0">
                <i id="confirmModalIcon" class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="flex-1 min-w-0">
                <h3 id="confirmModalTitle" class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight mb-1">
                    Confirm Action
                </h3>
                <p id="confirmModalMessage" class="text-xs font-bold text-slate-500 dark:text-slate-400 leading-relaxed break-words">
                    Are you sure you want to proceed with this action?
                </p>
            </div>
        </div>

        <div class="flex items-center justify-end space-x-3 pt-2 border-t border-gray-100 dark:border-slate-800">
            <button type="button" onclick="closeConfirmModal()" class="px-5 py-2.5 rounded-xl bg-gray-100 hover:bg-gray-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 font-black text-xs uppercase tracking-wider transition-all">
                No, Cancel
            </button>
            <button type="button" id="confirmModalYesBtn" class="px-6 py-2.5 rounded-xl font-black text-xs uppercase tracking-wider text-white shadow-lg transition-all flex items-center space-x-2">
                <span>Yes, Confirm</span>
            </button>
        </div>
    </div>
</div>

<script>
    let currentCategory = '<%= activeCategory %>';

    document.addEventListener('DOMContentLoaded', () => {
        updateCategoryCounts();
        selectCategoryFilter(currentCategory, false);
    });

    function updateCategoryCounts() {
        const rows = document.querySelectorAll('.archive-row');
        const counts = { 'All': rows.length, 'Public Advisories': 0, 'News Releases': 0, 'Crime Reports': 0 };

        rows.forEach(row => {
            const cat = row.getAttribute('data-category');
            if (counts.hasOwnProperty(cat)) {
                counts[cat]++;
            }
        });

        for (const [cat, count] of Object.entries(counts)) {
            const countEl = document.getElementById(`count-${cat}`);
            if (countEl) countEl.textContent = count;
        }
    }

    function selectCategoryFilter(category, updateUrl = true) {
        currentCategory = category;

        // Update button active states
        const buttons = document.querySelectorAll('.cat-tab-btn');
        buttons.forEach(btn => {
            const btnCat = btn.getAttribute('data-cat');
            if (btnCat === category) {
                btn.className = 'cat-tab-btn px-4 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue shadow-md border border-pnp-blue/20 dark:border-pnp-gold/20';
            } else {
                btn.className = 'cat-tab-btn px-4 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all bg-gray-50 dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-700 border border-transparent';
            }
        });

        if (updateUrl) {
            const newUrl = window.location.pathname + '?category=' + encodeURIComponent(category);
            window.history.pushState({ category }, '', newUrl);
        }

        filterArchiveTable();
    }

    function filterArchiveTable() {
        const searchInput = (document.getElementById('archiveSearchInput')?.value || '').toLowerCase().trim();
        const rows = document.querySelectorAll('.archive-row');
        let visibleCount = 0;

        rows.forEach(row => {
            const cat = row.getAttribute('data-category');
            const title = (row.getAttribute('data-title') || '').toLowerCase();
            const text = row.textContent.toLowerCase();

            const matchesCategory = (currentCategory === 'All') || (cat === currentCategory);
            const matchesSearch = !searchInput || text.includes(searchInput) || title.includes(searchInput);

            if (matchesCategory && matchesSearch) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });

        // Header Item Count Update
        const headerCount = document.getElementById('headerItemCount');
        if (headerCount) {
            headerCount.textContent = `${visibleCount} Archived Items`;
        }

        // No matching results row check
        const noResultsRow = document.getElementById('noResultsRow');
        const emptyStateRow = document.getElementById('emptyStateRow');
        if (noResultsRow) {
            if (rows.length > 0 && visibleCount === 0) {
                noResultsRow.classList.remove('hidden');
            } else {
                noResultsRow.classList.add('hidden');
            }
        }
    }

    // Modal Confirmation Logic
    let pendingAction = null;

    function openConfirmModal({ icon, iconBg, title, message, yesText, yesClass, onConfirm }) {
        const modal = document.getElementById('confirmModal');
        const iconBgEl = document.getElementById('confirmModalIconBg');
        const iconEl = document.getElementById('confirmModalIcon');
        const titleEl = document.getElementById('confirmModalTitle');
        const messageEl = document.getElementById('confirmModalMessage');
        const yesBtn = document.getElementById('confirmModalYesBtn');

        iconBgEl.className = `w-12 h-12 rounded-2xl flex items-center justify-center text-xl shrink-0 ${iconBg}`;
        iconEl.className = icon;
        titleEl.textContent = title;
        messageEl.innerHTML = message;
        yesBtn.className = `px-6 py-2.5 rounded-xl font-black text-xs uppercase tracking-wider text-white shadow-lg transition-all flex items-center space-x-2 ${yesClass}`;
        yesBtn.innerHTML = `<span>${yesText}</span>`;

        pendingAction = onConfirm;

        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeConfirmModal() {
        const modal = document.getElementById('confirmModal');
        modal.classList.add('hidden');
        document.body.style.overflow = '';
        pendingAction = null;
    }

    document.getElementById('confirmModalYesBtn').addEventListener('click', () => {
        if (typeof pendingAction === 'function') {
            const action = pendingAction;
            closeConfirmModal();
            action();
        }
    });

    document.getElementById('confirmModal').addEventListener('click', (e) => {
        if (e.target.id === 'confirmModal') {
            closeConfirmModal();
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeConfirmModal();
        }
    });

    // Prompt Functions
    function promptRestore(itemId, itemTitle) {
        openConfirmModal({
            icon: 'fas fa-rotate-left',
            iconBg: 'bg-emerald-500/10 text-emerald-500',
            title: 'Confirm Restore',
            message: `Are you sure you want to restore <span class="text-slate-800 dark:text-white font-black">"${itemTitle}"</span> back to active records?`,
            yesText: 'Yes, Restore',
            yesClass: 'bg-emerald-600 hover:bg-emerald-700',
            onConfirm: () => {
                const form = document.getElementById('restoreForm');
                form.action = `/admin/archive/${itemId}/restore`;
                form.submit();
            }
        });
    }

    function promptDelete(itemId, itemTitle) {
        openConfirmModal({
            icon: 'fas fa-trash-alt',
            iconBg: 'bg-red-500/10 text-red-500',
            title: 'Permanently Delete?',
            message: `Are you sure you want to permanently delete <span class="text-slate-800 dark:text-white font-black">"${itemTitle}"</span>? This action <strong class="text-red-500">cannot be undone</strong>.`,
            yesText: 'Yes, Delete',
            yesClass: 'bg-red-600 hover:bg-red-700',
            onConfirm: () => {
                const form = document.getElementById('deleteForm');
                form.action = `/admin/archive/${itemId}/permanent-delete`;
                form.submit();
            }
        });
    }

    function promptDeleteAll() {
        const rows = document.querySelectorAll('.archive-row');
        let activeCount = 0;
        rows.forEach(r => {
            if (r.style.display !== 'none') activeCount++;
        });

        if (activeCount === 0) {
            alert('No archived items available to delete in this category.');
            return;
        }

        const categoryText = currentCategory === 'All' ? 'ALL categories' : `the "${currentCategory}" category`;

        openConfirmModal({
            icon: 'fas fa-dumpster-fire',
            iconBg: 'bg-red-500/10 text-red-600',
            title: 'Delete All Archived Items?',
            message: `Are you sure you want to permanently delete <strong class="text-red-500 font-black">${activeCount} item(s)</strong> in ${categoryText}? This action <strong class="text-red-500">CANNOT BE UNDONE</strong>.`,
            yesText: 'Yes, Delete All',
            yesClass: 'bg-red-600 hover:bg-red-700',
            onConfirm: () => {
                document.getElementById('deleteAllCategoryInput').value = currentCategory;
                document.getElementById('deleteAllForm').submit();
            }
        });
    }
</script>
