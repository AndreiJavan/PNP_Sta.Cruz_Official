<%
    const activeCategory = category || 'All';
    const displayItems = items || [];
%>
<div class="space-y-8 animate-fade-in px-4 lg:px-4 max-w-7xl mx-auto w-full transition-all duration-300">
    <!-- Header -->
    <div class="pnp-card pnp-glass-dark border-pnp-blue/10 p-6 md:p-8 rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center space-x-5">
            <div class="w-14 h-14 bg-pnp-blue rounded-2xl flex items-center justify-center text-pnp-gold shadow-2xl rotate-3 border-2 border-white/10 shrink-0">
                <i class="fas fa-box-archive text-2xl"></i>
            </div>
            <div>
                <h1 class="text-2xl font-black text-pnp-blue dark:text-white uppercase tracking-tighter leading-none mb-1">Recycle Bin & Archive</h1>
                <p class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest italic">Restorable deleted data categorized for easy recovery</p>
            </div>
        </div>
        <div class="flex items-center space-x-3">
            <span class="text-xs font-black uppercase tracking-widest px-4 py-2 bg-pnp-blue/10 dark:bg-pnp-gold/10 text-pnp-blue dark:text-pnp-gold rounded-xl border border-pnp-blue/20">
                <%= displayItems.length %> Archived Items
            </span>
        </div>
    </div>

    <!-- Category Filter Tabs -->
    <div class="bg-white dark:bg-slate-900 p-4 md:p-6 rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-slate-800 flex flex-wrap justify-between items-center gap-4">
        <div class="flex flex-wrap gap-2">
            <a href="/admin/archive?category=All" class="px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all <%= activeCategory === 'All' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue shadow-md' : 'bg-gray-50 dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-700' %>">
                All Archives
            </a>
            <a href="/admin/archive?category=Public Advisories" class="px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all <%= activeCategory === 'Public Advisories' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue shadow-md' : 'bg-gray-50 dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-700' %>">
                Public Advisories
            </a>
            <a href="/admin/archive?category=News Releases" class="px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all <%= activeCategory === 'News Releases' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue shadow-md' : 'bg-gray-50 dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-700' %>">
                News Releases
            </a>
            <a href="/admin/archive?category=Crime Reports" class="px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider transition-all <%= activeCategory === 'Crime Reports' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue shadow-md' : 'bg-gray-50 dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-700' %>">
                Crime Reports
            </a>
        </div>
        <div class="relative w-full md:w-64">
            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
            <input type="text" id="archiveSearchInput" onkeyup="filterArchiveTable()" placeholder="Search archived items..." class="w-full pl-10 pr-4 py-3 bg-gray-50 dark:bg-slate-950 border border-gray-200 dark:border-slate-800 rounded-xl outline-none text-xs font-bold text-slate-700 dark:text-white uppercase tracking-wider">
        </div>
    </div>

    <!-- Archive Table -->
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden">
        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50 dark:bg-slate-950/50 border-b border-gray-100 dark:border-slate-800">
                        <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Category</th>
                        <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Title / Item Name</th>
                        <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Deleted By</th>
                        <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Deleted Date</th>
                        <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="archiveTableBody" class="divide-y divide-gray-50 dark:divide-slate-800">
                    <% if (displayItems.length === 0) { %>
                        <tr>
                            <td colspan="5" class="px-8 py-24 text-center">
                                <div class="flex flex-col items-center justify-center opacity-30">
                                    <i class="fas fa-box-open text-6xl mb-4"></i>
                                    <p class="text-xs font-black uppercase tracking-[0.3em]">No Archived Items Found</p>
                                </div>
                            </td>
                        </tr>
                    <% } else { %>
                        <% displayItems.forEach((item) => { %>
                            <tr class="hover:bg-gray-50/80 dark:hover:bg-slate-800/40 transition-all group">
                                <td class="px-8 py-6">
                                    <span class="px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest <%= item.category === 'Crime Reports' ? 'bg-red-500/10 text-red-500 border border-red-500/20' : (item.category === 'News Releases' ? 'bg-blue-500/10 text-blue-500 border border-blue-500/20' : 'bg-pnp-gold/10 text-pnp-gold border border-pnp-gold/20') %>">
                                        <%= item.category %>
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <div class="flex flex-col max-w-xs md:max-w-md">
                                        <span class="text-xs font-black text-slate-800 dark:text-white uppercase tracking-tight truncate"><%= item.title %></span>
                                        <span class="text-[10px] text-slate-400 font-bold truncate mt-1"><%= item.original_id ? 'ID: ' + item.original_id.slice(-8).toUpperCase() : 'N/A' %></span>
                                    </div>
                                </td>
                                <td class="px-8 py-6 text-xs font-bold text-slate-600 dark:text-slate-300 uppercase">
                                    <%= item.deleted_by || 'System Admin' %>
                                </td>
                                <td class="px-8 py-6 text-xs font-bold text-slate-500 dark:text-slate-400 font-mono">
                                    <%= new Date(item.deleted_at).toLocaleString(undefined, { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                </td>
                                <td class="px-8 py-6 text-right">
                                    <div class="flex items-center justify-end space-x-3">
                                        <form action="/admin/archive/<%= item.id %>/restore" method="POST" class="inline-block">
                                            <button type="submit" class="px-4 py-2 rounded-xl bg-emerald-500/10 hover:bg-emerald-500 text-emerald-600 hover:text-white border border-emerald-500/20 text-[10px] font-black uppercase tracking-widest transition-all flex items-center space-x-1.5 shadow-sm">
                                                <i class="fas fa-rotate-left"></i>
                                                <span>Restore</span>
                                            </button>
                                        </form>
                                        <form action="/admin/archive/<%= item.id %>/permanent-delete" method="POST" onsubmit="return confirm('Permanently remove from archive? This action cannot be undone.');" class="inline-block">
                                            <button type="submit" class="w-9 h-9 rounded-xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm" title="Permanently Delete">
                                                <i class="fas fa-trash-alt text-xs"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterArchiveTable() {
        const input = document.getElementById('archiveSearchInput').value.toLowerCase();
        const rows = document.querySelectorAll('#archiveTableBody tr');
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            if (text.includes(input)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>
