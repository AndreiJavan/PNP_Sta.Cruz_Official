     window.addNewSingleRow = function(insertIndex = null) {
         const todayStr = new Date().toISOString().split('T')[0];
         const newRow = {
             barangay: VALID_BARANGAYS[0],
             date_committed: todayStr,
             offense: '',
             category: 'Non-Index',
             description: ''
         };
         if (insertIndex !== null && typeof insertIndex === 'number' && insertIndex >= 0 && insertIndex <= reviewData.length) {
             reviewData.splice(insertIndex, 0, newRow);
         } else {
             reviewData.push(newRow);
         }
         renderReviewTable();
         setTimeout(() => {
             const tbody = document.getElementById('reviewTableBody');
             const container = tbody ? tbody.closest('.overflow-auto') : null;
             if (container) {
                 container.scrollTop = container.scrollHeight;
             }
         }, 50);
     };

     window.insertReviewRowAt = function(insertIndex) {
         window.addNewSingleRow(insertIndex);
     };

     window.updateReviewItem = function(index, field, value) {
         const todayStr = new Date().toISOString().split('T')[0];

         if (field === 'date_committed') {
             if (value && value > todayStr) {
                 window.strategicAlert({
                     title: "Invalid Timeline Date",
                     message: `Future dates are restricted. The maximum allowed date is today (${todayStr}).`,
                     type: "warning"
                 });
                 value = todayStr;
             } else if (value && value < '2024-01-01') {
                 window.strategicAlert({
                     title: "Invalid Timeline Date",
                     message: "Selectable date range cannot be prior to January 1, 2024.",
                     type: "warning"
                 });
                 value = '2024-01-01';
             }
         }

         if (!reviewData[index]) return;
         reviewData[index][field] = value;

         if (field === 'category' || field === 'date_committed') {
             if (field === 'category') {
                 reviewData[index].offense = ''; // Reset crime selection when category changes
             }
             renderReviewTable();
         }
     };

     window.updateReviewItemDate = function(index, part, value) {
         if (!reviewData[index]) return;
         const rawDateStr = reviewData[index].date_committed || reviewData[index].date || new Date().toISOString().split('T')[0];
         const parts = rawDateStr.split('-');
         let y = parts[0] || '2026';
         let m = parts[1] || '01';
         let d = parts[2] || '01';
         
         if (part === 'day') d = String(value).padStart(2, '0');
         if (part === 'month') m = String(value).padStart(2, '0');
         if (part === 'year') y = String(value);

         const newDate = `${y}-${m}-${d}`;
         reviewData[index].date_committed = newDate;
         reviewData[index].date = newDate;
     };
  
