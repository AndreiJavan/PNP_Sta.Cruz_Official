        if (!window.currentStatsClassification) window.currentStatsClassification = 'All';
        const category = window.currentStatsCategory;
        
        let baseData = window.currentStatsBarangay === 'All Barangays' ? allIncidents : allIncidents.filter(item => item.barangay === window.currentStatsBarangay);
        
        let filteredData = category === 'All' ? baseData : baseData.filter(item => item.category === category);
        
        // Dynamic Classification Filter Options base on the current category & sector data
        const existingOffenses = new Set();
        filteredData.forEach(item => {
            const off = item.incident_type || item.offense;
            if (off) {
                existingOffenses.add(off);
            }
        });
        const combinedOffenses = Array.from(existingOffenses).sort();

        // Check if previously selected classification is still valid, if not default to 'All'
        if (window.currentStatsClassification !== 'All' && !existingOffenses.has(window.currentStatsClassification)) {
            window.currentStatsClassification = 'All';
        }

        // Apply classification filtering
        let displayData = filteredData;
        if (window.currentStatsClassification !== 'All') {
            displayData = filteredData.filter(item => {
                const off = item.incident_type || item.offense || '';
                return off.toUpperCase() === window.currentStatsClassification.toUpperCase();
            });
        }

        const content = document.getElementById('reportDetailsContent');
        
        // Stats for the header
        const stats = {
            '8-Focus': baseData.filter(item => item.category === '8-Focus').length,
            'Non-Index': baseData.filter(item => item.category === 'Non-Index').length,
            'PSI': baseData.filter(item => item.category === 'PSI').length
        };

        content.innerHTML = `
            <!-- Global Intelligence Header -->
            <div class="bg-slate-900 border-b border-white/5 p-8 grid grid-cols-1 lg:grid-cols-12 gap-8 relative overflow-hidden">
                <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 20px 20px;"></div>
                
                <div class="lg:col-span-3 space-y-2 relative z-10">
                    <span class="text-[10px] font-black text-pnp-gold uppercase tracking-[0.3em] block">Sector Filter</span>
                    <div class="flex flex-col mt-2">
                        <select onchange="window.currentStatsBarangay = this.value; window.currentStatsClassification = 'All'; renderGlobalStatsModalContent()" class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-xs font-black text-white focus:ring-2 focus:ring-pnp-blue outline-none transition-all duration-300 appearance-none cursor-pointer">
                            ${["All Barangays", ...window.VALID_BARANGAYS].map(b => `<option value="${b}" ${b === window.currentStatsBarangay ? 'selected' : ''} class="bg-slate-800 text-white">${b}</option>`).join('')}
                        </select>
                        <p class="text-[10px] text-slate-500 font-bold uppercase mt-2 tracking-widest">Select specific barangay</p>
                    </div>
                </div>

                <div class="lg:col-span-3 space-y-2 relative z-10">
                    <span class="text-[10px] font-black text-pnp-gold uppercase tracking-[0.3em] block">Classification Filter</span>
