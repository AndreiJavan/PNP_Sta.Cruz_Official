<% 
    // Ensure all critical variables have defaults to prevent EJS crashes
    const displayReports = (typeof reports !== 'undefined' && reports) ? reports : [];
    const displayStats = (typeof stats !== 'undefined' && stats) ? stats : { '8-Focus': 0, 'PSI': 0, 'Non-Index': 0 };
    const displayIncidents = (typeof allIncidents !== 'undefined' && allIncidents) ? allIncidents : [];
%>
<div class="space-y-8 animate-fade-in px-4 lg:px-0">
    <!-- Header Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
        <div class="pnp-card pnp-glass-dark border-red-500/10 p-6 rounded-[2rem] flex flex-col justify-center text-left group">
            <span class="text-[10px] text-red-400 font-black uppercase tracking-[0.2em] mb-2 opacity-70">Focus Crimes</span>
            <div class="text-4xl font-black text-red-500 leading-none count-up-glow count-up" data-target="<%= displayStats['8-Focus'] || 0 %>" data-stat="8-Focus">0</div>
            <p class="text-[10px] text-slate-400 font-bold uppercase mt-4 tracking-wider leading-tight">Critical Strategic Targets Identified</p>
        </div>

        <div class="pnp-card pnp-glass-dark border-slate-500/10 p-6 rounded-[2rem] flex flex-col justify-center text-left group">
            <span class="text-[10px] text-slate-400 font-black uppercase tracking-[0.2em] mb-2 opacity-70">Miscellaneous</span>
            <div class="text-4xl font-black text-slate-200 leading-none count-up-glow count-up" data-target="<%= displayStats['Non-Index'] || 0 %>" data-stat="Non-Index">0</div>
            <p class="text-[10px] text-slate-400 font-bold uppercase mt-4 tracking-wider leading-tight">Non-Index Incident Stream Data</p>
        </div>

        <div class="pnp-card pnp-glass-dark border-pnp-blue/10 p-6 rounded-[2rem] flex flex-col justify-center text-left group">
            <span class="text-[10px] text-pnp-blue-300 font-black uppercase tracking-[0.2em] mb-2 opacity-70">Safety Index</span>
            <div class="text-4xl font-black text-pnp-blue-300 leading-none count-up-glow count-up" data-target="<%= displayStats['PSI'] || 0 %>" data-stat="PSI">0</div>
            <p class="text-[10px] text-slate-400 font-bold uppercase mt-4 tracking-wider leading-tight">Public Safety Operations Log</p>
        </div>

        <button onclick="openManualEntry()" class="pnp-card bg-slate-900 border-2 border-dashed border-white/5 p-6 rounded-[2rem] flex flex-col justify-center text-left group hover:border-pnp-gold transition-all relative overflow-hidden">
            <div class="absolute -right-4 -top-4 w-12 h-12 bg-pnp-gold/5 rounded-full blur-xl group-hover:bg-pnp-gold/10 transition-all"></div>
            <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center text-pnp-gold mb-4 group-hover:scale-110 transition-all border border-white/10">
                <i class="fas fa-keyboard"></i>
            </div>
            <div class="text-lg font-black text-white leading-none uppercase tracking-widest">Manual Input</div>
            <p class="text-[10px] text-white/30 font-bold uppercase mt-3 tracking-widest">Secure Data Entry Portal</p>
        </button>

        <button onclick="document.getElementById('fileConverterInput').click()" class="pnp-card pnp-gradient-blue p-6 rounded-[2rem] shadow-2xl flex flex-col justify-center border-2 border-white/10 text-left group hover:-translate-y-2 relative overflow-hidden">
            <div class="absolute inset-0 bg-pnp-gold/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            <div class="flex justify-between items-start w-full relative z-10">
                <span class="text-[10px] text-pnp-gold font-black uppercase tracking-[0.3em] mb-2 group-hover:animate-pulse">Active Scanner</span>
                <span onclick="event.stopPropagation(); purgeTacticalData()" title="Purge System Placeholders" class="text-[11px] text-white/20 hover:text-red-400 transition-colors cursor-help">
                    <i class="fas fa-microchip"></i>
                </span>
            </div>
            <div class="text-xl font-black text-white leading-none uppercase tracking-tighter relative z-10">Unit Periodic Report</div>
            <p class="text-[10px] text-white/40 font-bold uppercase mt-3 italic tracking-widest relative z-10">AI Extraction Neural Link</p>
            <input type="file" id="fileConverterInput" accept=".pdf,.xlsx,.xls,.docx" class="hidden" onchange="handleIntelConvert(this)">
        </button>
    </div>

        <!-- Extraction Batches View -->
        <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden">
            <div class="p-8 border-b border-gray-50 dark:border-slate-800 bg-gray-50/10 dark:bg-slate-900/50 flex justify-between items-center">
                <div>
                    <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-sm">Mission Records Archive</h3>
                    <p class="text-[10px] text-slate-400 font-bold uppercase mt-1 tracking-widest italic">Historical Tactical Batch History</p>
                </div>
                <div class="flex items-center space-x-3">
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">System Link Active</span>
                </div>
            </div>
    
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse min-w-[1000px] table-fixed">
                    <thead class="bg-gray-50/50 dark:bg-slate-950/50">
                        <tr>
                            <th class="w-44 px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800">Operational Log</th>
                            <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800">Mission Intelligence</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Volume</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">8-Focus</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Non-Index</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Safety</th>
                            <th class="w-32 px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Signal</th>
                            <th class="w-32 px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-slate-800">
                        <% if (displayReports.length === 0) { %>
                            <tr>
                                <td colspan="8" class="px-8 py-40 text-center text-gray-300 dark:text-slate-700 font-black uppercase tracking-[0.5em] italic">
                                    <div class="flex flex-col items-center justify-center">
                                        <i class="fas fa-barcode text-6xl mb-6 opacity-20"></i>
                                        <span>No tactical data signals found</span>
                                    </div>
                                </td>
                            </tr>
                        <% } else { %>
