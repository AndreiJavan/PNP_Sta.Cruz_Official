                            <span class="text-[8px] font-black uppercase tracking-widest mb-1" style="color: ${category === '8-Focus' ? '#fff' : `${window.categoryHighestColors?.['8-Focus'] || '#ef4444'}80`}">8-Focus</span>
                            <span class="text-xl font-black tabular-nums leading-none" style="color: ${category === '8-Focus' ? '#fff' : (window.categoryHighestColors?.['8-Focus'] || '#ef4444')}">${stats['8-Focus']}</span>
                        </button>
                        <button onclick="openStatsSpreadsheet('Non-Index')" class="p-3 rounded-2xl border transition-all flex flex-col items-center" style="${category === 'Non-Index' ? `background-color: ${window.categoryHighestColors?.['Non-Index'] || '#64748b'}; border-color: ${window.categoryHighestColors?.['Non-Index'] || '#64748b'}; box-shadow: 0 0 20px ${(window.categoryHighestColors?.['Non-Index'] || '#64748b')}4c; color: #fff;` : `background-color: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1);`}">
                            <span class="text-[8px] font-black uppercase tracking-widest mb-1" style="color: ${category === 'Non-Index' ? '#fff' : `${window.categoryHighestColors?.['Non-Index'] || '#64748b'}80`}">Non-Index</span>
                            <span class="text-xl font-black tabular-nums leading-none" style="color: ${category === 'Non-Index' ? '#fff' : (window.categoryHighestColors?.['Non-Index'] || '#64748b')}">${stats['Non-Index']}</span>
                        </button>
                        <button onclick="openStatsSpreadsheet('PSI')" class="p-3 rounded-2xl border transition-all flex flex-col items-center" style="${category === 'PSI' ? `background-color: ${window.categoryHighestColors?.['PSI'] || '#3b82f6'}; border-color: ${window.categoryHighestColors?.['PSI'] || '#3b82f6'}; box-shadow: 0 0 20px ${(window.categoryHighestColors?.['PSI'] || '#3b82f6')}4c; color: #fff;` : `background-color: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1);`}">
                            <span class="text-[8px] font-black uppercase tracking-widest mb-1" style="color: ${category === 'PSI' ? '#fff' : `${window.categoryHighestColors?.['PSI'] || '#3b82f6'}80`}">PSI</span>
                            <span class="text-xl font-black tabular-nums leading-none" style="color: ${category === 'PSI' ? '#fff' : (window.categoryHighestColors?.['PSI'] || '#3b82f6')}">${stats['PSI']}</span>
