<% 
    // Ensure all critical variables have defaults to prevent EJS crashes
    const displayReports = (typeof reports !== 'undefined' && reports) ? reports : [];
    const displayStats = (typeof stats !== 'undefined' && stats) ? stats : { '8-Focus': 0, 'PSI': 0, 'Non-Index': 0 };
    const displayIncidents = (typeof allIncidents !== 'undefined' && allIncidents) ? allIncidents : [];
%>
<div class="space-y-8 animate-fade-in px-4 lg:px-0">
    <!-- Header Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
        <div id="statsCard_8Focus" onclick="openStatsSpreadsheet('8-Focus')" class="bg-white dark:bg-slate-900 border border-gray-150 dark:border-slate-800/60 shadow-sm hover:shadow-2xl p-6 rounded-[2rem] flex flex-col justify-center text-left group cursor-pointer hover:scale-105 transition-all">
            <span id="statsLabel_8Focus" class="text-[10px] text-red-500 font-black uppercase tracking-[0.2em] mb-2">8-Focus</span>
            <div id="statsCount_8Focus" class="text-4xl font-black text-red-500 leading-none count-up-glow" data-target="<%= displayStats['8-Focus'] || 0 %>" data-stat="8-Focus"><%= displayStats['8-Focus'] || 0 %></div>
            <p class="text-[10px] text-slate-400 font-bold uppercase mt-4 tracking-wider leading-tight">Critical Targets</p>
        </div>

        <div id="statsCard_NonIndex" onclick="openStatsSpreadsheet('Non-Index')" class="bg-white dark:bg-slate-900 border border-gray-150 dark:border-slate-800/60 shadow-sm hover:shadow-2xl p-6 rounded-[2rem] flex flex-col justify-center text-left group cursor-pointer hover:scale-105 transition-all">
            <span id="statsLabel_NonIndex" class="text-[10px] text-pnp-blue dark:text-blue-400 font-black uppercase tracking-[0.2em] mb-2">Non-Index</span>
            <div id="statsCount_NonIndex" class="text-4xl font-black text-pnp-blue dark:text-blue-400 leading-none count-up-glow" data-target="<%= displayStats['Non-Index'] || 0 %>" data-stat="Non-Index"><%= displayStats['Non-Index'] || 0 %></div>
            <p class="text-[10px] text-slate-400 font-bold uppercase mt-4 tracking-wider leading-tight">Incident Data</p>
        </div>

        <div id="statsCard_PSI" onclick="openStatsSpreadsheet('PSI')" class="bg-white dark:bg-slate-900 border border-gray-150 dark:border-slate-800/60 shadow-sm hover:shadow-2xl p-6 rounded-[2rem] flex flex-col justify-center text-left group cursor-pointer hover:scale-105 transition-all">
            <span id="statsLabel_PSI" class="text-[10px] text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-[0.2em] mb-2">PSI</span>
            <div id="statsCount_PSI" class="text-4xl font-black text-pnp-blue dark:text-pnp-gold leading-none count-up-glow" data-target="<%= displayStats['PSI'] || 0 %>" data-stat="PSI"><%= displayStats['PSI'] || 0 %></div>
            <p class="text-[10px] text-slate-400 font-bold uppercase mt-4 tracking-wider leading-tight">Safety Operations</p>
        </div>

        <button onclick="openManualEntry()" class="bg-white dark:bg-slate-900 border-2 border-dashed border-gray-200 dark:border-slate-700/60 p-6 rounded-[2rem] flex flex-col justify-center text-left group hover:border-pnp-blue dark:hover:border-pnp-gold transition-all relative overflow-hidden">
            <div class="absolute -right-4 -top-4 w-12 h-12 bg-pnp-blue/5 dark:bg-pnp-gold/5 rounded-full blur-xl group-hover:bg-pnp-blue/10 dark:group-hover:bg-pnp-gold/10 transition-all"></div>
            <div class="w-10 h-10 bg-pnp-blue/10 dark:bg-white/5 rounded-xl flex items-center justify-center text-pnp-blue dark:text-pnp-gold mb-4 group-hover:scale-110 transition-all border border-pnp-blue/10 dark:border-white/10">
                <i class="fas fa-keyboard"></i>
            </div>
            <div class="text-lg font-black text-slate-800 dark:text-white leading-none uppercase tracking-widest">Manual Input</div>
            <p class="text-[10px] text-slate-400 dark:text-white/30 font-bold uppercase mt-3 tracking-widest">Manual Entry</p>
        </button>

        <button onclick="document.getElementById('fileConverterInput').click()" class="pnp-card pnp-gradient-blue p-6 rounded-[2rem] shadow-2xl flex flex-col justify-center border-2 border-white/10 text-left group hover:-translate-y-2 relative overflow-hidden">
            <div class="absolute inset-0 bg-pnp-gold/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            <div class="flex justify-between items-start w-full relative z-10">
                <span class="text-[10px] text-pnp-gold font-black uppercase tracking-[0.3em] mb-2 group-hover:animate-pulse">Active Scanner</span>
                <span onclick="event.stopPropagation(); purgeTacticalData()" title="Purge System Placeholders" class="text-[11px] text-white/20 hover:text-red-400 transition-colors cursor-help">
                    <i class="fas fa-microchip"></i>
                </span>
            </div>
            <div class="text-xl font-black text-white leading-none uppercase tracking-tighter relative z-10">Report Scanner</div>
            <p class="text-[10px] text-white/40 font-bold uppercase mt-3 italic tracking-widest relative z-10">GPT-OSS 120B Scanner</p>
            <input type="file" id="fileConverterInput" accept=".xlsx,.xls,.docx,.pdf" class="hidden" onchange="handleIntelConvert(this)">
        </button>
    </div>

        <!-- Extraction Batches View -->
        <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 overflow-hidden">
            <div class="p-8 border-b border-gray-50 dark:border-slate-800 bg-gray-50/10 dark:bg-slate-900/50 flex justify-between items-center">
                <div>
                    <h3 class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-sm">Records Archive</h3>
                    <p class="text-[10px] text-slate-400 font-bold uppercase mt-1 tracking-widest italic">Batch History</p>
                </div>
                <div class="flex items-center space-x-4 w-full md:w-auto mt-4 md:mt-0">
                    <div class="relative w-full md:w-72">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-xs"></i>
                        <input type="text" id="reportSearchInput" maxlength="100" oninput="if(this.value.length>100)this.value=this.value.slice(0,100);" onkeyup="filterReports()" placeholder="Search reports..." class="w-full pl-10 pr-4 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-100 dark:border-slate-800 rounded-2xl outline-none text-[10px] font-black text-slate-600 dark:text-white uppercase tracking-widest focus:ring-2 focus:ring-pnp-blue/20 transition-all placeholder:text-gray-300">
                    </div>
                </div>
            </div>
    
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse min-w-[1000px] table-fixed">
                    <thead class="bg-gray-50/50 dark:bg-slate-950/50">
                        <tr>
                            <th class="w-44 px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800">Date</th>
                            <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800">File Name</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Volume</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">8-Focus</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Non-Index</th>
                            <th class="w-24 px-2 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Safety</th>
                            <th class="w-32 px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-center">Signal</th>
                            <th class="w-32 px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-gray-100 dark:border-slate-800 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-slate-800">
                        <% if (displayReports.length === 0) { %>
                            <tr>
                                <td colspan="8" class="px-8 py-40 text-center text-gray-300 dark:text-slate-700 font-black uppercase tracking-[0.5em] italic">
                                    <div class="flex flex-col items-center justify-center">
                                        <i class="fas fa-barcode text-6xl mb-6 opacity-20"></i>
                                        <span>No tactical data signals found</span>
                                    </div>
                                </td>
                            </tr>
                        <% } else { %>
                            <% displayReports.sort((a,b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime()).forEach(report => { %>
                                <tr class="hover:bg-pnp-blue/5 dark:hover:bg-slate-800/40 transition-all group relative overflow-hidden cursor-pointer" onclick="handleReportRowClick(event, '<%= report.id %>')" ondblclick="handleReportRowDblClick(event, '<%= report.id %>', '<%= encodeURIComponent(report.barangay || '') %>')">
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-[11px] font-black text-slate-800 dark:text-white uppercase tracking-tighter">
                                                <%= new Date(report.timestamp).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                            </span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div onclick="event.stopPropagation(); viewReportDetails('<%= report.id %>')" title="Click to view report details" class="flex flex-col truncate max-w-[250px] cursor-pointer group/file">
                                            <span class="text-[11px] font-black uppercase text-slate-700 dark:text-slate-200 tracking-tight leading-tight group-hover/file:text-pnp-blue dark:group-hover/file:text-pnp-gold transition duration-300 hover:underline"><%= report.filename || 'Manual Transmission' %></span>
                                            <div class="flex items-center space-x-2 mt-1">
                                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest italic opacity-70"><%= report.admin_name || 'Sys Admin' %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="w-24 px-2 py-6 text-center">
                                        <span class="text-sm font-black text-slate-800 dark:text-white tabular-nums tracking-tighter"><%= report.total_records || 0 %></span>
                                    </td>
                                    <td class="w-24 px-2 py-6 text-center">
                                        <span class="px-3 py-1.5 rounded-xl text-[10px] font-black <%= (report.category_stats && report.category_stats['8-Focus']) > 0 ? 'bg-red-500/10 text-red-600 border border-red-500/10' : 'bg-gray-50 dark:bg-slate-800 text-gray-300 dark:text-slate-700' %>">
                                            <%= (report.category_stats && report.category_stats['8-Focus']) || 0 %>
                                        </span>
                                    </td>
                                    <td class="w-24 px-2 py-6 text-center">
                                        <span class="px-3 py-1.5 rounded-xl text-[10px] font-black <%= (report.category_stats && report.category_stats['Non-Index']) > 0 ? 'bg-blue-500/10 text-blue-500 border border-blue-500/10' : 'bg-gray-50 dark:bg-slate-800 text-gray-300 dark:text-slate-700' %>">
                                            <%= (report.category_stats && report.category_stats['Non-Index']) || 0 %>
                                        </span>
                                    </td>
                                    <td class="w-24 px-2 py-6 text-center">
                                        <span class="px-3 py-1.5 rounded-xl text-[10px] font-black <%= (report.category_stats && report.category_stats['PSI']) > 0 ? 'bg-pnp-gold/10 text-pnp-gold border border-pnp-gold/20' : 'bg-gray-50 dark:bg-slate-800 text-gray-300 dark:text-slate-700' %>">
                                            <%= (report.category_stats && report.category_stats['PSI']) || 0 %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-center">
                                        <% if (report.category_stats?.entry_type === 'manual' || report.filename?.includes('Manual')) { %>
                                            <span onclick="event.stopPropagation(); viewReportDetails('<%= report.id %>')" title="Click to view report details" class="px-4 py-2 rounded-2xl bg-emerald-500/5 text-emerald-500 hover:bg-emerald-500/15 text-[10px] font-black uppercase tracking-[0.2em] border border-emerald-500/10 cursor-pointer hover:scale-105 active:scale-95 transition-all inline-block shadow-sm">MANUAL</span>
                                        <% } else { %>
                                            <span onclick="event.stopPropagation(); viewReportDetails('<%= report.id %>')" title="Click to view report details" class="px-4 py-2 rounded-2xl bg-pnp-blue/5 text-pnp-blue-300 hover:bg-pnp-blue/15 text-[10px] font-black uppercase tracking-[0.2em] border border-pnp-blue/10 cursor-pointer hover:scale-105 active:scale-95 transition-all inline-block shadow-sm">SCANNED</span>
                                        <% } %>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <div class="flex items-center justify-end space-x-3">
                                            <form id="deleteReportForm_<%= report.id %>" action="/admin/reports/<%= report.id %>/delete" method="POST" onsubmit="confirmDeleteReport(event, '<%= report.id %>'); return false;">
                                                <button type="submit" class="w-10 h-10 rounded-2xl bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-white dark:hover:bg-slate-700 transition-all flex items-center justify-center border border-transparent hover:border-red-500/20 shadow-sm">
                                                    <i class="fas fa-trash-alt text-xs"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Records Archive Pagination Controls (5 per page) -->
            <div id="reportsPaginationContainer" class="px-8 py-5 border-t border-gray-100 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center bg-gray-50/50 dark:bg-slate-900/50 gap-4">
                <div class="text-[11px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">
                    Showing <span id="paginationRangeText" class="font-black text-slate-700 dark:text-slate-200">1 - 5</span> of <span id="paginationTotalText" class="font-black text-slate-700 dark:text-slate-200">0</span> Records
                </div>
                <div class="flex items-center space-x-3">
                    <button id="btnPrevPage" type="button" onclick="changeReportsPage(-1)" class="px-4 py-2.5 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-[10px] font-black text-slate-600 dark:text-slate-300 uppercase tracking-wider hover:bg-pnp-blue hover:text-white dark:hover:bg-pnp-gold dark:hover:text-slate-900 transition disabled:opacity-30 disabled:cursor-not-allowed shadow-sm flex items-center space-x-2">
                        <i class="fas fa-chevron-left text-[9px]"></i>
                        <span>Previous</span>
                    </button>
                    <span id="paginationPageIndicator" class="px-3 py-2 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest bg-pnp-blue/5 dark:bg-slate-800 rounded-xl border border-pnp-blue/10">
                        Page 1 of 1
                    </span>
                    <button id="btnNextPage" type="button" onclick="changeReportsPage(1)" class="px-4 py-2.5 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-[10px] font-black text-slate-600 dark:text-slate-300 uppercase tracking-wider hover:bg-pnp-blue hover:text-white dark:hover:bg-pnp-gold dark:hover:text-slate-900 transition disabled:opacity-30 disabled:cursor-not-allowed shadow-sm flex items-center space-x-2">
                        <span>Next</span>
                        <i class="fas fa-chevron-right text-[9px]"></i>
                    </button>
                </div>
            </div>
        </div>
</div>

<!-- Modal for raw data view (Polished Spreadsheet Style) -->
<div id="reportDetailsModal" class="fixed inset-0 z-[1500] hidden items-center justify-center bg-slate-900/90 backdrop-blur-md p-4">
    <div class="bg-white dark:bg-slate-800 w-full max-w-[95vw] lg:max-w-7xl rounded-[3rem] shadow-2xl border border-white/10 overflow-hidden flex flex-col max-h-[95vh] animate-fade-in-up">
        <div class="p-8 border-b border-gray-100 dark:border-slate-700 flex justify-between items-center bg-gray-50/50 dark:bg-slate-900/50 relative overflow-hidden">
            <!-- Decorative Accent -->
            <div class="absolute top-0 left-0 w-2 h-full bg-pnp-blue dark:bg-pnp-gold"></div>
            
            <div class="flex items-center space-x-6 pl-2">
                <div class="w-14 h-14 bg-pnp-blue rounded-2xl flex items-center justify-center text-pnp-gold shadow-lg rotate-3 border-2 border-white/20">
                    <i class="fas fa-file-invoice text-2xl"></i>
                </div>
                <div>
                    <h3 id="reportDetailsTitle" class="font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-[0.3em] text-lg">Recorded Intelligence</h3>
                </div>
            </div>
            <button onclick="closeReportDetails()" class="w-12 h-12 rounded-2xl bg-gray-100 dark:bg-slate-700 text-gray-500 hover:bg-red-500 hover:text-white transition-all transform hover:rotate-90 flex items-center justify-center shadow-sm">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div id="reportDetailsContent" class="p-0 overflow-y-auto custom-scrollbar flex-grow bg-gray-50/30 dark:bg-slate-900/10"></div>
    </div>
</div>

<!-- Intelligence Review Modal (Polished Grid Spreadsheet Style) -->
<style>
  .no-calendar-picker::-webkit-calendar-picker-indicator,
  .no-calendar-picker::-webkit-inner-spin-button {
      display: none !important;
      -webkit-appearance: none !important;
  }
  .no-calendar-picker {
      -moz-appearance: textfield !important;
  }
</style>
<div id="intelReviewModal" class="fixed inset-0 z-[2500] hidden items-center justify-center bg-slate-900/95 backdrop-blur-xl p-4">
    <div class="bg-white dark:bg-slate-800 w-full max-w-[95vw] lg:max-w-7xl rounded-[3rem] shadow-[0_0_100px_rgba(0,0,0,0.5)] border border-white/10 overflow-hidden animate-fade-in-up flex flex-col h-[90vh] max-h-[90vh]">
        <div class="p-8 border-b border-gray-100 dark:border-slate-700 bg-pnp-blue/5 dark:bg-slate-900/50 flex flex-col lg:flex-row justify-between items-start lg:items-center space-y-4 lg:space-y-0 flex-shrink-0">
            <div class="flex items-center space-x-5">
                <div class="w-14 h-14 bg-pnp-blue dark:bg-pnp-gold rounded-2xl flex items-center justify-center text-white dark:text-pnp-blue shadow-2xl rotate-3 border-2 border-white/20">
                    <i id="reviewModalIcon" class="fas fa-file-excel text-2xl"></i>
                </div>
                <div>
                    <h3 id="reviewModalTitle" class="text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-[0.3em] text-sm">Manual Input</h3>
                    <p id="reviewRowCount" class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-1">Staging Area: Validating Confirm...</p>
                </div>
            </div>

            <div class="flex items-center space-x-4 bg-white dark:bg-slate-700 p-2 rounded-2xl border border-gray-100 dark:border-slate-600 shadow-inner">
                <select id="reviewCategoryFilter" onchange="renderReviewTable()" class="bg-transparent border-none text-xs font-black text-pnp-blue dark:text-pnp-gold uppercase px-6 py-2 outline-none">
                    <option value="All">All</option>
                    <option value="8-Focus">8-Focus Target</option>
                    <option value="Non-Index">Non-Index</option>
                    <option value="PSI">PSI Sector</option>
                </select>
                <div class="w-px h-6 bg-gray-100 dark:bg-slate-600"></div>
                <div class="flex items-center space-x-5 px-6 py-2">
                    <div class="flex items-center space-x-2"><div class="w-2.5 h-2.5 rounded-full bg-red-500 shadow-sm shadow-red-500/50"></div><span id="count8Focus" class="text-sm font-black text-pnp-blue dark:text-white">0</span></div>
                    <div class="flex items-center space-x-2"><div class="w-2.5 h-2.5 rounded-full bg-slate-500 shadow-sm shadow-slate-500/50"></div><span id="countNonIndex" class="text-sm font-black text-pnp-blue dark:text-white">0</span></div>
                    <div class="flex items-center space-x-2"><div class="w-2.5 h-2.5 rounded-full bg-blue-500 shadow-sm shadow-blue-500/50"></div><span id="countPSI" class="text-sm font-black text-pnp-blue dark:text-white">0</span></div>
                </div>
            </div>
        </div>

        <div class="flex-grow overflow-auto p-6 bg-gray-50/50 dark:bg-slate-900/30 custom-scrollbar min-h-0">
            <div class="bg-white dark:bg-slate-800 rounded-3xl border border-gray-200 dark:border-slate-700 shadow-xl overflow-hidden">
                <table class="w-full text-left border-collapse table-fixed">
                    <thead class="sticky top-0 z-20 shadow-sm">
                        <tr class="bg-gray-100 dark:bg-slate-900 border-b border-gray-200 dark:border-slate-700">
                            <th class="px-2 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-200 dark:border-slate-700 w-14 text-center bg-gray-100 dark:bg-slate-900">
                                <button onclick="addNewSingleRow()" title="Add Single Row" class="w-7 h-7 rounded-lg bg-pnp-blue text-white hover:bg-black dark:bg-pnp-gold dark:text-slate-900 dark:hover:bg-white transition flex items-center justify-center mx-auto shadow-sm">
                                    <i class="fas fa-plus text-xs"></i>
                                </button>
                            </th>
                            <th class="px-4 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-200 dark:border-slate-700 w-16 text-center bg-gray-100 dark:bg-slate-900">ROW</th>
                            <th class="hidden px-6 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-200 dark:border-slate-700 w-1/4 bg-gray-100 dark:bg-slate-900">Source Intelligence</th>
                            <th class="px-6 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-200 dark:border-slate-700 w-48 bg-gray-100 dark:bg-slate-900">Sector (Barangay)</th>
                            <th class="px-6 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-200 dark:border-slate-700 w-40 bg-gray-100 dark:bg-slate-900">Timeline</th>
                            <th class="px-6 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-200 dark:border-slate-700 w-64 bg-gray-100 dark:bg-slate-900">Classification</th>
                            <th class="px-6 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-200 dark:border-slate-700 w-36 bg-gray-100 dark:bg-slate-900">Category</th>
                            <th class="px-2 py-5 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest w-16 text-center bg-gray-100 dark:bg-slate-900">X</th>
                        </tr>
                    </thead>
                    <tbody id="reviewTableBody" class="divide-y divide-gray-100 dark:divide-slate-700/50"></tbody>
                </table>
            </div>
        </div>

        <div class="p-8 border-t border-gray-100 dark:border-slate-700 bg-white dark:bg-slate-800 flex justify-between items-center relative z-10 flex-shrink-0">
            <div class="flex items-center space-x-3">
                <button onclick="addNewSingleRow()" class="px-6 py-4 bg-gray-50 dark:bg-slate-700/50 border border-gray-200 dark:border-slate-600 rounded-2xl text-xs font-black text-pnp-blue dark:text-white uppercase tracking-widest hover:bg-gray-100 dark:hover:bg-slate-600 transition shadow-sm group flex items-center space-x-2">
                    <i class="fas fa-plus text-pnp-blue dark:text-pnp-gold group-hover:scale-125 transition"></i>
                    <span>Add Row</span>
                </button>
                <button onclick="openBatchGeneratorModal()" class="px-6 py-4 bg-pnp-blue/10 dark:bg-pnp-gold/10 border border-pnp-blue/20 dark:border-pnp-gold/20 rounded-2xl text-xs font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest hover:bg-pnp-blue hover:text-white dark:hover:bg-pnp-gold dark:hover:text-slate-900 transition shadow-sm group flex items-center space-x-2">
                    <i class="fas fa-layer-group group-hover:scale-125 transition"></i>
                    <span>Add Multiple Rows</span>
                </button>
            </div>
            <div class="flex items-center space-x-4">
                <button onclick="closeIntelReview()" class="px-8 py-4 text-xs font-black text-slate-400 uppercase tracking-[0.2em] hover:text-red-500 transition-all">Cancel</button>
                <button onclick="confirmIntelReview()" class="px-12 py-5 bg-pnp-blue hover:bg-black text-white rounded-2xl text-xs font-black uppercase tracking-[0.3em] shadow-2xl shadow-pnp-blue/30 transition-all transform hover:scale-[1.02] active:scale-95 flex items-center space-x-3">
                    <i class="fas fa-shield-check"></i>
                    <span>Confirm</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Batch Generator Modal (Prompt for generating N rows with common values) -->
<div id="batchGeneratorModal" class="fixed inset-0 z-[2600] hidden items-center justify-center bg-slate-950/80 backdrop-blur-md p-4">
    <div class="bg-white dark:bg-slate-800 w-full max-w-lg rounded-3xl shadow-2xl border border-gray-200 dark:border-slate-700 overflow-hidden flex flex-col animate-fade-in-up">
        <div class="p-6 border-b border-gray-100 dark:border-slate-700 bg-pnp-blue/5 dark:bg-slate-900/50 flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 rounded-xl bg-pnp-blue text-white dark:bg-pnp-gold dark:text-slate-900 flex items-center justify-center font-bold">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div>
                    <h4 class="font-black text-pnp-blue dark:text-pnp-gold text-sm uppercase tracking-wider">Generate Data Rows</h4>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Batch Row Parameters</p>
                </div>
            </div>
            <button type="button" onclick="closeBatchGeneratorModal()" class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-slate-700 text-gray-400 hover:text-red-500 flex items-center justify-center transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <div class="p-6 space-y-4 text-left">
            <div>
                <div class="flex justify-between items-center mb-1">
                    <label class="block text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest">Number of Rows to Generate</label>
                    <span class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase">Max: 50</span>
                </div>
                <input type="number" id="batchCount" min="1" max="50" value="1" placeholder="1-50" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-800 dark:text-white outline-none focus:ring-2 focus:ring-pnp-blue">
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-1">Sector (Barangay)</label>
                <select id="batchBarangaySelect" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-800 dark:text-white outline-none focus:ring-2 focus:ring-pnp-blue cursor-pointer">
                </select>
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-1">Timeline Date</label>
                <div class="grid grid-cols-3 gap-2">
                    <div>
                        <label class="block text-[8px] font-black text-slate-400 uppercase tracking-wider mb-1">Day (DD)</label>
                        <select id="batchDaySelect" class="w-full px-3 py-2.5 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-800 dark:text-white outline-none focus:ring-2 focus:ring-pnp-blue cursor-pointer">
                            <% for(let d = 1; d <= 31; d++) { %>
                                <% const dd = String(d).padStart(2, '0'); %>
                                <option value="<%= dd %>"><%= dd %></option>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[8px] font-black text-slate-400 uppercase tracking-wider mb-1">Month</label>
                        <select id="batchMonthSelect" class="w-full px-3 py-2.5 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-800 dark:text-white outline-none focus:ring-2 focus:ring-pnp-blue cursor-pointer">
                            <% const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']; %>
                            <% months.forEach((mName, idx) => { %>
                                <% const mm = String(idx + 1).padStart(2, '0'); %>
                                <option value="<%= mm %>"><%= mName %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[8px] font-black text-slate-400 uppercase tracking-wider mb-1">Year (YYYY)</label>
                        <select id="batchYearSelect" class="w-full px-3 py-2.5 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-800 dark:text-white outline-none focus:ring-2 focus:ring-pnp-blue cursor-pointer">
                            <option value="2026">2026</option>
                            <option value="2025">2025</option>
                            <option value="2024">2024</option>
                            <option value="2023">2023</option>
                            <option value="2022">2022</option>
                        </select>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-1">Category</label>
                <select id="batchCategorySelect" onchange="onBatchCategoryChange(this.value)" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-800 dark:text-white outline-none focus:ring-2 focus:ring-pnp-blue cursor-pointer">
                    <option value="8-Focus">8-Focus</option>
                    <option value="Non-Index" selected>Non-Index</option>
                    <option value="PSI">PSI</option>
                </select>
            </div>

            <div>
                <div class="flex justify-between items-center mb-1">
                    <label class="block text-[10px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest">Classification (Offense)</label>
                    <span class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase">Max: 100 chars</span>
                </div>
                <input type="text" id="batchOffenseInput" list="batchCrimesList" maxlength="100" oninput="if(this.value.length>100)this.value=this.value.slice(0,100);" placeholder="Type or select classification..." class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl text-xs font-black text-pnp-blue dark:text-pnp-gold uppercase outline-none focus:ring-2 focus:ring-pnp-blue">
                <datalist id="batchCrimesList"></datalist>
            </div>
        </div>

        <div class="p-6 border-t border-gray-100 dark:border-slate-700 bg-gray-50/50 dark:bg-slate-900/50 flex justify-end space-x-3">
            <button type="button" onclick="closeBatchGeneratorModal()" class="px-6 py-3 rounded-xl text-xs font-black text-gray-400 uppercase hover:text-slate-700 dark:hover:text-white transition">Cancel</button>
            <button type="button" onclick="executeBatchGeneration()" class="px-8 py-3 bg-pnp-blue hover:bg-black text-white rounded-xl text-xs font-black uppercase tracking-wider shadow-lg flex items-center space-x-2 transition">
                <i class="fas fa-plus-circle"></i>
                <span>Generate Rows</span>
            </button>
        </div>
    </div>
</div>

<script type="module">

    const VALID_BARANGAYS = [
        "Alipit", "Bagumbayan", "Bubukal", "Calios", "Duhat", "Gatid", "Jasaan", "Labuin", 
        "Malinao", "Oogong", "Pagsawitan", "Palasan", "Patimbao", "Poblacion I (Barangay I)", 
        "Poblacion II (Barangay II)", "Poblacion III (Barangay III)", "Poblacion IV (Barangay IV)", 
        "Poblacion V (Barangay V)", "San Jose", "San Juan", "San Pablo Norte", "San Pablo Sur", 
        "Santisima Cruz", "Santo Angel Central", "Santo Angel Norte", "Santo Angel Sur"
    ];
    window.VALID_BARANGAYS = VALID_BARANGAYS;
    
    const CRIMES_BY_PILLAR = {
        '8-Focus': ['Murder', 'Homicide', 'Physical Injuries', 'Rape', 'Robbery', 'Theft', 'Carnapping (Motorcycle)', 'Carnapping (Motor Vehicle)'],
        'Non-Index': ['Violence Against Women and Children (VAWC)', 'Cybercrime', 'Estafa', 'Swindling / Fraud', 'Drug Possession', 'Drug Sale', 'Drug Use', 'Illegal Gambling', 'Illegal Possession of Firearms', 'Human Trafficking', 'Child Abuse (RA 7610)', 'Damage to Property', 'Malicious Mischief', 'Cybercrime (Online Fraud, Hacking, Identity Theft, Cyber Libel)', 'Illegal Recruitment', 'Ordinance Violations', 'Grave Threats', 'Alarm and Scandal'],
        'PSI': ['Vehicular Accident', 'Road Accident / Traffic Incident', 'Fire Incident', 'Flood Incident', 'Earthquake Incident', 'Landslide Incident', 'Disaster Incident Reports', 'Public Disturbance Incident', 'Emergency Response Incident', 'Missing Person Report', 'Rescue Operation Cases']
    };
    window.CRIMES_BY_PILLAR = CRIMES_BY_PILLAR;

    window.getCategoryExamples = function(cat) {
        if (cat === '8-Focus') {
            return "Murder, Homicide, Physical Injuries, Rape, Robbery, Theft, Carnapping (Motorcycle), Carnapping (Motor Vehicle)";
        } else if (cat === 'Non-Index') {
            return "VAWC, Cybercrime, Estafa, Swindling, Drug Offenses, Illegal Gambling, Ordinance Violations, etc.";
        } else if (cat === 'PSI') {
            return "Vehicular Accident, Road Accident, Fire Incident, Flood Incident, Earthquake Incident, Landslide Incident, etc.";
        } else if (cat === 'All') {
            return "All Classifications: 8-Focus (Murder, Theft, etc.), Non-Index (VAWC, Cybercrime, etc.), PSI (Accidents, Fire, etc.)";
        }
        return "";
    };

     window.handleIntelConvert = async function(input) {
        if (!input.files || !input.files[0]) return;

        const file = input.files[0];
        
        // Verification Protocol: Check for existing intelligence batches
        if (window.reports && window.reports.some(r => r.filename === file.name)) {
            window.strategicAlert({
                title: "Duplicate Signal Detected",
                message: `The intelligence batch [${file.name}] is already archived in the CPICRS database. Re-scanning duplicate datasets is restricted to preserve structural integrity.`,
                type: "warning"
            });
            input.value = '';
            return;
        }

        const loadingOverlay = document.getElementById('intelLoadingOverlay');
        const statusText = document.getElementById('intelLoadingText');

        loadingOverlay.classList.remove('hidden');

        try {
            const formData = new FormData();
            formData.append('file', file);

            statusText.textContent = `Scanned File: ${file.name} - Extracting via GPT-OSS 120B...`;

            // ✅ Targeted route for AI processing
            const res = await fetch('/admin/process-ai', {
                method: 'POST',
                body: formData
            });

            if (!res.ok) {
                const errText = await res.text();
                throw new Error(errText);
            }

            const result = await res.json();

            if (!result.success) {
                throw new Error(result.error || "GPT-OSS 120B processing failed");
            }

            const flattened = result.data;

            if (flattened.length === 0) {
                window.strategicAlert({
                    title: "Neural Scan Negative",
                    message: "No incident records detected in this document. Please verify source data.",
                    type: "warning"
                });
                return;
            }

            lastProcessedFile = { name: file.name, size: file.size };
            showIntelReview(flattened, file.name);

        } catch (error) {
            console.error("GPT-OSS 120B Error:", error);
            window.strategicAlert({
                title: "Extraction Failure",
                message: error.message,
                type: "danger"
            });
        } finally {
            loadingOverlay.classList.add('hidden');
            input.value = '';
        }
    };
     let reviewData = [];
     let currentFilename = "";
     let currentEntryType = "scanned";
     let lastProcessedFile = { name: "", size: 0 };     let targetInsertIndex = null;

     window.openBatchGeneratorModal = function(insertIndex = null) {
         targetInsertIndex = insertIndex;
         const now = new Date();
         const todayDay = String(now.getDate()).padStart(2, '0');
         const todayMonth = String(now.getMonth() + 1).padStart(2, '0');
         const todayYear = String(now.getFullYear());
         
         const modal = document.getElementById('batchGeneratorModal');
         const brgySelect = document.getElementById('batchBarangaySelect');
         const daySelect = document.getElementById('batchDaySelect');
         const monthSelect = document.getElementById('batchMonthSelect');
         const yearSelect = document.getElementById('batchYearSelect');
         const countInput = document.getElementById('batchCount');
         const offenseInput = document.getElementById('batchOffenseInput');
         const catSelect = document.getElementById('batchCategorySelect');

         if (brgySelect) {
             brgySelect.innerHTML = VALID_BARANGAYS.map(b => `<option value="${b}">${b}</option>`).join('');
         }
         
         if (daySelect) daySelect.value = todayDay;
         if (monthSelect) monthSelect.value = todayMonth;
         if (yearSelect) yearSelect.value = todayYear;

         if (countInput) countInput.value = '1';
         if (offenseInput) offenseInput.value = '';
         if (catSelect) catSelect.value = 'Non-Index';
         
         window.onBatchCategoryChange('Non-Index');

         if (modal) {
             modal.classList.remove('hidden');
             modal.classList.add('flex');
         }
     };

     window.closeBatchGeneratorModal = function() {
         const modal = document.getElementById('batchGeneratorModal');
         if (modal) {
             modal.classList.add('hidden');
             modal.classList.remove('flex');
         }
     };

     window.onBatchCategoryChange = function(cat) {
         const datalist = document.getElementById('batchCrimesList');
         const crimeOptions = CRIMES_BY_PILLAR[cat] || [];
         if (datalist) {
             datalist.innerHTML = crimeOptions.map(o => `<option value="${o}">`).join('');
         }
         const offenseInput = document.getElementById('batchOffenseInput');
         if (offenseInput) offenseInput.value = '';
     };

     window.executeBatchGeneration = function() {
         const countInput = document.getElementById('batchCount');
         const brgySelect = document.getElementById('batchBarangaySelect');
         const daySelect = document.getElementById('batchDaySelect');
         const monthSelect = document.getElementById('batchMonthSelect');
         const yearSelect = document.getElementById('batchYearSelect');
         const catSelect = document.getElementById('batchCategorySelect');
         const offenseInput = document.getElementById('batchOffenseInput');

         const rawCount = parseInt(countInput ? countInput.value : '1') || 0;
         if (rawCount < 1) {
             window.strategicAlert({
                 title: "Invalid Row Count",
                 message: "Please enter a valid number of rows (minimum 1).",
                 type: "warning"
             });
             return;
         }
         if (rawCount > 50) {
             window.strategicAlert({
                 title: "Row Limit Exceeded",
                 message: "Maximum row generation limit is 50 rows per batch.",
                 type: "warning"
             });
             return;
         }
         const count = rawCount;
         const barangay = (brgySelect ? brgySelect.value : '') || VALID_BARANGAYS[0];
         
         const dayVal = daySelect ? daySelect.value : String(new Date().getDate()).padStart(2, '0');
         const monthVal = monthSelect ? monthSelect.value : String(new Date().getMonth() + 1).padStart(2, '0');
         const yearVal = yearSelect ? yearSelect.value : String(new Date().getFullYear());
         const dateVal = `${yearVal}-${monthVal}-${dayVal}`;

         const category = (catSelect ? catSelect.value : '') || 'Non-Index';
         const offense = offenseInput ? offenseInput.value.trim() : '';

         const todayStr = new Date().toISOString().split('T')[0];

         if (!dateVal || dateVal > todayStr || dateVal < '2024-01-01') {
             window.strategicAlert({
                 title: "Invalid Timeline Date",
                 message: `Timeline date must be between January 1, 2024 and today (${todayStr}). Future dates are restricted.`,
                 type: "warning"
             });
             return;
         }

         const newRows = [];
         for (let i = 0; i < count; i++) {
             newRows.push({
                 barangay: barangay,
                 date_committed: dateVal,
                 offense: offense,
                 category: category,
                 description: ''
             });
         }

         if (targetInsertIndex !== null && targetInsertIndex >= 0 && targetInsertIndex <= reviewData.length) {
             reviewData.splice(targetInsertIndex, 0, ...newRows);
         } else {
             reviewData.push(...newRows);
         }

         closeBatchGeneratorModal();
         renderReviewTable();

         setTimeout(() => {
             const tbody = document.getElementById('reviewTableBody');
             const container = tbody ? tbody.closest('.overflow-auto') : null;
             if (container) {
                 container.scrollTop = container.scrollHeight;
             }
         }, 50);
     };

     window.openManualEntry = function() {
         reviewData = [{ 
             barangay: VALID_BARANGAYS[0], 
             date_committed: new Date().toISOString().split('T')[0], 
             offense: '', 
             category: 'Non-Index', 
             description: '' 
         }];
         currentFilename = "Manual Entry Session";
         currentEntryType = "manual";
         
         const modal = document.getElementById('intelReviewModal');
         const title = document.getElementById('reviewModalTitle') || modal.querySelector('h3');
         const subtitle = document.getElementById('reviewRowCount');
         const icon = document.getElementById('reviewModalIcon');
         
         if (title) title.textContent = "Manual Input";
         if (subtitle) subtitle.textContent = "Direct Data Entry";
         if (icon) icon.className = "fas fa-keyboard text-2xl";
         
         renderReviewTable();
         modal.classList.remove('hidden');
         modal.classList.add('flex');
     };

     window.showIntelReview = function(data, filename = "") {
         reviewData = data;
         currentFilename = filename;
         currentEntryType = "scanned";
         
         const modal = document.getElementById('intelReviewModal');
         const title = document.getElementById('reviewModalTitle') || modal.querySelector('h3');
         const subtitle = document.getElementById('reviewRowCount');
         const icon = document.getElementById('reviewModalIcon');
         
         if (title) title.textContent = "Scanned Document";
         if (subtitle) subtitle.textContent = `${reviewData.length} records detected in periodic report`;
         if (icon) icon.className = "fas fa-microchip text-2xl";
         
         renderReviewTable();
         modal.classList.remove('hidden');
         modal.classList.add('flex');
     };
  
     window.renderReviewTable = function() {
         const tbody = document.getElementById('reviewTableBody');
         const filter = document.getElementById('reviewCategoryFilter').value;
         tbody.innerHTML = '';
         let stats = { '8-Focus': 0, 'Non-Index': 0, 'PSI': 0 };
         let displayIndex = 1;

         const CRIMES_BY_PILLAR = {
             '8-Focus': ['Murder', 'Homicide', 'Physical Injuries', 'Rape', 'Robbery', 'Theft', 'Carnapping (Motorcycle)', 'Carnapping (Motor Vehicle)'],
             'Non-Index': ['Violence Against Women and Children (VAWC)', 'Cybercrime', 'Estafa', 'Swindling / Fraud', 'Drug Possession', 'Drug Sale', 'Drug Use', 'Illegal Gambling', 'Illegal Possession of Firearms', 'Human Trafficking', 'Child Abuse (RA 7610)', 'Damage to Property', 'Malicious Mischief', 'Cybercrime (Online Fraud, Hacking, Identity Theft, Cyber Libel)', 'Illegal Recruitment', 'Ordinance Violations', 'Grave Threats', 'Alarm and Scandal'],
             'PSI': ['Vehicular Accident', 'Road Accident / Traffic Incident', 'Fire Incident', 'Flood Incident', 'Earthquake Incident', 'Landslide Incident', 'Disaster Incident Reports', 'Public Disturbance Incident', 'Emergency Response Incident', 'Missing Person Report', 'Rescue Operation Cases']
         };

         reviewData.forEach((item, index) => {
             const cat = item.category || 'Non-Index';
             stats[cat]++;
             if (filter !== 'All' && cat !== filter) return;
   
             const tr = document.createElement('tr');
             tr.className = 'bg-white dark:bg-slate-900 transition-all hover:bg-pnp-blue/5 dark:hover:bg-slate-700/50 animate-fade-in-up group border-b border-gray-100 dark:border-slate-800';
             tr.style.animationDelay = `${index * 20}ms`;
             
             const isFocus = cat === '8-Focus';
             const isPSI = cat === 'PSI';
             const badgeClass = isFocus ? 'bg-red-500/10 text-red-500' : isPSI ? 'bg-blue-500/10 text-blue-500' : 'bg-slate-500/10 text-slate-500';
             
             const offenseValue = item.offense || item.incident_type || '';
             const crimeOptions = CRIMES_BY_PILLAR[cat] || [];
             
             const rawDateStr = item.date_committed || item.date || new Date().toISOString().split('T')[0];
             const dateParts = rawDateStr.split('-');
             const itemYear = dateParts[0] || '2026';
             const itemMonth = dateParts[1] || '01';
             const itemDay = dateParts[2] || '01';
             
             tr.innerHTML = `
                 <td class="px-2 py-4 text-center border-r border-gray-100 dark:border-slate-800 w-14">
                     <button onclick="insertReviewRowAt(${index + 1})" title="Insert / Generate Rows Below" class="w-7 h-7 rounded-lg bg-pnp-blue/10 dark:bg-pnp-gold/10 text-pnp-blue dark:text-pnp-gold hover:bg-pnp-blue hover:text-white dark:hover:bg-pnp-gold dark:hover:text-slate-900 transition flex items-center justify-center mx-auto">
                         <i class="fas fa-plus text-[10px]"></i>
                     </button>
                 </td>
                 <td class="px-4 py-4 text-[10px] font-black text-gray-400 border-r border-gray-100 dark:border-slate-800 w-16 text-center tabular-nums">${displayIndex++}</td>
                 <td class="hidden px-6 py-4 text-[10px] font-bold text-slate-400 border-r border-gray-100 dark:border-slate-800 truncate max-w-[120px]" title="${currentFilename}">
                    ${currentFilename || 'Buffer'}
                 </td>
                 <td class="px-0 py-0 border-r border-gray-100 dark:border-slate-800 focus-within:bg-pnp-blue/5 transition-colors w-48">
                    <select onchange="updateReviewItem(${index}, 'barangay', this.value)" class="w-full h-full bg-transparent border-none text-[11px] font-black text-slate-700 dark:text-white uppercase outline-none focus:ring-0 p-4 cursor-pointer">
                        ${VALID_BARANGAYS.map(b => `<option value="${b}" ${b === item.barangay ? 'selected' : ''} class="dark:bg-slate-900">${b}</option>`).join('')}
                    </select>
                 </td>
                 <td class="px-2 py-2 border-r border-gray-100 dark:border-slate-800 focus-within:bg-pnp-blue/5 transition-colors w-56">
                    <div class="flex items-center space-x-1 justify-center">
                        <select onchange="updateReviewItemDate(${index}, 'day', this.value)" title="Day (DD)" class="w-14 bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg text-[10px] font-black text-slate-800 dark:text-white px-1 py-1.5 outline-none focus:ring-1 focus:ring-pnp-blue cursor-pointer text-center">
                            ${[...Array(31)].map((_, i) => {
                                const d = String(i + 1).padStart(2, '0');
                                return `<option value="${d}" ${d === itemDay ? 'selected' : ''} class="dark:bg-slate-900">${d}</option>`;
                            }).join('')}
                        </select>
                        <span class="text-slate-400 font-bold text-[10px]">/</span>
                        <select onchange="updateReviewItemDate(${index}, 'month', this.value)" title="Month" class="w-16 bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg text-[10px] font-black text-slate-800 dark:text-white px-1 py-1.5 outline-none focus:ring-1 focus:ring-pnp-blue cursor-pointer text-center">
