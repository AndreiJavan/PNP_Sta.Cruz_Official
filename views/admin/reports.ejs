         const elPSI = document.querySelector('[data-stat="PSI"]');
         const elNon = document.querySelector('[data-stat="Non-Index"]');

         if (el8) { el8.dataset.target = total8FocusAll; el8.textContent = total8FocusAll; }
         if (elPSI) { elPSI.dataset.target = totalPSIAll; elPSI.textContent = totalPSIAll; }
         if (elNon) { elNon.dataset.target = totalNonIndexAll; elNon.textContent = totalNonIndexAll; }

         animateStats();
     }

     window.purgeTacticalData = async function() {
        const btn = document.querySelector('span[onclick*="purgeTacticalData"]');
        if (btn && btn.dataset.isPurging === 'true') return;

        const confirmed = await (window.strategicConfirm || (async () => confirm("This will purge all system placeholders and test intelligence batches. Dashboard counts will be reset. Proceed?")))({
            title: "Tactical Data Purge",
            message: "This will purge all system placeholders and test intelligence batches. Dashboard counts will be reset. Proceed?",
            confirmText: "Execute Purge",
            type: "danger"
        });
        if (!confirmed) return;

        if (btn) btn.dataset.isPurging = 'true';

        try {
            const res = await fetch('/admin/map/purge-placeholders', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                await window.strategicAlert({
                    title: "Purge Executed",
                    message: `${result.count} pins and ${result.reportsPurged} records have been identified and neutralized.`,
                    type: "info"
                });
                location.reload();
            }
        } catch (error) {
            window.strategicAlert({
                title: "Command Failure",
                message: "Intelligence link lost. Purge sequence interrupted.",
                type: "danger"
            });
            if (btn) btn.dataset.isPurging = 'false';
        }
     }

    window.confirmDeleteReport = async function(event, reportId) {
        if (event) event.preventDefault();
        
        const btn = document.querySelector(`#deleteReportForm_${reportId} button`);
        if (btn && btn.disabled) return false;

        const confirmed = await window.strategicConfirm({
            title: "Purge Confirmation",
            message: "Secure Warning: Purging this intelligence record is irreversible. Are you sure you want to proceed?",
            confirmText: "Delete Permanently",
            type: "danger"
        });

        if (confirmed) {
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            }
            const form = document.getElementById(`deleteReportForm_${reportId}`);
            if (form) form.submit();
        }
        return false;
    }

    window.filterReports = function() {
        const input = document.getElementById('reportSearchInput').value.toLowerCase();
        const rows = document.querySelectorAll('tbody.divide-y tr.group');
        rows.forEach(row => {
            const title = row.querySelector('td:nth-child(2) span.text-\\[11px\\]')?.textContent.toLowerCase() || '';
            const subtitle = row.querySelector('td:nth-child(2) span.text-\\[10px\\]')?.textContent.toLowerCase() || '';
            if (title.includes(input) || subtitle.includes(input)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
