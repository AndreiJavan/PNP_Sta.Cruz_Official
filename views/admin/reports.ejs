        </div>
    </div>

    <!-- Tactical Dataset (Spreadsheet View) -->
    <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-8 border-b border-gray-50 dark:border-slate-700 flex flex-col md:flex-row justify-between items-center bg-gray-50/10 gap-6">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-pnp-gold rounded-2xl flex items-center justify-center text-pnp-blue shadow-lg">
                    <i class="fas fa-table text-xl"></i>
                </div>
