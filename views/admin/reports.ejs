        if (!name) return '#94A3B8';
        const searchName = name.trim().toUpperCase();
        for (const [key, color] of Object.entries(allColors)) {
            if (key.toUpperCase() === searchName) return color;
        }
        for (const [key, color] of Object.entries(allColors)) {
            if (searchName.includes(key.toUpperCase()) || key.toUpperCase().includes(searchName)) return color;
        }
        return '#94A3B8';
    }

    function updateReportColors() {
        // Find the highest incident in each category from allIncidents
        const categoryCounts = {
            '8-Focus': {},
            'Non-Index': {},
            'PSI': {}
        };
        
        allIncidents.forEach(item => {
            const cat = item.category || 'Non-Index';
            const type = String(item.incident_type || item.offense || 'Unknown').trim().toUpperCase();
            if (type && type !== 'UNKNOWN') {
                if (categoryCounts[cat]) {
                    categoryCounts[cat][type] = (categoryCounts[cat][type] || 0) + 1;
                }
            }
        });

        function getTop(countsObj) {
            let topName = 'NONE';
            let topCount = 0;
            for (const [name, count] of Object.entries(countsObj)) {
                if (count > topCount) {
                    topCount = count;
                    topName = name;
                }
            }
            return { name: topName, count: topCount };
        }

        const top8Focus = getTop(categoryCounts['8-Focus']);
        const topNonIndex = getTop(categoryCounts['Non-Index']);
        const topPSI = getTop(categoryCounts['PSI']);

        const color8Focus = '#EF4444'; // Red
        const colorNonIndex = '#3B82F6'; // Blue
        const colorPSI = '#F59E0B'; // Gold

        // Save in window for global access
        window.categoryHighestColors = {
            '8-Focus': color8Focus,
            'Non-Index': colorNonIndex,
            'PSI': colorPSI
        };

        // Update top cards dynamic borders and text colors
        const card8 = document.getElementById('statsCard_8Focus');
        const label8 = document.getElementById('statsLabel_8Focus');
        const count8 = document.getElementById('statsCount_8Focus');
        if (card8) card8.style.borderColor = `${color8Focus}40`;
        if (label8) label8.style.color = color8Focus;
        if (count8) {
            count8.style.color = color8Focus;
            count8.style.textShadow = `0 0 10px ${color8Focus}30`;
        }

        const cardNon = document.getElementById('statsCard_NonIndex');
        const labelNon = document.getElementById('statsLabel_NonIndex');
        const countNon = document.getElementById('statsCount_NonIndex');
        if (cardNon) cardNon.style.borderColor = `${colorNonIndex}40`;
        if (labelNon) labelNon.style.color = colorNonIndex;
        if (countNon) {
            countNon.style.color = colorNonIndex;
            countNon.style.textShadow = `0 0 10px ${colorNonIndex}30`;
        }

        const cardPSI = document.getElementById('statsCard_PSI');
        const labelPSI = document.getElementById('statsLabel_PSI');
        const countPSI = document.getElementById('statsCount_PSI');
        if (cardPSI) cardPSI.style.borderColor = `${colorPSI}40`;
        if (labelPSI) labelPSI.style.color = colorPSI;
        if (countPSI) {
            countPSI.style.color = colorPSI;
            countPSI.style.textShadow = `0 0 10px ${colorPSI}30`;
        }

        // Also style Intelligence Review category counts dots if they exist
        const dot8 = document.getElementById('reviewDot_8Focus');
        if (dot8) { dot8.style.backgroundColor = color8Focus; dot8.style.boxShadow = `0 0 8px ${color8Focus}`; }
        const dotNon = document.getElementById('reviewDot_NonIndex');
        if (dotNon) { dotNon.style.backgroundColor = colorNonIndex; dotNon.style.boxShadow = `0 0 8px ${colorNonIndex}`; }
        const dotPSI = document.getElementById('reviewDot_PSI');
        if (dotPSI) { dotPSI.style.backgroundColor = colorPSI; dotPSI.style.boxShadow = `0 0 8px ${colorPSI}`; }
    }

    // Call updateReportColors on load
    document.addEventListener('DOMContentLoaded', () => {
        updateReportColors();
    });

