                </div>
                <div class="md:col-span-2 flex flex-col items-end justify-center space-y-4">
                    <div class="flex items-center space-x-2 bg-white dark:bg-slate-800 p-1.5 rounded-2xl border border-gray-200 dark:border-slate-700 shadow-sm">
                        <button onclick="renderReportDetailsModalContent('All')" class="px-5 py-2 text-[10px] font-black uppercase rounded-xl transition-all ${filter === 'All' ? 'bg-pnp-blue text-white shadow-lg' : 'text-slate-400 hover:text-pnp-blue'}">All Intel</button>
                        <button onclick="renderReportDetailsModalContent('8-Focus')" class="px-5 py-2 text-[10px] font-black uppercase rounded-xl transition-all ${filter === '8-Focus' ? 'bg-red-500 text-white shadow-lg' : 'text-slate-400 hover:text-red-500'}">8-Focus</button>
                        <button onclick="renderReportDetailsModalContent('Non-Index')" class="px-5 py-2 text-[10px] font-black uppercase rounded-xl transition-all ${filter === 'Non-Index' ? 'bg-slate-500 text-white shadow-lg' : 'text-slate-400 hover:text-slate-500'}">Non-Index</button>
                        <button onclick="renderReportDetailsModalContent('PSI')" class="px-5 py-2 text-[10px] font-black uppercase rounded-xl transition-all ${filter === 'PSI' ? 'bg-blue-500 text-white shadow-lg' : 'text-slate-400 hover:text-blue-500'}">PSI</button>
                    </div>
                    <div class="flex items-center space-x-3 text-right">
                        <div class="text-left flex flex-col space-y-1">
                            <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest block leading-none">Classification</span>
                            <select id="modalClassificationDropdown" onchange="renderReportDetailsModalContent('${filter}', this.value)" class="px-3 py-1.5 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase focus:ring-1 focus:ring-pnp-blue outline-none cursor-pointer max-w-[220px] truncate">
                                <option value="All" ${selectedOffense === 'All' ? 'selected' : ''} class="dark:bg-slate-900">All Classifications</option>
                                ${combinedOffenses.map(o => {
                                    const displayO = o.length > 25 ? o.slice(0, 23) + '...' : o;
                                    return `<option value="${o}" title="${o}" ${o.toUpperCase() === selectedOffense.toUpperCase() ? 'selected' : ''} class="dark:bg-slate-900">${displayO}</option>`;
                                }).join('')}
                            </select>
                        </div>
                        <div class="w-px h-8 bg-gray-200 dark:bg-slate-700"></div>
                        <div class="text-right">
                            <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest block leading-none">Total Staged</span>
                            <p class="text-lg font-black text-pnp-blue dark:text-white leading-none mt-1">${filteredData.length}</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Table Container -->
            <div class="p-8">
                <div class="bg-white dark:bg-slate-800 rounded-3xl border border-gray-200 dark:border-slate-800 shadow-xl overflow-hidden">
                    <table class="w-full text-left border-collapse table-fixed">
                        <thead class="sticky top-0 z-10">
                            <tr class="bg-gray-50 dark:bg-slate-900 border-b border-gray-200 dark:border-slate-700">
                                <th class="px-6 py-4 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-100 dark:border-slate-800 w-16 text-center bg-gray-50 dark:bg-slate-900">ROW</th>
                                <th class="px-8 py-4 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-100 dark:border-slate-800 w-1/5 bg-gray-50 dark:bg-slate-900">Timeline</th>
                                <th class="px-8 py-4 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-100 dark:border-slate-800 w-1/3 bg-gray-50 dark:bg-slate-900">Classification</th>
                                <th class="px-8 py-4 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest border-r border-gray-100 dark:border-slate-800 w-1/4 bg-gray-50 dark:bg-slate-900">Sector (Barangay)</th>
                                <th class="px-8 py-4 text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-center bg-gray-50 dark:bg-slate-900">Category</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-slate-800">
                            ${filteredData.length === 0 ? `
                                <tr>
                                    <td colspan="5" class="px-8 py-24 text-center">
                                        <div class="flex flex-col items-center space-y-4 opacity-40">
                                            <i class="fas fa-satellite-dish text-4xl text-pnp-blue"></i>
                                            <span class="text-xs font-black uppercase tracking-[0.3em] italic">Intelligence Grid Empty: No records match filter</span>
                                        </div>
                                    </td>
                                </tr>
                            ` : filteredData.map((item, idx) => {
                                const cat = item.category || 'Non-Index';
                                const badgeClass = cat === '8-Focus' ? 'bg-red-500/10 text-red-500 border-red-500/20' : (cat === 'PSI' ? 'bg-blue-500/10 text-blue-500 border-blue-500/20' : 'bg-slate-500/10 text-slate-500 border-slate-500/20');
                                return `
                                    <tr class="hover:bg-pnp-blue/5 dark:hover:bg-slate-700/50 transition-colors group animate-fade-in-up cursor-pointer" style="animation-delay: ${idx * 15}ms" ondblclick="navigateToMapForCrime('${encodeURIComponent(item.barangay || '')}', '${encodeURIComponent(item.offense || item.incident_type || '')}', '${item.latitude || item.lat || ''}', '${item.longitude || item.lng || ''}', '${report.id || ''}')">
                                        <td class="px-6 py-4 text-[10px] font-black text-gray-400 border-r border-gray-50 dark:border-slate-800 text-center tabular-nums">${idx + 1}</td>
                                        <td class="px-8 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 font-mono border-r border-gray-50 dark:border-slate-800 tracking-tighter">${item.date || item.date_committed || 'N/A'}</td>
                                        <td class="px-8 py-4 text-xs font-black text-pnp-blue dark:text-white uppercase border-r border-gray-50 dark:border-slate-800 truncate" title="${item.offense || item.incident_type || 'Unknown'}">${item.offense || item.incident_type || 'Unknown'}</td>
                                        <td class="px-8 py-4 text-xs font-black text-slate-600 dark:text-slate-300 uppercase border-r border-gray-50 dark:border-slate-800">BRGY. ${item.barangay || 'UNKNOWN'}</td>
                                        <td class="px-8 py-4 text-center">
                                            <div class="flex items-center justify-center">
                                                <span class="px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest border ${badgeClass}">
                                                    ${cat}
                                                </span>
                                            </div>
                                        </td>
                                    </tr>
                                `;
                            }).join('')}
                        </tbody>
                    </table>
                </div>
            </div>
        `;

        const modal = document.getElementById('reportDetailsModal');
        if (modal.classList.contains('hidden')) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
    }

    function closeReportDetails() {
        document.getElementById('reportDetailsModal').classList.add('hidden');
    }
</script>

<!-- Fullscreen Neural Grid Scanner Overlay (Moved for maximum coverage) -->
<div id="intelLoadingOverlay" class="hidden fixed inset-0 w-screen h-screen bg-slate-950/98 backdrop-blur-3xl z-[99999] flex flex-col items-center justify-center overflow-hidden">
    <!-- Passive Background Grid -->
    <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 30px 30px;"></div>
    
    <div class="relative flex flex-col items-center justify-center scale-110">
        <!-- Single Dominant Circling Core -->
        <div class="relative w-72 h-72 flex items-center justify-center">
            <!-- Outer Spinning Guard -->
            <div class="absolute inset-0 border-2 border-white/[0.03] rounded-full"></div>
            
            <!-- Circular Scanning Ring (Circling only on the middle) -->
            <div class="absolute inset-6 border-t-2 border-pnp-gold rounded-full animate-spin-tactical shadow-[0_0_40px_rgba(255,184,0,0.3)]"></div>
            
            <!-- Central Icon Hub -->
            <div class="w-36 h-36 bg-slate-900 rounded-full border border-pnp-gold/30 flex items-center justify-center shadow-[0_0_60px_rgba(0,0,0,0.5)] z-10">
                <div class="relative">
                    <i class="fas fa-radar text-pnp-gold text-5xl animate-radar-ping"></i>
                </div>
            </div>
        </div>

        <!-- Dynamic Intelligence Text -->
        <div class="mt-20 text-center">
            <h4 class="text-3xl font-black text-pnp-gold uppercase tracking-[0.8em] flex items-center justify-center pl-[0.8em]">
                <span>Scanning</span>
                <span class="loading-dots-tactical text-left w-16"></span>
            </h4>
            <div class="h-px w-64 bg-gradient-to-r from-transparent via-pnp-gold/20 to-transparent mx-auto mt-6"></div>
            <p id="intelLoadingText" class="mt-6 text-[10px] text-white/30 uppercase font-black tracking-[0.4em] animate-pulse max-w-xs leading-relaxed italic mx-auto">
                Analyzing tactical datasets via GPT-OSS 120B...
            </p>
        </div>
    </div>

    <style>
        @keyframes radar-ping {
            0% { transform: scale(0.85); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(0.85); opacity: 0.5; }
        }
        @keyframes spin-tactical {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        @keyframes dots-tactical {
            0% { content: ''; }
            25% { content: '.'; }
            50% { content: '..'; }
            75% { content: '...'; }
        }
        .animate-radar-ping {
            animation: radar-ping 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        .animate-spin-tactical {
            animation: spin-tactical 1.2s linear infinite;
        }
        .loading-dots-tactical::after {
            content: '';
            animation: dots-tactical 2s steps(4, end) infinite;
        }
        /* Absolute Override for Full Coverage */
        #intelLoadingOverlay {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            margin: 0 !important;
            padding: 0 !important;
        }
    </style>
</div>
