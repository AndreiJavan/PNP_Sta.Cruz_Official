     window.confirmIntelReview = async function() {
         const syncBtn = document.querySelector('button[onclick="confirmIntelReview()"]');
         if (syncBtn && syncBtn.disabled) return;

         if (!reviewData || reviewData.length === 0) {
             await window.strategicAlert({
                 title: "No Data",
                 message: "There are no records to synchronize. Please add or generate entries first.",
                 type: "warning"
             });
             return;
         }

         // Input & Data Integrity Validation Protocol BEFORE confirmation dialog
         const todayStr = new Date().toISOString().split('T')[0];
         const validCategories = ['8-Focus', 'Non-Index', 'PSI'];

         for (let i = 0; i < reviewData.length; i++) {
             const r = reviewData[i];
             const rowNum = i + 1;
             
             // 1. Missing basic fields check (Barangay)
             if (!r.barangay || !r.barangay.trim()) {
                 await window.strategicAlert({
                     title: "Validation Failure",
                     message: `Row #${rowNum}: Barangay (Sector) is missing. Please select a valid Barangay before synchronizing.`,
                     type: "warning"
                 });
                 return;
             }

             if (!VALID_BARANGAYS.includes(r.barangay.trim())) {
                 await window.strategicAlert({
                     title: "Invalid Sector",
                     message: `Row #${rowNum}: "${r.barangay}" is not a recognized Santa Cruz Barangay. Please select a valid Barangay.`,
                     type: "warning"
                 });
                 return;
             }

             // 2. Timeline Date Check
             const rawDate = r.date_committed || r.incident_date || r.date || '';
             if (!rawDate || !rawDate.trim()) {
                 await window.strategicAlert({
                     title: "Missing Date",
                     message: `Row #${rowNum}: Timeline Date is missing. Please set a valid date before synchronizing.`,
                     type: "warning"
                 });
                 return;
             }

             const dateVal = rawDate.trim();
             const dateObj = new Date(dateVal);
             if (isNaN(dateObj.getTime()) || !/^\d{4}-\d{2}-\d{2}$/.test(dateVal)) {
                 await window.strategicAlert({
                     title: "Invalid Date Format",
                     message: `Row #${rowNum}: "${dateVal}" is not a valid date format (YYYY-MM-DD required).`,
                     type: "warning"
                 });
                 return;
             }

             if (dateVal > todayStr) {
                 await window.strategicAlert({
                     title: "Future Date Restricted",
                     message: `Row #${rowNum}: Timeline date (${dateVal}) cannot be in the future. Maximum allowed date is today (${todayStr}).`,
                     type: "warning"
                 });
                 return;
             }

             if (dateVal < '2024-01-01') {
                 await window.strategicAlert({
                     title: "Timeline Date Out of Range",
                     message: `Row #${rowNum}: Timeline date (${dateVal}) cannot be prior to January 1, 2024.`,
                     type: "warning"
                 });
                 return;
             }

             // 3. Classification Check
             const offenseVal = (r.offense || r.incident_type || '').trim();
             if (!offenseVal) {
                 await window.strategicAlert({
                     title: "Incomplete Classification",
                     message: `Row #${rowNum}: Crime classification / offense is missing. Please enter or select a classification.`,
                     type: "warning"
                 });
                 return;
             }

             if (offenseVal.length < 2) {
                 await window.strategicAlert({
                     title: "Invalid Classification",
                     message: `Row #${rowNum}: Classification "${offenseVal}" must be at least 2 characters long (single-letter entries are not allowed).`,
                     type: "warning"
                 });
                 return;
             }

             // 4. Category Check
             const categoryVal = r.category || 'Non-Index';
             if (!validCategories.includes(categoryVal)) {
                 await window.strategicAlert({
                     title: "Invalid Category",
                     message: `Row #${rowNum}: Category "${categoryVal}" is invalid. Must be 8-Focus, Non-Index, or PSI.`,
                     type: "warning"
                 });
                 return;
             }
         }

         // ALL VALIDATIONS PASSED -> NOW DISPLAY CONFIRMATION DIALOG
         const confirmed = await (window.strategicConfirm || (async () => confirm(`Commit ${reviewData.length} records to the CPICRS Central Database?`)))({
             title: "Tactical Confirmation",
             message: `Commit ${reviewData.length} validated records to the CPICRS Central Database?`,
             confirmText: "Sync Now",
             type: "info"
         });
         if (!confirmed) return;
         
         const originalContent = syncBtn.innerHTML;
         syncBtn.disabled = true;
         syncBtn.classList.add('opacity-50', 'cursor-not-allowed');
         syncBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Syncing...';

         try {
             const response = await fetch('/admin/reports/save', {
                 method: 'POST',
                 headers: { 'Content-Type': 'application/json' },
                 body: JSON.stringify({ 
                    entries: reviewData, 
                    filename: currentFilename,
                    entryType: currentEntryType 
                 })
             });
             const result = await response.json();

             if (result.success) {
                    await window.strategicAlert({
                        title: "Sync Successful",
                        message: `Archive Updated: ${result.count} tactical records committed.`,
                        type: "success"
                    });
                    const urlParams = new URLSearchParams(window.location.search);
                    if (urlParams.get('return_to') === 'map') {
                        window.location.href = '/admin/map';
                    } else {
                        location.reload();
                    }
             } else {
                 throw new Error(result.message || "Disk Sync Failed");
             }
         } catch (error) { 
             window.strategicAlert({
                 title: "Synchronization Error",
                 message: error.message,
                 type: "danger"
             });
             syncBtn.disabled = false;
             syncBtn.classList.remove('opacity-50', 'cursor-not-allowed');
             syncBtn.innerHTML = originalContent;
         }
     };

