        `;

        const modal = document.getElementById('reportDetailsModal');
        if (modal.classList.contains('hidden')) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
    }

    function viewReportDetails(reportId) {
        window.isGlobalStats = false;
        const report = reports.find(r => r.id === reportId);
        if (!report) return;
        
        document.getElementById('reportDetailsTitle').textContent = 'Recorded Crime | Incident';
        
        window.currentViewingReport = report;
        renderReportDetailsModalContent('All');
    }

    function renderReportDetailsModalContent(filter, selectedOffense = 'All') {
        if (window.isGlobalStats) {
            window.currentStatsCategory = filter === 'All' ? '8-Focus' : filter; // Default to focus if 'All' clicked in global mode
            renderGlobalStatsModalContent();
            return;
        }
        const report = window.currentViewingReport;
        const rawData = report.raw_data || [];
        
        // Filter by category first
        let filteredData = filter === 'All' ? rawData : rawData.filter(item => item.category === filter);
        
        // Filter by selected offense / classification
        if (selectedOffense && selectedOffense !== 'All') {
            filteredData = filteredData.filter(item => {
                const itemOffense = (item.offense || item.incident_type || '').toUpperCase();
                return itemOffense === selectedOffense.toUpperCase();
            });
        }
        
        const content = document.getElementById('reportDetailsContent');
        const batchId = `#${report.id.slice(-8).toUpperCase()}`;
        const timestamp = new Date(report.timestamp).toLocaleString(undefined, { 
            month: 'short', day: 'numeric', year: 'numeric', 
            hour: '2-digit', minute: '2-digit', second: '2-digit'
        });

        // Collect classifications that are actually present in the given data for the selected category filter
        const existingOffenses = new Set();
        rawData.forEach(item => {
            const off = item.offense || item.incident_type;
            if (off && (filter === 'All' || item.category === filter)) {
                existingOffenses.add(off);
            }
        });

        const combinedOffenses = Array.from(existingOffenses).sort();

        content.innerHTML = `
