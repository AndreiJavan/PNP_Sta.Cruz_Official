        const btn = document.querySelector(`#deleteReportForm_${reportId} button`);
        if (btn && btn.disabled) return false;

        const confirmed = await window.strategicConfirm({
            title: "Archive Confirmation",
            message: "Are you sure you want to move this record to the Archive?",
            confirmText: "Move to Archive",
            type: "warning"
        });

        if (confirmed) {
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            }
            const form = document.getElementById(`deleteReportForm_${reportId}`);
            if (form) form.submit();
        }
        return false;
    }

    window.filterReports = function() {
        currentReportPage = 1;
        renderReportsTable();
    }
</script>

<script>
    window.reports = <%- JSON.stringify(displayReports) %>;
    const allIncidents = <%- JSON.stringify(displayIncidents) %>;

    const allColors = {
        'Murder': '#EF4444', 'Homicide': '#F87171', 'Physical Injuries': '#10B981', 'Rape': '#A855F7', 'Carnapping (Motorcycle)': '#F59E0B',
        'Carnapping (Motor Vehicle)': '#F97316', 'Violence Against Women and Children (VAWC)': '#E11D48',
        'Cybercrime': '#3B82F6', 'Estafa': '#0891B2', 'Swindling / Fraud': '#06B6D4',
        'Drug Possession': '#059669', 'Drug Sale': '#10B981', 'Drug Use': '#34D399',
        'Illegal Gambling': '#7C3AED', 'Illegal Possession of Firearms': '#475569',
        'Human Trafficking': '#DB2777', 'Child Abuse (RA 7610)': '#F43F5E', 'Damage to Property': '#B45309',
        'Malicious Mischief': '#D97706', 'Cybercrime (Online Fraud, Hacking, Identity Theft, Cyber Libel)': '#2563EB',
        'Illegal Recruitment': '#9333EA', 'Ordinance Violations': '#94A3B8', 'Grave Threats': '#64748B',
        'Alarm and Scandal': '#CBD5E1', 'Vehicular Accident': '#2563EB', 'Road Accident / Traffic Incident': '#1D4ED8',
