                                <tr class="hover:bg-pnp-blue/5 dark:hover:bg-slate-800/40 transition-all group relative overflow-hidden">
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-[11px] font-black text-slate-800 dark:text-white uppercase tracking-tighter">
                                                <%= new Date(report.timestamp).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                            </span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex items-center space-x-4">
                                            <div class="w-10 h-10 rounded-2xl bg-white dark:bg-slate-800 flex items-center justify-center text-pnp-blue dark:text-pnp-gold border border-gray-200 dark:border-slate-700 group-hover:scale-110 transition-all shadow-sm group-hover:rotate-3">
                                                <i class="fas fa-microchip text-xs"></i>
                                            </div>
                                            <div class="flex flex-col truncate max-w-[200px]">
                                                <span class="text-[11px] font-black uppercase text-slate-700 dark:text-slate-200 tracking-tight leading-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition duration-300"><%= report.filename || 'Manual Transmission' %></span>
                                                <div class="flex items-center space-x-2 mt-1">
                                                    <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest italic opacity-70"><%= report.admin_name || 'Sys Admin' %></span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="w-24 px-2 py-6 text-center">
                                        <span class="text-sm font-black text-pnp-blue dark:text-pnp-gold tabular-nums tracking-tighter"><%= report.total_records || 0 %></span>
                                    </td>
                                    <td class="w-24 px-2 py-6 text-center">
                                        <span class="px-3 py-1.5 rounded-xl text-[10px] font-black <%= (report.category_stats && report.category_stats['8-Focus']) > 0 ? 'bg-red-500/10 text-red-600 border border-red-500/10' : 'bg-gray-50 dark:bg-slate-800 text-gray-300 dark:text-slate-700' %>">
                                            <%= (report.category_stats && report.category_stats['8-Focus']) || 0 %>
                                        </span>
