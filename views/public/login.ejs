<div class="max-w-md mx-auto px-4 py-20">
    <div class="bg-white dark:bg-slate-800 rounded-[3rem] shadow-2xl overflow-hidden border border-gray-100 dark:border-slate-700">
        <!-- Header -->
        <div class="bg-pnp-blue p-10 text-center relative overflow-hidden">
            <div class="relative z-10">
                <div class="w-16 h-16 bg-pnp-gold text-white rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-xl">
                    <i class="fas fa-lock text-2xl"></i>
                </div>
                <h1 class="text-2xl font-black text-white mb-1 uppercase tracking-tighter">Public Login</h1>
                <p class="text-white/70 text-xs font-bold uppercase tracking-widest">Sign in to Submit Tips</p>
            </div>
        </div>

        <div class="p-10">
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 p-4 rounded-xl text-sm font-bold mb-6 flex items-center shadow-sm border border-red-100 dark:border-red-900/40">
                    <i class="fas fa-exclamation-circle mr-3"></i> <%= error %>
                </div>
            <% } %>

            <form action="/login" method="POST" class="space-y-6">
                <input type="hidden" name="redirect_url" value="<%= typeof redirect !== 'undefined' ? redirect : '' %>" />
                <div class="space-y-2">
                    <label for="email" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Email Address</label>
                    <input type="email" name="email" id="email" required placeholder="example@email.com" class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/20 focus:border-pnp-blue outline-none transition font-bold text-sm text-gray-900 dark:text-white">
                </div>

                <div class="space-y-2">
                    <label for="password" class="block text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Password</label>
                    <input type="password" name="password" id="password" required placeholder="••••••••" class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-2xl focus:ring-4 focus:ring-pnp-blue/20 focus:border-pnp-blue outline-none transition font-bold text-sm text-gray-900 dark:text-white">
                </div>

                <button type="submit" class="w-full bg-pnp-blue hover:bg-black text-white font-black py-4 rounded-2xl shadow-xl transition duration-300 flex items-center justify-center space-x-3 uppercase tracking-widest text-sm mt-4">
                    <i class="fas fa-sign-in-alt"></i>
                    <span>Log In</span>
                </button>
            </form>
            
            <div class="mt-8 text-center border-t border-gray-100 dark:border-slate-700 pt-6">
                <p class="text-sm font-bold text-gray-500 dark:text-gray-400">
                    Don't have an account? 
                    <a href="/register" class="text-pnp-gold hover:text-black dark:hover:text-white transition uppercase tracking-widest text-[10px]">Create Account</a>
                </p>
            </div>
        </div>
    </div>
</div>
