<!-- Hero Section -->
<section id="hero-section" class="relative min-h-[40vh] py-16 md:py-24 flex items-center justify-center overflow-hidden bg-slate-950 bg-cover bg-center bg-no-repeat"
    style="background-image: linear-gradient(to bottom, rgba(15, 23, 42, 0.78), rgba(15, 23, 42, 0.92)), url('/images/directory-pnp-2.jpg');">
    <div class="absolute inset-0 z-0 bg-gradient-to-br from-pnp-blue/20 via-slate-950/40 to-slate-950/80"></div>

    <div class="container mx-auto px-4 relative z-10 text-center flex flex-col items-center">
        <div
            class="inline-flex items-center space-x-2 bg-white/10 backdrop-blur-md text-pnp-gold px-5 py-2 rounded-full mb-4 border border-white/20 animate-fade-in-up">
            <i class="fas fa-shield-halved text-sm"></i>
            <span class="text-xs font-bold uppercase tracking-widest">Official Portal &bull; PNP Sta. Cruz</span>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight tracking-tight drop-shadow-lg animate-fade-in-up"
            style="animation-delay: 0.1s;">
            Welcome to the <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-pnp-gold to-yellow-300">Public
                Bulletin</span>
        </h1>

        <p class="text-base md:text-lg text-blue-100 font-light max-w-3xl mx-auto mb-6 leading-relaxed drop-shadow-md animate-fade-in-up"
            style="animation-delay: 0.2s;">
            Stay informed with the latest updates, advisories, missing persons, and wanted persons alerts from the Sta.
            Cruz PNP Station.
        </p>
    </div>
</section>

<!-- Bulletins Section -->
<section id="bulletins-section" class="py-8 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 relative min-h-[40vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <% if (locals.policeNewsList && policeNewsList.length > 0) { %>
            <% const carouselNews = policeNewsList.slice(0, 5); %>
            <!-- Carousel Container -->
            <div class="mb-10">
                <div class="mb-4 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
                    <div>
                        <div class="inline-flex items-center space-x-2 bg-pnp-blue/5 dark:bg-pnp-gold/10 text-pnp-blue dark:text-pnp-gold px-3.5 py-1.5 rounded-full mb-2 border border-pnp-blue/10 dark:border-pnp-gold/25">
                            <i class="fas fa-newspaper text-[10px]"></i>
                            <span class="text-[9px] font-black uppercase tracking-widest">Official News</span>
                        </div>
                        <h2 class="text-xl font-bold text-pnp-blue dark:text-white uppercase tracking-tight leading-none">Police News</h2>
                    </div>
                </div>

                <!-- Carousel Wrapper (Outer Relative Wrapper) -->
                <div class="relative w-full">
                    <!-- Floating Navigation Controls -->
                    <button id="carousel-prev" class="absolute left-2 lg:-left-6 top-1/2 -translate-y-1/2 z-40 w-12 h-12 rounded-full bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-pnp-blue hover:text-white dark:hover:bg-pnp-gold dark:hover:text-pnp-blue flex items-center justify-center transition-all shadow-lg border border-gray-150 dark:border-slate-800 focus:outline-none transform hover:scale-110 active:scale-95">
                        <i class="fas fa-chevron-left text-sm"></i>
                    </button>
                    <button id="carousel-next" class="absolute right-2 lg:-right-6 top-1/2 -translate-y-1/2 z-40 w-12 h-12 rounded-full bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-pnp-blue hover:text-white dark:hover:bg-pnp-gold dark:hover:text-pnp-blue flex items-center justify-center transition-all shadow-lg border border-gray-150 dark:border-slate-800 focus:outline-none transform hover:scale-110 active:scale-95">
                        <i class="fas fa-chevron-right text-sm"></i>
                    </button>

                    <!-- Carousel Inner (Overflow Mask) -->
                    <div class="overflow-hidden w-full rounded-[2.5rem] border border-gray-100 dark:border-slate-800/60 shadow-xl bg-white dark:bg-slate-900">
                    <!-- Inner Track -->
                    <div id="carousel-track" class="flex transition-transform duration-700 ease-in-out">
                        <% carouselNews.forEach((news, index) => { %>
                            <div class="w-full shrink-0 flex-none px-4 md:px-8 py-6 md:py-8">
                                <div onclick="window.location.href='/news'" class="flex flex-col sm:flex-row items-stretch gap-5 sm:gap-6 md:gap-8 group cursor-pointer">
                                    <!-- Image / Facebook Container -->
                                    <div class="w-full sm:w-1/2 h-52 sm:h-64 md:h-72 lg:h-80 rounded-[1.5rem] overflow-hidden relative shadow-md shrink-0 bg-slate-100 dark:bg-slate-950 border border-gray-100 dark:border-slate-800/50 flex items-center justify-center">
                                        <% if (news.facebook_url) { %>
                                            <iframe src="https://www.facebook.com/plugins/<%= /video|watch|reel/i.test(news.facebook_url) ? 'video.php' : 'post.php' %>?href=<%= encodeURIComponent(news.facebook_url) %>&show_text=false&width=500" 
                                                width="100%" height="100%" style="border:none;overflow:hidden;min-height:220px;" scrolling="no" frameborder="0" allowfullscreen="true" 
                                                allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" class="w-full h-full pointer-events-none"></iframe>
                                        <% } else if (news.urlToImage) { %>
                                            <img src="<%= news.urlToImage %>" alt="<%= news.headline %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
                                        <% } else { %>
                                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-850">
                                                <i class="fas fa-newspaper text-5xl text-slate-300 dark:text-slate-700"></i>
                                            </div>
                                        <% } %>
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-40 group-hover:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
                                        <div class="absolute bottom-4 left-4 sm:bottom-6 sm:left-6 text-white font-black text-[9px] uppercase tracking-widest bg-pnp-blue/80 dark:bg-slate-950/80 backdrop-blur-md px-3.5 py-1.5 sm:px-4 sm:py-2 rounded-xl border border-white/10 z-10">
                                            <i class="fas fa-clock mr-1.5 text-pnp-gold"></i>
                                            <%= new Date(news.publishedAt).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'}) %>
                                        </div>
                                    </div>
                                    
                                    <!-- Content Info -->
                                    <div class="w-full sm:w-1/2 flex flex-col justify-center text-left py-2">
                                        <div class="mb-4">
                                            <% if (news.facebook_url || (news.author && (news.author.startsWith('http://') || news.author.startsWith('https://')))) { %>
                                                <a href="<%= news.facebook_url || news.author %>" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation();" class="inline-flex items-center space-x-1.5 px-3 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest text-[#1877F2] dark:text-blue-400 bg-blue-50 dark:bg-blue-950/60 border border-blue-200 dark:border-blue-800 hover:bg-blue-100 dark:hover:bg-blue-900/60 transition shadow-sm" title="Open Official Facebook Post">
                                                    <i class="fab fa-facebook text-xs"></i>
                                                    <span>Official Facebook Post</span>
                                                    <i class="fas fa-external-link-alt text-[8px] ml-1 opacity-70"></i>
                                                </a>
                                            <% } else { %>
                                                <span class="px-3.5 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border text-slate-600 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 border-gray-200 dark:border-slate-700">
                                                    By <%= news.author || 'Station Desk' %>
                                                </span>
                                            <% } %>
                                        </div>
                                        
                                        <h3 class="text-2xl md:text-3xl font-black text-slate-900 dark:text-white leading-tight mb-5 group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors tracking-tight line-clamp-2">
                                            <%= news.headline %>
                                        </h3>
                                        
                                        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6 line-clamp-3">
                                            <%= news.description || 'Click to read full article...' %>
                                        </p>
                                        
                                        <div class="mt-2">
                                            <span class="inline-flex items-center text-pnp-blue dark:text-pnp-gold font-black text-xs uppercase tracking-widest group-hover:translate-x-1 transition-transform">
                                                See More <i class="fas fa-arrow-right ml-2.5 text-[9px]"></i>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <!-- Slide Dots/Indicators -->
                    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex items-center space-x-2 z-30">
                        <% carouselNews.forEach((_, index) => { %>
                            <button class="carousel-dot w-2 h-2 rounded-full bg-slate-300 dark:bg-slate-700 hover:bg-pnp-gold transition-all duration-300 focus:outline-none" data-slide="<%= index %>"></button>
                        <% }) %>
                    </div>
                </div> <!-- Closes Carousel Inner -->
            </div> <!-- Closes Carousel Wrapper (Outer) -->
        </div> <!-- Closes Carousel Container -->
        <% } %>

        <!-- Bulletins Content -->
        <div class="mt-16">
            <div class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
                <div>
                    <div class="inline-flex items-center space-x-2 bg-pnp-blue/5 dark:bg-pnp-gold/10 text-pnp-blue dark:text-pnp-gold px-3.5 py-1.5 rounded-full mb-2 border border-pnp-blue/10 dark:border-pnp-gold/25">
                        <i class="fas fa-bullhorn text-[10px]"></i>
                        <span class="text-[9px] font-black uppercase tracking-widest">Public Advisory</span>
                    </div>
                    <h2 class="text-xl font-bold text-pnp-blue dark:text-white uppercase tracking-tight leading-none">Public Advisories & Updates</h2>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% if (locals.bulletins && bulletins.length > 0) { %>
                    <% bulletins.slice(0, 3).forEach(bulletin => { %>
                        <div class="bulletin-card group bg-white dark:bg-slate-900 rounded-[2rem] shadow-sm hover:shadow-2xl border border-gray-150 dark:border-slate-800/60 overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1 cursor-pointer" data-category="<%= bulletin.category %>" onclick="openBulletinModal('<%= bulletin.id %>')">
                            <% if (bulletin.video_paths && bulletin.video_paths.length > 0) { %>
                                <div class="h-48 overflow-hidden relative bg-black">
                                    <video src="<%= bulletin.video_paths[0] %>" muted class="w-full h-full object-cover group-hover:scale-105 transition duration-700 pointer-events-none"></video>
                                    <% if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                                        <div class="absolute bottom-3 right-3 bg-slate-900/80 backdrop-blur-md px-2.5 py-1 rounded-full text-white text-[9px] font-black tracking-widest flex items-center space-x-1.5 border border-white/10 shadow-lg">
                                            <i class="fas fa-images"></i>
                                            <span>+<%= bulletin.photo_paths.length %></span>
                                        </div>
                                    <% } %>
                                </div>
                            <% } else if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                                <div class="h-48 overflow-hidden relative bg-slate-100 dark:bg-slate-800">
                                    <img src="<%= bulletin.photo_paths[0] %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
                                    <% if (bulletin.photo_paths.length > 1) { %>
                                        <div class="absolute bottom-3 right-3 bg-slate-900/80 backdrop-blur-md px-2.5 py-1 rounded-full text-white text-[9px] font-black tracking-widest flex items-center space-x-1.5 border border-white/10 shadow-lg">
                                            <i class="fas fa-images"></i>
                                            <span>+<%= bulletin.photo_paths.length - 1 %></span>
                                        </div>
                                    <% } %>
                                </div>
                            <% } else if (bulletin.photo_path) { %>
                                <div class="h-48 overflow-hidden relative bg-slate-100 dark:bg-slate-800">
                                    <img src="<%= bulletin.photo_path %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
                                </div>
                            <% } else if (bulletin.facebook_url) { %>
                                <div class="h-64 overflow-hidden relative bg-slate-950 shrink-0 flex items-center justify-center border-b border-slate-800">
                                    <iframe src="https://www.facebook.com/plugins/<%= /video|watch|reel/i.test(bulletin.facebook_url) ? 'video.php' : 'post.php' %>?href=<%= encodeURIComponent(bulletin.facebook_url) %>&show_text=false&width=500" 
                                        width="100%" height="100%" style="border:none;overflow:hidden;min-height:240px;" scrolling="no" frameborder="0" allowfullscreen="true" 
                                        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" class="w-full h-full"></iframe>
                                </div>
                            <% } else { %>
                                <div class="h-48 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-800 dark:to-slate-900 flex items-center justify-center border-b border-gray-100 dark:border-slate-800/50">
                                    <i class="fas fa-bullhorn text-4xl text-slate-300 dark:text-slate-700 group-hover:text-pnp-blue transition-colors"></i>
                                </div>
                            <% } %>

                            <div class="p-6 flex-grow flex flex-col">
                                <div class="flex justify-between items-start mb-4">
                                    <% const badgeColors = { 'Wanted Person': 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400 border-rose-200 dark:border-rose-800', 'Missing Person': 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 border-amber-200 dark:border-amber-800', 'Crime Advisory': 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400 border-orange-200 dark:border-orange-800', 'Recovered Property': 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 border-emerald-200 dark:border-emerald-800', 'General Announcement': 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 border-blue-200 dark:border-blue-800' }; %>
                                    <span class="px-2.5 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest border shadow-sm <%= badgeColors[bulletin.category] || 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 border-slate-200 dark:border-slate-700' %>">
                                        <%= bulletin.category %>
                                    </span>
                                    <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest bg-slate-50 dark:bg-slate-800/50 px-2 py-1 rounded-md">
                                        <%= new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'}) %>
                                    </span>
                                </div>

                                <h3 class="text-lg font-black text-slate-800 dark:text-white leading-tight mb-3 group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition duration-200 line-clamp-2">
                                    <%= bulletin.title %>
                                </h3>
                                <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed mb-6 line-clamp-3">
                                    <%= bulletin.body %>
                                </p>

                                <div class="mt-auto pt-4 border-t border-gray-100 dark:border-slate-800 flex items-center justify-between">
                                    <button type="button" onclick="event.stopPropagation(); openBulletinModal('<%= bulletin.id %>')" class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold uppercase tracking-widest group-hover:underline flex items-center focus:outline-none">
                                        See More <i class="fas fa-arrow-right ml-1.5 text-[8px]"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <% if (locals.bulletins && bulletins.length > 0) { %>
                <div class="mt-12 text-center">
                    <a href="/bulletins" class="inline-flex items-center space-x-2 bg-pnp-blue hover:bg-pnp-gold hover:text-pnp-blue dark:bg-pnp-gold dark:text-pnp-blue dark:hover:bg-white text-white font-bold px-8 py-4 rounded-xl transition duration-300 shadow-md uppercase tracking-widest text-xs">
                        <span>See More Bulletins</span>
                        <i class="fas fa-arrow-right text-[10px]"></i>
                    </a>
                </div>
            <% } %>

            <div id="bulletins-empty-state" class="hidden text-center py-16 bg-white dark:bg-slate-900 rounded-[2.5rem] border border-gray-100 dark:border-slate-800 shadow-sm">
                <div class="w-16 h-16 bg-slate-50 dark:bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-folder-open text-2xl text-slate-300 dark:text-slate-600"></i>
                </div>
                <h3 class="text-sm font-black text-slate-600 dark:text-slate-400 uppercase tracking-widest">No Bulletins Found</h3>
                <p class="text-xs text-slate-500 mt-2">No records match the selected category.</p>
            </div>
        </div>
    </div>
</section>

<!-- Directory Section -->
<section id="directory-section" class="py-16 bg-white dark:bg-slate-900 transition-colors duration-300 relative border-t border-gray-50 dark:border-slate-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col lg:flex-row gap-12 items-center">
            <!-- Left Side: Image -->
            <div class="w-full lg:w-[45%] rounded-[2rem] overflow-hidden shadow-2xl border border-gray-100 dark:border-slate-700/60 group relative bg-gray-50 dark:bg-slate-800 flex items-center justify-center p-2 shrink-0">
                <img src="/images/directory-pnp.jpg" alt="Sta Cruz Municipal Police Station Directory" class="w-full h-auto object-contain rounded-[1.5rem] group-hover:scale-[1.02] transition-transform duration-500">
            </div>

            <!-- Right Side: Text Directory -->
            <div class="w-full lg:w-[55%] space-y-8 pl-0 lg:pl-4">
                <div class="border-l-4 border-pnp-gold pl-6 py-2 inline-block w-full bg-gradient-to-r from-gray-50 to-transparent dark:from-slate-800/50 dark:to-transparent rounded-r-2xl">
                    <h2 class="text-3xl md:text-4xl font-black text-pnp-blue dark:text-white uppercase tracking-tight leading-none mb-2">Sta Cruz</h2>
                    <h2 class="text-2xl md:text-3xl font-black text-slate-700 dark:text-slate-300 uppercase tracking-tighter leading-none mb-2">Municipal Police Station</h2>
                    <h2 class="text-xl md:text-2xl font-black text-pnp-gold uppercase tracking-[0.2em] leading-none">Directory</h2>
                </div>

                <div class="space-y-6">
                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PGEN JOSE MELENCIO C NARTATE JR</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Chief PNP</p>
                    </div>

                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PBGEN HANSEL M MARANTAN</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Acting Regional Director</p>
                    </div>

                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PCOL SANDRO JAY DC TAPALLA</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Acting Provincial Director, Laguna PPO</p>
                    </div>

                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PLT COL JOJO J SABENIANO</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Chief of Police</p>
                    </div>

                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PCPT GADY R MABANTO</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Deputy Chief of Police</p>
                    </div>

                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PCPT ANDY O MESANA</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Chief Operation PCO</p>
                    </div>

                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PLT ARIEL T GENTOLEO</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Cadmin and Intelligence Section</p>
                    </div>

                    <!-- Item -->
                    <div class="border-l-2 border-pnp-blue/20 dark:border-slate-700 pl-4 hover:border-pnp-blue dark:hover:border-pnp-gold transition-colors group">
                        <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors">PEMS MANOLITO M BINALAY</h4>
                        <p class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">Mespo</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Jurisdiction Disclaimer Modal -->
<div id="jurisdiction-modal"
    class="fixed inset-0 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-500">
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="relative bg-white dark:bg-slate-900 w-11/12 max-w-lg rounded-[2rem] p-8 md:p-10 shadow-2xl border border-gray-100 dark:border-slate-800 transform scale-95 transition-transform duration-500"
        id="modal-content">
        <div
            class="flex items-center justify-center w-16 h-16 bg-pnp-blue text-white rounded-full mb-6 mx-auto shadow-lg">
            <i class="fas fa-info-circle text-2xl"></i>
        </div>
        <h3 class="text-2xl font-black text-center text-slate-900 dark:text-white mb-4">Important Notice</h3>
        <div class="text-slate-600 dark:text-slate-300 text-sm md:text-base leading-relaxed text-center space-y-4 mb-8">
            <p>Welcome to the Sta. Cruz Municipal Police Station Portal.</p>
            <p>Please be advised that this platform <strong>exclusively provides data and bulletins managed by the Sta.
                    Cruz Laguna PNP</strong>.</p>
            <p>We do not provide or handle data outside of our station's jurisdiction, such as fire incidents, which are
                covered by the Bureau of Fire Protection (BFP) and local fire stations.</p>
        </div>
        <button id="accept-disclaimer"
            class="w-full bg-pnp-blue hover:bg-pnp-gold hover:text-pnp-blue text-white font-bold py-4 rounded-xl transition-colors duration-300 uppercase tracking-widest text-sm shadow-md">
            I Understand
        </button>
    </div>
</div>

<!-- INTERACTIVE BULLETIN DETAIL MODAL -->
<div id="bulletin-modal" class="fixed inset-0 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-slate-900/90 backdrop-blur-md" onclick="closeBulletinModal()"></div>
    <div class="relative bg-white dark:bg-slate-900 w-[95%] max-w-6xl rounded-[2rem] md:rounded-[3rem] overflow-hidden shadow-2xl border border-gray-150 dark:border-slate-800/60 transform scale-95 transition-all duration-300 flex flex-col lg:flex-row max-h-[90vh]">
        
        <!-- Left Side: Media Carousel -->
        <div class="w-full lg:w-[50%] relative bg-black flex items-center justify-center min-h-[250px] md:min-h-[400px] shrink-0 border-b lg:border-b-0 lg:border-r border-slate-800/60">
            <div id="bulletin-modal-media-container" class="w-full h-full relative overflow-hidden flex">
                <!-- Media injected here -->
            </div>
            
            <button id="modal-prev-btn" onclick="bulletinModalPrev()" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 hover:bg-pnp-blue text-white flex items-center justify-center backdrop-blur-sm transition-all z-20 hidden">
                <i class="fas fa-chevron-left text-sm"></i>
            </button>
            <button id="modal-next-btn" onclick="bulletinModalNext()" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 hover:bg-pnp-blue text-white flex items-center justify-center backdrop-blur-sm transition-all z-20 hidden">
                <i class="fas fa-chevron-right text-sm"></i>
            </button>
            
            <div id="modal-dots-container" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex space-x-2 z-20 hidden"></div>
        </div>

        <!-- Right Side: Text Content -->
        <div class="w-full lg:w-[50%] p-6 md:p-10 overflow-y-auto bg-white dark:bg-slate-900 custom-modal-scrollbar relative max-h-[50vh] lg:max-h-none">
            <button onclick="closeBulletinModal()" class="absolute top-4 right-4 md:top-6 md:right-6 w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 flex items-center justify-center focus:outline-none transition-all duration-300 z-10">
                <i class="fas fa-times"></i>
            </button>

            <div class="mb-4 pr-12 flex items-center justify-between flex-wrap gap-2">
                <div class="flex items-center space-x-2 flex-wrap gap-y-2">
                    <span id="bulletin-modal-category" class="inline-block text-[10px] md:text-xs font-black uppercase tracking-widest text-slate-700 dark:text-slate-200 bg-slate-100 dark:bg-slate-800 px-4 py-2 rounded-xl border border-slate-200 dark:border-slate-700"></span>
                    <div id="bulletin-modal-fb-btn" class="inline-block"></div>
                </div>
                <button id="tts-bulletin-modal-btn" onclick="" class="text-xs font-black text-slate-700 dark:text-slate-200 hover:text-pnp-blue dark:hover:text-pnp-gold uppercase tracking-widest flex items-center space-x-2 focus:outline-none transition px-3 py-1.5 rounded-xl bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
                    <i class="fas fa-volume-high text-xs"></i>
                    <span>Read Advisory</span>
                </button>
            </div>
            <div id="bulletin-modal-date" class="text-[10px] md:text-xs font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest mb-4 flex items-center"></div>
            <h3 id="bulletin-modal-title" class="text-2xl md:text-3xl lg:text-4xl font-black text-slate-900 dark:text-white leading-tight mb-8 tracking-tight"></h3>
            
            <div id="bulletin-modal-content" class="text-slate-700 dark:text-slate-300 text-sm md:text-base leading-relaxed space-y-5 whitespace-pre-wrap mb-10"></div>
        </div>
    </div>
</div>

<script>
    const bulletinsDatabase = <%- JSON.stringify(locals.bulletins || []) %>;

    function openBulletinModal(bulletinId) {
        const bulletin = bulletinsDatabase.find(b => b.id === bulletinId);
        if (!bulletin) return;

        const mediaContainer = document.getElementById('bulletin-modal-media-container');
        const prevBtn = document.getElementById('modal-prev-btn');
        const nextBtn = document.getElementById('modal-next-btn');
        const dotsContainer = document.getElementById('modal-dots-container');

        if (mediaContainer) {
            mediaContainer.innerHTML = '';
            dotsContainer.innerHTML = '';
            
            const mediaItems = [];
            
            if (bulletin.video_paths && bulletin.video_paths.length > 0) {
                bulletin.video_paths.forEach(url => {
                    if (url) mediaItems.push({ type: 'video', url });
                });
            } else if (bulletin.video_path) {
                mediaItems.push({ type: 'video', url: bulletin.video_path });
            }

            if (bulletin.photo_paths && bulletin.photo_paths.length > 0) {
                bulletin.photo_paths.forEach(url => {
                    if (url) mediaItems.push({ type: 'photo', url });
                });
            } else if (bulletin.photo_path) {
                mediaItems.push({ type: 'photo', url: bulletin.photo_path });
            }

            if (mediaItems.length > 0) {
                const renderItemHtml = (item, idx) => {
                    if (item.type === 'video') {
                        return `<div class="absolute inset-0 w-full h-full transition-opacity duration-500 flex items-center justify-center bg-black ${idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'}" data-slide="${idx}">
                                    <video src="${item.url}" controls class="w-full h-full object-contain"></video>
                                </div>`;
                    } else {
                        return `<div class="absolute inset-0 w-full h-full transition-opacity duration-500 flex items-center justify-center bg-black ${idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'}" data-slide="${idx}">
                                    <img src="${item.url}" class="w-full h-full object-contain" alt="Media ${idx + 1}">
                                </div>`;
                    }
                };
                
                mediaContainer.innerHTML = mediaItems.map((item, idx) => renderItemHtml(item, idx)).join('');
                
                window.currentBulletinModalSlide = 0;
                window.totalBulletinModalSlides = mediaItems.length;

                if (mediaItems.length > 1) {
                    prevBtn.classList.remove('hidden');
                    nextBtn.classList.remove('hidden');
                    dotsContainer.classList.remove('hidden');
                    
                    dotsContainer.innerHTML = mediaItems.map((_, idx) => `
                        <button onclick="bulletinModalGoTo(${idx})" class="w-2 h-2 rounded-full transition-all ${idx === 0 ? 'bg-white scale-125' : 'bg-white/40 hover:bg-white/80'}" data-dot="${idx}"></button>
                    `).join('');
                } else {
                    prevBtn.classList.add('hidden');
                    nextBtn.classList.add('hidden');
                    dotsContainer.classList.add('hidden');
                }
            } else {
                mediaContainer.innerHTML = `<div class="w-full h-full bg-slate-900 flex items-center justify-center text-slate-700">
                    <i class="fas fa-image text-5xl"></i>
                </div>`;
                prevBtn.classList.add('hidden');
                nextBtn.classList.add('hidden');
                dotsContainer.classList.add('hidden');
            }
        }

        document.getElementById('bulletin-modal-category').textContent = bulletin.category;
        document.getElementById('bulletin-modal-date').innerHTML = `<i class="fas fa-calendar-day mr-2"></i>${new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'long', day: 'numeric', year: 'numeric'})}`;
        document.getElementById('bulletin-modal-title').textContent = bulletin.title;
        document.getElementById('bulletin-modal-content').textContent = bulletin.body;

        const fbBtn = document.getElementById('bulletin-modal-fb-btn');
        if (fbBtn) {
            if (bulletin.facebook_url) {
                fbBtn.innerHTML = `<a href="${bulletin.facebook_url}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 px-3.5 py-1.5 bg-[#1877F2] hover:bg-blue-700 text-white rounded-xl text-[11px] font-black uppercase tracking-wider transition shadow-sm">
                    <i class="fab fa-facebook text-xs"></i>
                    <span>Open Official Facebook Post</span>
                    <i class="fas fa-external-link-alt text-[9px] ml-1 opacity-80"></i>
                </a>`;
            } else {
                fbBtn.innerHTML = '';
            }
        }

        const ttsBtn = document.getElementById('tts-bulletin-modal-btn');
        if (ttsBtn) {
            const speechText = `${bulletin.title}. ${bulletin.body}`;
            ttsBtn.onclick = () => speakReport('tts-bulletin-modal-btn', speechText);
        }

        const modal = document.getElementById('bulletin-modal');
        const content = modal.querySelector('.relative');

        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
        }, 50);
    }

    function closeBulletinModal() {
        if (typeof stopSpeech === 'function') stopSpeech();
        const modal = document.getElementById('bulletin-modal');
        if (!modal) return;
        const content = modal.querySelector('.relative');
        
        const videos = modal.querySelectorAll('video');
        videos.forEach(v => {
            try {
                v.pause();
            } catch (e) {}
        });

        modal.classList.add('opacity-0');
        if (content) {
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
        }
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    function bulletinModalUpdate() {
        const slides = document.querySelectorAll('#bulletin-modal-media-container [data-slide]');
        const dots = document.querySelectorAll('#modal-dots-container [data-dot]');
        
        slides.forEach((slide, idx) => {
            if (idx === window.currentBulletinModalSlide) {
                slide.classList.replace('opacity-0', 'opacity-100');
                slide.classList.replace('z-0', 'z-10');
                slide.classList.remove('pointer-events-none');
            } else {
                slide.classList.replace('opacity-100', 'opacity-0');
                slide.classList.replace('z-10', 'z-0');
                slide.classList.add('pointer-events-none');
                
                const vid = slide.querySelector('video');
                if (vid) { try { vid.pause(); } catch(e){} }
            }
        });
        
        dots.forEach((dot, idx) => {
            if (idx === window.currentBulletinModalSlide) {
                dot.classList.replace('bg-white/40', 'bg-white');
                dot.classList.remove('hover:bg-white/80');
                dot.classList.add('scale-125');
            } else {
                dot.classList.replace('bg-white', 'bg-white/40');
                dot.classList.add('hover:bg-white/80');
                dot.classList.remove('scale-125');
            }
        });
    }

    function bulletinModalNext() {
        if (!window.totalBulletinModalSlides || window.totalBulletinModalSlides <= 1) return;
        window.currentBulletinModalSlide = (window.currentBulletinModalSlide + 1) % window.totalBulletinModalSlides;
        bulletinModalUpdate();
    }

    function bulletinModalPrev() {
        if (!window.totalBulletinModalSlides || window.totalBulletinModalSlides <= 1) return;
        window.currentBulletinModalSlide = (window.currentBulletinModalSlide - 1 + window.totalBulletinModalSlides) % window.totalBulletinModalSlides;
        bulletinModalUpdate();
    }

    function bulletinModalGoTo(idx) {
        if (!window.totalBulletinModalSlides || window.totalBulletinModalSlides <= 1) return;
        window.currentBulletinModalSlide = idx;
        bulletinModalUpdate();
    }

    document.addEventListener('keydown', (e) => {
        const modal = document.getElementById('bulletin-modal');
        if (modal && !modal.classList.contains('hidden')) {
            if (e.key === 'ArrowLeft') {
                bulletinModalPrev();
            } else if (e.key === 'ArrowRight') {
                bulletinModalNext();
            } else if (e.key === 'Escape') {
                closeBulletinModal();
            }
        }
    });

    async function generateTrendsReport() {
        const btn = document.querySelector('button[onclick="generateTrendsReport()"]');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Loading...</span>';
        btn.disabled = true;

        try {
            const response = await fetch('/api/map-points');
            const currentPoints = await response.json();
            
            if (!currentPoints || currentPoints.length === 0) {
                alert('No crime data available to generate a report.');
                btn.innerHTML = originalText;
                btn.disabled = false;
                return;
            }

            let totalCrimes = currentPoints.length;
            
            const typeCounts = {};
            const barangayCounts = {};
            const monthCounts = {};

            currentPoints.forEach(p => {
                const type = p.incident_type || 'Unknown';
                const brgy = p.barangay || 'Unknown';
                typeCounts[type] = (typeCounts[type] || 0) + 1;
                barangayCounts[brgy] = (barangayCounts[brgy] || 0) + 1;
                
                const pDate = new Date(p.incident_date || p.date || p.created_at);
                if (!isNaN(pDate.getTime())) {
                    const month = pDate.toLocaleString('default', { month: 'long' });
                    monthCounts[month] = (monthCounts[month] || 0) + 1;
                }
            });

            const sortedTypes = Object.entries(typeCounts).sort((a, b) => b[1] - a[1]);
            const sortedBarangays = Object.entries(barangayCounts).sort((a, b) => b[1] - a[1]);
            const sortedMonths = Object.entries(monthCounts).sort((a, b) => b[1] - a[1]);

            // Calculate time scope
            const dates = currentPoints
                .map(p => new Date(p.incident_date || p.date || p.created_at).getTime())
                .filter(t => !isNaN(t));
            let timeScope = "";
            if (dates.length > 0) {
                const minDate = new Date(Math.min(...dates)).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
                const maxDate = new Date(Math.max(...dates)).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
                timeScope = minDate === maxDate ? `on ${minDate}` : `for the period between ${minDate} and ${maxDate}`;
            } else {
                timeScope = "for the selected period";
            }

            const mostCommonCrime = sortedTypes.length > 0 ? sortedTypes[0] : ['N/A', 0];
            const mostAffectedBrgy = sortedBarangays.length > 0 ? sortedBarangays[0] : ['N/A', 0];
            const peakMonth = sortedMonths.length > 0 ? sortedMonths[0] : ['N/A', 0];
            
            const crimePercentage = totalCrimes > 0 ? ((mostCommonCrime[1]/totalCrimes)*100).toFixed(1) : 0;

            const reportHtml = `
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div class="bg-gray-50 dark:bg-slate-800 p-4 rounded-xl border border-gray-100 dark:border-slate-700">
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Total Incidents</p>
                        <p class="text-3xl font-black text-pnp-blue dark:text-pnp-gold">${totalCrimes}</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-slate-800 p-4 rounded-xl border border-gray-100 dark:border-slate-700">
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Peak Month</p>
                        <p class="text-xl font-black text-pnp-blue dark:text-pnp-gold">${peakMonth[0]} <span class="text-sm text-gray-500">(${peakMonth[1]} cases)</span></p>
                    </div>
                    <div class="bg-gray-50 dark:bg-slate-800 p-4 rounded-xl border border-gray-100 dark:border-slate-700">
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Most Prevalent Crime</p>
                        <p class="text-xl font-black text-pnp-blue dark:text-pnp-gold">${mostCommonCrime[0]} <span class="text-sm text-gray-500">(${mostCommonCrime[1]} cases)</span></p>
                    </div>
                    <div class="bg-gray-50 dark:bg-slate-800 p-4 rounded-xl border border-gray-100 dark:border-slate-700">
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Most Affected Barangay</p>
                        <p class="text-xl font-black text-pnp-blue dark:text-pnp-gold">${mostAffectedBrgy[0]} <span class="text-sm text-gray-500">(${mostAffectedBrgy[1]} cases)</span></p>
                    </div>
                </div>
                <div>
                    <h4 class="font-bold text-slate-800 dark:text-white mb-2">Executive Summary</h4>
                    <p>Based on the system's recorded data, a total of <strong>${totalCrimes}</strong> incidents have been logged <strong>${timeScope}</strong>. The most frequent classification is <strong>${mostCommonCrime[0]}</strong>, accounting for <strong>${crimePercentage}%</strong> of total crimes. The area with the highest concentration of reported incidents is <strong>${mostAffectedBrgy[0]}</strong>. Incident frequency peaked during the month of <strong>${peakMonth[0]}</strong>.</p>
                </div>
            `;

            document.getElementById('trends-report-content').innerHTML = reportHtml;

            const modal = document.getElementById('trends-modal');
            const content = document.getElementById('trends-modal-content');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 10);
            
            btn.innerHTML = originalText;
            btn.disabled = false;
        } catch (err) {
            console.error(err);
            alert('An error occurred while generating the report.');
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    function closeTrendsModal() {
        const modal = document.getElementById('trends-modal');
        const content = document.getElementById('trends-modal-content');
        modal.classList.add('opacity-0');
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 500);
    }


    function switchTab(tabId) {
        const bulletinsBtn = document.getElementById('tab-btn-bulletins');
        const incidentsBtn = document.getElementById('tab-btn-incidents');
        const bulletinsContent = document.getElementById('tab-content-bulletins');
        const incidentsContent = document.getElementById('tab-content-incidents');

        if (!bulletinsBtn || !incidentsBtn || !bulletinsContent || !incidentsContent) return;

        if (tabId === 'bulletins') {
            bulletinsBtn.className = 'flex items-center space-x-2 px-6 py-3 rounded-xl text-xs font-black uppercase tracking-wider transition-all duration-300 bg-white dark:bg-slate-800 text-pnp-blue dark:text-pnp-gold shadow-md';
            incidentsBtn.className = 'flex items-center space-x-2 px-6 py-3 rounded-xl text-xs font-black uppercase tracking-wider transition-all duration-300 text-slate-500 dark:text-slate-400 hover:text-pnp-blue dark:hover:text-pnp-gold';
            
            bulletinsContent.classList.remove('hidden', 'opacity-0');
            bulletinsContent.classList.add('block', 'opacity-100');
            
            incidentsContent.classList.add('hidden', 'opacity-0');
            incidentsContent.classList.remove('block', 'opacity-100');
        } else {
            incidentsBtn.className = 'flex items-center space-x-2 px-6 py-3 rounded-xl text-xs font-black uppercase tracking-wider transition-all duration-300 bg-white dark:bg-slate-800 text-pnp-blue dark:text-pnp-gold shadow-md';
            bulletinsBtn.className = 'flex items-center space-x-2 px-6 py-3 rounded-xl text-xs font-black uppercase tracking-wider transition-all duration-300 text-slate-500 dark:text-slate-400 hover:text-pnp-blue dark:hover:text-pnp-gold';
            
            incidentsContent.classList.remove('hidden', 'opacity-0');
            incidentsContent.classList.add('block', 'opacity-100');
            
            bulletinsContent.classList.add('hidden', 'opacity-0');
            bulletinsContent.classList.remove('block', 'opacity-100');
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Disclaimer Modal Logic
        const modal = document.getElementById('jurisdiction-modal');
        const content = document.getElementById('modal-content');
        const acceptBtn = document.getElementById('accept-disclaimer');

        if (!sessionStorage.getItem('staCruzDisclaimerAccepted')) {
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 100);
        }

        acceptBtn.addEventListener('click', () => {
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 500);
            sessionStorage.setItem('staCruzDisclaimerAccepted', 'true');
        });

        // Carousel Slider Logic
        const track = document.getElementById('carousel-track');
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        const dots = document.querySelectorAll('.carousel-dot');
        
        if (track) {
            const slides = track.children;
            const totalSlides = slides.length;
            let currentSlide = 0;
            let autoplayTimer = null;

            if (totalSlides > 0) {
                function updateCarousel() {
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                    dots.forEach((dot, index) => {
                        if (index === currentSlide) {
                            dot.classList.add('bg-pnp-gold', 'w-8');
                            dot.classList.remove('bg-slate-300', 'dark:bg-slate-700');
                        } else {
                            dot.classList.remove('bg-pnp-gold', 'w-8');
                            dot.classList.add('bg-slate-300', 'dark:bg-slate-700');
                        }
                    });
                }

                function nextSlide() {
                    currentSlide = (currentSlide + 1) % totalSlides;
                    updateCarousel();
                }

                function prevSlide() {
                    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
                    updateCarousel();
                }

                function startAutoplay() {
                    stopAutoplay();
                    autoplayTimer = setInterval(nextSlide, 6000);
                }

                function stopAutoplay() {
                    if (autoplayTimer) {
                        clearInterval(autoplayTimer);
                        autoplayTimer = null;
                    }
                }

                if (prevBtn) {
                    prevBtn.addEventListener('click', () => {
                        prevSlide();
                        startAutoplay();
                    });
                }

                if (nextBtn) {
                    nextBtn.addEventListener('click', () => {
                        nextSlide();
                        startAutoplay();
                    });
                }

                dots.forEach((dot, index) => {
                    dot.addEventListener('click', () => {
                        currentSlide = index;
                        updateCarousel();
                        startAutoplay();
                    });
                });

                const wrapper = track.parentElement;
                if (wrapper) {
                    wrapper.addEventListener('mouseenter', stopAutoplay);
                    wrapper.addEventListener('mouseleave', startAutoplay);
                }

                // Initialize
                updateCarousel();
                startAutoplay();
            }
        }

        // Tab and Category from query string check
        const urlParams = new URLSearchParams(window.location.search);
        const tab = urlParams.get('tab');
        const categoryParam = urlParams.get('category');
        
        if (tab === 'incidents') {
            switchTab('incidents');
            const feedEl = document.getElementById('tab-btn-incidents');
            if (feedEl) {
                setTimeout(() => {
                    feedEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }, 300);
            }
        } else if (tab === 'bulletins' || categoryParam) {
            switchTab('bulletins');
            const feedEl = document.getElementById('tab-btn-bulletins');
            if (feedEl) {
                setTimeout(() => {
                    feedEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }, 300);
            }
        }
    });
</script>

<!-- Additional Styles for Micro-animations -->
<style>
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
