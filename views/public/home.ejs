<!-- Hero Section -->
<section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-slate-900">
    <div class="absolute inset-0 z-0">
        <img src="/images/home-hero.jpg" alt="Sta. Cruz Laguna"
            class="w-full h-full object-cover opacity-40 mix-blend-overlay scale-105 animate-[pulse_10s_ease-in-out_infinite_alternate]"
            onerror="this.src='https://images.unsplash.com/photo-1572949645841-094f3a9c4c94?q=80&w=1920&auto=format&fit=crop'">
        <div
            class="absolute inset-0 bg-gradient-to-b from-pnp-blue/80 via-pnp-blue/60 to-slate-900 dark:from-slate-950/90 dark:via-slate-900/80 dark:to-slate-950">
        </div>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center flex flex-col items-center mt-10">
        <div
            class="inline-flex items-center space-x-2 bg-white/10 backdrop-blur-md text-pnp-gold px-5 py-2 rounded-full mb-8 border border-white/20 animate-fade-in-up">
            <i class="fas fa-shield-halved text-sm"></i>
            <span class="text-xs font-bold uppercase tracking-widest">Official Portal &bull; PNP Sta. Cruz</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight tracking-tight drop-shadow-lg animate-fade-in-up"
            style="animation-delay: 0.1s;">
            Welcome to the <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-pnp-gold to-yellow-300">Public
                Bulletin</span>
        </h1>

        <p class="text-lg md:text-xl text-blue-100 font-light max-w-3xl mx-auto mb-6 leading-relaxed drop-shadow-md animate-fade-in-up"
            style="animation-delay: 0.2s;">
            Stay informed with the latest updates, advisories, missing persons, and wanted persons alerts from the Sta.
            Cruz PNP Station.
        </p>
    </div>
</section>

<!-- Bulletins Section -->
<section class="py-16 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 relative min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <% if (locals.bulletins && bulletins.length > 0) { %>
            <% const carouselBulletins = bulletins.slice(0, 6); %>
            <!-- Carousel Container -->
            <div class="mb-20">
                <div class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
                    <div>
                        <div class="inline-flex items-center space-x-2 bg-pnp-blue/5 dark:bg-pnp-gold/10 text-pnp-blue dark:text-pnp-gold px-3.5 py-1.5 rounded-full mb-3 border border-pnp-blue/10 dark:border-pnp-gold/25">
                            <i class="fas fa-bullhorn text-[10px]"></i>
                            <span class="text-[9px] font-black uppercase tracking-widest">Recent Announcements</span>
                        </div>
                        <h2 class="text-3xl font-black text-pnp-blue dark:text-white uppercase tracking-tight leading-none">Latest Bulletins</h2>
                    </div>
                    <!-- Navigation Controls -->
                    <div class="flex items-center space-x-2 shrink-0">
                        <button id="carousel-prev" class="w-11 h-11 rounded-xl bg-white hover:bg-pnp-blue hover:text-white dark:bg-slate-900 dark:hover:bg-pnp-gold dark:hover:text-pnp-blue text-slate-600 dark:text-slate-300 flex items-center justify-center transition-all shadow-sm border border-gray-100 dark:border-slate-800/80 focus:outline-none">
                            <i class="fas fa-chevron-left text-xs"></i>
                        </button>
                        <button id="carousel-next" class="w-11 h-11 rounded-xl bg-white hover:bg-pnp-blue hover:text-white dark:bg-slate-900 dark:hover:bg-pnp-gold dark:hover:text-pnp-blue text-slate-600 dark:text-slate-300 flex items-center justify-center transition-all shadow-sm border border-gray-100 dark:border-slate-800/80 focus:outline-none">
                            <i class="fas fa-chevron-right text-xs"></i>
                        </button>
                    </div>
                </div>

                <!-- Carousel Wrapper -->
                <div class="relative overflow-hidden w-full rounded-[2.5rem] border border-gray-100 dark:border-slate-800/60 shadow-xl bg-white dark:bg-slate-900">
                    <!-- Inner Track -->
                    <div id="carousel-track" class="flex transition-transform duration-700 ease-in-out">
                        <% carouselBulletins.forEach((bulletin, index) => { %>
                            <div class="w-full shrink-0 flex-none px-6 md:px-12 py-10 md:py-14">
                                <a href="/bulletins/<%= bulletin.id %>" class="flex flex-col lg:flex-row items-stretch gap-10 hover:no-underline group">
                                    <!-- Image Container -->
                                    <div class="w-full lg:w-1/2 h-64 md:h-80 rounded-[2rem] overflow-hidden relative shadow-md shrink-0 bg-slate-100 dark:bg-slate-950 border border-gray-100 dark:border-slate-800/50">
                                        <% if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                                            <img src="<%= bulletin.photo_paths[0] %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
                                        <% } else if (bulletin.photo_path) { %>
                                            <img src="<%= bulletin.photo_path %>" alt="<%= bulletin.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
                                        <% } else { %>
                                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-850">
                                                <i class="fas fa-bullhorn text-5xl text-slate-300 dark:text-slate-700"></i>
                                            </div>
                                        <% } %>
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-40 group-hover:opacity-20 transition-opacity duration-300"></div>
                                        <div class="absolute bottom-6 left-6 text-white font-black text-[9px] uppercase tracking-widest bg-pnp-blue/80 dark:bg-slate-950/80 backdrop-blur-md px-4 py-2 rounded-xl border border-white/10">
                                            <i class="fas fa-clock mr-1.5 text-pnp-gold"></i>
                                            <%= new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'}) %>
                                        </div>
                                    </div>
                                    
                                    <!-- Content Info -->
                                    <div class="w-full lg:w-1/2 flex flex-col justify-center text-left py-2">
                                        <div class="mb-4">
                                            <% 
                                                const badgeColors = {
                                                    'Crime Advisory': 'text-yellow-600 dark:text-yellow-400 bg-yellow-50 dark:bg-yellow-950/30 border-yellow-100 dark:border-yellow-900/20',
                                                    'Recovered Property': 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-950/30 border-green-100 dark:border-green-900/20',
                                                    'General Announcement': 'text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-950/30 border-blue-100 dark:border-blue-900/20'
                                                };
                                                const defaultBadge = 'text-slate-600 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 border-gray-200 dark:border-slate-700';
                                            %>
                                            <span class="px-3.5 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border <%= badgeColors[bulletin.category] || defaultBadge %>">
                                                <%= bulletin.category %>
                                            </span>
                                        </div>
                                        
                                        <h3 class="text-2xl md:text-3xl font-black text-slate-900 dark:text-white leading-tight mb-5 group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors tracking-tight line-clamp-2">
                                            <%= bulletin.title %>
                                        </h3>
                                        
                                        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6 line-clamp-3">
                                            <%= bulletin.body %>
                                        </p>
                                        
                                        <div class="mt-2">
                                            <span class="inline-flex items-center text-pnp-blue dark:text-pnp-gold font-black text-xs uppercase tracking-widest group-hover:translate-x-1 transition-transform">
                                                Read Announcement <i class="fas fa-arrow-right ml-2.5 text-[9px]"></i>
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        <% }) %>
                    </div>

                    <!-- Slide Dots/Indicators -->
                    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex items-center space-x-2 z-30">
                        <% carouselBulletins.forEach((_, index) => { %>
                            <button class="carousel-dot w-2 h-2 rounded-full bg-slate-300 dark:bg-slate-700 hover:bg-pnp-gold transition-all duration-300 focus:outline-none" data-slide="<%= index %>"></button>
                        <% }) %>
                    </div>
                </div>
            </div>
        <% } %>

        <div class="border-t border-gray-100 dark:border-slate-800/80 pt-16">
            <div class="mb-10 text-center md:text-left">
                <h3 class="text-2xl font-black text-pnp-blue dark:text-white uppercase tracking-tight">All Directives & Advisories</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-2 font-medium">Browse the full feed of general announcements</p>
            </div>
            <% if (locals.bulletins && bulletins.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% bulletins.forEach(bulletin=> { %>
                        <a href="/bulletins/<%= bulletin.id %>"
                            class="group flex flex-col bg-white dark:bg-slate-900 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 dark:border-slate-800 overflow-hidden transform hover:-translate-y-2 h-full">
                            <% if (bulletin.photo_paths && bulletin.photo_paths.length> 0) { %>
                                <div class="h-48 overflow-hidden relative shrink-0">
                                    <img src="<%= bulletin.photo_paths[0] %>" alt="<%= bulletin.title %>"
                                        class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
                                    <div
                                        class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                    </div>
                                </div>
                                <% } else { %>
                                    <div
                                        class="h-48 bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 flex items-center justify-center shrink-0">
                                        <i class="fas fa-file-alt text-4xl text-slate-300 dark:text-slate-600"></i>
                                    </div>
                                    <% } %>
                                        <div class="p-8 flex flex-col flex-grow">
                                            <% const badgeColors={ 'Wanted Person'
                                                : 'text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20'
                                                , 'Missing Person'
                                                : 'text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20'
                                                , 'Crime Advisory'
                                                : 'text-yellow-600 dark:text-yellow-400 bg-yellow-50 dark:bg-yellow-900/20'
                                                , 'Recovered Property'
                                                : 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20'
                                                , 'General Announcement'
                                                : 'text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20' }; %>
                                                <div class="mb-4">
                                                    <span
                                                        class="inline-block px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= badgeColors[bulletin.category] || 'text-slate-600 bg-slate-100 dark:text-slate-400 dark:bg-slate-800' %>">
                                                        <%= bulletin.category %>
                                                    </span>
                                                </div>
                                                <h4
                                                    class="text-xl font-bold text-slate-900 dark:text-white leading-tight mb-3 group-hover:text-pnp-blue dark:group-hover:text-pnp-gold transition-colors line-clamp-2">
                                                    <%= bulletin.title %>
                                                </h4>
                                                <p
                                                    class="text-sm text-slate-500 dark:text-slate-400 line-clamp-3 mb-6 leading-relaxed flex-grow">
                                                    <%= bulletin.body %>
                                                </p>
                                                <div
                                                    class="pt-4 border-t border-gray-50 dark:border-slate-800 text-xs text-slate-400 dark:text-slate-500 font-bold flex justify-between items-center mt-auto">
                                                    <span><i class="far fa-calendar-alt mr-1"></i>
                                                        <%= new Date(bulletin.created_at).toLocaleDateString(undefined, {
                                                            year: 'numeric' , month: 'short' , day: 'numeric' }) %>
                                                    </span>
                                                    <span
                                                        class="text-pnp-blue dark:text-pnp-gold opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform translate-x-2 group-hover:translate-x-0"><i
                                                            class="fas fa-arrow-right"></i></span>
                                                </div>
                                        </div>
                        </a>
                        <% }) %>
                </div>
            <% } else { %>
                <div
                    class="text-center py-20 bg-white dark:bg-slate-900 rounded-[2rem] border border-dashed border-gray-200 dark:border-slate-800 max-w-3xl mx-auto">
                    <div
                        class="w-20 h-20 bg-slate-50 dark:bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-400 shadow-inner">
                        <i class="fas fa-inbox text-3xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-700 dark:text-slate-300 mb-2">No Active Bulletins</h3>
                    <p class="text-slate-500 dark:text-slate-400 font-medium">There are currently no public
                        announcements or updates to display.</p>
                </div>
            <% } %>
        </div>
    </div>
</section>

<!-- Jurisdiction Disclaimer Modal -->
<div id="jurisdiction-modal"
    class="fixed inset-0 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-500">
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="relative bg-white dark:bg-slate-900 w-11/12 max-w-lg rounded-[2rem] p-8 md:p-10 shadow-2xl border border-gray-100 dark:border-slate-800 transform scale-95 transition-transform duration-500"
        id="modal-content">
        <div
            class="flex items-center justify-center w-16 h-16 bg-pnp-blue text-white rounded-full mb-6 mx-auto shadow-lg">
            <i class="fas fa-info-circle text-2xl"></i>
        </div>
        <h3 class="text-2xl font-black text-center text-slate-900 dark:text-white mb-4">Important Notice</h3>
        <div class="text-slate-600 dark:text-slate-300 text-sm md:text-base leading-relaxed text-center space-y-4 mb-8">
            <p>Welcome to the Sta. Cruz Municipal Police Station Portal.</p>
            <p>Please be advised that this platform <strong>exclusively provides data and bulletins managed by the Sta.
                    Cruz Laguna PNP</strong>.</p>
            <p>We do not provide or handle data outside of our station's jurisdiction, such as fire incidents, which are
                covered by the Bureau of Fire Protection (BFP) and local fire stations.</p>
        </div>
        <button id="accept-disclaimer"
            class="w-full bg-pnp-blue hover:bg-pnp-gold hover:text-pnp-blue text-white font-bold py-4 rounded-xl transition-colors duration-300 uppercase tracking-widest text-sm shadow-md">
            I Understand
        </button>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Disclaimer Modal Logic
        const modal = document.getElementById('jurisdiction-modal');
        const content = document.getElementById('modal-content');
        const acceptBtn = document.getElementById('accept-disclaimer');

        if (!localStorage.getItem('staCruzDisclaimerAccepted')) {
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 100);
        }

        acceptBtn.addEventListener('click', () => {
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 500);
            localStorage.setItem('staCruzDisclaimerAccepted', 'true');
        });

        // Carousel Slider Logic
        const track = document.getElementById('carousel-track');
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        const dots = document.querySelectorAll('.carousel-dot');
        
        if (track) {
            const slides = track.children;
            const totalSlides = slides.length;
            let currentSlide = 0;
            let autoplayTimer = null;

            if (totalSlides > 0) {
                function updateCarousel() {
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                    dots.forEach((dot, index) => {
                        if (index === currentSlide) {
                            dot.classList.add('bg-pnp-gold', 'w-8');
                            dot.classList.remove('bg-slate-300', 'dark:bg-slate-700');
                        } else {
                            dot.classList.remove('bg-pnp-gold', 'w-8');
                            dot.classList.add('bg-slate-300', 'dark:bg-slate-700');
                        }
                    });
                }

                function nextSlide() {
                    currentSlide = (currentSlide + 1) % totalSlides;
                    updateCarousel();
                }

                function prevSlide() {
                    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
                    updateCarousel();
                }

                function startAutoplay() {
                    stopAutoplay();
                    autoplayTimer = setInterval(nextSlide, 6000);
                }

                function stopAutoplay() {
                    if (autoplayTimer) {
                        clearInterval(autoplayTimer);
                        autoplayTimer = null;
                    }
                }

                if (prevBtn) {
                    prevBtn.addEventListener('click', () => {
                        prevSlide();
                        startAutoplay();
                    });
                }

                if (nextBtn) {
                    nextBtn.addEventListener('click', () => {
                        nextSlide();
                        startAutoplay();
                    });
                }

                dots.forEach((dot, index) => {
                    dot.addEventListener('click', () => {
                        currentSlide = index;
                        updateCarousel();
                        startAutoplay();
                    });
                });

                const wrapper = track.parentElement;
                if (wrapper) {
                    wrapper.addEventListener('mouseenter', stopAutoplay);
                    wrapper.addEventListener('mouseleave', startAutoplay);
                }

                // Initialize
                updateCarousel();
                startAutoplay();
            }
        }
    });
</script>

<!-- Additional Styles for Micro-animations -->
<style>
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
</style>