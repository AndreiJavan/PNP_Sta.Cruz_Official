<div class="relative min-h-[45vh] flex items-center overflow-hidden bg-slate-950 pt-24 pb-16">
    <div class="absolute inset-0 z-0 bg-gradient-to-br from-pnp-blue/20 via-slate-950 to-slate-950"></div>

    <!-- Hero Content -->
    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-3xl">
            <div
                class="inline-flex items-center space-x-2 bg-pnp-gold/20 text-pnp-gold px-4 py-2 rounded-full mb-8 border border-pnp-gold/30 animate-fade-in">
                <i class="fas fa-shield-halved text-sm"></i>
                <span class="text-xs font-bold uppercase tracking-widest">Official Public Safety Portal</span>
            </div>

            <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-white mb-6 leading-tight tracking-tighter">
                <span class="text-pnp-gold"><%= title %></span>
            </h1>

            <p class="text-xl text-blue-100 dark:text-gray-300 mb-8 leading-relaxed max-w-2xl">
                Stay updated with the latest alerts and activities in Sta. Cruz.
            </p>

            <div class="flex flex-wrap gap-4">
                <!-- Public posting disabled -->
            </div>
        </div>
    </div>
</div>

<style>
    @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
</style>

<div class="container mx-auto px-4 py-20 <%= (category === 'Wanted Person' || category === 'Missing Person') ? 'pt-24' : '' %>">
    <!-- Category Pills instead of Search -->
    <% if (category !== 'Wanted Person' && category !== 'Missing Person') { %>
    <div class="bg-white dark:bg-slate-800 p-6 md:p-8 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-700 -mt-32 relative z-20 mb-16 max-w-4xl mx-auto flex flex-col items-center">
        <div class="flex flex-wrap gap-3 justify-center">
            <% 
                const activeCat = category && category !== 'All' ? category : 'Crime Advisory';
            %>
            <button onclick="setCategoryFilter('Crime Advisory', this)" class="category-pill-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider <%= activeCat === 'Crime Advisory' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue border border-transparent shadow-md' : 'bg-gray-50 dark:bg-slate-900 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 border border-gray-200 dark:border-slate-700' %> transition duration-300">
                Crime Advisories
            </button>
            <button onclick="setCategoryFilter('Traffic Advisory', this)" class="category-pill-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider <%= activeCat === 'Traffic Advisory' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue border border-transparent shadow-md' : 'bg-gray-50 dark:bg-slate-900 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 border border-gray-200 dark:border-slate-700' %> transition duration-300">
                Traffic Advisories
            </button>
            <button onclick="setCategoryFilter('Cybercrime Advisory', this)" class="category-pill-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider <%= activeCat === 'Cybercrime Advisory' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue border border-transparent shadow-md' : 'bg-gray-50 dark:bg-slate-900 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 border border-gray-200 dark:border-slate-700' %> transition duration-300">
                Cybercrime Advisories
            </button>
            <button onclick="setCategoryFilter('Community Awareness', this)" class="category-pill-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider <%= activeCat === 'Community Awareness' ? 'bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue border border-transparent shadow-md' : 'bg-gray-50 dark:bg-slate-900 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 border border-gray-200 dark:border-slate-700' %> transition duration-300">
                Community Awareness
            </button>
        </div>
    </div>
    <% } %>

    <!-- Bulletin Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <% bulletins.forEach(bulletin=> { %>
            <div
                class="group bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden hover:shadow-2xl transition duration-500 flex flex-col"
                data-category="<%= bulletin.category %>">
                <% if (bulletin.video_paths && bulletin.video_paths.length > 0) { %>
                    <div class="h-64 overflow-hidden relative bg-black">
                        <video src="<%= bulletin.video_paths[0] %>" muted class="w-full h-full object-cover group-hover:scale-110 transition duration-700 pointer-events-none"></video>
                        <div class="absolute inset-0 bg-black/25 flex items-center justify-center">
                            <i class="fas fa-play text-white text-4xl opacity-90 group-hover:scale-110 transition duration-300"></i>
                        </div>
                        <% if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                            <div class="absolute bottom-4 right-4 bg-black/60 backdrop-blur-md px-3 py-1 rounded-full text-white text-[10px] font-bold tracking-widest flex items-center space-x-2">
                                <i class="fas fa-images"></i>
                                <span>+<%= bulletin.photo_paths.length %></span>
                            </div>
                        <% } %>
                    </div>
                <% } else if (bulletin.photo_paths && bulletin.photo_paths.length > 0) { %>
                    <div class="h-64 overflow-hidden relative">
                        <img src="<%= bulletin.photo_paths[0] %>" alt="<%= bulletin.title %>"
                            class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                        <% if (bulletin.photo_paths.length > 1) { %>
                            <div class="absolute bottom-4 right-4 bg-black/60 backdrop-blur-md px-3 py-1 rounded-full text-white text-[10px] font-bold tracking-widest flex items-center space-x-2">
                                <i class="fas fa-images"></i>
                                <span>+<%= bulletin.photo_paths.length - 1 %></span>
                            </div>
                        <% } %>
                    </div>
                <% } else if (bulletin.photo_path) { %>
                    <div class="h-64 overflow-hidden">
                        <img src="<%= bulletin.photo_path %>" alt="<%= bulletin.title %>"
                            class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    </div>
                <% } else { %>
                    <div class="h-64 bg-gray-50 dark:bg-slate-900/50 flex items-center justify-center">
                        <i class="fas fa-bullhorn text-4xl text-gray-200 dark:text-slate-700 group-hover:text-pnp-blue transition-colors"></i>
                    </div>
                <% } %>

                            <div class="p-6 md:p-10 flex-grow flex flex-col">
                                <div class="flex flex-wrap justify-between items-center gap-2 mb-6">
                                    <% const badgeColors={ 'Wanted Person'
                                        : 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400'
                                        , 'Missing Person'
                                        : 'bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400'
                                        , 'Crime Advisory'
                                        : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400'
                                        , 'Crime Advisories'
                                        : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400'
                                        , 'Traffic Advisory'
                                        : 'bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400'
                                        , 'Traffic Advisories'
                                        : 'bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400'
                                        , 'VAWC Advisory'
                                        : 'bg-pink-100 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400'
                                        , 'VAWC Advisories'
                                        : 'bg-pink-100 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400'
                                        , 'Community Awareness'
                                        : 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400'
                                        , 'Recovered Property'
                                        : 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400'
                                        , 'General Announcement'
                                        : 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400' }; %>
                                        <span
                                            class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= badgeColors[bulletin.category] || 'bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-400' %>">
                                            <%= bulletin.category %>
                                        </span>
                                        <span
                                            class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase tracking-widest">
                                            <%= new Date(bulletin.created_at).toLocaleDateString() %>
                                        </span>
                                </div>

                                <h3
                                    class="text-xl font-black text-pnp-blue dark:text-white mb-4 leading-tight group-hover:text-pnp-gold transition duration-300">
                                    <%= bulletin.title %>
                                </h3>
                                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mb-8 line-clamp-3">
                                    <%= bulletin.body %>
                                </p>

                                <div class="mt-auto pt-8 border-t border-gray-50 dark:border-slate-700">
                                    <button onclick="openBulletinModal('<%= bulletin.id %>')"
                                        class="inline-flex items-center text-pnp-blue dark:text-pnp-gold font-black text-xs uppercase tracking-widest hover:text-pnp-gold dark:hover:text-white transition focus:outline-none">
                                        Read Full Details <i class="fas fa-arrow-right ml-3 text-[10px]"></i>
                                    </button>
                                </div>
                            </div>
            </div>
            <% }) %>
    </div>

    <div id="noResultsDiv" class="text-center py-20" style="<%= bulletins.length === 0 ? 'display: block;' : 'display: none;' %>">
        <div class="w-20 h-20 bg-gray-50 dark:bg-slate-900/50 text-gray-200 dark:text-slate-700 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-search text-3xl"></i>
        </div>
        <h3 class="text-xl font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">No bulletins found
        </h3>
        <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Try adjusting your search or filter criteria.</p>
    </div>
</div>

<!-- INTERACTIVE BULLETIN DETAIL MODAL -->
<div id="bulletin-modal" class="fixed inset-0 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-slate-900/90 backdrop-blur-md" onclick="closeBulletinModal()"></div>
    <div class="relative bg-white dark:bg-slate-900 w-[95%] max-w-5xl rounded-[2rem] md:rounded-[3rem] overflow-hidden shadow-2xl border border-gray-150 dark:border-slate-800/60 transform scale-95 transition-all duration-300 flex flex-col max-h-[90vh]">
        <!-- Header / Media Banner -->
        <div class="relative h-64 md:h-[32rem] bg-slate-950 overflow-hidden shrink-0">
            <!-- Dynamic Media Collage Container -->
            <div id="bulletin-modal-collage-container" class="w-full h-full"></div>
            
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent pointer-events-none"></div>
            <button onclick="closeBulletinModal()" class="absolute top-6 right-6 md:top-8 md:right-8 w-12 h-12 rounded-full bg-black/40 hover:bg-black/80 backdrop-blur-md text-white flex items-center justify-center focus:outline-none transition-all duration-300 z-10 border border-white/10 hover:scale-110">
                <i class="fas fa-times text-lg"></i>
            </button>
            <div class="absolute bottom-6 left-6 md:bottom-10 md:left-10 md:right-10 pointer-events-none z-10 flex flex-col items-start">
                <span id="bulletin-modal-category" class="text-[10px] md:text-xs font-black uppercase tracking-widest text-pnp-gold bg-pnp-blue/90 px-3 py-1.5 rounded-lg border border-white/10 mb-4 shadow-lg backdrop-blur-sm"></span>
            </div>
        </div>

        <!-- Body Scrollable Content -->
        <div class="p-6 md:p-12 overflow-y-auto bg-slate-50 dark:bg-slate-900">
            <div id="bulletin-modal-date" class="text-[10px] md:text-xs font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest mb-4 flex items-center"></div>
            <h3 id="bulletin-modal-title" class="text-2xl md:text-4xl lg:text-5xl font-black text-slate-900 dark:text-white leading-tight mb-8 tracking-tight"></h3>
            
            <div id="bulletin-modal-content" class="text-slate-600 dark:text-slate-300 text-base md:text-lg leading-relaxed md:leading-loose space-y-6 whitespace-pre-wrap"></div>
        </div>

        <!-- Footer -->
        <div class="p-6 md:p-8 border-t border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-950 shrink-0 flex justify-end">
            <button onclick="closeBulletinModal()" class="bg-slate-100 hover:bg-pnp-blue dark:bg-slate-800 dark:hover:bg-pnp-gold text-slate-700 hover:text-white dark:text-slate-300 dark:hover:text-slate-900 font-bold px-8 py-3.5 rounded-xl transition-all duration-300 uppercase tracking-widest text-xs focus:outline-none shadow-sm hover:shadow-md">
                Close
            </button>
        </div>
    </div>
</div>

<script>
    const bulletinsDatabase = <%- JSON.stringify(bulletins) %>;
    let currentCategory = '<%= category && category !== "All" ? category : "Crime Advisory" %>';

    function setCategoryFilter(category, btnElement) {
        currentCategory = category;
        
        // Update styling of pill buttons
        const buttons = document.querySelectorAll('.category-pill-btn');
        buttons.forEach(btn => {
            btn.className = 'category-pill-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider bg-gray-50 dark:bg-slate-900 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 border border-gray-200 dark:border-slate-700 transition duration-300';
        });
        
        // Mark the clicked one as active
        btnElement.className = 'category-pill-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider bg-pnp-blue text-white dark:bg-pnp-gold dark:text-pnp-blue border border-transparent shadow-md transition duration-300';
        
        filterPublicBulletins();
    }

    function filterPublicBulletins() {
        const searchInputEl = document.getElementById('publicSearchInput');
        const searchInput = searchInputEl ? searchInputEl.value.toLowerCase() : '';
        const cards = document.querySelectorAll('.grid > .group');
        
        let anyVisible = false;
        const pageCategory = '<%= category %>';
        
        cards.forEach(card => {
            const h3 = card.querySelector('h3');
            const p = card.querySelector('p');
            const cat = card.getAttribute('data-category') || '';
            if (!h3 || !p) return;
            
            const title = h3.textContent.toLowerCase();
            const body = p.textContent.toLowerCase();
            
            const matchesSearch = searchInput === '' || title.includes(searchInput) || body.includes(searchInput);
            
            let matchesCategory = false;
            if (pageCategory === 'Wanted Person' || pageCategory === 'Missing Person') {
                matchesCategory = true; // No filter buttons shown, so allow all matching the page's category
            } else {
                const normCat = cat.toLowerCase().trim();
                const normCur = currentCategory.toLowerCase().trim();
                
                if (normCur === 'crime advisory' && (normCat === 'crime advisory' || normCat === 'crime advisories')) {
                    matchesCategory = true;
                } else if (normCur === 'traffic advisory' && (normCat === 'traffic advisory' || normCat === 'traffic advisories')) {
                    matchesCategory = true;
                } else if (normCur === 'cybercrime advisory' && (normCat === 'cybercrime advisory' || normCat === 'cybercrime advisories' || normCat.includes('cyber'))) {
                    matchesCategory = true;
                } else if (normCur === 'community awareness' && (normCat === 'community awareness' || normCat.includes('community') || normCat.includes('awareness'))) {
                    matchesCategory = true;
                } else if (normCur === normCat) {
                    matchesCategory = true;
                }
            }
            
            if (matchesSearch && matchesCategory) {
                card.style.display = 'flex';
                anyVisible = true;
            } else {
                card.style.display = 'none';
            }
        });
        
        const noResultsDiv = document.getElementById('noResultsDiv');
        if (noResultsDiv) {
            noResultsDiv.style.display = anyVisible ? 'none' : 'block';
        }
    }

    function openBulletinModal(bulletinId) {
        const bulletin = bulletinsDatabase.find(b => b.id === bulletinId);
        if (!bulletin) return;

        const collageContainer = document.getElementById('bulletin-modal-collage-container');
        if (collageContainer) {
            collageContainer.innerHTML = '';
            
            // Collect all photos and videos
            const mediaItems = [];
            
            if (bulletin.video_paths && bulletin.video_paths.length > 0) {
                bulletin.video_paths.forEach(url => {
                    if (url) mediaItems.push({ type: 'video', url });
                });
            } else if (bulletin.video_path) {
                mediaItems.push({ type: 'video', url: bulletin.video_path });
            }

            if (bulletin.photo_paths && bulletin.photo_paths.length > 0) {
                bulletin.photo_paths.forEach(url => {
                    if (url) mediaItems.push({ type: 'photo', url });
                });
            } else if (bulletin.photo_path) {
                mediaItems.push({ type: 'photo', url: bulletin.photo_path });
            }

            if (mediaItems.length === 0) {
                collageContainer.innerHTML = `
                    <div class="w-full h-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
                        <i class="fas fa-bullhorn text-6xl text-slate-300 dark:text-slate-600"></i>
                    </div>
                `;
            } else if (mediaItems.length === 1) {
                const item = mediaItems[0];
                if (item.type === 'video') {
                    collageContainer.innerHTML = `<video src="${item.url}" controls class="w-full h-full object-cover"></video>`;
                } else {
                    collageContainer.innerHTML = `<img src="${item.url}" class="w-full h-full object-cover" alt="${bulletin.title}">`;
                }
            } else if (mediaItems.length === 2) {
                collageContainer.innerHTML = `
                    <div class="grid grid-cols-2 h-full w-full gap-1">
                        ${mediaItems.map(item => {
                            if (item.type === 'video') {
                                return `<div class="relative h-full bg-black"><video src="${item.url}" controls class="w-full h-full object-cover"></video></div>`;
                            } else {
                                return `<div class="relative h-full overflow-hidden bg-black"><img src="${item.url}" class="w-full h-full object-cover hover:scale-105 transition duration-500"></div>`;
                            }
                        }).join('')}
                    </div>
                `;
            } else if (mediaItems.length === 3) {
                const renderItemHtml = (item, extraClass = '') => {
                    if (item.type === 'video') {
                        return `<div class="relative ${extraClass} bg-black"><video src="${item.url}" controls class="w-full h-full object-cover"></video></div>`;
                    } else {
                        return `<div class="relative ${extraClass} overflow-hidden bg-black"><img src="${item.url}" class="w-full h-full object-cover hover:scale-105 transition duration-500"></div>`;
                    }
                };
                collageContainer.innerHTML = `
                    <div class="grid grid-cols-3 h-full w-full gap-1 bg-black">
                        ${renderItemHtml(mediaItems[0], 'col-span-2 h-full')}
                        <div class="grid grid-rows-2 gap-1 h-full">
                            ${renderItemHtml(mediaItems[1], 'h-full')}
                            ${renderItemHtml(mediaItems[2], 'h-full')}
                        </div>
                    </div>
                `;
            } else {
                // 4 or more items
                const mainItem = mediaItems[0];
                const sideItems = mediaItems.slice(1, 4); // get up to 3 items for the right side
                const remainingCount = mediaItems.length - 4;

                const renderItemHtml = (item, extraClass = '') => {
                    if (item.type === 'video') {
                        return `<div class="relative ${extraClass} bg-black"><video src="${item.url}" controls class="w-full h-full object-cover"></video></div>`;
                    } else {
                        return `<div class="relative ${extraClass} overflow-hidden bg-black"><img src="${item.url}" class="w-full h-full object-cover hover:scale-105 transition duration-500"></div>`;
                    }
                };

                const renderSideItemHtml = (item, index) => {
                    const isLast = index === 2 && remainingCount > 0;
                    if (item.type === 'video') {
                        return `
                        <div class="relative h-full bg-black">
                            <video src="${item.url}" controls class="w-full h-full object-cover"></video>
                            ${isLast ? `
                            <div class="absolute inset-0 bg-black/60 flex items-center justify-center">
                                <span class="text-white text-xl font-black">+${remainingCount + 1}</span>
                            </div>` : ''}
                        </div>`;
                    } else {
                        return `
                        <div class="relative h-full overflow-hidden bg-black">
                            <img src="${item.url}" class="w-full h-full object-cover hover:scale-105 transition duration-500">
                            ${isLast ? `
                            <div class="absolute inset-0 bg-black/60 flex items-center justify-center">
                                <span class="text-white text-xl font-black">+${remainingCount + 1}</span>
                            </div>` : ''}
                        </div>`;
                    }
                };

                collageContainer.innerHTML = `
                    <div class="grid grid-cols-3 h-full w-full gap-1 bg-black">
                        ${renderItemHtml(mainItem, 'col-span-2 h-full')}
                        <div class="grid grid-rows-3 gap-1 h-full">
                            ${sideItems.map((item, idx) => renderSideItemHtml(item, idx)).join('')}
                        </div>
                    </div>
                `;
            }
        }

        document.getElementById('bulletin-modal-category').textContent = bulletin.category;
        document.getElementById('bulletin-modal-date').innerHTML = `<i class="fas fa-calendar-day mr-2"></i>${new Date(bulletin.created_at).toLocaleDateString(undefined, {month: 'long', day: 'numeric', year: 'numeric'})}`;
        document.getElementById('bulletin-modal-title').textContent = bulletin.title;
        document.getElementById('bulletin-modal-content').textContent = bulletin.body;

        const modal = document.getElementById('bulletin-modal');
        const content = modal.querySelector('.relative');

        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
        }, 50);
    }

    function closeBulletinModal() {
        const modal = document.getElementById('bulletin-modal');
        const content = modal.querySelector('.relative');
        
        // Pause all videos in collage if any
        if (modal) {
            const videos = modal.querySelectorAll('video');
            videos.forEach(v => {
                try {
                    v.pause();
                } catch (e) {}
            });
        }

        modal.classList.add('opacity-0');
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    // Trigger initial filter on DOMContentLoaded
    window.addEventListener('DOMContentLoaded', () => {
        filterPublicBulletins();
    });
</script>