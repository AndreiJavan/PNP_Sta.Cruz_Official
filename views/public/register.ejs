<div class="max-w-md mx-auto px-4 py-20">
    <div class="bg-white dark:bg-slate-800 rounded-[2rem] shadow-2xl p-8 border border-gray-100 dark:border-slate-700">
        <div
            class="w-16 h-16 bg-pnp-gold text-pnp-blue rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl">
            <i class="fas fa-user-plus text-2xl"></i>
        </div>
        <h2 class="text-2xl font-black text-center text-gray-900 dark:text-white mb-2 uppercase tracking-tighter">
            Citizen Registration</h2>
        <p class="text-xs text-center text-gray-500 dark:text-gray-400 font-bold uppercase tracking-widest mb-8">Join to
            submit secure tips</p>

        <% if (locals.error_msg) { %>
            <div
                class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 p-4 rounded-xl text-sm font-medium mb-6">
                <%= error_msg %>
            </div>
            <% } %>

                <form action="/register" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <div class="space-y-2">
                        <label for="email"
                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest">Email
                            Address</label>
                        <input type="email" name="email" id="email" required
                            class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-4 focus:ring-pnp-gold/20 focus:border-pnp-gold dark:text-white outline-none transition font-bold text-sm">
                    </div>

                    <div class="space-y-2">
                        <label for="password"
                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest">Password</label>
                        <input type="password" name="password" id="password" required minlength="8"
                            class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-4 focus:ring-pnp-gold/20 focus:border-pnp-gold dark:text-white outline-none transition font-bold text-sm"
                            placeholder="Min. 8 characters">
                    </div>

                    <div class="space-y-2">
                        <label for="confirm_password"
                            class="block text-[10px] font-black text-gray-400 uppercase tracking-widest">Confirm
                            Password</label>
                        <input type="password" id="confirm_password" required
                            class="w-full px-5 py-4 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-4 focus:ring-pnp-gold/20 focus:border-pnp-gold dark:text-white outline-none transition font-bold text-sm">
                        <p id="password_error" class="text-[9px] text-red-500 font-bold hidden">Passwords do not match.
                        </p>
                    </div>

                    <div class="space-y-2">
                        <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest">Location
                            Verification</label>
                        <button type="button" id="verify_location_btn"
                            class="w-full bg-slate-100 hover:bg-slate-200 dark:bg-slate-700 dark:hover:bg-slate-600 text-pnp-blue dark:text-white font-bold py-4 rounded-xl transition flex items-center justify-center space-x-2 text-sm border-2 border-dashed border-gray-300 dark:border-slate-500">
                            <i class="fas fa-location-dot"></i>
                            <span>Verify My Location</span>
                        </button>
                        <p id="location_status" class="text-[9px] text-gray-500 font-bold hidden"></p>
                    </div>

                    <button type="submit" id="submit_btn" disabled
                        class="w-full bg-pnp-gold hover:bg-yellow-500 disabled:opacity-50 disabled:cursor-not-allowed text-pnp-blue font-black py-4 rounded-xl shadow-xl transition transform hover:-translate-y-1 disabled:hover:translate-y-0 uppercase tracking-widest text-sm">
                        Create Account
                    </button>
                </form>

                <p class="mt-8 text-center text-sm text-gray-600 dark:text-gray-400 font-medium">
                    Already have an account? <a href="/login"
                        class="text-pnp-gold font-bold hover:underline tracking-wide">Login here</a>
                </p>
    </div>
</div>

<script>
    document.querySelector('form').addEventListener('submit', function (e) {
        let valid = true;
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;
        const passwordError = document.getElementById('password_error');

        if (password !== confirmPassword) {
            passwordError.classList.remove('hidden');
            valid = false;
        } else {
            passwordError.classList.add('hidden');
        }

        if (!valid) {
            e.preventDefault();
        }
    });

    // Real-time validation clears
    document.getElementById('confirm_password').addEventListener('input', () => {
        document.getElementById('password_error').classList.add('hidden');
    });

    // Haversine Distance Calculator (km)
    function calculateDistance(lat1, lon1, lat2, lon2) {
        const R = 6371; // Earth's radius in km
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lon2 - lon1) * Math.PI / 180;
        const a =
            Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon / 2) * Math.sin(dLon / 2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c;
    }

    // Geofencing Logic
    const STA_CRUZ_LAT = 14.275;
    const STA_CRUZ_LNG = 121.410;
    const MAX_DISTANCE_KM = 20;

    const verifyBtn = document.getElementById('verify_location_btn');
    const submitBtn = document.getElementById('submit_btn');
    const statusMsg = document.getElementById('location_status');

    verifyBtn.addEventListener('click', () => {
        statusMsg.classList.remove('hidden', 'text-red-500', 'text-green-500');
        statusMsg.classList.add('text-gray-500');
        statusMsg.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Checking location...';

        if (!navigator.geolocation) {
            statusMsg.classList.replace('text-gray-500', 'text-red-500');
            statusMsg.innerText = 'Geolocation is not supported by your browser.';
            return;
        }

        navigator.geolocation.getCurrentPosition(
            (position) => {
                const userLat = position.coords.latitude;
                const userLng = position.coords.longitude;
                const distance = calculateDistance(userLat, userLng, STA_CRUZ_LAT, STA_CRUZ_LNG);

                if (distance <= MAX_DISTANCE_KM) {
                    statusMsg.classList.replace('text-gray-500', 'text-green-500');
                    statusMsg.innerText = 'Location verified! You are within Sta. Cruz bounds.';
                    verifyBtn.classList.replace('border-gray-300', 'border-green-500');
                    verifyBtn.innerHTML = '<i class="fas fa-check text-green-500"></i> <span class="text-green-600">Verified</span>';
                    verifyBtn.disabled = true;
                    submitBtn.disabled = false;
                } else {
                    statusMsg.classList.replace('text-gray-500', 'text-red-500');
                    statusMsg.innerText = `Registration restricted: You are approx. ${Math.round(distance)}km outside Sta. Cruz borders.`;
                }
            },
            (error) => {
                statusMsg.classList.replace('text-gray-500', 'text-red-500');
                statusMsg.innerText = 'Unable to retrieve location. Please allow location access to register.';
            },
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
        );
    });
</script>