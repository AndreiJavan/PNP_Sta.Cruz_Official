        { name: 'Poblacion I (Barangay I)', lat: 14.277068, lng: 121.418881 },
        { name: 'Poblacion II (Barangay II)', lat: 14.279647, lng: 121.416006 },
        { name: 'Poblacion III (Barangay III)', lat: 14.282028, lng: 121.415159 },
