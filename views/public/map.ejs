<div class="h-[calc(100vh-80px)] md:h-[calc(100vh-96px)] relative z-0 overflow-hidden">
    <!-- Map Container -->
    <div id="leafletMap" class="h-full w-full transition-all duration-500"></div>

    <!-- Loading Overlay -->
    <div id="mapLoading"
        class="absolute inset-0 bg-pnp-blue z-[1200] flex flex-col items-center justify-center text-white transition-opacity duration-500">
        <div class="w-20 h-20 border-4 border-pnp-gold border-t-transparent rounded-full animate-spin mb-6"></div>
        <p class="text-xs font-black uppercase tracking-[0.3em] animate-pulse">Initializing Secure Map Data...</p>
    </div>

    <!-- Toggle Button (Always Visible on Desktop) -->
    <button id="sidebarToggle" onclick="toggleSidebar()"
        class="absolute top-8 left-8 z-[1100] w-12 h-12 bg-pnp-blue text-pnp-gold rounded-2xl shadow-2xl hidden md:flex items-center justify-center text-xl hover:bg-pnp-blue/90 transition-all duration-300 group opacity-0 pointer-events-none">
        <i class="fas fa-info group-hover:scale-110 transition"></i>
    </button>

    <div id="filterSidebar"
        class="absolute top-4 left-4 md:top-8 md:left-8 z-[1000] w-[calc(100vw-2rem)] sm:w-80 bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-[2rem] md:rounded-[2.5rem] shadow-2xl border border-white/30 dark:border-slate-700/30 overflow-hidden flex flex-col max-h-[calc(100%-120px)] md:max-h-[calc(100%-64px)] transition-all duration-500 origin-top-left sidebar-visible">
        <div class="bg-pnp-blue p-6 pr-16 text-white relative">
            <h3 class="text-xs font-black text-pnp-gold uppercase tracking-[0.3em] mb-2">Location Overview</h3>
            <h4 class="text-xl font-black tracking-tighter">Sta. Cruz Map</h4>
            <!-- Close button inside sidebar for better UX -->
            <button onclick="toggleSidebar()"
                class="absolute top-6 right-8 text-pnp-gold/50 hover:text-pnp-gold transition">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>

        <div class="flex-grow overflow-y-auto sidebar-scroll">
            <div class="p-5 space-y-5">
                <div class="space-y-3">
                    <label
                        class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Filter
                        Incidents</label>
                    <div class="space-y-2">
                        <div class="space-y-1">
                            <label class="text-[9px] font-bold text-gray-400 uppercase">Barangay</label>
                            <div class="flex space-x-2">
                                <select id="filterBarangay" onchange="loadMapPoints()"
                                    class="flex-1 px-4 py-2 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl text-xs font-bold focus:ring-2 focus:ring-pnp-blue outline-none transition-all duration-300 dark:text-white appearance-none">
                                    <option value="">All Barangays</option>
                                    <% ["Alipit", "Bagumbayan" , "Bubukal" , "Calios" , "Duhat" , "Gatid" , "Jasaan"
                                        , "Labuin" , "Malinao" , "Oogong" , "Pagsawitan" , "Palasan" , "Patimbao"
                                        , "Poblacion I (Barangay I)" , "Poblacion II (Barangay II)"
                                        , "Poblacion III (Barangay III)" , "Poblacion IV (Barangay IV)"
                                        , "Poblacion V (Barangay V)" , "San Jose" , "San Juan" , "San Pablo Norte"
                                        , "San Pablo Sur" , "Santisima Cruz" , "Santo Angel Central"
                                        , "Santo Angel Norte" , "Santo Angel Sur" ].forEach(brgy=> { %>
                                        <option value="<%= brgy %>">
                                            <%= brgy %>
                                        </option>
                                        <% }) %>
                                </select>
                                <button onclick="locateBarangay()"
                                    class="px-4 py-2 bg-pnp-blue dark:bg-pnp-gold text-white dark:text-pnp-blue rounded-xl shadow-lg hover:scale-105 transition-all duration-300 flex items-center justify-center"
                                    title="Locate on Map">
                                    <i class="fas fa-crosshairs"></i>
                                </button>
                            </div>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[9px] font-bold text-gray-400 uppercase">Date Range</label>
                            <select id="filterRange" onchange="loadMapPoints()"
                                class="w-full px-4 py-2 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl text-xs font-bold focus:ring-2 focus:ring-pnp-blue outline-none transition-all duration-300 dark:text-white appearance-none">
                                <option value="">All Time</option>
                                <option value="7days">Last 7 Days</option>
                                <option value="30days">Last 30 Days</option>
                                <option value="6months">Last 6 Months</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="space-y-3 pt-5 border-t border-gray-100 dark:border-slate-700">
                    <div class="flex items-center justify-between pointer-events-auto mb-2">
                        <label
                            class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest flex items-center">
                            <i class="fas fa-layer-group mr-2 text-pnp-blue dark:text-pnp-gold"></i> Map Display &
                            Legend
                        </label>
                        <button onclick="clearMapDisplay()"
                            class="text-[9px] font-black text-gray-500 hover:text-red-500 uppercase transition-colors bg-gray-100 dark:bg-slate-800 hover:bg-red-50 dark:hover:bg-red-900/30 px-3 py-1 rounded-lg cursor-pointer">
                            Clear
                        </button>
                    </div>

                    <select id="mapDisplayMode" onchange="updateHeatmap(); updateLegend();"
                        class="w-full px-4 py-2 bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-xl text-xs font-bold focus:ring-2 focus:ring-pnp-blue outline-none transition-all duration-300 dark:text-white appearance-none cursor-pointer mb-2">
                        <option value="density">Incident Density (Heatmap: Green to Red)</option>
                        <option value="dominant">Dominant Crime Type</option>
                        <option value="clear" class="hidden" disabled>Clear (No Overlay)</option>
                    </select>

                    <div id="dynamicLegend"
                        class="grid grid-cols-1 gap-1 bg-gray-50 dark:bg-slate-900/80 p-3 rounded-2xl border border-gray-100 dark:border-slate-700 max-h-32 overflow-y-auto sidebar-scroll">
                        <p class="text-[9px] text-gray-400 font-bold uppercase text-center py-2">Loading data...</p>
                    </div>
                </div>

                <div id="topIncidentsSection" class="space-y-3 pt-5 border-t border-gray-100 dark:border-slate-700">
                    <label class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest">Top
                        3 Incidents</label>
                    <p id="topIncidentsRange" class="text-[9px] font-bold text-pnp-gold uppercase tracking-widest"></p>
                    <div id="topIncidentsList" class="space-y-2">
                        <!-- Top incidents will be injected here -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Legend (Mobile) -->
    <div class="absolute bottom-8 right-8 z-[1000] md:hidden">
        <button onclick="toggleSidebar()"
            class="w-16 h-16 bg-pnp-blue text-white rounded-2xl shadow-2xl flex items-center justify-center text-2xl">
            <i class="fas fa-info"></i>
        </button>
    </div>
</div>

<script>
    let map;
    let santaCruzGeoJSON;
    let incidentMarkers = L.layerGroup();
    let selectedPinsLayer = L.layerGroup();
    let boundaryLayerGroup;
    let currentPoints = [];
    const barangayGeoJsonUrl = '/data/santa_cruz_boundaries.json';

    const allColors = {
        'Theft': '#FFE135', 'Robbery': '#D97706', 'Murder': '#FF0000', 'Homicide': '#EF4444',
        'Physical Injuries': '#10B981', 'Rape': '#A855F7', 'Carnapping (Motorcycle)': '#F59E0B',
        'Carnapping (Motor Vehicle)': '#F97316', 'Violence Against Women and Children (VAWC)': '#E11D48',
        'Cybercrime': '#3B82F6', 'Estafa': '#0891B2', 'Swindling / Fraud': '#06B6D4',
        'Drug Possession': '#059669', 'Drug Sale': '#10B981', 'Drug Use': '#34D399',
        'Illegal Gambling': '#7C3AED', 'Illegal Possession of Firearms': '#475569',
        'Human Trafficking': '#DB2777', 'Child Abuse (RA 7610)': '#F43F5E', 'Damage to Property': '#B45309',
        'Malicious Mischief': '#D97706', 'Cybercrime (Online Fraud, Hacking, Identity Theft, Cyber Libel)': '#2563EB',
        'Illegal Recruitment': '#9333EA', 'Ordinance Violations': '#94A3B8', 'Grave Threats': '#64748B',
        'Alarm and Scandal': '#CBD5E1', 'Vehicular Accident': '#2563EB', 'Road Accident / Traffic Incident': '#1D4ED8',
        'Fire Incident': '#EA580C', 'Flood Incident': '#3B82F6', 'Earthquake Incident': '#78350F',
        'Landslide Incident': '#451A03', 'Disaster Incident Reports': '#4B5563', 'Public Disturbance Incident': '#4338CA',
        'Emergency Response Incident': '#0891B2', 'Missing Person Report': '#0D9488', 'Rescue Operation Cases': '#059669'
    };

    function getTacticalColor(name) {
        if (!name) return '#ccc';
        const searchName = name.trim().toUpperCase();
        for (const [key, color] of Object.entries(allColors)) {
            if (key.toUpperCase() === searchName) return color;
        }
        for (const [key, color] of Object.entries(allColors)) {
            if (searchName.includes(key.toUpperCase()) || key.toUpperCase().includes(searchName)) return color;
        }
        return '#ccc';
    }

    function hideLoading() {
        const loading = document.getElementById('mapLoading');
        if (loading) {
            loading.classList.add('opacity-0');
            setTimeout(() => {
                loading.classList.add('hidden');
            }, 500);
        }
    }

    let boundaryLayer;
    let glowLayer;

    async function loadMunicipalBoundary() {
        try {
            console.log("Fetching municipal boundary for Sta. Cruz, Laguna...");
            // Use a more specific query including Philippines to avoid ambiguity
            const response = await fetch('https://nominatim.openstreetmap.org/search?format=json&q=Santa+Cruz,+Laguna,+Philippines&polygon_geojson=1&limit=5');
            const data = await response.json();

            // Find the administrative boundary relation (usually the most accurate for municipalities)
            const boundary = data.find(item =>
                item.osm_type === 'relation' &&
                item.geojson &&
                (item.addresstype === 'municipality' || item.type === 'administrative')
            ) || (data[0] && data[0].geojson ? data[0] : null);

            if (boundary && boundary.geojson) {
                const updateStyles = () => {
                    const zoom = map.getZoom();
                    // Dynamic weight based on zoom level: make it much thicker as we zoom in
                    const baseWeight = zoom < 14 ? 10 : (zoom < 16 ? 18 : 30);
                    const glowWeight = baseWeight * 1.8;

                    // Boundary layers removed by user request
                };

                console.log("Municipal boundary successfully rendered (Responsive):", boundary.display_name);
            } else {
                console.warn("Could not find a valid boundary polygon for Santa Cruz, Laguna.");
            }
        } catch (err) {
            console.error("Error loading municipal boundary:", err);
        }
    }

    function locateBarangay(shouldMinimize = true) {
        const selectedName = document.getElementById('filterBarangay').value;

        // Always clear any currently drawn selected pins first!
        selectedPinsLayer.clearLayers();

        if (!selectedName) {
            // Reset to default view if "All Barangays" is selected
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            map.flyToBounds(bounds, {
                padding: [50, 50],
                duration: 1.5
            });
            // Disable interaction when in summary view
            map.dragging.disable();
            map.touchZoom.disable();
            map.doubleClickZoom.disable();
            map.scrollWheelZoom.disable();
            map.boxZoom.disable();
            map.keyboard.disable();
            return;
        }

        const pin = manualPins.find(p => p.name.toLowerCase() === selectedName.toLowerCase());
        if (pin && map) {
            // Enable interaction when a barangay is selected
            map.dragging.enable();
            map.touchZoom.enable();
            map.doubleClickZoom.enable();
            map.scrollWheelZoom.enable();
            map.boxZoom.enable();
            map.keyboard.enable();

            // Minimize sidebar to view the whole map if requested
            const sidebar = document.getElementById('filterSidebar');
            if (shouldMinimize && sidebar && sidebar.classList.contains('sidebar-visible')) {
                toggleSidebar();
            }

            map.flyTo([pin.lat, pin.lng], 16, {
                animate: true,
                duration: 1.5
            });

            // Create and show the beautiful gold Tactical Pin for the selected barangay!
            const tacticalPin = L.marker([pin.lat, pin.lng], {
                icon: L.divIcon({
                    className: 'manual-pin-container',
                    html: `
                        <div class="relative group flex flex-col items-center">
                            <div class="absolute w-8 h-8 bg-pnp-gold/30 rounded-full animate-ping"></div>
                            <div class="relative w-10 h-10 bg-pnp-blue dark:bg-pnp-gold rounded-full flex items-center justify-center shadow-2xl border-2 border-white dark:border-slate-900 transform group-hover:scale-110 transition-all duration-300">
                                <i class="fas fa-location-dot text-white dark:text-pnp-blue text-lg"></i>
                            </div>
                            <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-pnp-blue dark:border-t-pnp-gold -mt-1"></div>
                        </div>
                    `,
                    iconSize: [40, 48],
                    iconAnchor: [20, 48]
                })
            }).addTo(selectedPinsLayer);

            tacticalPin.bindPopup(`
                <div class="p-4 min-w-[200px] bg-white dark:bg-slate-800 rounded-xl">
                    <div class="flex items-center space-x-3 mb-3 pb-3 border-b border-gray-100 dark:border-slate-700">
                        <div class="w-8 h-8 bg-pnp-blue dark:bg-pnp-gold rounded-lg flex items-center justify-center">
                            <i class="fas fa-shield-halved text-white dark:text-pnp-blue text-xs"></i>
                        </div>
                        <div>
                            <h3 class="text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-widest text-xs leading-none">${pin.name}</h3>
                            <p class="text-[8px] text-gray-400 font-bold uppercase mt-1">S-SPS Sector Location</p>
                        </div>
                    </div>
                </div>
            `);

            // Open popup after a short delay to allow flyTo to finish
            setTimeout(() => {
                tacticalPin.openPopup();

                // Re-open sidebar to show stats after zoom is complete if it was minimized
                if (shouldMinimize && sidebar && sidebar.classList.contains('sidebar-hidden')) {
                    toggleSidebar();
                }
            }, 1500);
        }
    }

    async function loadMapPoints(shouldLocate = true) {
        const range = document.getElementById('filterRange').value;
        const barangay = document.getElementById('filterBarangay').value;


        // Automatically locate when barangay is selected
        if (barangay && shouldLocate) {
            locateBarangay();
        } else if (!barangay && shouldLocate) {
            // Optional: reset view when "All Barangays" is selected
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            map.flyToBounds(bounds, { padding: [50, 50], duration: 1.5 });
        }

        const topIncidentsSection = document.getElementById('topIncidentsSection');
        const topIncidentsList = document.getElementById('topIncidentsList');
        const topIncidentsRange = document.getElementById('topIncidentsRange');

        const rangeText = {
            '': 'All Time',
            '7days': 'Last 7 Days',
            '30days': 'Last 30 Days',
            '6months': 'Last 6 Months'
        };
        if (topIncidentsRange) topIncidentsRange.textContent = rangeText[range] || 'All Time';

        try {
            const url = `/api/map-points?range=${encodeURIComponent(range)}&barangay=${encodeURIComponent(barangay)}`;
            const response = await fetch(url);
            const points = await response.json();

            currentPoints = Array.isArray(points) ? points : [];
            updateHeatmap();
            updateLegend();

            incidentMarkers.clearLayers();

            // Calculate Top 3 Incidents
            const incidentCounts = {};
            if (currentPoints.length > 0) {
                currentPoints.forEach(point => {
                    incidentCounts[point.incident_type] = (incidentCounts[point.incident_type] || 0) + 1;
                });
            }


            const sortedIncidents = Object.entries(incidentCounts)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 3);

            if (topIncidentsList) {
                topIncidentsList.innerHTML = sortedIncidents.length > 0
                    ? sortedIncidents.map(([type, count]) => `
                        <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-700">
                            <div class="flex items-center space-x-3">
                                <span class="w-2 h-2 rounded-full" style="background-color: ${getTacticalColor(type)}"></span>
                                <span class="text-[10px] font-black text-gray-700 dark:text-gray-300 uppercase tracking-widest">${type}</span>
                            </div>
                            <span class="text-xs font-black text-pnp-blue dark:text-pnp-gold">${count}</span>
                        </div>
                    `).join('')
                    : `<p class="text-[10px] text-gray-400 font-bold uppercase text-center py-4">No incidents recorded</p>`;
            }
        } catch (err) {
            console.error('Error loading map points:', err);
        }
    }

    // Simple Point in Polygon function
    function isPointInPolygon(point, vs) {
        const x = point[0], y = point[1];
        let inside = false;

        if (Array.isArray(vs[0][0][0])) {
            for (let i = 0; i < vs.length; i++) {
                if (isPointInPolygon(point, vs[i])) return true;
            }
            return false;
        }

        const polygon = Array.isArray(vs[0][0]) ? vs[0] : vs;

        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            const xi = polygon[i][0], yi = polygon[i][1];
            const xj = polygon[j][0], yj = polygon[j][1];
            const intersect = ((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
            if (intersect) inside = !inside;
        }
        return inside;
    }

    function checkGeofence(latlng) {
        let isInside = false;
        if (santaCruzGeoJSON) {
            const point = [latlng.lng, latlng.lat];
            for (const feature of santaCruzGeoJSON.features) {
                if (isPointInPolygon(point, feature.geometry.coordinates)) {
                    isInside = true;
                    break;
                }
            }
        }
        return isInside;
    }

    function getThematicStyleForFeature(feature) {
        const normalizeBrgyName = (name) => {
            const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
            if (match) return `Poblacion ${match[1]} (Barangay ${match[1]})`;
            return name;
        };
        const brgyName = normalizeBrgyName(feature.properties.ADM4_EN);
        const brgyPoints = currentPoints.filter(p => p.barangay === brgyName);
        const modeSelect = document.getElementById('mapDisplayMode');
        const mode = modeSelect ? modeSelect.value : 'density';

        let fillColor = 'transparent';
        let weight = 1;
        let fillOpacity = 0;
        const totalIncidents = brgyPoints.length;

        if (mode === 'density') {
            // Find max incidents across all barangays
            const allCounts = Object.values(currentPoints.reduce((acc, curr) => {
                acc[curr.barangay] = (acc[curr.barangay] || 0) + 1;
                return acc;
            }, {}));
            const max = Math.max(...allCounts, 1);

            if (totalIncidents === 0) {
                weight = 1; fillOpacity = 0.1; fillColor = '#1A3A5C';
            } else {
                const ratio = totalIncidents / max; // from >0 to 1
                if (ratio >= 0.75) fillColor = '#EF4444'; // Red (High Crime)
                else if (ratio >= 0.40) fillColor = '#F97316'; // Orange (Medium-High)
                else if (ratio >= 0.15) fillColor = '#FBBF24'; // Yellow (Medium-Low)
                else fillColor = '#10B981'; // Green (Low)

                fillOpacity = 0.7;
                weight = 2;
            }
        } else if (mode === 'dominant') {
            // Dominant Crime Type
            if (totalIncidents > 0) {
                const stats = {};
                brgyPoints.forEach(p => { stats[p.incident_type] = (stats[p.incident_type] || 0) + 1; });
                const topCrime = Object.entries(stats).sort((a, b) => b[1] - a[1])[0];
                fillColor = getTacticalColor(topCrime[0]);
                fillOpacity = 0.6;
                weight = 2;
            } else {
                weight = 1;
                fillOpacity = 0.1;
                fillColor = '#1A3A5C';
            }
        } else {
            // Clear / No overlay
            weight = 1;
            fillOpacity = 0.1;
            fillColor = '#1A3A5C';
        }

        const selected = document.getElementById('filterBarangay').value;
        if (selected && selected !== brgyName) {
            fillOpacity = 0.05;
            weight = 1;
            fillColor = 'rgba(15, 23, 42, 0.5)';
        }

        return { color: '#C8A415', weight: weight, fillOpacity: fillOpacity, fillColor: fillColor };
    }

    function clearMapDisplay() {
        const modeSelect = document.getElementById('mapDisplayMode');
        if (modeSelect) {
            // Temporarily enable 'clear' option so we can select it, though it's hidden
            const clearOpt = modeSelect.querySelector('option[value="clear"]');
            if (clearOpt) clearOpt.disabled = false;
            modeSelect.value = 'clear';
            updateHeatmap();
            updateLegend();
        }
    }

    function updateHeatmap() {
        if (boundaryLayerGroup) {
            boundaryLayerGroup.eachLayer(layer => {
                if (layer.feature) {
                    layer.setStyle(getThematicStyleForFeature(layer.feature));
                }
            });
        }
    }

    function updateLegend() {
        const legendContainer = document.getElementById('dynamicLegend');
        if (!legendContainer) return;

        const modeSelect = document.getElementById('mapDisplayMode');
        const mode = modeSelect ? modeSelect.value : 'density';

        if (mode === 'density') {
            if (currentPoints.length === 0) {
                legendContainer.innerHTML = '<p class="text-[9px] text-gray-400 font-bold uppercase text-center py-2">No incidents recorded</p>';
                return;
            }
            // Density Legend
            legendContainer.innerHTML = `
                <div class="flex items-center justify-between px-3 py-2 bg-white/50 dark:bg-slate-800/80 hover:bg-white dark:hover:bg-slate-800 rounded-xl transition-colors border border-gray-100/50 dark:border-slate-700/50">
                    <div class="flex items-center space-x-2"><div class="w-3 h-3 rounded-full shadow-sm shrink-0 bg-[#EF4444]"></div><span class="text-[10px] font-black uppercase tracking-tight text-slate-700 dark:text-slate-200">High Density (Red)</span></div>
                </div>
                <div class="flex items-center justify-between px-3 py-2 bg-white/50 dark:bg-slate-800/80 hover:bg-white dark:hover:bg-slate-800 rounded-xl transition-colors border border-gray-100/50 dark:border-slate-700/50">
                    <div class="flex items-center space-x-2"><div class="w-3 h-3 rounded-full shadow-sm shrink-0 bg-[#F97316]"></div><span class="text-[10px] font-black uppercase tracking-tight text-slate-700 dark:text-slate-200">Medium-High (Orange)</span></div>
                </div>
                <div class="flex items-center justify-between px-3 py-2 bg-white/50 dark:bg-slate-800/80 hover:bg-white dark:hover:bg-slate-800 rounded-xl transition-colors border border-gray-100/50 dark:border-slate-700/50">
                    <div class="flex items-center space-x-2"><div class="w-3 h-3 rounded-full shadow-sm shrink-0 bg-[#FBBF24]"></div><span class="text-[10px] font-black uppercase tracking-tight text-slate-700 dark:text-slate-200">Medium-Low (Yellow)</span></div>
                </div>
                <div class="flex items-center justify-between px-3 py-2 bg-white/50 dark:bg-slate-800/80 hover:bg-white dark:hover:bg-slate-800 rounded-xl transition-colors border border-gray-100/50 dark:border-slate-700/50">
                    <div class="flex items-center space-x-2"><div class="w-3 h-3 rounded-full shadow-sm shrink-0 bg-[#10B981]"></div><span class="text-[10px] font-black uppercase tracking-tight text-slate-700 dark:text-slate-200">Low Density (Green)</span></div>
                </div>
            `;
        } else if (mode === 'dominant') {
            // Dominant Crime Legend
            const stats = {};
            currentPoints.forEach(p => { stats[p.incident_type] = (stats[p.incident_type] || 0) + 1; });
            const sortedTypes = Object.entries(stats).sort((a, b) => b[1] - a[1]).map(e => e[0]);

            if (sortedTypes.length === 0) {
                legendContainer.innerHTML = '<p class="text-[9px] text-gray-400 font-bold uppercase text-center py-2">No incidents recorded</p>';
                return;
            }

            legendContainer.innerHTML = sortedTypes.slice(0, 10).map(type => `
                <div class="flex items-center justify-between px-3 py-2 bg-white/50 dark:bg-slate-800/80 hover:bg-white dark:hover:bg-slate-800 rounded-xl transition-colors border border-gray-100/50 dark:border-slate-700/50">
                    <div class="flex items-center space-x-2 truncate">
                        <div class="w-3 h-3 rounded-full shadow-sm shrink-0" style="background-color: ${getTacticalColor(type)}"></div>
                        <span class="text-[10px] font-black uppercase tracking-tight text-slate-700 dark:text-slate-200 truncate" title="${type}">${type}</span>
                    </div>
                    <span class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold bg-pnp-blue/5 dark:bg-pnp-gold/10 px-2 py-0.5 rounded-md">${stats[type]}</span>
                </div>
            `).join('');
        } else {
            // Clear legend
            legendContainer.innerHTML = '<p class="text-[9px] text-gray-400 font-bold uppercase text-center py-2">Map overlay cleared</p>';
        }
    }

    const manualPins = [
        { name: 'Alipit', lat: 14.223931, lng: 121.405213 },
