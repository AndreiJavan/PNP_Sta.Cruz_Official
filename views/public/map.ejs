            address: "Manila East Road, Brgy. Pagsawitan, Sta. Cruz, Laguna",
            contact: "PNP Hotlines Available"
        },
        {
            name: "PNP Police Outpost - Bubukal Rotunda",
            lat: 14.2565,
            lng: 121.3992,
            type: "outpost",
            address: "Bubukal Junction, Brgy. Bubukal, Sta. Cruz, Laguna",
            contact: "PNP Hotlines Available"
        },
        {
            name: "PNP Police Outpost - Gatid Highway",
            lat: 14.2600,
            lng: 121.3830,
