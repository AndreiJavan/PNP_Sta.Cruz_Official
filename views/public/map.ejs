    function addPoliceStations() {
        policeStationsLayer.clearLayers();
        policeStations.forEach(station => {
            const iconHtml = `
                <div class="relative group flex flex-col items-center">
                    <div class="absolute w-7 h-7 bg-blue-500/20 rounded-full animate-ping"></div>
                    <div class="relative w-8 h-8 bg-blue-600 dark:bg-blue-700 rounded-full flex items-center justify-center shadow-xl border-2 border-white dark:border-slate-900 transform hover:scale-110 transition-all duration-300">
                        <i class="fas fa-building-shield text-white text-xs"></i>
                    </div>
                </div>
            `;
            L.marker([station.lat, station.lng], {
                icon: L.divIcon({
                    className: 'police-station-marker',
                    html: iconHtml,
                    iconSize: [32, 32],
                    iconAnchor: [16, 16]
                })
            }).addTo(policeStationsLayer).bindPopup(`
                <div class="p-4 min-w-[220px] bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-xl space-y-2.5">
                    <div class="flex items-center space-x-2.5 pb-2.5 border-b border-gray-100 dark:border-slate-700">
                        <div class="w-7 h-7 bg-blue-50 dark:bg-blue-950/50 text-blue-600 dark:text-blue-400 rounded-lg flex items-center justify-center shadow-sm">
                            <i class="fas fa-building-shield text-xs"></i>
                        </div>
                        <div>
                            <h4 class="text-[10px] font-black text-slate-800 dark:text-white uppercase tracking-wider leading-none">${station.name}</h4>
                            <span class="text-[7px] font-black uppercase text-blue-500 dark:text-blue-400 tracking-widest mt-1 inline-block">${station.type.replace('_', ' ')}</span>
                        </div>
                    </div>
                    <div class="space-y-2 text-[9px]">
                        <p class="text-slate-500 dark:text-slate-400 leading-relaxed"><strong class="text-slate-750 dark:text-slate-300 font-bold uppercase tracking-wider text-[8px]">Location:</strong><br>${station.address}</p>
                        <p class="text-slate-500 dark:text-slate-400"><strong class="text-slate-750 dark:text-slate-300 font-bold uppercase tracking-wider text-[8px]">Emergency Hotline:</strong><br>${station.contact}</p>
                    </div>
                </div>
            `, {
                className: 'police-popup',
                maxWidth: 260
            });
        });
    }

    const allColors = {
        'Theft': '#FFE135', 'Robbery': '#D97706', 'Murder': '#FF0000', 'Homicide': '#EF4444',
        'Physical Injuries': '#10B981', 'Rape': '#A855F7', 'Carnapping (Motorcycle)': '#F59E0B',
        'Carnapping (Motor Vehicle)': '#F97316', 'Violence Against Women and Children (VAWC)': '#E11D48',
        'Cybercrime': '#3B82F6', 'Estafa': '#0891B2', 'Swindling / Fraud': '#06B6D4',
        'Drug Possession': '#059669', 'Drug Sale': '#10B981', 'Drug Use': '#34D399',
        'Illegal Gambling': '#7C3AED', 'Illegal Possession of Firearms': '#475569',
        'Human Trafficking': '#DB2777', 'Child Abuse (RA 7610)': '#F43F5E', 'Damage to Property': '#B45309',
        'Malicious Mischief': '#D97706', 'Cybercrime (Online Fraud, Hacking, Identity Theft, Cyber Libel)': '#2563EB',
        'Illegal Recruitment': '#9333EA', 'Ordinance Violations': '#94A3B8', 'Grave Threats': '#64748B',
        'Alarm and Scandal': '#CBD5E1', 'Vehicular Accident': '#2563EB', 'Road Accident / Traffic Incident': '#1D4ED8',
        'Fire Incident': '#EA580C', 'Flood Incident': '#3B82F6', 'Earthquake Incident': '#78350F',
        'Landslide Incident': '#451A03', 'Disaster Incident Reports': '#4B5563', 'Public Disturbance Incident': '#4338CA',
        'Emergency Response Incident': '#0891B2', 'Missing Person Report': '#0D9488', 'Rescue Operation Cases': '#059669'
    };

    function getBarangayLabel(name, zoom) {
        const pobMatch = name.match(/Poblacion (I{1,3}|IV|V)/);
        if (pobMatch) {
            const romanToNum = { 'I': '1', 'II': '2', 'III': '3', 'IV': '4', 'V': '5' };
            const num = romanToNum[pobMatch[1]];
            if (zoom < 16) {
                return `POB. ${num}`;
            } else {
                return name.replace('Poblacion', 'POB.').replace(' (Barangay ', '\n(BRGY. ').replace(')', '');
            }
        }
        return name.replace('Poblacion', 'POB.').replace(' (Barangay ', '\n(BRGY. ').replace(')', '');
    }

    function getTacticalColor(name) {
        if (!name) return '#ccc';
        const searchName = name.trim().toUpperCase();
        for (const [key, color] of Object.entries(allColors)) {
            if (key.toUpperCase() === searchName) return color;
        }
        for (const [key, color] of Object.entries(allColors)) {
            if (searchName.includes(key.toUpperCase()) || key.toUpperCase().includes(searchName)) return color;
        }
        return '#ccc';
    }

    function hideLoading() {
        const loading = document.getElementById('mapLoading');
        if (loading) {
            loading.classList.add('opacity-0');
            setTimeout(() => {
                loading.classList.add('hidden');
            }, 500);
        }
    }

    let boundaryLayer;
    let glowLayer;

    async function loadMunicipalBoundary() {
        try {
            console.log("Fetching municipal boundary for Sta. Cruz, Laguna...");
            // Use a more specific query including Philippines to avoid ambiguity
            const response = await fetch('https://nominatim.openstreetmap.org/search?format=json&q=Santa+Cruz,+Laguna,+Philippines&polygon_geojson=1&limit=5');
            const data = await response.json();

            // Find the administrative boundary relation (usually the most accurate for municipalities)
            const boundary = data.find(item =>
                item.osm_type === 'relation' &&
                item.geojson &&
                (item.addresstype === 'municipality' || item.type === 'administrative')
            ) || (data[0] && data[0].geojson ? data[0] : null);

            if (boundary && boundary.geojson) {
                // Create an inverted polygon to blur the outside of the municipality
                const worldRing = [
                    [180, 90],
                    [180, -90],
                    [-180, -90],
                    [-180, 90],
                    [180, 90]
                ];
                
                let maskCoordinates = [];
                if (boundary.geojson.type === 'Polygon') {
                    maskCoordinates = [worldRing, ...boundary.geojson.coordinates];
                } else if (boundary.geojson.type === 'MultiPolygon') {
                    maskCoordinates = [worldRing];
                    boundary.geojson.coordinates.forEach(polygon => {
                        maskCoordinates.push(polygon[0]);
                    });
                }
                
                if (maskCoordinates.length > 0) {
                    L.geoJSON({
                        type: 'Feature',
                        geometry: {
                            type: 'Polygon',
                            coordinates: maskCoordinates
                        }
                    }, {
                        style: {
                            fillColor: '#0f172a',
                            fillOpacity: 0.55,
                            color: 'transparent',
                            weight: 0,
                            className: 'map-outside-mask'
                        },
                        interactive: false
                    }).addTo(map);
                }

                const updateStyles = () => {
                    const zoom = map.getZoom();
                    // Dynamic weight based on zoom level: make it much thicker as we zoom in
                    const baseWeight = zoom < 14 ? 10 : (zoom < 16 ? 18 : 30);
                    const glowWeight = baseWeight * 1.8;

                    // Boundary layers removed by user request
                };

                console.log("Municipal boundary successfully rendered (Responsive):", boundary.display_name);
            } else {
                console.warn("Could not find a valid boundary polygon for Santa Cruz, Laguna.");
            }
        } catch (err) {
            console.error("Error loading municipal boundary:", err);
        }
    }

    function locateBarangay(shouldMinimize = true) {
        const selectedName = document.getElementById('filterBarangay').value;

        // Always clear any currently drawn selected pins first!
        selectedPinsLayer.clearLayers();

        if (!selectedName) {
            // Reset to default view if "All Barangays" is selected
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            map.flyToBounds(bounds, {
                padding: [50, 50],
                duration: 1.5
            });
            // Disable interaction when in summary view
            map.dragging.disable();
            map.touchZoom.disable();
            map.doubleClickZoom.disable();
            map.scrollWheelZoom.disable();
            map.boxZoom.disable();
            map.keyboard.disable();
            return;
        }

        const pin = manualPins.find(p => p.name.toLowerCase() === selectedName.toLowerCase());
        if (pin && map) {
            // Enable interaction when a barangay is selected
            map.dragging.enable();
            map.touchZoom.enable();
            map.doubleClickZoom.enable();
            map.scrollWheelZoom.enable();
            map.boxZoom.enable();
            map.keyboard.enable();

            // Minimize sidebar to view the whole map if requested
            const sidebar = document.getElementById('filterSidebar');
            if (shouldMinimize && sidebar && sidebar.classList.contains('sidebar-visible')) {
                toggleSidebar();
            }

            map.flyTo([pin.lat, pin.lng], 16, {
                animate: true,
                duration: 1.5
            });

            // Create and show the beautiful gold Tactical Pin for the selected barangay!
            const tacticalPin = L.marker([pin.lat, pin.lng], {
                icon: L.divIcon({
                    className: 'manual-pin-container',
                    html: `
                        <div class="relative group flex flex-col items-center">
                            <div class="absolute w-8 h-8 bg-pnp-gold/30 rounded-full animate-ping"></div>
                            <div class="relative w-10 h-10 bg-pnp-blue dark:bg-pnp-gold rounded-full flex items-center justify-center shadow-2xl border-2 border-white dark:border-slate-900 transform group-hover:scale-110 transition-all duration-300">
                                <i class="fas fa-location-dot text-white dark:text-pnp-blue text-lg"></i>
                            </div>
                            <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-pnp-blue dark:border-t-pnp-gold -mt-1"></div>
                        </div>
                    `,
                    iconSize: [40, 48],
                    iconAnchor: [20, 48]
                })
            }).addTo(selectedPinsLayer);

            // Calculate sector stats
            const brgyPoints = currentPoints.filter(p => p.barangay === pin.name);
            const totalIncidents = brgyPoints.length;

            const allCounts = Object.values(currentPoints.reduce((acc, curr) => {
                acc[curr.barangay] = (acc[curr.barangay] || 0) + 1;
                return acc;
            }, {}));
            const max = Math.max(...allCounts, 1);

            let classification = "Minimal Density";
            let classificationBg = "bg-emerald-500/10 dark:bg-emerald-400/10 text-emerald-500 dark:text-emerald-400";
            if (totalIncidents > 0) {
                const ratio = totalIncidents / max;
                if (ratio >= 0.75) {
                    classification = "High Density";
                    classificationBg = "bg-rose-500/10 dark:bg-rose-400/10 text-rose-500 dark:text-rose-400";
                } else if (ratio >= 0.40) {
                    classification = "Medium-High Density";
                    classificationBg = "bg-orange-500/10 dark:bg-orange-400/10 text-orange-500 dark:text-orange-400";
                } else if (ratio >= 0.15) {
                    classification = "Medium-Low Density";
                    classificationBg = "bg-amber-500/10 dark:bg-amber-400/10 text-amber-500 dark:text-amber-400";
                } else {
                    classification = "Low Density";
                    classificationBg = "bg-emerald-500/10 dark:bg-emerald-400/10 text-emerald-500 dark:text-emerald-400";
                }
            } else {
                classification = "Sector Clear";
                classificationBg = "bg-slate-500/10 dark:bg-slate-400/10 text-slate-500 dark:text-slate-400";
            }

            let dominantCrime = "None";
            let dominantColor = "#94A3B8";
            let dominantCount = 0;
            if (totalIncidents > 0) {
                const stats = {};
                brgyPoints.forEach(p => { stats[p.incident_type] = (stats[p.incident_type] || 0) + 1; });
                const topCrime = Object.entries(stats).sort((a, b) => b[1] - a[1])[0];
                dominantCrime = topCrime[0];
                dominantColor = getTacticalColor(topCrime[0]);
                dominantCount = topCrime[1];
            }

            tacticalPin.bindPopup(`
                <div class="p-4 min-w-[220px] bg-white dark:bg-slate-800 rounded-xl space-y-3">
                    <div class="flex items-center space-x-3 mb-2 pb-2 border-b border-gray-150 dark:border-slate-700">
                        <div class="w-8 h-8 bg-pnp-blue dark:bg-pnp-gold rounded-lg flex items-center justify-center shadow-md">
                            <i class="fas fa-shield-halved text-white dark:text-pnp-blue text-xs"></i>
                        </div>
                        <div>
                            <h3 class="text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-widest text-xs leading-none">${pin.name}</h3>
                            <p class="text-[8px] text-gray-400 font-bold uppercase mt-1">S-SPS Tactical Summary</p>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center text-[10px]">
                            <span class="text-gray-500 dark:text-gray-400 font-bold">Total Cases:</span>
                            <span class="font-black text-slate-850 dark:text-slate-200">${totalIncidents}</span>
                        </div>
                        <div class="flex justify-between items-center text-[10px]">
                            <span class="text-gray-500 dark:text-gray-400 font-bold">Density Class:</span>
