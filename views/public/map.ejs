    function addManualPins() {
        manualPins.forEach(pin => {
            const marker = L.marker([pin.lat, pin.lng], {
                icon: L.divIcon({
                    className: 'manual-pin-container',
                    html: `
                        <div class="relative group flex flex-col items-center">
                            <!-- Pulse Effect -->
                            <div class="absolute w-8 h-8 bg-pnp-gold/30 rounded-full animate-ping"></div>
                            <!-- Main Pin -->
                            <div class="relative w-10 h-10 bg-pnp-blue dark:bg-pnp-gold rounded-full flex items-center justify-center shadow-2xl border-2 border-white dark:border-slate-900 transform group-hover:scale-110 transition-all duration-300">
                                <i class="fas fa-location-dot text-white dark:text-pnp-blue text-lg"></i>
                            </div>
                            <!-- Pointer -->
                            <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-pnp-blue dark:border-t-pnp-gold -mt-1"></div>
                        </div>
                    `,
                    iconSize: [40, 48],
                    iconAnchor: [20, 48]
                })
            }).addTo(map);

            marker.on('click', () => {
                // Enable interaction when a marker is clicked
                map.dragging.enable();
                map.touchZoom.enable();
                map.doubleClickZoom.enable();
                map.scrollWheelZoom.enable();
                map.boxZoom.enable();
                map.keyboard.enable();

                const barangaySelect = document.getElementById('filterBarangay');
                if (barangaySelect) {
                    barangaySelect.value = pin.name;
                    // Trigger loadMapPoints to update sidebar stats, but don't re-locate
                    loadMapPoints(false);

                    // Ensure sidebar is visible to show the stats
                    const sidebar = document.getElementById('filterSidebar');
                    if (sidebar && sidebar.classList.contains('sidebar-hidden')) {
                        toggleSidebar();
                    }
                }
            });

            marker.bindPopup(`
                <div class="p-4 min-w-[200px] bg-white dark:bg-slate-800 rounded-xl">
                    <div class="flex items-center space-x-3 mb-3 pb-3 border-b border-gray-100 dark:border-slate-700">
                        <div class="w-8 h-8 bg-pnp-blue dark:bg-pnp-gold rounded-lg flex items-center justify-center">
                            <i class="fas fa-shield-halved text-white dark:text-pnp-blue text-xs"></i>
                        </div>
                        <div>
                            <h3 class="text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-widest text-xs leading-none">${pin.name}</h3>
                            <p class="text-[8px] text-gray-400 font-bold uppercase mt-1">Sta. Cruz, Laguna</p>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <span class="text-[9px] text-gray-500 font-bold uppercase">Classification</span>
                            <span class="px-2 py-0.5 bg-blue-50 dark:bg-blue-900/30 text-pnp-blue dark:text-blue-400 rounded-full text-[8px] font-black uppercase">Reference Point</span>
                        </div>
                        <div class="p-3 bg-gray-50 dark:bg-slate-900 rounded-xl border border-gray-100 dark:border-slate-700">
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-[8px] font-black text-gray-400 uppercase">Latitude</span>
                                <span class="text-[9px] font-mono font-bold text-gray-700 dark:text-gray-300">${pin.lat.toFixed(6)}</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-[8px] font-black text-gray-400 uppercase">Longitude</span>
                                <span class="text-[9px] font-mono font-bold text-gray-700 dark:text-gray-300">${pin.lng.toFixed(6)}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `, {
                className: 'custom-pnp-popup',
                maxWidth: 300
            });
        });
    }


    function initMap() {
        try {
            // Shifted bounds slightly north and west to center Sta. Cruz
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];

            map = L.map('leafletMap', {
                zoomControl: false,
                dragging: false,
                touchZoom: false,
                doubleClickZoom: false,
                scrollWheelZoom: false,
                boxZoom: false,
                keyboard: false,
                attributionControl: true,
                minZoom: 13,
                maxZoom: 18,
                maxBounds: bounds,
                maxBoundsViscosity: 1.0
            }).fitBounds(bounds);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
            }).addTo(map);

            // Initialize incident markers layer
            incidentMarkers.addTo(map);
            selectedPinsLayer.addTo(map);
            // Initial markers are now handled dynamically by GeoJSON load to ensure precision
            // addManualPins();
            loadMapPoints();
            loadMunicipalBoundary();

            // Track mouse movement for live coordinates
            /* 
            // Removing live mouse coord tracking to avoid clutter, will use click instead
            map.on('mousemove', (e) => {
                document.getElementById('liveLat').textContent = e.latlng.lat.toFixed(6);
                document.getElementById('liveLng').textContent = e.latlng.lng.toFixed(6);
            });
            */



            // Hide loading as soon as map is initialized
            hideLoading();

            // Load Barangay GeoJSON
            fetch(barangayGeoJsonUrl)
                .then(res => {
                    if (!res.ok) throw new Error('Network response was not ok');
                    return res.json();
                })
                .then(data => {
                    santaCruzGeoJSON = data;
                    boundaryLayerGroup = L.geoJSON(data, {
                        style: function (feature) {
                            return getThematicStyleForFeature(feature);
                        },
                        onEachFeature: function (feature, layer) {
                            let name = feature.properties.ADM4_EN;
                            // Helper to normalize Poblacion names to match manualPins
                            const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
                            if (match) {
                                name = `Poblacion ${match[1]} (Barangay ${match[1]})`;
                            }

                            layer.on({
                                mouseover: function (e) {
                                    const layer = e.target;
                                    layer.setStyle({
                                        fillOpacity: 0.8,
                                        weight: 3,
                                        color: '#FFFFFF'
                                    });
                                },
                                mouseout: function (e) {
                                    const layer = e.target;
                                    layer.setStyle(getThematicStyleForFeature(feature));
                                },
                                click: function (e) {
                                    if (map) {
                                        map.dragging.enable();
                                        map.touchZoom.enable();
                                        map.doubleClickZoom.enable();
                                        map.scrollWheelZoom.enable();
                                        map.boxZoom.enable();
                                        map.keyboard.enable();
                                    }
                                    const barangaySelect = document.getElementById('filterBarangay');
                                    if (barangaySelect) {
                                        barangaySelect.value = name;
                                        loadMapPoints(false); // Update stats without relocating yet
                                        locateBarangay(); // Now do the fancy locate animation
                                    }
                                }
                            });

                            // Add marker for each barangay at true geographic center
                            try {
                                const centroid = layer.getBounds().getCenter();

                                // Update dynamic reference for search/locate system
                                const pinIndex = manualPins.findIndex(p => p.name.toLowerCase() === name.toLowerCase());
                                if (pinIndex !== -1) {
                                    manualPins[pinIndex].lat = centroid.lat;
                                    manualPins[pinIndex].lng = centroid.lng;
                                }
                            } catch (err) {
                                console.error('Error adding accurate marker for barangay:', name, err);
                            }
                        }
                    }).addTo(map);
                })
                .catch(err => {
                    console.error('Error loading GeoJSON:', err);
                });
        } catch (err) {
            console.error('Error initializing map:', err);
            hideLoading();
        }
    }


    function toggleSidebar() {
        const sidebar = document.getElementById('filterSidebar');
        const toggleBtn = document.getElementById('sidebarToggle');

        if (sidebar.classList.contains('sidebar-hidden')) {
            sidebar.classList.remove('sidebar-hidden');
            sidebar.classList.add('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.add('opacity-0', 'pointer-events-none');

            // Re-render data when sidebar opens
            loadMapPoints(false);
        } else {
            sidebar.classList.add('sidebar-hidden');
            sidebar.classList.remove('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.remove('opacity-0', 'pointer-events-none');
        }
    }

    document.addEventListener('DOMContentLoaded', initMap);
</script>

