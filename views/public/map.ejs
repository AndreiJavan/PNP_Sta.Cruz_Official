    async function loadMapPoints(shouldLocate = true) {
        const range = document.getElementById('filterRange').value;
        const barangay = document.getElementById('filterBarangay').value;


        // Automatically locate when barangay is selected
        if (barangay && shouldLocate) {
            locateBarangay();
        } else if (!barangay && shouldLocate) {
            // Optional: reset view when "All Barangays" is selected
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            map.flyToBounds(bounds, { padding: [50, 50], duration: 1.5 });
        }

        const topIncidentsSection = document.getElementById('topIncidentsSection');
        const topIncidentsList = document.getElementById('topIncidentsList');
        const topIncidentsRange = document.getElementById('topIncidentsRange');

        const rangeText = {
            '': 'All Time',
            '1month': 'Last 1 Month',
            '2months': 'Last 2 Months',
            '3months': 'Last 3 Months'
        };
        if (topIncidentsRange) topIncidentsRange.textContent = rangeText[range] || 'All Time';

        try {
            // Fetch ALL points for the selected range to ensure correct density/heatmap calculations relative to global peak density!
            const url = `/api/map-points?range=${encodeURIComponent(range)}`;
            const response = await fetch(url);
            const points = await response.json();

            currentPoints = Array.isArray(points) ? points : [];
            updateHeatmap();
            updateLegend();

            incidentMarkers.clearLayers();

            // Calculate Top 3 Incidents based on the selected barangay if one is selected!
            const statsPoints = barangay
                ? currentPoints.filter(p => p.barangay.toLowerCase() === barangay.toLowerCase())
                : currentPoints;

            const incidentCounts = {};
            if (statsPoints.length > 0) {
                statsPoints.forEach(point => {
                    incidentCounts[point.incident_type] = (incidentCounts[point.incident_type] || 0) + 1;
                });
            }


            const sortedIncidents = Object.entries(incidentCounts)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 3);

            if (topIncidentsList) {
                topIncidentsList.innerHTML = sortedIncidents.length > 0
                    ? sortedIncidents.map(([type, count]) => `
                        <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-700">
                            <div class="flex items-center space-x-3">
                                <span class="w-2 h-2 rounded-full" style="background-color: ${getTacticalColor(type)}"></span>
                                <span class="text-[10px] font-black text-gray-700 dark:text-gray-300 uppercase tracking-widest">${type}</span>
                            </div>
                            <span class="text-xs font-black text-pnp-blue dark:text-pnp-gold">${count}</span>
                        </div>
                    `).join('')
                    : `<p class="text-[10px] text-gray-400 font-bold uppercase text-center py-4">No incidents recorded</p>`;
            }
        } catch (err) {
            console.error('Error loading map points:', err);
        }
    }

    // Simple Point in Polygon function
    function isPointInPolygon(point, vs) {
        const x = point[0], y = point[1];
        let inside = false;

        if (Array.isArray(vs[0][0][0])) {
            for (let i = 0; i < vs.length; i++) {
                if (isPointInPolygon(point, vs[i])) return true;
            }
            return false;
        }

        const polygon = Array.isArray(vs[0][0]) ? vs[0] : vs;

        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            const xi = polygon[i][0], yi = polygon[i][1];
            const xj = polygon[j][0], yj = polygon[j][1];
            const intersect = ((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
            if (intersect) inside = !inside;
        }
        return inside;
    }

    function checkGeofence(latlng) {
        let isInside = false;
        if (santaCruzGeoJSON) {
            const point = [latlng.lng, latlng.lat];
            for (const feature of santaCruzGeoJSON.features) {
                if (isPointInPolygon(point, feature.geometry.coordinates)) {
                    isInside = true;
                    break;
                }
            }
        }
        return isInside;
    }

    function getThematicStyleForFeature(feature) {
        const normalizeBrgyName = (name) => {
            const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
            if (match) return `Poblacion ${match[1]} (Barangay ${match[1]})`;
            return name;
        };
        const brgyName = normalizeBrgyName(feature.properties.ADM4_EN);
        const brgyPoints = currentPoints.filter(p => p.barangay === brgyName);
        const modeSelect = document.getElementById('mapDisplayMode');
        const mode = modeSelect ? modeSelect.value : 'density';

        let fillColor = 'transparent';
        let weight = 1;
        let fillOpacity = 0;
        const totalIncidents = brgyPoints.length;

        if (mode === 'density') {
            // Find max incidents across all barangays
            const allCounts = Object.values(currentPoints.reduce((acc, curr) => {
                acc[curr.barangay] = (acc[curr.barangay] || 0) + 1;
                return acc;
            }, {}));
            const max = Math.max(...allCounts, 1);

            if (totalIncidents === 0) {
                fillColor = '#10B981'; // Minimal density is Green
                fillOpacity = 0.7;
                weight = 2;
            } else {
                const ratio = totalIncidents / max; // from >0 to 1
                if (ratio >= 0.75) fillColor = '#EF4444'; // Red (High Crime)
                else if (ratio >= 0.40) fillColor = '#F97316'; // Orange (Medium-High)
                else if (ratio >= 0.15) fillColor = '#FBBF24'; // Yellow (Medium-Low)
                else fillColor = '#10B981'; // Green (Low)

                fillOpacity = 0.7;
                weight = 2;
            }
        } else if (mode === 'dominant') {
            // Dominant Crime Type
            if (totalIncidents > 0) {
                const stats = {};
                brgyPoints.forEach(p => { stats[p.incident_type] = (stats[p.incident_type] || 0) + 1; });
                const topCrime = Object.entries(stats).sort((a, b) => b[1] - a[1])[0];
                fillColor = getTacticalColor(topCrime[0]);
                fillOpacity = 0.6;
                weight = 2;
            } else {
                fillColor = '#94A3B8'; // Slate/Grey for zero incidents
                fillOpacity = 0.2;
                weight = 1;
            }
        } else {
            // Clear / No overlay
            weight = 1;
            fillOpacity = 0.1;
            fillColor = '#1A3A5C';
        }

        const selected = document.getElementById('filterBarangay').value;
        if (selected && selected !== brgyName) {
            fillOpacity = 0.05;
            weight = 1;
            fillColor = 'rgba(15, 23, 42, 0.5)';
        }

        return { color: '#C8A415', weight: weight, fillOpacity: fillOpacity, fillColor: fillColor };
    }

    function updateBarangayLabels() {
        if (!boundaryLayerGroup || !map) return;
        const currentZoom = map.getZoom();
        boundaryLayerGroup.eachLayer(layer => {
            const feature = layer.feature;
            if (!feature) return;
            let name = feature.properties.ADM4_EN;
            const match = name.match(/Barangay (I{1,3}|IV|V) \(Pob\.\)/);
            if (match) name = `Poblacion ${match[1]} (Barangay ${match[1]})`;

            const newLabel = getBarangayLabel(name, currentZoom);
            layer.setTooltipContent(newLabel);
        });
    }

    function manageTooltipVisibility() {
        if (!map) return;
        // Sorting tooltips to ensure consistent behavior
        const tooltips = Array.from(document.querySelectorAll('.barangay-label-tooltip'));
        const boxes = [];

        tooltips.forEach(t => {
            const rect = t.getBoundingClientRect();
            // Skip unrendered elements
            if (rect.width === 0 && rect.height === 0) return;

            let isColliding = false;
            const pad = 2; // Extra padding

            for (let i = 0; i < boxes.length; i++) {
                const b = boxes[i];
                if (!(rect.right + pad < b.left ||
                    rect.left - pad > b.right ||
                    rect.bottom + pad < b.top ||
                    rect.top - pad > b.bottom)) {
                    isColliding = true;
                    break;
                }
            }

            if (isColliding) {
                t.style.opacity = '0';
                t.style.pointerEvents = 'none';
            } else {
                t.style.opacity = '1';
                boxes.push(rect);
            }
        });
    }

    function clearMapDisplay() {
        const modeSelect = document.getElementById('mapDisplayMode');
        if (modeSelect) {
            // Temporarily enable 'clear' option so we can select it, though it's hidden
            const clearOpt = modeSelect.querySelector('option[value="clear"]');
