<!-- Strategic Intelligence Notification System -->
<div id="strategicAlert" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 animate-fade-in">
    <div class="absolute inset-0 bg-slate-900/90 backdrop-blur-md"></div>
    
    <div class="relative bg-white dark:bg-slate-800 w-full max-w-md rounded-[2.5rem] shadow-[0_0_50px_rgba(0,0,0,0.5)] border border-white/10 overflow-hidden transform transition-all scale-95 opacity-0 duration-300" id="alertContainer">
        <!-- Decoration -->
        <div class="absolute top-0 left-0 w-full h-1.5 bg-pnp-blue dark:bg-pnp-gold"></div>
        
        <div class="p-8 space-y-6">
            <div class="flex items-center space-x-4">
                <div id="alertIconContainer" class="w-14 h-14 bg-pnp-blue/10 rounded-2xl flex items-center justify-center text-pnp-blue dark:text-pnp-gold">
                    <i id="alertIcon" class="fas fa-shield-alt text-2xl"></i>
                </div>
                <div>
                    <h3 id="alertTitle" class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-sm">Strategic Alert</h3>
                    <p id="alertSubtitle" class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1">Operational Protocol Active</p>
                </div>
            </div>
            
            <p id="alertMessage" class="text-sm font-bold text-slate-600 dark:text-slate-300 leading-relaxed">
                Confirming intelligence parameters for deployment...
            </p>
            
            <div class="flex items-center space-x-3 pt-2">
                <button id="alertCancelBtn" class="flex-1 px-6 py-4 rounded-2xl text-xs font-black uppercase tracking-widest text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-all">
                    Abort
                </button>
                <button id="alertConfirmBtn" class="flex-2 px-10 py-4 bg-pnp-blue dark:bg-pnp-gold text-white dark:text-pnp-blue rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl shadow-pnp-blue/20 transition-all hover:scale-[1.02] active:scale-95">
                    Proceed
                </button>
            </div>
        </div>

        <!-- Progress bar for auto-close if implemented later -->
        <div id="alertProgress" class="h-1 bg-pnp-blue/20 w-0"></div>
    </div>
</div>

<!-- Cooldown/Rate Limit Neural Modal -->
<div id="cooldownModal" class="fixed inset-0 z-[10000] hidden items-center justify-center p-4 animate-fade-in">
    <div class="absolute inset-0 bg-slate-950/95 backdrop-blur-xl"></div>
    
    <div class="relative bg-white dark:bg-slate-900 w-full max-w-md rounded-[3rem] shadow-[0_0_100px_rgba(0,0,0,0.8)] border border-white/5 overflow-hidden transform transition-all scale-95 opacity-0 duration-500" id="cooldownContainer">
        <!-- Neural Line Decoration -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-pnp-gold to-transparent opacity-50"></div>
        
        <div class="p-10 flex flex-col items-center text-center space-y-8">
            <!-- Animated Icon -->
            <div class="relative">
                <div class="absolute inset-0 bg-pnp-gold/20 rounded-full blur-2xl animate-pulse"></div>
                <div class="w-24 h-24 bg-pnp-blue dark:bg-slate-800 rounded-[2rem] flex items-center justify-center text-pnp-gold border-2 border-pnp-gold/20 shadow-2xl relative z-10 rotate-3">
                    <i class="fas fa-hourglass-half text-4xl animate-bounce"></i>
                </div>
            </div>
            
            <div class="space-y-3">
                <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.4em] text-lg">System Throttled</h3>
                <p class="text-[10px] text-pnp-gold font-black uppercase tracking-[0.2em] italic">Neural Link Rate Limit Exceeded</p>
            </div>
            
            <p class="text-sm font-bold text-slate-500 dark:text-slate-400 leading-relaxed max-w-xs">
                To maintain structural integrity, the AI extraction link has been temporarily suspended. Please standby for synchronization.
            </p>
            
            <!-- Countdown Timer -->
            <div class="bg-gray-50 dark:bg-slate-800/50 w-full py-6 rounded-3xl border border-gray-100 dark:border-white/5 shadow-inner">
                <div id="cooldownTimer" class="text-5xl font-black text-pnp-blue dark:text-pnp-gold tabular-nums tracking-tighter">05:00</div>
                <p class="text-[9px] text-slate-400 font-bold uppercase mt-2 tracking-widest">Time Remaining Until Signal Restoration</p>
            </div>
            
            <button onclick="closeCooldownModal()" class="w-full py-5 bg-pnp-blue dark:bg-slate-800 text-white dark:text-pnp-gold rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] shadow-2xl transition-all hover:bg-black dark:hover:bg-slate-700 active:scale-95 border border-white/5">
                Acknowledged & Standby
            </button>
        </div>
    </div>
</div>


<script>
    (function() {
        const modal = document.getElementById('strategicAlert');
        const container = document.getElementById('alertContainer');
        const title = document.getElementById('alertTitle');
        const message = document.getElementById('alertMessage');
        const cancelBtn = document.getElementById('alertCancelBtn');
        const confirmBtn = document.getElementById('alertConfirmBtn');
        const icon = document.getElementById('alertIcon');
        const iconContainer = document.getElementById('alertIconContainer');
        
        let activeCallback = null;
        let activeCancelCallback = null;

        window.strategicConfirm = function(options) {
            return new Promise((resolve) => {
                const { 
                    title: t = 'Strategic Confirmation', 
                    message: m = 'Proceed with operation?', 
                    confirmText = 'Proceed', 
                    cancelText = 'Abort',
                    type = 'info' // info, warning, danger
                } = options;

                title.textContent = t;
                message.textContent = m;
                confirmBtn.textContent = confirmText;
                cancelBtn.textContent = cancelText;
                cancelBtn.classList.remove('hidden');

                // Tone adjustment
                if (type === 'danger') {
                    iconContainer.className = 'w-14 h-14 bg-red-500/10 rounded-2xl flex items-center justify-center text-red-500';
                    icon.className = 'fas fa-exclamation-triangle text-2xl';
                    confirmBtn.className = 'flex-2 px-10 py-4 bg-red-500 text-white rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl shadow-red-500/20 transition-all hover:scale-[1.02] active:scale-95';
                } else if (type === 'warning') {
                    iconContainer.className = 'w-14 h-14 bg-amber-500/10 rounded-2xl flex items-center justify-center text-amber-500';
                    icon.className = 'fas fa-radiation text-2xl';
                    confirmBtn.className = 'flex-2 px-10 py-4 bg-amber-500 text-white rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl shadow-amber-500/20 transition-all hover:scale-[1.02] active:scale-95';
                } else {
                    iconContainer.className = 'w-14 h-14 bg-pnp-blue/10 rounded-2xl flex items-center justify-center text-pnp-blue dark:text-pnp-gold';
                    icon.className = 'fas fa-shield-alt text-2xl';
                    confirmBtn.className = 'flex-2 px-10 py-4 bg-pnp-blue dark:bg-pnp-gold text-white dark:text-pnp-blue rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl shadow-pnp-blue/20 transition-all hover:scale-[1.02] active:scale-95';
                }

                modal.classList.remove('hidden');
                modal.classList.add('flex');
                
                setTimeout(() => {
                    container.classList.remove('scale-95', 'opacity-0');
                    container.classList.add('scale-100', 'opacity-100');
                }, 10);

                const cleanup = () => {
                    container.classList.remove('scale-100', 'opacity-100');
                    container.classList.add('scale-95', 'opacity-0');
                    setTimeout(() => {
                        modal.classList.add('hidden');
                        modal.classList.remove('flex');
                    }, 300);
                    
                    confirmBtn.removeEventListener('click', onConfirm);
                    cancelBtn.removeEventListener('click', onCancel);
                };

                const onConfirm = () => {
                    cleanup();
                    resolve(true);
                };

                const onCancel = () => {
                    cleanup();
                    resolve(false);
                };

                confirmBtn.addEventListener('click', onConfirm);
                cancelBtn.addEventListener('click', onCancel);
            });
        };

        window.strategicAlert = function(options) {
            const { 
                title: t = 'System Notification', 
                message: m = '', 
                confirmText = 'Acknowledged',
                type = 'info' 
            } = options;

            return strategicConfirm({
                title: t,
                message: m,
                confirmText,
                cancelText: '',
                type
            }).then(() => true);
        };

        // --- Cooldown Modal Logic ---
        const cooldownModal = document.getElementById('cooldownModal');
        const cooldownContainer = document.getElementById('cooldownContainer');
        const cooldownTimerEl = document.getElementById('cooldownTimer');
        let cooldownInterval = null;

        window.strategicCooldownAlert = function(seconds = 300) {
            return new Promise((resolve) => {
                let timeLeft = seconds;
                
                const updateTimer = () => {
                    const mins = Math.floor(timeLeft / 60);
                    const secs = timeLeft % 60;
                    cooldownTimerEl.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
                };

                updateTimer();
                cooldownModal.classList.remove('hidden');
                cooldownModal.classList.add('flex');
                
                setTimeout(() => {
                    cooldownContainer.classList.remove('scale-95', 'opacity-0');
                    cooldownContainer.classList.add('scale-100', 'opacity-100');
                }, 10);

                if (cooldownInterval) clearInterval(cooldownInterval);
                
                cooldownInterval = setInterval(() => {
                    timeLeft--;
                    if (timeLeft <= 0) {
                        clearInterval(cooldownInterval);
                        closeCooldownModal();
                    } else {
                        updateTimer();
                    }
                }, 1000);

                window.closeCooldownModal = () => {
                    clearInterval(cooldownInterval);
                    cooldownContainer.classList.remove('scale-100', 'opacity-100');
                    cooldownContainer.classList.add('scale-95', 'opacity-0');
                    setTimeout(() => {
                        cooldownModal.classList.add('hidden');
                        cooldownModal.classList.remove('flex');
                        resolve(true);
                    }, 500);
                };
            });
        };

        window.confirmOperationalAction = async function(event, options = {}) {
            event.preventDefault();
            const form = event.target.closest('form');
            if (!form) return;

            const confirmed = await strategicConfirm({
                title: options.title || 'Operational Confirmation',
                message: options.message || 'Are you sure you want to proceed with this action?',
                confirmText: options.confirmText || 'Proceed',
                type: options.type || 'warning'
            });

            if (confirmed) {
                form.submit();
            }
        };

        // Override default alert/confirm if requested (optional but helpful)
        // window.alert = (msg) => strategicAlert({ message: msg });
    })();
</script>
