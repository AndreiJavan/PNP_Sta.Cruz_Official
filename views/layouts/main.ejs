                        &copy; 2026 PNP Sta. Cruz Municipal Police Station. All rights reserved.
                    </p>
                    <div class="flex space-x-4">
                        <a href="https://www.facebook.com/stacruzpolicelagunappo" target="_blank"
                            class="w-8 h-8 rounded-full bg-white/5 hover:bg-pnp-gold flex items-center justify-center text-blue-200 hover:text-pnp-blue transition duration-300">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                    </div>
                </div>
            </div>
        </footer>
        <% } %>

            <!-- Floating Dark Mode Toggle -->
            <button id="darkModeToggle"
                class="fixed bottom-6 right-6 z-50 w-12 h-12 bg-white dark:bg-slate-800 shadow-2xl rounded-full flex items-center justify-center text-pnp-blue dark:text-pnp-gold transition-all duration-300 hover:scale-110 border border-gray-200 dark:border-slate-700">
                <i class="fas fa-moon text-lg dark:hidden"></i>
                <i class="fas fa-sun text-lg hidden dark:block"></i>
            </button>

            <% if (locals.user) { %>
            <!-- Floating Admin Dashboard Button -->
            <a href="/admin/dashboard" title="Admin Dashboard"
                class="fixed bottom-6 right-20 z-50 w-12 h-12 bg-pnp-blue dark:bg-pnp-gold shadow-2xl rounded-full flex items-center justify-center text-white dark:text-pnp-blue transition-all duration-300 hover:scale-110 border border-pnp-blue dark:border-pnp-gold">
                <i class="fas fa-shield-halved text-lg"></i>
            </a>
            <% } %>

             <script>
                const mobileMenuBtn = document.getElementById('mobileMenuBtn');
                const closeMenuBtn = document.getElementById('closeMenuBtn');
                const mobileMenu = document.getElementById('mobileMenu');
                const mobileMenuBackdrop = document.getElementById('mobileMenuBackdrop');
                const darkModeToggle = document.getElementById('darkModeToggle');

                // Dark Mode Logic
                darkModeToggle.addEventListener('click', () => {
                    document.documentElement.classList.toggle('dark');
                    localStorage.setItem('darkMode', document.documentElement.classList.contains('dark'));
                });

                // Active Navigation Link Highlighting
                const currentPath = window.location.pathname;

                // Desktop Nav
                const desktopLinks = document.querySelectorAll('header nav a');
                desktopLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    if (href) {
                        const pathOnly = href.split('#')[0] || '/';
                        if (currentPath === pathOnly || (pathOnly !== '/' && currentPath.startsWith(pathOnly))) {
                            link.classList.add('bg-white/20', 'text-pnp-gold');
                        }
                    }
                });

                // Mobile Nav
                const mobileLinks = document.querySelectorAll('#mobileMenu nav a');
                mobileLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    if (href) {
                        const pathOnly = href.split('#')[0] || '/';
                        if (currentPath === pathOnly || (pathOnly !== '/' && currentPath.startsWith(pathOnly))) {
                            link.classList.remove('text-white');
                            link.classList.add('text-pnp-gold');
                        }
                    }
                });

                const closeMenu = () => {
                    mobileMenu.classList.add('translate-x-full');
                    mobileMenuBackdrop.classList.add('opacity-0');
                    setTimeout(() => {
                        mobileMenuBackdrop.classList.add('hidden');
                    }, 300);
                    document.body.style.overflow = 'auto';
                };

                mobileMenuBtn.addEventListener('click', () => {
                    mobileMenuBackdrop.classList.remove('hidden');
                    // Small delay to allow display block to apply before opacity
                    setTimeout(() => mobileMenuBackdrop.classList.remove('opacity-0'), 10);
                    mobileMenu.classList.remove('translate-x-full');
                    document.body.style.overflow = 'hidden';
                });

                closeMenuBtn.addEventListener('click', closeMenu);
                mobileMenuBackdrop.addEventListener('click', closeMenu);

                // Smooth Scroll Logic for Hash Anchors
                const initSmoothScroll = () => {
                    const handleAnchorClick = (e) => {
                        const href = e.currentTarget.getAttribute('href');
                        if (href && (href.startsWith('/#') || href.startsWith('#'))) {
                            const hashIndex = href.indexOf('#');
                            const targetId = href.substring(hashIndex);
                            try {
                                const targetEl = document.querySelector(targetId);
                                if (targetEl) {
                                    e.preventDefault();
                                    closeMenu();
                                    
                                    const headerHeight = document.querySelector('header')?.offsetHeight || 96;
                                    const targetPosition = targetEl.getBoundingClientRect().top + window.pageYOffset - headerHeight - 16;
                                    
                                    window.scrollTo({
                                        top: targetPosition,
                                        behavior: 'smooth'
                                    });
                                    
                                    // Update URL hash without scroll jumping
                                    history.pushState(null, '', href);
                                }
                            } catch (err) {
                                console.error('Error in selector query:', err);
                            }
                        }
                    };

                    document.querySelectorAll('a[href*="#"]').forEach(link => {
                        link.removeEventListener('click', handleAnchorClick);
                        link.addEventListener('click', handleAnchorClick);
                    });

                    // On-load smooth scroll if hash is present
                    if (window.location.hash) {
                        setTimeout(() => {
                            try {
                                const targetEl = document.querySelector(window.location.hash);
                                if (targetEl) {
                                    const headerHeight = document.querySelector('header')?.offsetHeight || 96;
                                    const targetPosition = targetEl.getBoundingClientRect().top + window.pageYOffset - headerHeight - 16;
                                    window.scrollTo({
                                        top: targetPosition,
                                        behavior: 'smooth'
                                    });
                                }
                            } catch (err) {
                                console.error('Error on-load hash scroll:', err);
                            }
                        }, 400);
                    }
                };

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initSmoothScroll);
                } else {
                    initSmoothScroll();
                }
            </script>
</body>

</html>