<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CPICRS - PNP Sta. Cruz, Laguna</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        pnp: {
                            blue: '#1A3A5C',
                            gold: '#C8A415',
                        }
                    }
                }
            }
        }
    </script>
    <script>
        // Check for dark mode preference
        if (localStorage.getItem('darkMode') === 'true' || (!('darkMode' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

        body {
            font-family: 'Inter', sans-serif;
        }

        .bg-pnp-blue {
            background-color: #1A3A5C;
        }

        .text-pnp-blue {
            color: #1A3A5C;
        }

        .bg-pnp-gold {
            background-color: #C8A415;
        }

        .text-pnp-gold {
            color: #C8A415;
        }

        .border-pnp-gold {
            border-color: #C8A415;
        }

        /* Dark mode overrides for custom classes if needed */
        .dark .bg-gray-50 {
            background-color: #0f172a;
        }

        .dark .bg-white {
            background-color: #1e293b;
        }

        .dark .text-gray-800 {
            color: #f1f5f9;
        }

        .dark .text-gray-700 {
            color: #e2e8f0;
        }

        .dark .text-gray-600 {
            color: #cbd5e1;
        }

        .dark .text-gray-500 {
            color: #94a3b8;
        }

        .dark .text-gray-400 {
            color: #64748b;
        }

        .dark .border-gray-100 {
            border-color: #334155;
        }

        .dark .border-gray-200 {
            border-color: #475569;
        }

        /* Leaflet Dark Mode Support */
        .dark .leaflet-tile {
            filter: invert(100%) hue-rotate(180deg) brightness(95%) contrast(90%);
        }

        .dark .leaflet-container {
            background: #0f172a;
        }

        .dark .leaflet-popup-content-wrapper,
        .dark .leaflet-popup-tip {
            background-color: #1e293b;
            color: #f8fafc;
        }

        .grid-label,
        .corner-coord-container,
        .grid-intersection-label,
        .manual-pin-container {
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
        }

        .barangay-label-tooltip {
            background: rgba(26, 58, 92, 0.9) !important;
            border: 1px solid #C8A415 !important;
            color: #C8A415 !important;
            font-weight: 900 !important;
            font-size: 8px !important;
            text-transform: uppercase !important;
            letter-spacing: 0.1em !important;
            padding: 2px 6px !important;
            border-radius: 4px !important;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
        }

        .barangay-label-tooltip::before {
            border-top-color: rgba(26, 58, 92, 0.9) !important;
        }

        /* Custom PNP Popup Styling */
        .custom-pnp-popup .leaflet-popup-content-wrapper {
            padding: 0;
            overflow: hidden;
            border-radius: 1.5rem;
            border: 2px solid #C8A415;
        }

        .custom-pnp-popup .leaflet-popup-content {
            margin: 0;
            width: auto !important;
        }

        .custom-pnp-popup .leaflet-popup-tip {
            background: #C8A415;
        }
    </style>
</head>

<body class="bg-gray-50 dark:bg-slate-900 flex flex-col min-h-screen transition-colors duration-300">
    <!-- Header -->
    <header class="bg-pnp-blue text-white sticky top-0 z-50 shadow-2xl border-b-4 border-pnp-gold">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between h-20 md:h-24">
                <!-- Logo -->
                <a href="/" class="flex items-center space-x-4 group">
                    <div
                        class="w-12 h-12 md:w-16 md:h-16 bg-white rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-105 transition duration-300">
                        <i class="fas fa-shield-halved text-pnp-blue text-2xl md:text-3xl"></i>
                    </div>
                    <div class="hidden sm:block">
                        <h1 class="text-lg md:text-xl font-black tracking-tighter leading-none">CRIME MAP <span
                                class="text-pnp-gold">STA. CRUZ</span></h1>
                        <p class="text-[10px] md:text-xs text-blue-200 uppercase tracking-widest font-bold mt-1">
                            Incident Visualization System</p>
                    </div>
                </a>

                <!-- Desktop Nav -->
                <nav class="hidden lg:flex items-center space-x-1">
                    <a href="/"
                        class="px-5 py-2 rounded-xl text-sm font-bold hover:bg-white/10 transition duration-300">Home</a>
                    <a href="/map"
                        class="px-5 py-2 rounded-xl text-sm font-bold hover:bg-white/10 transition duration-300">Crime
                        Map</a>
                    <a href="/bulletins"
                        class="px-5 py-2 rounded-xl text-sm font-bold hover:bg-white/10 transition duration-300">Bulletins</a>
                    <a href="/tip"
                        class="px-5 py-2 rounded-xl text-sm font-bold hover:bg-white/10 transition duration-300">Submit
                        Tip</a>
                    <a href="/hotlines"
                        class="px-5 py-2 rounded-xl text-sm font-bold hover:bg-white/10 transition duration-300">Hotlines</a>
                    <a href="/about"
                        class="px-5 py-2 rounded-xl text-sm font-bold hover:bg-white/10 transition duration-300">About</a>


                </nav>

                <!-- Action Buttons -->
                <div class="flex items-center space-x-4">
                    <!-- Mobile Menu Toggle -->
                    <button id="mobileMenuBtn"
                        class="lg:hidden w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center text-xl">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Mobile Menu Overlay -->
    <div id="mobileMenu" class="fixed inset-0 bg-pnp-blue z-[100] hidden flex flex-col p-8 animate-fade-in">
        <div class="flex justify-between items-center mb-12">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center">
                    <i class="fas fa-shield-halved text-pnp-blue text-2xl"></i>
                </div>
                <h1 class="text-white text-xl font-black tracking-tighter">CPICRS</h1>
            </div>
            <button id="closeMenuBtn"
                class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center text-white text-xl">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <nav class="flex flex-col space-y-4">
            <a href="/" class="text-2xl font-black text-white hover:text-pnp-gold transition">Home</a>
            <a href="/map" class="text-2xl font-black text-white hover:text-pnp-gold transition">Crime Map</a>
            <a href="/bulletins" class="text-2xl font-black text-white hover:text-pnp-gold transition">Bulletins</a>
            <a href="/tip" class="text-2xl font-black text-white hover:text-pnp-gold transition">Submit Tip</a>
            <a href="/hotlines" class="text-2xl font-black text-white hover:text-pnp-gold transition">Hotlines</a>
            <a href="/about" class="text-2xl font-black text-white hover:text-pnp-gold transition">About PNP</a>



            <a href="/admin/login" class="text-2xl font-black text-pnp-gold pt-8">Admin Portal</a>
        </nav>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
        <%- body %>
    </main>

    <% if (!locals.hideFooter) { %>
        <!-- Footer -->
        <footer class="bg-pnp-blue text-white dark:bg-slate-900 border-t-4 border-pnp-gold mt-auto py-12">
            <div class="container mx-auto px-4">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
                    <!-- Brand Section -->
                    <div class="flex flex-col space-y-4">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-lg">
                                <i class="fas fa-shield-halved text-pnp-blue text-xl"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-black tracking-tighter leading-none">CPICRS</h2>
                                <p class="text-[9px] text-blue-200 uppercase tracking-widest font-bold mt-0.5">PNP Sta.
                                    Cruz
                                </p>
                            </div>
                        </div>
                        <p class="text-xs text-blue-200/80 max-w-sm leading-relaxed">
                            To enforce the law, prevent and control crimes, maintain peace and order, and ensure public
                            safety and internal security with the active support of the community.
                        </p>
                    </div>

                    <!-- Quick Links -->
                    <div class="flex flex-col space-y-3">
                        <h3 class="text-sm font-bold text-pnp-gold uppercase tracking-widest mb-2">Quick Links</h3>
                        <div class="grid grid-cols-2 gap-2">
                            <a href="/"
                                class="text-xs text-blue-200 hover:text-white transition group flex items-center">
                                <i
                                    class="fas fa-chevron-right text-[8px] mr-2 text-pnp-gold opacity-0 group-hover:opacity-100 transition"></i>
                                Home
                            </a>
                            <a href="/map"
                                class="text-xs text-blue-200 hover:text-white transition group flex items-center">
                                <i
                                    class="fas fa-chevron-right text-[8px] mr-2 text-pnp-gold opacity-0 group-hover:opacity-100 transition"></i>
                                Crime Map
                            </a>
                            <a href="/bulletins"
                                class="text-xs text-blue-200 hover:text-white transition group flex items-center">
                                <i
                                    class="fas fa-chevron-right text-[8px] mr-2 text-pnp-gold opacity-0 group-hover:opacity-100 transition"></i>
                                Bulletins
                            </a>
                            <a href="/tip"
                                class="text-xs text-blue-200 hover:text-white transition group flex items-center">
                                <i
                                    class="fas fa-chevron-right text-[8px] mr-2 text-pnp-gold opacity-0 group-hover:opacity-100 transition"></i>
                                Submit Tip
                            </a>
                            <a href="/hotlines"
                                class="text-xs text-blue-200 hover:text-white transition group flex items-center">
                                <i
                                    class="fas fa-chevron-right text-[8px] mr-2 text-pnp-gold opacity-0 group-hover:opacity-100 transition"></i>
                                Hotlines
                            </a>
                            <a href="/about"
                                class="text-xs text-blue-200 hover:text-white transition group flex items-center">
                                <i
                                    class="fas fa-chevron-right text-[8px] mr-2 text-pnp-gold opacity-0 group-hover:opacity-100 transition"></i>
                                About
                            </a>
                            <a href="/admin/login"
                                class="text-xs text-pnp-gold hover:text-white transition group flex items-center mt-1">
                                <i class="fas fa-lock text-[8px] mr-2 transition"></i> Admin Portal
                            </a>
                        </div>
                    </div>

                    <!-- Contact Info / Hotlines -->
                    <div class="flex flex-col space-y-3">
                        <h3 class="text-sm font-bold text-pnp-gold uppercase tracking-widest mb-2">Emergency Hotlines
                        </h3>

                        <div class="text-xs text-blue-200 flex space-x-3 items-center">
                            <i class="fas fa-phone-volume text-red-400 w-3"></i>
                            <span>PNP Sta. Cruz: <strong class="text-white">0998 598 5667</strong></span>
                        </div>
                        <div class="text-xs text-blue-200 flex space-x-3 items-center">
                            <i class="fas fa-phone-volume text-red-400 w-3"></i>
                            <span>BFP Sta. Cruz: <strong class="text-white">0923-456-7890</strong></span>
                        </div>
                        <div class="text-xs text-blue-200 flex space-x-3 items-center">
                            <i class="fas fa-phone-volume text-red-400 w-3"></i>
                            <span>Sta. Cruz Rescue: <strong class="text-white">0934-567-8901</strong></span>
                        </div>
                        <div class="text-xs text-blue-200 flex space-x-3 items-center">
                            <i class="fas fa-phone-volume text-red-400 w-3"></i>
                            <span>MDRRMO: <strong class="text-white">0945-678-9012</strong></span>
                        </div>
                        <div class="text-xs text-blue-200 flex space-x-3 items-center">
                            <i class="fas fa-phone-volume text-red-400 w-3"></i>
                            <span>Red Cross Laguna: <strong class="text-white">0956-789-0123</strong></span>
                        </div>

                        <div
                            class="mt-4 text-xs text-blue-200 flex space-x-3 items-start border-t border-white/10 pt-4">
                            <i class="fas fa-map-marker-alt mt-1 text-pnp-gold w-3 text-center"></i>
                            <span>Sta. Cruz Municipal Police Station<br>Sta. Cruz, Laguna, Philippines</span>
                        </div>
                    </div>
                </div>

                <!-- Bottom Bar -->
                <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
                    <p
                        class="text-[10px] text-blue-200/60 font-bold uppercase tracking-widest text-center md:text-left">
                        &copy; 2026 PNP Sta. Cruz Municipal Police Station. All rights reserved.
                    </p>
                    <div class="flex space-x-4">
                        <a href="https://www.facebook.com/PnpStaCruzLaguna" target="_blank"
                            class="w-8 h-8 rounded-full bg-white/5 hover:bg-pnp-gold flex items-center justify-center text-blue-200 hover:text-pnp-blue transition duration-300">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                    </div>
                </div>
            </div>
        </footer>
        <% } %>

            <!-- Floating Dark Mode Toggle -->
            <button id="darkModeToggle"
                class="fixed bottom-6 right-6 z-50 w-12 h-12 bg-white dark:bg-slate-800 shadow-2xl rounded-full flex items-center justify-center text-pnp-blue dark:text-pnp-gold transition-all duration-300 hover:scale-110 border border-gray-200 dark:border-slate-700">
                <i class="fas fa-moon text-lg dark:hidden"></i>
                <i class="fas fa-sun text-lg hidden dark:block"></i>
            </button>

            <script>
                const mobileMenuBtn = document.getElementById('mobileMenuBtn');
                const closeMenuBtn = document.getElementById('closeMenuBtn');
                const mobileMenu = document.getElementById('mobileMenu');
                const darkModeToggle = document.getElementById('darkModeToggle');

                // Dark Mode Logic
                darkModeToggle.addEventListener('click', () => {
                    document.documentElement.classList.toggle('dark');
                    localStorage.setItem('darkMode', document.documentElement.classList.contains('dark'));
                });

                mobileMenuBtn.addEventListener('click', () => {
                    mobileMenu.classList.remove('hidden');
                    document.body.style.overflow = 'hidden';
                });

                closeMenuBtn.addEventListener('click', () => {
                    mobileMenu.classList.add('hidden');
                    document.body.style.overflow = 'auto';
                });
            </script>
</body>

</html>