<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/favicon.png">
    <title>Admin Dashboard - Sta. Cruz Crime Mapping</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        pnp: {
                            blue: {
                                50: '#EBF1F7',
                                100: '#D1DEEB',
                                200: '#A3BDD7',
                                300: '#759CC3',
                                400: '#477BAF',
                                500: '#1A3A5C',
                                600: '#152E4A',
                                700: '#102237',
                                800: '#0A1725',
                                900: '#050B12',
                                DEFAULT: '#1A3A5C',
                            },
                            gold: {
                                50: '#FAF7E8',
                                100: '#F5F0D1',
                                200: '#EBE1A3',
                                300: '#E1D275',
                                400: '#D7C347',
                                500: '#C8A415',
                                600: '#A08311',
                                700: '#78620D',
                                800: '#504109',
                                900: '#282104',
                                DEFAULT: '#C8A415',
                            }
                        }
                    }
                }
            }
        }
    </script>
    <script>
        // Check for dark mode preference
        if (localStorage.getItem('darkMode') === 'true' || (!('darkMode' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

        body {
            font-family: 'Inter', sans-serif;
        }

        .bg-pnp-blue {
            background-color: #1A3A5C;
        }

        .text-pnp-blue {
            color: #1A3A5C;
        }

        .bg-pnp-gold {
            background-color: #C8A415;
        }

        .text-pnp-gold {
            color: #C8A415;
        }

        .border-pnp-gold {
            border-color: #C8A415;
        }

        .pnp-gradient-blue {
            background: linear-gradient(135deg, #1A3A5C 0%, #0A1725 100%);
        }

        .pnp-card {
            @apply bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700/50 shadow-sm transition-all duration-300;
        }

        .pnp-card:hover {
            @apply shadow-xl border-pnp-blue/20 transform -translate-y-1;
        }

        .pnp-glass {
            background: rgba(255, 255, 255, 0.01);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .pnp-glass-dark {
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .text-shadow-tactical {
            text-shadow: 0 0 20px rgba(200, 164, 21, 0.3);
        }

        .sidebar-item-active {
            @apply bg-white/10 border-l-4 border-pnp-gold/80 shadow-[inset_-10px_0_20px_rgba(0, 0, 0, 0.1)];
        }

        /* Global scrollbar hiding */
        * {
            scrollbar-width: none !important;
            -ms-overflow-style: none !important;
        }

        *::-webkit-scrollbar {
            display: none !important;
        }

        /* Sidebar toggle states */
        .sidebar-hidden {
            transform: translateX(-100%);
        }

        .main-content-expanded {
            margin-left: 0 !important;
            width: 100% !important;
        }

        @media (min-width: 1024px) {
            #sidebar:not(.sidebar-hidden)+#mainContent {
                margin-left: 18rem;
                /* w-72 matches aside width */
            }
        }

        #layoutHeader,
        #layoutFooter {
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>

<body class="bg-gray-50 dark:bg-slate-900 min-h-screen flex transition-colors duration-300 overflow-x-hidden">
    <!-- Sidebar -->
    <aside id="sidebar"
        class="w-72 pnp-gradient-blue text-white flex flex-col fixed h-full z-50 shadow-2xl border-r-4 border-pnp-gold/50 transition-transform duration-300 sidebar-scroll overflow-y-auto <%= typeof hideSidebar !== 'undefined' && hideSidebar ? 'sidebar-hidden' : '' %>">
        <div class="p-8 border-b border-white/10 flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <img src="/images/PNP.jpg" alt="PNP Logo" class="w-10 h-10 object-contain drop-shadow-lg"
                    onerror="this.onerror=null; this.src='/favicon.ico';">
                <div>
                    <h1 class="text-lg font-black tracking-tighter leading-none italic">STA. CRUZ CRIME MAPPING</h1>
                    <p class="text-[10px] text-blue-200 uppercase tracking-widest font-bold mt-0.5">Records</p>
                </div>
            </div>
            <button id="sidebarClose" class="lg:hidden text-white/50 hover:text-white transition">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <nav class="flex-grow p-4 space-y-1.5">
            <p class="text-[10px] text-blue-400 uppercase tracking-[0.2em] font-black mb-4 px-4 opacity-50">Main Menu
            </p>

            <a href="/admin/dashboard"
                class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl transition-all duration-300 group <%= title === 'Dashboard' ? 'sidebar-item-active text-pnp-gold' : 'hover:bg-white/5 text-slate-400 hover:text-white' %>">
                <div
                    class="w-8 h-8 rounded-xl bg-white/5 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i class="fas fa-chart-line text-xs"></i>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest">Dashboard</span>
            </a>

            <a href="/admin/bulletins"
                class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl transition-all duration-300 group <%= title === 'Bulletins' || title === 'New Bulletin' || title === 'Edit Bulletin' ? 'sidebar-item-active text-pnp-gold' : 'hover:bg-white/5 text-slate-400 hover:text-white' %>">
                <div
                    class="w-8 h-8 rounded-xl bg-white/5 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i class="fas fa-bullhorn text-xs"></i>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest">Bulletins</span>
            </a>

            <a href="/admin/reports"
                class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl transition-all duration-300 group <%= title === 'Crime Reports' ? 'sidebar-item-active text-pnp-gold' : 'hover:bg-white/5 text-slate-400 hover:text-white' %>">
                <div
                    class="w-8 h-8 rounded-xl bg-white/5 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i class="fas fa-file-invoice text-xs"></i>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest">Crime Reports</span>
            </a>



            <a href="/admin/map"
                class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl transition-all duration-300 group <%= title === 'Map' ? 'sidebar-item-active text-pnp-gold' : 'hover:bg-white/5 text-slate-400 hover:text-white' %>">
                <div
                    class="w-8 h-8 rounded-xl bg-white/5 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i class="fas fa-map-marked-alt text-xs"></i>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest">Map</span>
            </a>

            <a href="/admin/hotlines"
                class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl transition-all duration-300 group <%= title === 'Hotlines' ? 'sidebar-item-active text-pnp-gold' : 'hover:bg-white/5 text-slate-400 hover:text-white' %>">
                <div
                    class="w-8 h-8 rounded-xl bg-white/5 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i class="fas fa-phone-volume text-xs"></i>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest">Hotlines</span>
            </a>

            <% if (user && user.role==='superadmin' ) { %>


                <a href="/admin/users"
                    class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl transition-all duration-300 group <%= title === 'Users' ? 'sidebar-item-active text-pnp-gold' : 'hover:bg-white/5 text-slate-400 hover:text-white' %>">
                    <div
                        class="w-8 h-8 rounded-xl bg-white/5 flex items-center justify-center group-hover:scale-110 transition-transform">
                        <i class="fas fa-users-cog text-xs"></i>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-widest">Users</span>
                </a>


                <% } %>
        </nav>

        <div class="p-6 border-t border-white/10">
            <a href="/admin/logout"
                class="flex items-center space-x-3 px-4 py-3 rounded-xl bg-red-600/10 text-red-400 hover:bg-red-600 hover:text-white transition duration-300 group">
                <i class="fas fa-sign-out-alt text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div id="mainContent"
        class="flex-grow lg:ml-72 <%= typeof hideSidebar !== 'undefined' && hideSidebar ? 'main-content-expanded' : '' %> flex flex-col min-h-screen transition-all duration-300 w-full lg:w-auto">
        <!-- Top Header -->
        <header
            class="bg-white/80 dark:bg-slate-800/80 backdrop-blur-md h-20 border-b border-gray-100 dark:border-slate-700 flex items-center justify-between px-6 md:px-10 fixed top-0 right-0 z-40 transition-all duration-300"
            style="left: <%= typeof hideSidebar !== 'undefined' && hideSidebar ? '0' : '18rem' %>;" id="layoutHeader">
            <div class="flex items-center space-x-4">
                <button id="sidebarToggle"
                    class="w-10 h-10 bg-gray-50 dark:bg-slate-700 hover:bg-gray-100 dark:hover:bg-slate-600 rounded-xl flex items-center justify-center text-pnp-blue dark:text-white transition border border-gray-100 dark:border-slate-600">
                    <i class="fas fa-bars"></i>
                </button>

                <div class="hidden sm:flex items-center space-x-4">
                    <h2 class="text-xl font-black text-pnp-blue dark:text-white tracking-tighter uppercase">
                        <%= title %>
                    </h2>
                </div>
            </div>

            <div class="flex items-center space-x-4">
                <!-- Help / Manual Button -->
                <button onclick="toggleHelpModal()" title="View Instruction Manual"
                    class="w-10 h-10 bg-white dark:bg-slate-800 shadow-sm rounded-full flex items-center justify-center text-pnp-blue dark:text-pnp-gold transition-all duration-300 hover:scale-110 border border-gray-200 dark:border-slate-700">
                    <i class="fas fa-question text-sm"></i>
                </button>

                <!-- Public Site Button -->
                <a href="/" title="View Public Site"
                    class="w-10 h-10 bg-white dark:bg-slate-800 shadow-sm rounded-full flex items-center justify-center text-pnp-blue dark:text-white transition-all duration-300 hover:scale-110 border border-gray-200 dark:border-slate-700">
                    <i class="fas fa-globe text-sm"></i>
                </a>

                <!-- Dark Mode Toggle (Synced with Public Design) -->
                <button id="darkModeToggle"
                    class="w-10 h-10 bg-white dark:bg-slate-800 shadow-sm rounded-full flex items-center justify-center text-pnp-blue dark:text-pnp-gold transition-all duration-300 hover:scale-110 border border-gray-200 dark:border-slate-700">
                    <i class="fas fa-moon text-sm dark:hidden"></i>
                    <i class="fas fa-sun text-sm hidden dark:block"></i>
                </button>
            </div>
        </header>

        <!-- Page Body -->
        <main
            class="flex-grow animate-fade-in <%= title === 'Map Management' || title === 'Map' ? 'p-0 pt-20' : 'p-10 pt-28 pb-32' %>">
            <!-- Flash Messages -->
            <% if (typeof success_msg !=='undefined' && success_msg) { %>
                <div
                    class="bg-green-50 text-green-600 p-6 rounded-2xl text-xs font-bold uppercase tracking-widest mb-8 border border-green-100 flex items-center space-x-4 shadow-sm mx-10">
                    <i class="fas fa-check-circle text-lg"></i>
                    <span>
                        <%= success_msg %>
                    </span>
                </div>
                <% } %>
                    <% if (typeof error_msg !=='undefined' && error_msg) { %>
                        <div
                            class="bg-red-50 text-red-600 p-6 rounded-2xl text-xs font-bold uppercase tracking-widest mb-8 border border-red-100 flex items-center space-x-4 shadow-sm mx-10">
                            <i class="fas fa-exclamation-circle text-lg"></i>
                            <span>
                                <%= error_msg %>
                            </span>
                        </div>
                        <% } %>

                            <%- body %>
        </main>
    </div>
    <script>
        const darkModeToggle = document.getElementById('darkModeToggle');
        darkModeToggle.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('darkMode', document.documentElement.classList.contains('dark'));
        });

        // Sidebar Toggle Logic
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarClose = document.getElementById('sidebarClose');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');
        const layoutHeader = document.getElementById('layoutHeader');
        const layoutFooter = document.getElementById('layoutFooter');

        const toggleSidebar = () => {
            sidebar.classList.toggle('sidebar-hidden');
            mainContent.classList.toggle('main-content-expanded');

            const isHidden = sidebar.classList.contains('sidebar-hidden');
            if (isHidden) {
                layoutHeader.style.left = '0';
                if (layoutFooter) layoutFooter.style.left = '0';
            } else {
                layoutHeader.style.left = '18rem';
                if (layoutFooter) layoutFooter.style.left = '18rem';
            }

            localStorage.setItem('sidebarHidden', isHidden);

            // Notify server to persist state across refreshes
            fetch('/admin/api/toggle-sidebar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ hideSidebar: isHidden })
            }).catch(err => console.error('Failed to sync sidebar state'));
        };

        sidebarToggle.addEventListener('click', toggleSidebar);
        sidebarClose.addEventListener('click', toggleSidebar);

        // Global Double-Click and Repetitive Action Prevention
        document.addEventListener('submit', (e) => {
            if (e.defaultPrevented) return;
            const form = e.target;
            const submitButtons = form.querySelectorAll('button[type="submit"]');
            submitButtons.forEach(btn => {
                if (btn.dataset.isPruned === 'true') {
                    // e.preventDefault(); // Don't prevent standard submission if it's already pruning
                    return;
                }
                btn.dataset.isPruned = 'true';
                const originalText = btn.innerHTML;
                setTimeout(() => {
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Transmitting...';
                    btn.disabled = true;
                    btn.classList.add('opacity-50', 'cursor-not-allowed');
                }, 10);
            });
        });

        // Hide Header and only show Footer at the bottom
        let lastScrollTop = 0;
        const footer = document.getElementById('layoutFooter');

        window.addEventListener('scroll', () => {
            let scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            let windowHeight = window.innerHeight;
            let documentHeight = document.documentElement.scrollHeight;

            // Header logic: hide on scroll down, show on scroll up
            if (scrollTop > lastScrollTop && scrollTop > 50) {
                layoutHeader.style.transform = 'translateY(-100%)';
            } else {
                layoutHeader.style.transform = 'translateY(0)';
            }

            // Footer logic: only show when near the bottom
            if (footer) {
                if ((windowHeight + scrollTop) >= (documentHeight - 100)) {
                    footer.style.transform = 'translateY(0)';
                    footer.style.opacity = '1';
                } else {
                    footer.style.transform = 'translateY(100%)';
                    footer.style.opacity = '0';
                }
            }

            lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
        }, { passive: true });

        // Responsive Sidebar Initial State
        const savedState = localStorage.getItem('sidebarHidden');
        const forceHide = <%= typeof hideSidebar !== 'undefined' && hideSidebar ? 'true' : 'false' %>;


        if (forceHide || window.innerWidth < 1024 || savedState === 'true') {
            sidebar.classList.add('sidebar-hidden');
            mainContent.classList.add('main-content-expanded');
            layoutHeader.style.left = '0';
            if (layoutFooter) layoutFooter.style.left = '0';

            // If it was forced, save it to local storage for consistency
            if (forceHide) localStorage.setItem('sidebarHidden', 'true');
        }

        // Global Keyboard Shortcuts
        document.addEventListener('keydown', (e) => {
            // Ignore if typing in an input
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;

            // CTRL + / -> Toggle Help Modal
            if (e.ctrlKey && e.key === '/') {
                e.preventDefault();
                if (typeof toggleHelpModal === 'function') toggleHelpModal();
            }

            // CTRL + B -> Toggle Sidebar
            if (e.ctrlKey && e.key.toLowerCase() === 'b') {
                e.preventDefault();
                toggleSidebar();
            }

            // ESC -> Close Help Modal
            if (e.key === 'Escape') {
                const helpModal = document.getElementById('helpModal');
                if (helpModal && !helpModal.classList.contains('hidden') && typeof toggleHelpModal === 'function') {
                    toggleHelpModal();
                }
            }
        });

    </script>


    <%- include('../partials/notifications') %>
    <%- include('../partials/help_modal') %>
</body>

</html>